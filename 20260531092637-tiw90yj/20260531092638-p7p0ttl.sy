,"Type":"NodeParagraph","Properties":{"id":"20260605081425-tb5zfcv","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260605081425-egv5ae7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-egv5ae7","updated":"20260605081425"},"Children":[{"ID":"20260605081425-yx2iekl","Type":"NodeParagraph","Properties":{"id":"20260605081425-yx2iekl","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260605081425-tm91ccl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-tm91ccl","updated":"20260605081425"},"Children":[{"ID":"20260605081425-2axfs9k","Type":"NodeParagraph","Properties":{"id":"20260605081425-2axfs9k","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260605081425-qo550lb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-qo550lb","updated":"20260605081425"},"Children":[{"ID":"20260605081425-3vjvycm","Type":"NodeParagraph","Properties":{"id":"20260605081425-3vjvycm","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260605081425-sn424s6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-sn424s6","updated":"20260605081425"},"Children":[{"ID":"20260605081425-fida32u","Type":"NodeParagraph","Properties":{"id":"20260605081425-fida32u","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260605081425-gouiupl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-gouiupl","updated":"20260605081425"},"Children":[{"ID":"20260605081425-530v5qj","Type":"NodeParagraph","Properties":{"id":"20260605081425-530v5qj","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260605081425-ooqn7lw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ooqn7lw","updated":"20260605081425"},"Children":[{"ID":"20260605081425-76kta5x","Type":"NodeParagraph","Properties":{"id":"20260605081425-76kta5x","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260605081425-sv7j672","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-sv7j672","updated":"20260605081425"},"Children":[{"ID":"20260605081425-138vjcs","Type":"NodeParagraph","Properties":{"id":"20260605081425-138vjcs","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260605081425-b1qvhp6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-b1qvhp6","updated":"20260605081425"},"Children":[{"ID":"20260605081425-w8g3mhh","Type":"NodeParagraph","Properties":{"id":"20260605081425-w8g3mhh","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260605081425-oe9lz5j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-oe9lz5j","updated":"20260605081425"},"Children":[{"ID":"20260605081425-14g1nq5","Type":"NodeParagraph","Properties":{"id":"20260605081425-14g1nq5","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260605081425-j2xjwrw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-j2xjwrw","updated":"20260605081425"},"Children":[{"ID":"20260605081425-0z0m3wt","Type":"NodeParagraph","Properties":{"id":"20260605081425-0z0m3wt","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260605081425-ahx0ivl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ahx0ivl","updated":"20260605081425"},"Children":[{"ID":"20260605081425-w9s2fte","Type":"NodeParagraph","Properties":{"id":"20260605081425-w9s2fte","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260605081425-mlqm4ej","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-mlqm4ej","updated":"20260605081425"},"Children":[{"ID":"20260605081425-c6p3l5l","Type":"NodeParagraph","Properties":{"id":"20260605081425-c6p3l5l","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260605081425-z0rj04y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-z0rj04y","updated":"20260605081425"},"Children":[{"ID":"20260605081425-8luh9xi","Type":"NodeParagraph","Properties":{"id":"20260605081425-8luh9xi","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260605081425-2lqbwo9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-2lqbwo9","updated":"20260605081425"},"Children":[{"ID":"20260605081425-kpdkgnl","Type":"NodeParagraph","Properties":{"id":"20260605081425-kpdkgnl","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260605081425-mvbqnwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-mvbqnwm","updated":"20260605081425"},"Children":[{"ID":"20260605081425-sraztuy","Type":"NodeParagraph","Properties":{"id":"20260605081425-sraztuy","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260605081425-8rtxrs5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-8rtxrs5","updated":"20260605081425"},"Children":[{"ID":"20260605081425-i0ijm6f","Type":"NodeParagraph","Properties":{"id":"20260605081425-i0ijm6f","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260605081425-7r3kh6f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-7r3kh6f","updated":"20260605081425"},"Children":[{"ID":"20260605081425-o6ouh6i","Type":"NodeParagraph","Properties":{"id":"20260605081425-o6ouh6i","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260605081425-nygbzxo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-nygbzxo","updated":"20260605081425"},"Children":[{"ID":"20260605081425-tic03yi","Type":"NodeParagraph","Properties":{"id":"20260605081425-tic03yi","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260605081425-ga0m4zu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ga0m4zu","updated":"20260605081425"},"Children":[{"ID":"20260605081425-dxoaw8e","Type":"NodeParagraph","Properties":{"id":"20260605081425-dxoaw8e","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260605081425-u11lrim","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-u11lrim","updated":"20260605081425"},"Children":[{"ID":"20260605081425-pc1qon9","Type":"NodeParagraph","Properties":{"id":"20260605081425-pc1qon9","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260605081425-bikm9k7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-bikm9k7","updated":"20260605081425"},"Children":[{"ID":"20260605081425-g7uf4ra","Type":"NodeParagraph","Properties":{"id":"20260605081425-g7uf4ra","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260605081425-2fnoy33","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-2fnoy33","updated":"20260605081425"},"Children":[{"ID":"20260605081425-7gki9ar","Type":"NodeParagraph","Properties":{"id":"20260605081425-7gki9ar","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260605081425-du7yn47","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-du7yn47","updated":"20260605081425"},"Children":[{"ID":"20260605081425-q50afms","Type":"NodeParagraph","Properties":{"id":"20260605081425-q50afms","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260605081425-3wnkkr5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-3wnkkr5","updated":"20260605081425"},"Children":[{"ID":"20260605081425-gz44d2g","Type":"NodeParagraph","Properties":{"id":"20260605081425-gz44d2g","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260605081425-a2pz3ws","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-a2pz3ws","updated":"20260605081425"},"Children":[{"ID":"20260605081425-jj50uy3","Type":"NodeParagraph","Properties":{"id":"20260605081425-jj50uy3","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260605081425-rjy70d3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-rjy70d3","updated":"20260605081425"},"Children":[{"ID":"20260605081425-ln1rzvs","Type":"NodeParagraph","Properties":{"id":"20260605081425-ln1rzvs","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260605081425-0ag5c58","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-0ag5c58","updated":"20260605081425"},"Children":[{"ID":"20260605081425-pzl3mvo","Type":"NodeParagraph","Properties":{"id":"20260605081425-pzl3mvo","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260605081425-re89sxp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-re89sxp","updated":"20260605081425"},"Children":[{"ID":"20260605081425-4lmilay","Type":"NodeParagraph","Properties":{"id":"20260605081425-4lmilay","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260605081425-ixuv0vp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ixuv0vp","updated":"20260605081425"},"Children":[{"ID":"20260605081425-d1xmrw2","Type":"NodeParagraph","Properties":{"id":"20260605081425-d1xmrw2","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260605081425-1v50zfp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-1v50zfp","updated":"20260605081425"},"Children":[{"ID":"20260605081425-sn7jzpm","Type":"NodeParagraph","Properties":{"id":"20260605081425-sn7jzpm","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260605081425-1spvacc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-1spvacc","updated":"20260605081425"},"Children":[{"ID":"20260605081425-52zkdnm","Type":"NodeParagraph","Properties":{"id":"20260605081425-52zkdnm","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260605081425-lzvm0o2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-lzvm0o2","updated":"20260605081425"},"Children":[{"ID":"20260605081425-ufj9ppb","Type":"NodeParagraph","Properties":{"id":"20260605081425-ufj9ppb","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260605081425-ofyykge","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ofyykge","updated":"20260605081425"},"Children":[{"ID":"20260605081425-b7gff4n","Type":"NodeParagraph","Properties":{"id":"20260605081425-b7gff4n","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]},{"ID":"20260605081425-s3wuhsl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-s3wuhsl","updated":"20260605081425"},"Children":[{"ID":"20260605081425-dq7skuu","Type":"NodeParagraph","Properties":{"id":"20260605081425-dq7skuu","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"古人云：“知行合一。”而在现代决策理论中，这一思想被进一步具体化为一种动态更新的过程：人并非先有完备之知，才敢行动，而是在行动中修正认知。正如贝叶斯原理所揭示的——判断并非一成不变，而是在一次次反馈中逼近真实。由此看来，真正的理性，不是避免犯错，而是不断纠错。"}]}]},{"ID":"20260605081425-f2ftrey","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-f2ftrey","updated":"20260605081425"},"Children":[{"ID":"20260605081425-ske5rh6","Type":"NodeParagraph","Properties":{"id":"20260605081425-ske5rh6","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"破窗效应：如果环境中的不良现象被放任存在，会诱使人们效仿，甚至变本加厉。"}]}]},{"ID":"20260605081425-vfumxia","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-vfumxia","updated":"20260605081425"},"Children":[{"ID":"20260605081425-2jyzuli","Type":"NodeParagraph","Properties":{"id":"20260605081425-2jyzuli","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"锚定效应：人们在做决定时，容易受第一印象或第一条信息的支配。"}]}]},{"ID":"20260605081425-vr68rct","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-vr68rct","updated":"20260605081425"},"Children":[{"ID":"20260605081425-hw6reta","Type":"NodeParagraph","Properties":{"id":"20260605081425-hw6reta","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"羊群效应：指人们经常受到多数人影响，而跟从大众的思想或行为。"}]}]},{"ID":"20260605081425-mdtohka","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-mdtohka","updated":"20260605081425"},"Children":[{"ID":"20260605081425-43i41u5","Type":"NodeParagraph","Properties":{"id":"20260605081425-43i41u5","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"习得性无助：指人在经历了某种失败或挫折后，产生的放弃努力的悲观心理。"}]}]},{"ID":"20260605081425-2nvnvdb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-2nvnvdb","updated":"20260605081425"},"Children":[{"ID":"20260605081425-2jigzvg","Type":"NodeParagraph","Properties":{"id":"20260605081425-2jigzvg","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"手表定律：只有一只手表时能知道时间，拥有两只或以上反而无法确定时间。"}]}]},{"ID":"20260605081425-uwmy94r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-uwmy94r","updated":"20260605081425"},"Children":[{"ID":"20260605081425-m0t58la","Type":"NodeParagraph","Properties":{"id":"20260605081425-m0t58la","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"鳄鱼法则：当被鳄鱼咬住腿，若用手去解救，手也会被咬。唯一的办法是牺牲那条腿。它揭示了及时止损、果决舍弃的智慧。"}]}]},{"ID":"20260605081425-4f03s5a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-4f03s5a","updated":"20260605081425"},"Children":[{"ID":"20260605081425-oyzst0y","Type":"NodeParagraph","Properties":{"id":"20260605081425-oyzst0y","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"刺猬理论：刺猬天冷时靠拢取暖，但必须保持距离以免刺伤对方。完美诠释了人际交往中“距离产生美”以及分寸感的重要性。"}]}]},{"ID":"20260605081425-1osg7vu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-1osg7vu","updated":"20260605081425"},"Children":[{"ID":"20260605081425-ojr0oxr","Type":"NodeParagraph","Properties":{"id":"20260605081425-ojr0oxr","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"熵增定律：在一个封闭系统中，若无外力做功，系统会自发趋向无序和混乱。人需要主动引入“负熵”（如持续学习、自律），才能对抗生命的无序与懈怠。"}]}]},{"ID":"20260605081425-kx6vk57","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-kx6vk57","updated":"20260605081425"},"Children":[{"ID":"20260605081425-8tqocde","Type":"NodeParagraph","Properties":{"id":"20260605081425-8tqocde","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"氨基酸组合效应：组成人体蛋白的8种氨基酸，只要有一种不足，其他7种就无法合成蛋白质。适合论证团队合作中缺一不可的整体性，或者个人素养的全面性。"}]}]},{"ID":"20260605081425-1t83oeu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-1t83oeu","updated":"20260605081425"},"Children":[{"ID":"20260605081425-zwvpjnv","Type":"NodeParagraph","Properties":{"id":"20260605081425-zwvpjnv","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"幸存者效应：只看到“活下来的人”“成功者”“被看见的案例”，却忽略了那些被淘汰、失败、沉默的大多数，于是容易得出片面甚至错误的结论。"}]}]},{"ID":"20260605081425-9q8lnl9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-9q8lnl9","updated":"20260605081425"},"Children":[{"ID":"20260605081425-sr71j0r","Type":"NodeParagraph","Properties":{"id":"20260605081425-sr71j0r","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"奥卡姆剃刀：如无必要，勿增实体。"}]}]},{"ID":"20260605081425-ig6h14n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ig6h14n","updated":"20260605081425"},"Children":[{"ID":"20260605081425-wzhjjgg","Type":"NodeParagraph","Properties":{"id":"20260605081425-wzhjjgg","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"墨菲定律：如果有两种或两种以上的方式去做某件事，而其中一种会导致灾难，那么必定会有人选择这种方式。"}]}]},{"ID":"20260605081425-paw7ml6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-paw7ml6","updated":"20260605081425"},"Children":[{"ID":"20260605081425-4viqlh5","Type":"NodeParagraph","Properties":{"id":"20260605081425-4viqlh5","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"波普尔证伪主义：科学理论的价值不在于被证明为真，而在于能够被不断检验并有可能被证伪，从而在批判中逐步逼近真理。"}]}]},{"ID":"20260605081425-xk97icc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-xk97icc","updated":"20260605081425"},"Children":[{"ID":"20260605081425-qssvjf7","Type":"NodeParagraph","Properties":{"id":"20260605081425-qssvjf7","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"皮亚杰建构主义：知识不是接受的，是主动建构的"}]}]},{"ID":"20260605081425-nizz99w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-nizz99w","updated":"20260605081425"},"Children":[{"ID":"20260605081425-3lhlds8","Type":"NodeParagraph","Properties":{"id":"20260605081425-3lhlds8","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"怀疑主义：对既有认知保持怀疑"}]}]},{"ID":"20260605081425-knt3jly","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-knt3jly","updated":"20260605081425"},"Children":[{"ID":"20260605081425-l62fxuz","Type":"NodeParagraph","Properties":{"id":"20260605081425-l62fxuz","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"黑格尔辩证法：真理在矛盾和冲突中发展"}]}]},{"ID":"20260605081425-esemu3b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-esemu3b","updated":"20260605081425"},"Children":[{"ID":"20260605081425-q8muy3n","Type":"NodeParagraph","Properties":{"id":"20260605081425-q8muy3n","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"实践论：实践是检验真理的唯一标准"}]}]}]}]},{"ID":"20260605081425-fzavlgu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-fzavlgu","updated":"20260605081425"},"Children":[{"ID":"20260605081425-djvgplh","Type":"NodeParagraph","Properties":{"id":"20260605081425-djvgplh","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。"}]}]}]}]},{"ID":"20260605081425-891dc8d","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260605081425-891dc8d","updated":"20260605081425"},"Children":[{"ID":"20260605081425-a52tpab","Type":"NodeParagraph","Properties":{"id":"20260605081425-a52tpab","updated":"20260605081425"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：840至860字"}]}]},{"ID":"20260605081425-n8qxty2","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OS4=","Num":9},"Properties":{"id":"20260605081425-n8qxty2","updated":"20260605081425"},"Children":[{"ID":"20260605081425-lq2i9po","Type":"NodeParagraph","Properties":{"id":"20260605081425-lq2i9po","updated":"20260605081425"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260605081425-049cskv","Type":"NodeList","ListData":{},"Properties":{"id":"20260605081425-049cskv","updated":"20260605081425"},"Children":[{"ID":"20260605081425-t8vvu9n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-t8vvu9n","updated":"20260605081425"},"Children":[{"ID":"20260605081425-pvjyzty","Type":"NodeParagraph","Properties":{"id":"20260605081425-pvjyzty","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260605081425-ae2rwf3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081425-ae2rwf3","updated":"20260605081425"},"Children":[{"ID":"20260605081425-a6nwgd6","Type":"NodeParagraph","Properties":{"id":"20260605081425-a6nwgd6","updated":"20260605081425"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]}]}]}