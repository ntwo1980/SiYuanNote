}]},{"ID":"20260603085254-950c64u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-950c64u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-c2u7t0a","Type":"NodeParagraph","Properties":{"id":"20260603085254-c2u7t0a","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"隐性植入辩证法"},{"Type":"NodeText","Data":"：将辩证法的三大规律(对立同一、量变质变、否定之否定)之一内化为文章的底层逻辑，但"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁直接出现"},{"Type":"NodeText","Data":"“对立统一”、“量变质变”、“否定之否定”等哲学术语。具体操作如下："}]},{"ID":"20260603085254-yoeo4ae","Type":"NodeList","ListData":{},"Properties":{"id":"20260603085254-yoeo4ae","updated":"20260603085254"},"Children":[{"ID":"20260603085254-js2i49m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-js2i49m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-36d701o","Type":"NodeParagraph","Properties":{"id":"20260603085254-36d701o","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现矛盾转化"},{"Type":"NodeText","Data":"：分析事物内部的矛盾双方（如危与机、强与弱），阐述它们在特定条件下如何相互依存并向对立面转化。"}]}]},{"ID":"20260603085254-qopuneo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qopuneo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v94fkev","Type":"NodeParagraph","Properties":{"id":"20260603085254-v94fkev","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现积累与飞跃"},{"Type":"NodeText","Data":"：论述从微小的积累到质的突破的过程，强调厚积薄发的重要性。"}]}]},{"ID":"20260603085254-3mmzles","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3mmzles","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tyowil0","Type":"NodeParagraph","Properties":{"id":"20260603085254-tyowil0","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现螺旋上升"},{"Type":"NodeText","Data":"：展现事物发展不是简单的循环，而是看似回归原点实则境界提升的曲折前进过程。"}]}]}]}]},{"ID":"20260603085254-ydnwk5e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ydnwk5e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5oqakum","Type":"NodeParagraph","Properties":{"id":"20260603085254-5oqakum","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辅助论式拓展"},{"Type":"NodeText","Data":"：可适当穿插使用道理/引证论证、类比论证或反证法，丰富文章的论证维度。在进行深层逻辑剖析时，可灵活调用以下思维模型，以增强文章的思辨厚度："}]},{"ID":"20260603085254-gxkxkuf","Type":"NodeList","ListData":{},"Properties":{"id":"20260603085254-gxkxkuf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qgho7dv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qgho7dv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-oa2fgx5","Type":"NodeParagraph","Properties":{"id":"20260603085254-oa2fgx5","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"社会与心理效应"},{"Type":"NodeText","Data":"：破窗效应、羊群效应、习得性无助、幸存者效应。"}]}]},{"ID":"20260603085254-z1bwlxa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-z1bwlxa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5x2tmy7","Type":"NodeParagraph","Properties":{"id":"20260603085254-5x2tmy7","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"决策与管理智慧"},{"Type":"NodeText","Data":"：锚定效应、手表定律、鳄鱼法则（及时止损）、氨基酸组合效应（整体与部分）。"}]}]},{"ID":"20260603085254-gtrk64w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gtrk64w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wizi3v9","Type":"NodeParagraph","Properties":{"id":"20260603085254-wizi3v9","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"哲学与科学原理"},{"Type":"NodeText","Data":"：熵增定律（对抗无序）、奥卡姆剃刀（化繁为简）、墨菲定律、波普尔证伪主义、贝叶斯原理（动态认知）、皮亚杰建构主义、黑格尔辩证法、实践论。"}]}]}]}]},{"ID":"20260603085254-v33auq2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-v33auq2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k8t1o7l","Type":"NodeParagraph","Properties":{"id":"20260603085254-k8t1o7l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"使用要求：严禁直接罗列名词或进行枯燥的科学解释。必须将这些原理内化为比喻或隐喻，自然地融入论证中（例如：用“熵增”比喻精神的懈怠，用“鳄鱼法则”比喻壮士断腕的决心）。"}]}]},{"ID":"20260603085254-8dr0670","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8dr0670","updated":"20260603085254"},"Children":[{"ID":"20260603085254-udjn8p8","Type":"NodeParagraph","Properties":{"id":"20260603085254-udjn8p8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"论据要充分且鲜活，拒绝陈词滥调（避免过度使用司马迁、李白、爱迪生等老套素材）。结合时事热点、历史文化等多维度素材。"}]}]}]}]},{"ID":"20260603085254-bf57u4g","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260603085254-bf57u4g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-q0gut9x","Type":"NodeParagraph","Properties":{"id":"20260603085254-q0gut9x","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"古典底蕴与化用："}]},{"ID":"20260603085254-qdanaw0","Type":"NodeList","ListData":{},"Properties":{"id":"20260603085254-qdanaw0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ns33sn1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ns33sn1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9kbjszs","Type":"NodeParagraph","Properties":{"id":"20260603085254-9kbjszs","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"至少自然嵌入2–3条下面提供的的典故、文章(不必引用原文，文章总结、提炼亦可)、诗词名句、电影，并保证与论证逻辑紧密相关。"}]},{"ID":"20260603085254-7qr19rk","Type":"NodeList","ListData":{},"Properties":{"id":"20260603085254-7qr19rk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mzus5jv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mzus5jv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fns0rlg","Type":"NodeParagraph","Properties":{"id":"20260603085254-fns0rlg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《尚书》五福：寿、福、康宁、攸好德、考终命"}]}]},{"ID":"20260603085254-i9jwzwc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-i9jwzwc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zowz6yf","Type":"NodeParagraph","Properties":{"id":"20260603085254-zowz6yf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"鲁迅：无穷的远方，无数的人们，都与我相关。"}]}]},{"ID":"20260603085254-qwhrvn2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qwhrvn2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-95o9g6p","Type":"NodeParagraph","Properties":{"id":"20260603085254-95o9g6p","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260603085254-ul8yn1i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ul8yn1i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-w0ytkmd","Type":"NodeParagraph","Properties":{"id":"20260603085254-w0ytkmd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603085254-8vdawzg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8vdawzg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2mf8ek6","Type":"NodeParagraph","Properties":{"id":"20260603085254-2mf8ek6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260603085254-e67az5y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e67az5y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-41ry9y2","Type":"NodeParagraph","Properties":{"id":"20260603085254-41ry9y2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260603085254-fk49kof","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fk49kof","updated":"20260603085254"},"Children":[{"ID":"20260603085254-acxbduk","Type":"NodeParagraph","Properties":{"id":"20260603085254-acxbduk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260603085254-bfsankx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bfsankx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-88co8ph","Type":"NodeParagraph","Properties":{"id":"20260603085254-88co8ph","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260603085254-1d50xmz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1d50xmz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cxchdkj","Type":"NodeParagraph","Properties":{"id":"20260603085254-cxchdkj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260603085254-93bfr3s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-93bfr3s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fbci2ig","Type":"NodeParagraph","Properties":{"id":"20260603085254-fbci2ig","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260603085254-sihrtx9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sihrtx9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fomw8ff","Type":"NodeParagraph","Properties":{"id":"20260603085254-fomw8ff","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《美丽心灵》约翰·纳什"}]}]},{"ID":"20260603085254-1ofh87j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1ofh87j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0l9vmct","Type":"NodeParagraph","Properties":{"id":"20260603085254-0l9vmct","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"西格里夫·萨松：心有猛虎，细嗅蔷薇。"}]}]},{"ID":"20260603085254-tehw0n9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tehw0n9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k31oiwu","Type":"NodeParagraph","Properties":{"id":"20260603085254-k31oiwu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260603085254-o22zgtp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-o22zgtp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jn8hk73","Type":"NodeParagraph","Properties":{"id":"20260603085254-jn8hk73","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260603085254-4cn2kii","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4cn2kii","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pzmdzzy","Type":"NodeParagraph","Properties":{"id":"20260603085254-pzmdzzy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260603085254-kdrblss","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kdrblss","updated":"20260603085254"},"Children":[{"ID":"20260603085254-shvhuo5","Type":"NodeParagraph","Properties":{"id":"20260603085254-shvhuo5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海明威：一个人可以被毁灭， "},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"但不能被打败。"}]}]},{"ID":"20260603085254-ogzsobs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ogzsobs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x2ndg71","Type":"NodeParagraph","Properties":{"id":"20260603085254-x2ndg71","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"杨绛：生活一半是柴米油盐，一半是星辰大海。"}]}]},{"ID":"20260603085254-24mcmwn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-24mcmwn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xx8krq4","Type":"NodeParagraph","Properties":{"id":"20260603085254-xx8krq4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰：世界上只有一种英雄主义，就是在认清生活的真相之后依然热爱生活。"}]}]},{"ID":"20260603085254-1b543lv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1b543lv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pmcc99a","Type":"NodeParagraph","Properties":{"id":"20260603085254-pmcc99a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗素：参差多态乃是人类幸福的本源。"}]}]},{"ID":"20260603085254-w89jk4j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w89jk4j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vnzhpq7","Type":"NodeParagraph","Properties":{"id":"20260603085254-vnzhpq7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260603085254-bnugvv1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bnugvv1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-levosju","Type":"NodeParagraph","Properties":{"id":"20260603085254-levosju","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260603085254-kkk6n0t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kkk6n0t","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r8jfgtm","Type":"NodeParagraph","Properties":{"id":"20260603085254-r8jfgtm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260603085254-lpv5vyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lpv5vyb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kol4p3d","Type":"NodeParagraph","Properties":{"id":"20260603085254-kol4p3d","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260603085254-yyitilq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yyitilq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5trik8t","Type":"NodeParagraph","Properties":{"id":"20260603085254-5trik8t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260603085254-lxby22x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lxby22x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ctbbvnf","Type":"NodeParagraph","Properties":{"id":"20260603085254-ctbbvnf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260603085254-vtesbdv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vtesbdv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-94cu2ah","Type":"NodeParagraph","Properties":{"id":"20260603085254-94cu2ah","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260603085254-zbrrkff","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zbrrkff","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zgr2k0y","Type":"NodeParagraph","Properties":{"id":"20260603085254-zgr2k0y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260603085254-pba753k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pba753k","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p5o09y8","Type":"NodeParagraph","Properties":{"id":"20260603085254-p5o09y8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260603085254-5dn6y86","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5dn6y86","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9mbd8ke","Type":"NodeParagraph","Properties":{"id":"20260603085254-9mbd8ke","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260603085254-60vvpjq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-60vvpjq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-y4aarg7","Type":"NodeParagraph","Properties":{"id":"20260603085254-y4aarg7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260603085254-07gmvdu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-07gmvdu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xtqd1a5","Type":"NodeParagraph","Properties":{"id":"20260603085254-xtqd1a5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260603085254-qte84mw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qte84mw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v7b6pzm","Type":"NodeParagraph","Properties":{"id":"20260603085254-v7b6pzm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260603085254-4qh52fo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4qh52fo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5wylo2f","Type":"NodeParagraph","Properties":{"id":"20260603085254-5wylo2f","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"特鲁多医生墓志铭：医生有时治愈，常常帮助，总是安慰。"}]}]},{"ID":"20260603085254-d6yeuon","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d6yeuon","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tg719jv","Type":"NodeParagraph","Properties":{"id":"20260603085254-tg719jv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260603085254-xgd7p7s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xgd7p7s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1e1m9om","Type":"NodeParagraph","Properties":{"id":"20260603085254-1e1m9om","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260603085254-rsknksz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rsknksz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lp8q66q","Type":"NodeParagraph","Properties":{"id":"20260603085254-lp8q66q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260603085254-gb17bk4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gb17bk4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-io4y8u8","Type":"NodeParagraph","Properties":{"id":"20260603085254-io4y8u8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260603085254-3bl8ycu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3bl8ycu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-je5ap3b","Type":"NodeParagraph","Properties":{"id":"20260603085254-je5ap3b","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260603085254-5m5j9le","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5m5j9le","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9ue607z","Type":"NodeParagraph","Properties":{"id":"20260603085254-9ue607z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260603085254-kut2fs1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kut2fs1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-12ksx2e","Type":"NodeParagraph","Properties":{"id":"20260603085254-12ksx2e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260603085254-2s9j03k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2s9j03k","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i8vv6ds","Type":"NodeParagraph","Properties":{"id":"20260603085254-i8vv6ds","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260603085254-m0c1csq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m0c1csq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ylgbxyf","Type":"NodeParagraph","Properties":{"id":"20260603085254-ylgbxyf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260603085254-r49znxj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r49znxj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6m0b3bq","Type":"NodeParagraph","Properties":{"id":"20260603085254-6m0b3bq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260603085254-15v4y2n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-15v4y2n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-96yznnm","Type":"NodeParagraph","Properties":{"id":"20260603085254-96yznnm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260603085254-5zoidum","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5zoidum","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n5g8kw9","Type":"NodeParagraph","Properties":{"id":"20260603085254-n5g8kw9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260603085254-gi9z2q9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gi9z2q9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4g6ya6i","Type":"NodeParagraph","Properties":{"id":"20260603085254-4g6ya6i","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260603085254-98qic92","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-98qic92","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0dqa8bu","Type":"NodeParagraph","Properties":{"id":"20260603085254-0dqa8bu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260603085254-6lqr0pc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6lqr0pc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-eifk7o4","Type":"NodeParagraph","Properties":{"id":"20260603085254-eifk7o4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260603085254-rw2ralk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rw2ralk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hz05mn2","Type":"NodeParagraph","Properties":{"id":"20260603085254-hz05mn2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260603085358-klooekd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085358-klooekd","updated":"20260603085254"},"Children":[{"ID":"20260603085358-qg6r5of","Type":"NodeParagraph","Properties":{"id":"20260603085358-qg6r5of","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260603085358-nz98m83","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085358-nz98m83","updated":"20260603085254"},"Children":[{"ID":"20260603085358-h1x3224","Type":"NodeParagraph","Properties":{"id":"20260603085358-h1x3224","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨果：在逆境中，把俯视墓穴的悲痛，转换为仰望星空的情感。"}]}]},{"ID":"20260603085358-gbu9zqg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085358-gbu9zqg","updated":"20260603085358"},"Children":[{"ID":"20260603085358-d5sfhbg","Type":"NodeParagraph","Properties":{"id":"20260603085358-d5sfhbg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260603085358-t8xfbyh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085358-t8xfbyh","updated":"20260603085358"},"Children":[{"ID":"20260603085358-s560zl0","Type":"NodeParagraph","Properties":{"id":"20260603085358-s560zl0","updated":"20260603085319"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260603085254-ru76lvf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ru76lvf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ljzurvb","Type":"NodeParagraph","Properties":{"id":"20260603085254-ljzurvb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260603085254-oreb6o6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oreb6o6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g02ga3q","Type":"NodeParagraph","Properties":{"id":"20260603085254-g02ga3q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260603085254-mk7lsrw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mk7lsrw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yet530x","Type":"NodeParagraph","Properties":{"id":"20260603085254-yet530x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260603085254-61bzlxr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-61bzlxr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8xoqeyq","Type":"NodeParagraph","Properties":{"id":"20260603085254-8xoqeyq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260603085254-kq4ntm5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kq4ntm5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-girv0r8","Type":"NodeParagraph","Properties":{"id":"20260603085254-girv0r8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260603085254-gwgg9qp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gwgg9qp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kckqiz0","Type":"NodeParagraph","Properties":{"id":"20260603085254-kckqiz0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260603085254-5pbp1nb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5pbp1nb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h4fyik8","Type":"NodeParagraph","Properties":{"id":"20260603085254-h4fyik8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260603085254-fv7hz0m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fv7hz0m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-92ob2b0","Type":"NodeParagraph","Properties":{"id":"20260603085254-92ob2b0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260603085254-hsd9b1g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hsd9b1g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0cacbaa","Type":"NodeParagraph","Properties":{"id":"20260603085254-0cacbaa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260603085254-b48nrq8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b48nrq8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vuypyef","Type":"NodeParagraph","Properties":{"id":"20260603085254-vuypyef","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260603085254-wvkgi6a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wvkgi6a","updated":"20260603085254"},"Children":[{"ID":"20260603085254-38ecods","Type":"NodeParagraph","Properties":{"id":"20260603085254-38ecods","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603085254-f5vte9j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-f5vte9j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-iw44p7y","Type":"NodeParagraph","Properties":{"id":"20260603085254-iw44p7y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260603085254-122j074","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-122j074","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bf71ntj","Type":"NodeParagraph","Properties":{"id":"20260603085254-bf71ntj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260603085254-rl5ydxz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rl5ydxz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kb8dpom","Type":"NodeParagraph","Properties":{"id":"20260603085254-kb8dpom","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260603085254-ai05rit","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ai05rit","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jhd7epy","Type":"NodeParagraph","Properties":{"id":"20260603085254-jhd7epy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260603085254-8zoojg2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8zoojg2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gspb7jm","Type":"NodeParagraph","Properties":{"id":"20260603085254-gspb7jm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260603085254-yscphjb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yscphjb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v5pcgx9","Type":"NodeParagraph","Properties":{"id":"20260603085254-v5pcgx9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260603085254-5zcl2eu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5zcl2eu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-izo5wyw","Type":"NodeParagraph","Properties":{"id":"20260603085254-izo5wyw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260603085254-fn1uw9o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fn1uw9o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gffac4y","Type":"NodeParagraph","Properties":{"id":"20260603085254-gffac4y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260603085254-ymtmmyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ymtmmyb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-psnkf4m","Type":"NodeParagraph","Properties":{"id":"20260603085254-psnkf4m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260603085254-mz2lqlg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mz2lqlg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1v27af2","Type":"NodeParagraph","Properties":{"id":"20260603085254-1v27af2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260603085254-kyz5doi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kyz5doi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ozvnbhv","Type":"NodeParagraph","Properties":{"id":"20260603085254-ozvnbhv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603085254-xf54rin","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xf54rin","updated":"20260603085254"},"Children":[{"ID":"20260603085254-puyc479","Type":"NodeParagraph","Properties":{"id":"20260603085254-puyc479","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260603085254-bipaf95","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bipaf95","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ebi1dt7","Type":"NodeParagraph","Properties":{"id":"20260603085254-ebi1dt7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260603085254-8fkdwa4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8fkdwa4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ls7u3a1","Type":"NodeParagraph","Properties":{"id":"20260603085254-ls7u3a1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603085254-qg02vod","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qg02vod","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vazv8qf","Type":"NodeParagraph","Properties":{"id":"20260603085254-vazv8qf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260603085254-uwgpqt3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uwgpqt3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xqcazpn","Type":"NodeParagraph","Properties":{"id":"20260603085254-xqcazpn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260603085254-bjv8rso","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bjv8rso","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fugui9y","Type":"NodeParagraph","Properties":{"id":"20260603085254-fugui9y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260603085254-1nzonvr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1nzonvr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0h4rll0","Type":"NodeParagraph","Properties":{"id":"20260603085254-0h4rll0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260603085254-dk5myo8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dk5myo8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-a77g8yi","Type":"NodeParagraph","Properties":{"id":"20260603085254-a77g8yi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260603085254-qm731tc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qm731tc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-q7nz40h","Type":"NodeParagraph","Properties":{"id":"20260603085254-q7nz40h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260603085254-4344dfp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4344dfp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3uaxd8e","Type":"NodeParagraph","Properties":{"id":"20260603085254-3uaxd8e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260603085254-ovm994y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ovm994y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5tvoewt","Type":"NodeParagraph","Properties":{"id":"20260603085254-5tvoewt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260603085254-h0ekthy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h0ekthy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zzwe13t","Type":"NodeParagraph","Properties":{"id":"20260603085254-zzwe13t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260603085254-b21cdy5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b21cdy5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-a6z78tt","Type":"NodeParagraph","Properties":{"id":"20260603085254-a6z78tt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260603085254-akjamsi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-akjamsi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ktmkh69","Type":"NodeParagraph","Properties":{"id":"20260603085254-ktmkh69","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260603085254-3paelo6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3paelo6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h2p078q","Type":"NodeParagraph","Properties":{"id":"20260603085254-h2p078q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603085254-obnori1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-obnori1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vqf1yah","Type":"NodeParagraph","Properties":{"id":"20260603085254-vqf1yah","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260603085254-bfygvuz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bfygvuz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gpyg8sw","Type":"NodeParagraph","Properties":{"id":"20260603085254-gpyg8sw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260603085254-0gx94ci","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0gx94ci","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8pwjxvm","Type":"NodeParagraph","Properties":{"id":"20260603085254-8pwjxvm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260603085254-bozpy9x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bozpy9x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vg9t55w","Type":"NodeParagraph","Properties":{"id":"20260603085254-vg9t55w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260603085254-181sg6i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-181sg6i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3e4intq","Type":"NodeParagraph","Properties":{"id":"20260603085254-3e4intq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260603085254-p2do823","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-p2do823","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uv8gr8y","Type":"NodeParagraph","Properties":{"id":"20260603085254-uv8gr8y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260603085254-i7tjirg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-i7tjirg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xm7js7q","Type":"NodeParagraph","Properties":{"id":"20260603085254-xm7js7q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260603085254-bw6ue8b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bw6ue8b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7d4asxf","Type":"NodeParagraph","Properties":{"id":"20260603085254-7d4asxf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260603085254-365gpeu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-365gpeu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zjdt6mw","Type":"NodeParagraph","Properties":{"id":"20260603085254-zjdt6mw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260603085254-bmbupfv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bmbupfv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-sas2cgh","Type":"NodeParagraph","Properties":{"id":"20260603085254-sas2cgh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260603085254-yeuiuz4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yeuiuz4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2l2kivp","Type":"NodeParagraph","Properties":{"id":"20260603085254-2l2kivp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260603085254-zlsqqh3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zlsqqh3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7hxak5q","Type":"NodeParagraph","Properties":{"id":"20260603085254-7hxak5q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260603085254-iijd75v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-iijd75v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3t7fn4m","Type":"NodeParagraph","Properties":{"id":"20260603085254-3t7fn4m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260603085254-2rmndnr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2rmndnr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9bs79hb","Type":"NodeParagraph","Properties":{"id":"20260603085254-9bs79hb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260603085254-t8o3v1m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t8o3v1m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pnhzh8p","Type":"NodeParagraph","Properties":{"id":"20260603085254-pnhzh8p","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260603085254-4dgm182","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4dgm182","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dvy2tmt","Type":"NodeParagraph","Properties":{"id":"20260603085254-dvy2tmt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260603085254-szr39w0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-szr39w0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k4empsr","Type":"NodeParagraph","Properties":{"id":"20260603085254-k4empsr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260603085254-eyjq1pw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-eyjq1pw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-acc9emq","Type":"NodeParagraph","Properties":{"id":"20260603085254-acc9emq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260603085254-rbocabs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rbocabs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uw6sacl","Type":"NodeParagraph","Properties":{"id":"20260603085254-uw6sacl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260603085254-gu5c309","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gu5c309","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0ho4wkp","Type":"NodeParagraph","Properties":{"id":"20260603085254-0ho4wkp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260603085254-fdb45b2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fdb45b2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6mv6qv3","Type":"NodeParagraph","Properties":{"id":"20260603085254-6mv6qv3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260603085254-zse8dp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zse8dp1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qn6ag21","Type":"NodeParagraph","Properties":{"id":"20260603085254-qn6ag21","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260603085254-xcvbpwb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xcvbpwb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bg9726g","Type":"NodeParagraph","Properties":{"id":"20260603085254-bg9726g","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260603085254-5u09vsm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5u09vsm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fuawutf","Type":"NodeParagraph","Properties":{"id":"20260603085254-fuawutf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260603085254-6few7aq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6few7aq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n28ro9t","Type":"NodeParagraph","Properties":{"id":"20260603085254-n28ro9t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260603085254-s7x23bo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s7x23bo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fdkvys2","Type":"NodeParagraph","Properties":{"id":"20260603085254-fdkvys2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260603085254-dd1wh0m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dd1wh0m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nt0ubg8","Type":"NodeParagraph","Properties":{"id":"20260603085254-nt0ubg8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260603085254-oyro1ke","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oyro1ke","updated":"20260603085254"},"Children":[{"ID":"20260603085254-c2amw5r","Type":"NodeParagraph","Properties":{"id":"20260603085254-c2amw5r","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260603085254-utsyh56","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-utsyh56","updated":"20260603085254"},"Children":[{"ID":"20260603085254-sgree5z","Type":"NodeParagraph","Properties":{"id":"20260603085254-sgree5z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260603085254-of07ope","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-of07ope","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xyvlmx8","Type":"NodeParagraph","Properties":{"id":"20260603085254-xyvlmx8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260603085254-mofekmp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mofekmp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gimxip0","Type":"NodeParagraph","Properties":{"id":"20260603085254-gimxip0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260603085254-0w75yk7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0w75yk7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7rzw4zf","Type":"NodeParagraph","Properties":{"id":"20260603085254-7rzw4zf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260603085254-a1hfo48","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-a1hfo48","updated":"20260603085254"},"Children":[{"ID":"20260603085254-84ipwv3","Type":"NodeParagraph","Properties":{"id":"20260603085254-84ipwv3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260603085254-rewa7il","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rewa7il","updated":"20260603085254"},"Children":[{"ID":"20260603085254-s646j80","Type":"NodeParagraph","Properties":{"id":"20260603085254-s646j80","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260603085254-c06onrk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c06onrk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-31uxf3d","Type":"NodeParagraph","Properties":{"id":"20260603085254-31uxf3d","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260603085254-kd9hczg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kd9hczg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6sc9ef8","Type":"NodeParagraph","Properties":{"id":"20260603085254-6sc9ef8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260603085254-2wbb247","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2wbb247","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pmck52n","Type":"NodeParagraph","Properties":{"id":"20260603085254-pmck52n","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260603085254-2illhlz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2illhlz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fyl5fvt","Type":"NodeParagraph","Properties":{"id":"20260603085254-fyl5fvt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260603085254-enzgljy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-enzgljy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t2kt88b","Type":"NodeParagraph","Properties":{"id":"20260603085254-t2kt88b","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260603085254-zlmgwtm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zlmgwtm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0mlfo2q","Type":"NodeParagraph","Properties":{"id":"20260603085254-0mlfo2q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260603085254-vnjyn3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vnjyn3x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7o19thv","Type":"NodeParagraph","Properties":{"id":"20260603085254-7o19thv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260603085254-gq3if5o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gq3if5o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9a8nvzy","Type":"NodeParagraph","Properties":{"id":"20260603085254-9a8nvzy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260603085254-ew2nu68","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ew2nu68","updated":"20260603085254"},"Children":[{"ID":"20260603085254-iicib19","Type":"NodeParagraph","Properties":{"id":"20260603085254-iicib19","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260603085254-heefqdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-heefqdt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9vdz482","Type":"NodeParagraph","Properties":{"id":"20260603085254-9vdz482","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260603085254-bw2xmdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bw2xmdt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i1mujma","Type":"NodeParagraph","Properties":{"id":"20260603085254-i1mujma","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260603085254-cfd3ue4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cfd3ue4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kkym72x","Type":"NodeParagraph","Properties":{"id":"20260603085254-kkym72x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260603085254-a1eru79","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-a1eru79","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jh57h3y","Type":"NodeParagraph","Properties":{"id":"20260603085254-jh57h3y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"歌德：才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260603085254-ku8whr6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ku8whr6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wzsvrrl","Type":"NodeParagraph","Properties":{"id":"20260603085254-wzsvrrl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260603085254-7k1a7xh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7k1a7xh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x16x6o7","Type":"NodeParagraph","Properties":{"id":"20260603085254-x16x6o7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260603085254-rvvukhp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rvvukhp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9guea6y","Type":"NodeParagraph","Properties":{"id":"20260603085254-9guea6y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260603085254-xykbcwk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xykbcwk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xiuv1ch","Type":"NodeParagraph","Properties":{"id":"20260603085254-xiuv1ch","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260603085254-mkfs4y5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mkfs4y5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bg79ks6","Type":"NodeParagraph","Properties":{"id":"20260603085254-bg79ks6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260603085254-g24k00j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g24k00j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-972ydff","Type":"NodeParagraph","Properties":{"id":"20260603085254-972ydff","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260603085254-bx07dsj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bx07dsj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kj13evx","Type":"NodeParagraph","Properties":{"id":"20260603085254-kj13evx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260603085254-y70zwv5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y70zwv5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ugo08xb","Type":"NodeParagraph","Properties":{"id":"20260603085254-ugo08xb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260603085254-e5rj57w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e5rj57w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bkmbwg2","Type":"NodeParagraph","Properties":{"id":"20260603085254-bkmbwg2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260603085254-wdbjjuy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wdbjjuy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fg1jc2j","Type":"NodeParagraph","Properties":{"id":"20260603085254-fg1jc2j","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260603085254-pjei2yb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pjei2yb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pefuh24","Type":"NodeParagraph","Properties":{"id":"20260603085254-pefuh24","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260603085254-jtn3qi3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jtn3qi3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1j5ld5a","Type":"NodeParagraph","Properties":{"id":"20260603085254-1j5ld5a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260603085254-dqs1ke3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dqs1ke3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ahzbv5h","Type":"NodeParagraph","Properties":{"id":"20260603085254-ahzbv5h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260603085254-ay3kuax","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ay3kuax","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vq1dfao","Type":"NodeParagraph","Properties":{"id":"20260603085254-vq1dfao","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260603085254-iwzbfo4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-iwzbfo4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lro5r8m","Type":"NodeParagraph","Properties":{"id":"20260603085254-lro5r8m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260603085254-x476pad","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-x476pad","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cl4f34w","Type":"NodeParagraph","Properties":{"id":"20260603085254-cl4f34w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260603085254-ijxjcay","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ijxjcay","updated":"20260603085254"},"Children":[{"ID":"20260603085254-m546hzh","Type":"NodeParagraph","Properties":{"id":"20260603085254-m546hzh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260603085254-zifa2au","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zifa2au","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yqob3z0","Type":"NodeParagraph","Properties":{"id":"20260603085254-yqob3z0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260603085254-8sq3a5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8sq3a5l","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3uxk4ij","Type":"NodeParagraph","Properties":{"id":"20260603085254-3uxk4ij","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260603085254-quyyivk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-quyyivk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-skxpctw","Type":"NodeParagraph","Properties":{"id":"20260603085254-skxpctw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260603085254-d4131bk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d4131bk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6su31sk","Type":"NodeParagraph","Properties":{"id":"20260603085254-6su31sk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260603085254-vgmn2uq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vgmn2uq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3eyvrc7","Type":"NodeParagraph","Properties":{"id":"20260603085254-3eyvrc7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260603085254-l1r21yu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-l1r21yu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u888vw2","Type":"NodeParagraph","Properties":{"id":"20260603085254-u888vw2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260603085254-so3h4vw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-so3h4vw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z5f2wd5","Type":"NodeParagraph","Properties":{"id":"20260603085254-z5f2wd5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260603085254-0wluc8u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0wluc8u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uxjdir3","Type":"NodeParagraph","Properties":{"id":"20260603085254-uxjdir3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260603085254-npdi0ka","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-npdi0ka","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gof3zd2","Type":"NodeParagraph","Properties":{"id":"20260603085254-gof3zd2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260603085254-80s4zpq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-80s4zpq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r9egcev","Type":"NodeParagraph","Properties":{"id":"20260603085254-r9egcev","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260603085254-bhvinvn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bhvinvn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3d6a60o","Type":"NodeParagraph","Properties":{"id":"20260603085254-3d6a60o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260603085254-9ox5mpa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9ox5mpa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uor1b64","Type":"NodeParagraph","Properties":{"id":"20260603085254-uor1b64","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260603085254-pdh4q29","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pdh4q29","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yyr0s1e","Type":"NodeParagraph","Properties":{"id":"20260603085254-yyr0s1e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260603085254-gmwf0rb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gmwf0rb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-03stwez","Type":"NodeParagraph","Properties":{"id":"20260603085254-03stwez","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260603085254-ofg2ucd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ofg2ucd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bjx6vi3","Type":"NodeParagraph","Properties":{"id":"20260603085254-bjx6vi3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260603085254-7g8t1zq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7g8t1zq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4a0d1et","Type":"NodeParagraph","Properties":{"id":"20260603085254-4a0d1et","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260603085254-tku2xfh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tku2xfh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-m0jt3sy","Type":"NodeParagraph","Properties":{"id":"20260603085254-m0jt3sy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260603085254-orlsakt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-orlsakt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ilgwvx8","Type":"NodeParagraph","Properties":{"id":"20260603085254-ilgwvx8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260603085254-9duqukk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9duqukk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u9h23y8","Type":"NodeParagraph","Properties":{"id":"20260603085254-u9h23y8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260603085254-wm25qfl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wm25qfl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5le43n6","Type":"NodeParagraph","Properties":{"id":"20260603085254-5le43n6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260603085254-jyw76fe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jyw76fe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qyd5qcg","Type":"NodeParagraph","Properties":{"id":"20260603085254-qyd5qcg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260603085254-01r930o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-01r930o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-crcjgrq","Type":"NodeParagraph","Properties":{"id":"20260603085254-crcjgrq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260603085254-0ykat5o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0ykat5o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-s6pundh","Type":"NodeParagraph","Properties":{"id":"20260603085254-s6pundh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260603085254-kejyzz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kejyzz2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i8ayuan","Type":"NodeParagraph","Properties":{"id":"20260603085254-i8ayuan","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260603085254-vhxupow","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vhxupow","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dntdd4t","Type":"NodeParagraph","Properties":{"id":"20260603085254-dntdd4t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260603085254-0dfulyf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0dfulyf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z8ihdd3","Type":"NodeParagraph","Properties":{"id":"20260603085254-z8ihdd3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260603085254-sgk7764","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sgk7764","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bz3l7lq","Type":"NodeParagraph","Properties":{"id":"20260603085254-bz3l7lq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260603085254-81agowr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-81agowr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kvgx9zh","Type":"NodeParagraph","Properties":{"id":"20260603085254-kvgx9zh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260603085254-fbff6gg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fbff6gg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j6z2ijq","Type":"NodeParagraph","Properties":{"id":"20260603085254-j6z2ijq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260603085254-ygohiwr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ygohiwr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-86mxobv","Type":"NodeParagraph","Properties":{"id":"20260603085254-86mxobv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260603085254-q6cy61s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-q6cy61s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5lkf2mr","Type":"NodeParagraph","Properties":{"id":"20260603085254-5lkf2mr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260603085254-s06okcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s06okcq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yzxwfl0","Type":"NodeParagraph","Properties":{"id":"20260603085254-yzxwfl0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260603085254-q49oomf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-q49oomf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nny0obf","Type":"NodeParagraph","Properties":{"id":"20260603085254-nny0obf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260603085254-4i7tlnv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4i7tlnv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9ue7s3y","Type":"NodeParagraph","Properties":{"id":"20260603085254-9ue7s3y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260603085254-c69pe2c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c69pe2c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-eip6ce0","Type":"NodeParagraph","Properties":{"id":"20260603085254-eip6ce0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260603085254-ji1fg3u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ji1fg3u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-swf7rqp","Type":"NodeParagraph","Properties":{"id":"20260603085254-swf7rqp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260603085254-a934xo2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-a934xo2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4p4c9of","Type":"NodeParagraph","Properties":{"id":"20260603085254-4p4c9of","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260603085254-sdsyi4h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sdsyi4h","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zrsei7x","Type":"NodeParagraph","Properties":{"id":"20260603085254-zrsei7x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260603085254-5voxk9n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5voxk9n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ae4j1pb","Type":"NodeParagraph","Properties":{"id":"20260603085254-ae4j1pb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260603085254-hcudtvi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hcudtvi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-224a1z3","Type":"NodeParagraph","Properties":{"id":"20260603085254-224a1z3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260603085254-hoiiwnm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hoiiwnm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-luixkil","Type":"NodeParagraph","Properties":{"id":"20260603085254-luixkil","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260603085254-lwff124","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lwff124","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p3y8404","Type":"NodeParagraph","Properties":{"id":"20260603085254-p3y8404","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260603085254-onu9hw3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-onu9hw3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lngdhpd","Type":"NodeParagraph","Properties":{"id":"20260603085254-lngdhpd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260603085254-xqyobjp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xqyobjp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4bex09k","Type":"NodeParagraph","Properties":{"id":"20260603085254-4bex09k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603085254-6fayt1w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6fayt1w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-79e0md9","Type":"NodeParagraph","Properties":{"id":"20260603085254-79e0md9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260603085254-dpjjmqw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dpjjmqw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z28yjz5","Type":"NodeParagraph","Properties":{"id":"20260603085254-z28yjz5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260603085254-7w6d45f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7w6d45f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bkkw35c","Type":"NodeParagraph","Properties":{"id":"20260603085254-bkkw35c","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260603085254-rbqzgj8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rbqzgj8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v69jjyl","Type":"NodeParagraph","Properties":{"id":"20260603085254-v69jjyl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260603085254-w915d8a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w915d8a","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2ujfksf","Type":"NodeParagraph","Properties":{"id":"20260603085254-2ujfksf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260603085254-i43pz9s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-i43pz9s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-udowkjx","Type":"NodeParagraph","Properties":{"id":"20260603085254-udowkjx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260603085254-qj4f6at","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qj4f6at","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bguc8or","Type":"NodeParagraph","Properties":{"id":"20260603085254-bguc8or","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260603085254-n2p0nhv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n2p0nhv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gjvwyo2","Type":"NodeParagraph","Properties":{"id":"20260603085254-gjvwyo2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260603085254-6zab5jq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6zab5jq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lflwbkn","Type":"NodeParagraph","Properties":{"id":"20260603085254-lflwbkn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260603085254-4cc4f0i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4cc4f0i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uxb3mcn","Type":"NodeParagraph","Properties":{"id":"20260603085254-uxb3mcn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260603085254-15odcwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-15odcwm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vv6fcqb","Type":"NodeParagraph","Properties":{"id":"20260603085254-vv6fcqb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260603085254-brz123z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-brz123z","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ty5bm60","Type":"NodeParagraph","Properties":{"id":"20260603085254-ty5bm60","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260603085254-m8874bo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m8874bo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vd2v7aq","Type":"NodeParagraph","Properties":{"id":"20260603085254-vd2v7aq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260603085254-va4ax77","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-va4ax77","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7kyphiy","Type":"NodeParagraph","Properties":{"id":"20260603085254-7kyphiy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260603085254-l0p24nn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-l0p24nn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t88d4hl","Type":"NodeParagraph","Properties":{"id":"20260603085254-t88d4hl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260603085254-bcf0sli","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bcf0sli","updated":"20260603085254"},"Children":[{"ID":"20260603085254-o2yl0bz","Type":"NodeParagraph","Properties":{"id":"20260603085254-o2yl0bz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260603085254-55c0ibg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-55c0ibg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3pn85jt","Type":"NodeParagraph","Properties":{"id":"20260603085254-3pn85jt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260603085254-d1lyc1g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d1lyc1g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ut56q7i","Type":"NodeParagraph","Properties":{"id":"20260603085254-ut56q7i","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260603085254-kmq4duc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kmq4duc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5mcky4t","Type":"NodeParagraph","Properties":{"id":"20260603085254-5mcky4t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260603085254-um05zj2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-um05zj2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-e14mimr","Type":"NodeParagraph","Properties":{"id":"20260603085254-e14mimr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260603085254-1t5k6d8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1t5k6d8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-d7kcmlb","Type":"NodeParagraph","Properties":{"id":"20260603085254-d7kcmlb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260603085254-d76k8ed","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d76k8ed","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nlqwhn8","Type":"NodeParagraph","Properties":{"id":"20260603085254-nlqwhn8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260603085254-nz7jqzm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nz7jqzm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v68vy9h","Type":"NodeParagraph","Properties":{"id":"20260603085254-v68vy9h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260603085254-2ppmdcj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2ppmdcj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ci0pc12","Type":"NodeParagraph","Properties":{"id":"20260603085254-ci0pc12","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260603085254-vnwvlrd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vnwvlrd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gyro69h","Type":"NodeParagraph","Properties":{"id":"20260603085254-gyro69h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260603085254-rmu5w90","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rmu5w90","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hlut69r","Type":"NodeParagraph","Properties":{"id":"20260603085254-hlut69r","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260603085254-yk6cbjg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yk6cbjg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jqvumq1","Type":"NodeParagraph","Properties":{"id":"20260603085254-jqvumq1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260603085254-5jxh0az","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5jxh0az","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uev3w76","Type":"NodeParagraph","Properties":{"id":"20260603085254-uev3w76","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260603085254-3orc5vn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3orc5vn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z4x8zg6","Type":"NodeParagraph","Properties":{"id":"20260603085254-z4x8zg6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260603085254-40bkr9n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-40bkr9n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6b5q4p2","Type":"NodeParagraph","Properties":{"id":"20260603085254-6b5q4p2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260603085254-kk9vmpp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kk9vmpp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wdnyey5","Type":"NodeParagraph","Properties":{"id":"20260603085254-wdnyey5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260603085254-jrvwr9u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jrvwr9u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-70w0m8k","Type":"NodeParagraph","Properties":{"id":"20260603085254-70w0m8k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260603085254-blbjgdz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-blbjgdz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-542m2rl","Type":"NodeParagraph","Properties":{"id":"20260603085254-542m2rl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260603085254-e2prfh2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e2prfh2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uk7gtk9","Type":"NodeParagraph","Properties":{"id":"20260603085254-uk7gtk9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260603085254-zd8jkiw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zd8jkiw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-d4kq9yq","Type":"NodeParagraph","Properties":{"id":"20260603085254-d4kq9yq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260603085254-5k832c4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5k832c4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bn5gy7d","Type":"NodeParagraph","Properties":{"id":"20260603085254-bn5gy7d","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260603085254-1hbyqfj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1hbyqfj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hyj9x6l","Type":"NodeParagraph","Properties":{"id":"20260603085254-hyj9x6l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260603085254-vip94ju","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vip94ju","updated":"20260603085254"},"Children":[{"ID":"20260603085254-acgs7v1","Type":"NodeParagraph","Properties":{"id":"20260603085254-acgs7v1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260603085254-06vywqz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-06vywqz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yskg1p6","Type":"NodeParagraph","Properties":{"id":"20260603085254-yskg1p6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260603085254-37oygu7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-37oygu7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ty6dv2x","Type":"NodeParagraph","Properties":{"id":"20260603085254-ty6dv2x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260603085254-491d8to","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-491d8to","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5qdr5i8","Type":"NodeParagraph","Properties":{"id":"20260603085254-5qdr5i8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260603085254-ek9zl8w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ek9zl8w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pigo632","Type":"NodeParagraph","Properties":{"id":"20260603085254-pigo632","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260603085254-hqumxns","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hqumxns","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xcc4b1z","Type":"NodeParagraph","Properties":{"id":"20260603085254-xcc4b1z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260603085254-zx3ka5c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zx3ka5c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x4i5t18","Type":"NodeParagraph","Properties":{"id":"20260603085254-x4i5t18","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260603085254-focght4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-focght4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ybwwvk9","Type":"NodeParagraph","Properties":{"id":"20260603085254-ybwwvk9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260603085254-ubxhd3h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ubxhd3h","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gd3epy6","Type":"NodeParagraph","Properties":{"id":"20260603085254-gd3epy6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260603085254-ydjw2vy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ydjw2vy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qg2f952","Type":"NodeParagraph","Properties":{"id":"20260603085254-qg2f952","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260603085254-r9yiqld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r9yiqld","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ml7ou5v","Type":"NodeParagraph","Properties":{"id":"20260603085254-ml7ou5v","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260603085254-xz7p26l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xz7p26l","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g6ynixb","Type":"NodeParagraph","Properties":{"id":"20260603085254-g6ynixb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260603085254-sq7bwp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sq7bwp1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lyucmxp","Type":"NodeParagraph","Properties":{"id":"20260603085254-lyucmxp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260603085254-vgps32q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vgps32q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-y7vufoz","Type":"NodeParagraph","Properties":{"id":"20260603085254-y7vufoz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260603085254-42d31sb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-42d31sb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0zl0t4a","Type":"NodeParagraph","Properties":{"id":"20260603085254-0zl0t4a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260603085254-hihvr62","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hihvr62","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j0afw3t","Type":"NodeParagraph","Properties":{"id":"20260603085254-j0afw3t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260603085254-pbhh4j7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pbhh4j7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qgqpe6p","Type":"NodeParagraph","Properties":{"id":"20260603085254-qgqpe6p","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260603085254-znvt87v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-znvt87v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-l9wclht","Type":"NodeParagraph","Properties":{"id":"20260603085254-l9wclht","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260603085254-sr2hkq2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sr2hkq2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-loqcuk3","Type":"NodeParagraph","Properties":{"id":"20260603085254-loqcuk3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260603085254-zul0fym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zul0fym","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xqqv02j","Type":"NodeParagraph","Properties":{"id":"20260603085254-xqqv02j","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260603085254-j6ytau2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-j6ytau2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wq34xw0","Type":"NodeParagraph","Properties":{"id":"20260603085254-wq34xw0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260603085254-vfoanyj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vfoanyj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nld46v3","Type":"NodeParagraph","Properties":{"id":"20260603085254-nld46v3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260603085254-cslb5ds","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cslb5ds","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ka6glmr","Type":"NodeParagraph","Properties":{"id":"20260603085254-ka6glmr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260603085254-xnqby06","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xnqby06","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bdj0fij","Type":"NodeParagraph","Properties":{"id":"20260603085254-bdj0fij","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260603085254-fun419r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fun419r","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f1houql","Type":"NodeParagraph","Properties":{"id":"20260603085254-f1houql","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260603085254-onm7y2q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-onm7y2q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fuw8y30","Type":"NodeParagraph","Properties":{"id":"20260603085254-fuw8y30","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260603085254-t2p2gi1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t2p2gi1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zne6nrd","Type":"NodeParagraph","Properties":{"id":"20260603085254-zne6nrd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260603085254-h2ehb05","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h2ehb05","updated":"20260603085254"},"Children":[{"ID":"20260603085254-c58xdyq","Type":"NodeParagraph","Properties":{"id":"20260603085254-c58xdyq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260603085254-npc24kn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-npc24kn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0fwuftv","Type":"NodeParagraph","Properties":{"id":"20260603085254-0fwuftv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260603085254-9kdvmh3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9kdvmh3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dhyegwl","Type":"NodeParagraph","Properties":{"id":"20260603085254-dhyegwl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260603085254-8o2gret","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8o2gret","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7rgcthw","Type":"NodeParagraph","Properties":{"id":"20260603085254-7rgcthw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260603085254-ed9g18u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ed9g18u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fm3ikzo","Type":"NodeParagraph","Properties":{"id":"20260603085254-fm3ikzo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260603085254-l6oh3a7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-l6oh3a7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ih33l81","Type":"NodeParagraph","Properties":{"id":"20260603085254-ih33l81","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260603085254-4ws3xy1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4ws3xy1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-w9lpi6h","Type":"NodeParagraph","Properties":{"id":"20260603085254-w9lpi6h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260603085254-qtklxav","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qtklxav","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xsx33nc","Type":"NodeParagraph","Properties":{"id":"20260603085254-xsx33nc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260603085254-gq1ye0s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gq1ye0s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-55fsbpz","Type":"NodeParagraph","Properties":{"id":"20260603085254-55fsbpz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260603085254-wsy11e6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wsy11e6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h66h0cj","Type":"NodeParagraph","Properties":{"id":"20260603085254-h66h0cj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260603085254-lz2wnmd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lz2wnmd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zu0xj7e","Type":"NodeParagraph","Properties":{"id":"20260603085254-zu0xj7e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260603085254-fh2csyv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fh2csyv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1bhjma9","Type":"NodeParagraph","Properties":{"id":"20260603085254-1bhjma9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260603085254-bxt1782","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bxt1782","updated":"20260603085254"},"Children":[{"ID":"20260603085254-q9ixyu3","Type":"NodeParagraph","Properties":{"id":"20260603085254-q9ixyu3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260603085254-rrhshqe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rrhshqe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kqhxwzl","Type":"NodeParagraph","Properties":{"id":"20260603085254-kqhxwzl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260603085254-d1scpdq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d1scpdq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3hl7h8u","Type":"NodeParagraph","Properties":{"id":"20260603085254-3hl7h8u","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260603085254-2daovoq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2daovoq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-oa15tys","Type":"NodeParagraph","Properties":{"id":"20260603085254-oa15tys","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260603085254-8okeewy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8okeewy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k7747vb","Type":"NodeParagraph","Properties":{"id":"20260603085254-k7747vb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260603085254-29t76vm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-29t76vm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8c3altj","Type":"NodeParagraph","Properties":{"id":"20260603085254-8c3altj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260603085254-nl6xnxe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nl6xnxe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5r9e5w2","Type":"NodeParagraph","Properties":{"id":"20260603085254-5r9e5w2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260603085254-1t39s8i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1t39s8i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mpr3pbn","Type":"NodeParagraph","Properties":{"id":"20260603085254-mpr3pbn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260603085254-fr4j66y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fr4j66y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mxq9ts7","Type":"NodeParagraph","Properties":{"id":"20260603085254-mxq9ts7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260603085254-2705yrj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2705yrj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-b4tfzi1","Type":"NodeParagraph","Properties":{"id":"20260603085254-b4tfzi1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260603085254-sxhqt59","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sxhqt59","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6r0stao","Type":"NodeParagraph","Properties":{"id":"20260603085254-6r0stao","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260603085254-n90m53n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n90m53n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-eb8ctel","Type":"NodeParagraph","Properties":{"id":"20260603085254-eb8ctel","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260603085254-491mh7i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-491mh7i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v1nopz2","Type":"NodeParagraph","Properties":{"id":"20260603085254-v1nopz2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260603085254-s5c1h45","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s5c1h45","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xgki6wj","Type":"NodeParagraph","Properties":{"id":"20260603085254-xgki6wj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260603085254-vyhi115","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vyhi115","updated":"20260603085254"},"Children":[{"ID":"20260603085254-95wzeou","Type":"NodeParagraph","Properties":{"id":"20260603085254-95wzeou","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260603085254-qe7a93c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qe7a93c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xnkpj4f","Type":"NodeParagraph","Properties":{"id":"20260603085254-xnkpj4f","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260603085254-jgey4wz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jgey4wz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bio4wsz","Type":"NodeParagraph","Properties":{"id":"20260603085254-bio4wsz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260603085254-eu9h931","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-eu9h931","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nvl7d9e","Type":"NodeParagraph","Properties":{"id":"20260603085254-nvl7d9e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260603085254-9se6hqs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9se6hqs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xr7noeg","Type":"NodeParagraph","Properties":{"id":"20260603085254-xr7noeg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260603085254-vu1uks5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vu1uks5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9yj1r2m","Type":"NodeParagraph","Properties":{"id":"20260603085254-9yj1r2m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260603085254-lg40i1y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lg40i1y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-e0g7by1","Type":"NodeParagraph","Properties":{"id":"20260603085254-e0g7by1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603085254-qyqdzfh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qyqdzfh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z6wlnu7","Type":"NodeParagraph","Properties":{"id":"20260603085254-z6wlnu7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260603085254-hku4vqq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hku4vqq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gczcb8a","Type":"NodeParagraph","Properties":{"id":"20260603085254-gczcb8a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260603085254-c01cs16","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c01cs16","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3fxgcwu","Type":"NodeParagraph","Properties":{"id":"20260603085254-3fxgcwu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260603085254-9uriflx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9uriflx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3g5wzp0","Type":"NodeParagraph","Properties":{"id":"20260603085254-3g5wzp0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260603085254-jgw1rkt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jgw1rkt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ue6g9xt","Type":"NodeParagraph","Properties":{"id":"20260603085254-ue6g9xt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260603085254-ytototd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ytototd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nzk7tk9","Type":"NodeParagraph","Properties":{"id":"20260603085254-nzk7tk9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260603085254-jsmihjx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jsmihjx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-q34mxi9","Type":"NodeParagraph","Properties":{"id":"20260603085254-q34mxi9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260603085254-ydutbvz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ydutbvz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wrssnpn","Type":"NodeParagraph","Properties":{"id":"20260603085254-wrssnpn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260603085254-5eww51f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5eww51f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g83og0c","Type":"NodeParagraph","Properties":{"id":"20260603085254-g83og0c","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260603085254-yk86j5t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yk86j5t","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h3o5a1a","Type":"NodeParagraph","Properties":{"id":"20260603085254-h3o5a1a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260603085254-polz0rr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-polz0rr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-q5f92df","Type":"NodeParagraph","Properties":{"id":"20260603085254-q5f92df","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260603085254-yx2mnnc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yx2mnnc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zkbgz9e","Type":"NodeParagraph","Properties":{"id":"20260603085254-zkbgz9e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260603085254-15otp6x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-15otp6x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bu9pq95","Type":"NodeParagraph","Properties":{"id":"20260603085254-bu9pq95","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260603085254-ll34mb9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ll34mb9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nozuwuh","Type":"NodeParagraph","Properties":{"id":"20260603085254-nozuwuh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260603085254-2sdgixk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2sdgixk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3kc7icq","Type":"NodeParagraph","Properties":{"id":"20260603085254-3kc7icq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260603085254-g3l183x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g3l183x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hq2gh20","Type":"NodeParagraph","Properties":{"id":"20260603085254-hq2gh20","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260603085254-y245tym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y245tym","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0ecerrz","Type":"NodeParagraph","Properties":{"id":"20260603085254-0ecerrz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260603085254-2otthrq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2otthrq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-25kgiz4","Type":"NodeParagraph","Properties":{"id":"20260603085254-25kgiz4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260603085254-sf4m1j8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sf4m1j8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-to8jv74","Type":"NodeParagraph","Properties":{"id":"20260603085254-to8jv74","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260603085254-t1zsa14","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t1zsa14","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fmcs525","Type":"NodeParagraph","Properties":{"id":"20260603085254-fmcs525","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603085254-t347l28","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t347l28","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x5qcc51","Type":"NodeParagraph","Properties":{"id":"20260603085254-x5qcc51","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260603085254-407ogq1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-407ogq1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qhd3j9m","Type":"NodeParagraph","Properties":{"id":"20260603085254-qhd3j9m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260603085254-adqy406","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-adqy406","updated":"20260603085254"},"Children":[{"ID":"20260603085254-skglzg1","Type":"NodeParagraph","Properties":{"id":"20260603085254-skglzg1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260603085254-yqffe06","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yqffe06","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5ynk0wt","Type":"NodeParagraph","Properties":{"id":"20260603085254-5ynk0wt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260603085254-2ux6qsp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2ux6qsp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wo921xv","Type":"NodeParagraph","Properties":{"id":"20260603085254-wo921xv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260603085254-g3crmz6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g3crmz6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xwv19ys","Type":"NodeParagraph","Properties":{"id":"20260603085254-xwv19ys","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260603085254-xg05vs6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xg05vs6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ccd5k8a","Type":"NodeParagraph","Properties":{"id":"20260603085254-ccd5k8a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260603085254-hmvvihg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hmvvihg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hmrhr6k","Type":"NodeParagraph","Properties":{"id":"20260603085254-hmrhr6k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260603085254-dm46izm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dm46izm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hy7nqat","Type":"NodeParagraph","Properties":{"id":"20260603085254-hy7nqat","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260603085254-hdn6idn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hdn6idn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-quakxah","Type":"NodeParagraph","Properties":{"id":"20260603085254-quakxah","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260603085254-ctz6cr9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ctz6cr9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-eizcnfr","Type":"NodeParagraph","Properties":{"id":"20260603085254-eizcnfr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260603085254-rb3g4cm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rb3g4cm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4ugbzkm","Type":"NodeParagraph","Properties":{"id":"20260603085254-4ugbzkm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260603085254-walvzr8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-walvzr8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bgy64ro","Type":"NodeParagraph","Properties":{"id":"20260603085254-bgy64ro","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260603085254-jonmbpq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jonmbpq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5y4wxsh","Type":"NodeParagraph","Properties":{"id":"20260603085254-5y4wxsh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260603085254-2n1hzxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2n1hzxh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xlauvyi","Type":"NodeParagraph","Properties":{"id":"20260603085254-xlauvyi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260603085254-1isqh7k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1isqh7k","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gg0bqp1","Type":"NodeParagraph","Properties":{"id":"20260603085254-gg0bqp1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260603085254-yens57r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yens57r","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6x6ygq7","Type":"NodeParagraph","Properties":{"id":"20260603085254-6x6ygq7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260603085254-jjil4wa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jjil4wa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6t3cc8z","Type":"NodeParagraph","Properties":{"id":"20260603085254-6t3cc8z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260603085254-zccw9ju","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zccw9ju","updated":"20260603085254"},"Children":[{"ID":"20260603085254-id4as95","Type":"NodeParagraph","Properties":{"id":"20260603085254-id4as95","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260603085254-nzst7h3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nzst7h3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kp8pji5","Type":"NodeParagraph","Properties":{"id":"20260603085254-kp8pji5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260603085254-x2ncs0j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-x2ncs0j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hw46ge0","Type":"NodeParagraph","Properties":{"id":"20260603085254-hw46ge0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260603085254-fttvtov","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fttvtov","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fmgad51","Type":"NodeParagraph","Properties":{"id":"20260603085254-fmgad51","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260603085254-xv8v8gy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xv8v8gy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-42rpz66","Type":"NodeParagraph","Properties":{"id":"20260603085254-42rpz66","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260603085254-746ao9n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-746ao9n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-aubsp98","Type":"NodeParagraph","Properties":{"id":"20260603085254-aubsp98","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260603085254-0tmqpca","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0tmqpca","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ahwvtc4","Type":"NodeParagraph","Properties":{"id":"20260603085254-ahwvtc4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260603085254-sgde98x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sgde98x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mm4d6l6","Type":"NodeParagraph","Properties":{"id":"20260603085254-mm4d6l6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260603085254-q4fy4kc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-q4fy4kc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-sdj0crk","Type":"NodeParagraph","Properties":{"id":"20260603085254-sdj0crk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260603085254-uewhd30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uewhd30","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qjrbmu4","Type":"NodeParagraph","Properties":{"id":"20260603085254-qjrbmu4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260603085254-c0la8oc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c0la8oc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ke1qksb","Type":"NodeParagraph","Properties":{"id":"20260603085254-ke1qksb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260603085254-1ph3jek","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1ph3jek","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3b7mkuz","Type":"NodeParagraph","Properties":{"id":"20260603085254-3b7mkuz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260603085254-veqsj8c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-veqsj8c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-prh59f6","Type":"NodeParagraph","Properties":{"id":"20260603085254-prh59f6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260603085254-fzwt71b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fzwt71b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zpalhv6","Type":"NodeParagraph","Properties":{"id":"20260603085254-zpalhv6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260603085254-eyrc3uh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-eyrc3uh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qm4omjv","Type":"NodeParagraph","Properties":{"id":"20260603085254-qm4omjv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260603085254-xkj5q4d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xkj5q4d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7g5o2fl","Type":"NodeParagraph","Properties":{"id":"20260603085254-7g5o2fl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260603085254-krm74gd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-krm74gd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wt65dsl","Type":"NodeParagraph","Properties":{"id":"20260603085254-wt65dsl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260603085254-0azw7dx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0azw7dx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mfyxcvn","Type":"NodeParagraph","Properties":{"id":"20260603085254-mfyxcvn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260603085254-lql0r64","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lql0r64","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7qrjac1","Type":"NodeParagraph","Properties":{"id":"20260603085254-7qrjac1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260603085254-12l704c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-12l704c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z67rxcw","Type":"NodeParagraph","Properties":{"id":"20260603085254-z67rxcw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260603085254-s8q6vt1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s8q6vt1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-oa2ikac","Type":"NodeParagraph","Properties":{"id":"20260603085254-oa2ikac","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260603085254-nre8ywu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nre8ywu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qehqk81","Type":"NodeParagraph","Properties":{"id":"20260603085254-qehqk81","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260603085254-3uvt8m0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3uvt8m0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2c2gqdk","Type":"NodeParagraph","Properties":{"id":"20260603085254-2c2gqdk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260603085254-k5uy5mn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k5uy5mn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-feafisw","Type":"NodeParagraph","Properties":{"id":"20260603085254-feafisw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260603085254-qfk5wno","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qfk5wno","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bh406jq","Type":"NodeParagraph","Properties":{"id":"20260603085254-bh406jq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260603085254-qlobnje","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qlobnje","updated":"20260603085254"},"Children":[{"ID":"20260603085254-svz4ang","Type":"NodeParagraph","Properties":{"id":"20260603085254-svz4ang","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260603085254-8qpj64d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8qpj64d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nklydqu","Type":"NodeParagraph","Properties":{"id":"20260603085254-nklydqu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260603085254-piiaxta","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-piiaxta","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k2pmkop","Type":"NodeParagraph","Properties":{"id":"20260603085254-k2pmkop","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260603085254-he9abfd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-he9abfd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qqvh0wg","Type":"NodeParagraph","Properties":{"id":"20260603085254-qqvh0wg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260603085254-14b3miu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-14b3miu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5ludhk0","Type":"NodeParagraph","Properties":{"id":"20260603085254-5ludhk0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260603085254-gv29zmr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gv29zmr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2sxjioy","Type":"NodeParagraph","Properties":{"id":"20260603085254-2sxjioy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260603085254-c711sqn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c711sqn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6tyhl5p","Type":"NodeParagraph","Properties":{"id":"20260603085254-6tyhl5p","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260603085254-ig828kl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ig828kl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h5udgi4","Type":"NodeParagraph","Properties":{"id":"20260603085254-h5udgi4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260603085254-foxws50","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-foxws50","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lwpqunm","Type":"NodeParagraph","Properties":{"id":"20260603085254-lwpqunm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260603085254-gch9ggq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gch9ggq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-520jp4x","Type":"NodeParagraph","Properties":{"id":"20260603085254-520jp4x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260603085254-c2jvn3z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c2jvn3z","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ue5cprl","Type":"NodeParagraph","Properties":{"id":"20260603085254-ue5cprl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260603085254-b85m50x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b85m50x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cwz9oqv","Type":"NodeParagraph","Properties":{"id":"20260603085254-cwz9oqv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260603085254-pqb9vpe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pqb9vpe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6ic6ono","Type":"NodeParagraph","Properties":{"id":"20260603085254-6ic6ono","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260603085254-7z1hjpp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7z1hjpp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cb3t7t0","Type":"NodeParagraph","Properties":{"id":"20260603085254-cb3t7t0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260603085254-pp7q3uu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pp7q3uu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ww4f4bx","Type":"NodeParagraph","Properties":{"id":"20260603085254-ww4f4bx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260603085254-us06fff","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-us06fff","updated":"20260603085254"},"Children":[{"ID":"20260603085254-d3nesls","Type":"NodeParagraph","Properties":{"id":"20260603085254-d3nesls","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260603085254-fab7omn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fab7omn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rl196db","Type":"NodeParagraph","Properties":{"id":"20260603085254-rl196db","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260603085254-320355z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-320355z","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1r15x9e","Type":"NodeParagraph","Properties":{"id":"20260603085254-1r15x9e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260603085254-bc8oaq5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bc8oaq5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fxh047v","Type":"NodeParagraph","Properties":{"id":"20260603085254-fxh047v","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260603085254-r80dut8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r80dut8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-54dquma","Type":"NodeParagraph","Properties":{"id":"20260603085254-54dquma","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260603085254-fgmjhrt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fgmjhrt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1u0udgl","Type":"NodeParagraph","Properties":{"id":"20260603085254-1u0udgl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260603085254-dd0v7ai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dd0v7ai","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k0yhcku","Type":"NodeParagraph","Properties":{"id":"20260603085254-k0yhcku","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260603085254-i4qgzci","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-i4qgzci","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1k0tpvb","Type":"NodeParagraph","Properties":{"id":"20260603085254-1k0tpvb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260603085254-44l92j5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-44l92j5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dgszekg","Type":"NodeParagraph","Properties":{"id":"20260603085254-dgszekg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260603085254-83rwww2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-83rwww2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6qvqiet","Type":"NodeParagraph","Properties":{"id":"20260603085254-6qvqiet","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260603085254-lzjzfxb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lzjzfxb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-stok0o4","Type":"NodeParagraph","Properties":{"id":"20260603085254-stok0o4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260603085254-nx90f8d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nx90f8d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cyjr9ps","Type":"NodeParagraph","Properties":{"id":"20260603085254-cyjr9ps","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260603085254-w82kurx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w82kurx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ubg18fq","Type":"NodeParagraph","Properties":{"id":"20260603085254-ubg18fq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260603085254-0q9n3zh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0q9n3zh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-msjsldk","Type":"NodeParagraph","Properties":{"id":"20260603085254-msjsldk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260603085254-b3yo9uc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b3yo9uc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-iupf1bv","Type":"NodeParagraph","Properties":{"id":"20260603085254-iupf1bv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260603085254-dfah7lh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dfah7lh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6mttde3","Type":"NodeParagraph","Properties":{"id":"20260603085254-6mttde3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260603085254-k90xdph","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k90xdph","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lebsqi1","Type":"NodeParagraph","Properties":{"id":"20260603085254-lebsqi1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260603085254-8cw8cuu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8cw8cuu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-05dpsjv","Type":"NodeParagraph","Properties":{"id":"20260603085254-05dpsjv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260603085254-0ebijk6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0ebijk6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u18zytr","Type":"NodeParagraph","Properties":{"id":"20260603085254-u18zytr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260603085254-jxxndi4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jxxndi4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-aav16f2","Type":"NodeParagraph","Properties":{"id":"20260603085254-aav16f2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260603085254-g3r11n5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g3r11n5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7l7qpp1","Type":"NodeParagraph","Properties":{"id":"20260603085254-7l7qpp1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260603085254-idq5bys","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-idq5bys","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h7yw26y","Type":"NodeParagraph","Properties":{"id":"20260603085254-h7yw26y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260603085254-ez60kv5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ez60kv5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5fcfpl6","Type":"NodeParagraph","Properties":{"id":"20260603085254-5fcfpl6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260603085254-92887ty","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-92887ty","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dutim7n","Type":"NodeParagraph","Properties":{"id":"20260603085254-dutim7n","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260603085254-1s3ka7n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1s3ka7n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-linw1u1","Type":"NodeParagraph","Properties":{"id":"20260603085254-linw1u1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260603085254-31ooyd8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-31ooyd8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-642wizq","Type":"NodeParagraph","Properties":{"id":"20260603085254-642wizq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260603085254-o168dsf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-o168dsf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-a8ere83","Type":"NodeParagraph","Properties":{"id":"20260603085254-a8ere83","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260603085254-c70k9y5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c70k9y5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-50weuit","Type":"NodeParagraph","Properties":{"id":"20260603085254-50weuit","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260603085254-62svh23","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-62svh23","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nkqlcnb","Type":"NodeParagraph","Properties":{"id":"20260603085254-nkqlcnb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260603085254-btthdhx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-btthdhx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yv0up5l","Type":"NodeParagraph","Properties":{"id":"20260603085254-yv0up5l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260603085254-a28h06r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-a28h06r","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qn8hdnf","Type":"NodeParagraph","Properties":{"id":"20260603085254-qn8hdnf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260603085254-y4it582","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y4it582","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4wk08et","Type":"NodeParagraph","Properties":{"id":"20260603085254-4wk08et","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260603085254-lt1noxk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lt1noxk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zmftu90","Type":"NodeParagraph","Properties":{"id":"20260603085254-zmftu90","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260603085254-3px8bmk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3px8bmk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kb87r8z","Type":"NodeParagraph","Properties":{"id":"20260603085254-kb87r8z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260603085254-e0clj66","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e0clj66","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g6417uo","Type":"NodeParagraph","Properties":{"id":"20260603085254-g6417uo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260603085254-24rli8a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-24rli8a","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g8a85eo","Type":"NodeParagraph","Properties":{"id":"20260603085254-g8a85eo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260603085254-qsjx19r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qsjx19r","updated":"20260603085254"},"Children":[{"ID":"20260603085254-359jyad","Type":"NodeParagraph","Properties":{"id":"20260603085254-359jyad","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260603085254-hvpncxt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hvpncxt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-a5zaqal","Type":"NodeParagraph","Properties":{"id":"20260603085254-a5zaqal","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260603085254-ilvawwd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ilvawwd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-w78fswl","Type":"NodeParagraph","Properties":{"id":"20260603085254-w78fswl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260603085254-04i3edh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-04i3edh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i6gz9ft","Type":"NodeParagraph","Properties":{"id":"20260603085254-i6gz9ft","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260603085254-9g5p0o4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9g5p0o4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-e36jyvx","Type":"NodeParagraph","Properties":{"id":"20260603085254-e36jyvx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺。"}]}]},{"ID":"20260603085254-en6kkve","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-en6kkve","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5nbmbkj","Type":"NodeParagraph","Properties":{"id":"20260603085254-5nbmbkj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260603085254-opq46zz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-opq46zz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pk5isv7","Type":"NodeParagraph","Properties":{"id":"20260603085254-pk5isv7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260603085254-iv5120g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-iv5120g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5off39h","Type":"NodeParagraph","Properties":{"id":"20260603085254-5off39h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260603085254-yxtxrfe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yxtxrfe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7wwq5cp","Type":"NodeParagraph","Properties":{"id":"20260603085254-7wwq5cp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260603085254-qbvspjr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qbvspjr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x45daxe","Type":"NodeParagraph","Properties":{"id":"20260603085254-x45daxe","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260603085254-6w0jfil","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6w0jfil","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bnjsf3u","Type":"NodeParagraph","Properties":{"id":"20260603085254-bnjsf3u","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260603085254-7q1yncb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7q1yncb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ohbfaaw","Type":"NodeParagraph","Properties":{"id":"20260603085254-ohbfaaw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260603085254-734j6zb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-734j6zb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5l5ydlv","Type":"NodeParagraph","Properties":{"id":"20260603085254-5l5ydlv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]},{"ID":"20260603085254-f21653v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-f21653v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2qvor9x","Type":"NodeParagraph","Properties":{"id":"20260603085254-2qvor9x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260603085254-mz8f1cy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mz8f1cy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zz331jl","Type":"NodeParagraph","Properties":{"id":"20260603085254-zz331jl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260603085254-at0qzo8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-at0qzo8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-c75xlwq","Type":"NodeParagraph","Properties":{"id":"20260603085254-c75xlwq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260603085254-c6n2hp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c6n2hp1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4qfrkds","Type":"NodeParagraph","Properties":{"id":"20260603085254-4qfrkds","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260603085254-4ku7ati","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4ku7ati","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4fohwo8","Type":"NodeParagraph","Properties":{"id":"20260603085254-4fohwo8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260603085254-wkpvb2s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wkpvb2s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hp64qxm","Type":"NodeParagraph","Properties":{"id":"20260603085254-hp64qxm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260603085254-5xa8fp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5xa8fp1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-v5uahea","Type":"NodeParagraph","Properties":{"id":"20260603085254-v5uahea","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260603085254-az013dl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-az013dl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i6qanuz","Type":"NodeParagraph","Properties":{"id":"20260603085254-i6qanuz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260603085254-rfaw2r2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rfaw2r2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2xyhfmt","Type":"NodeParagraph","Properties":{"id":"20260603085254-2xyhfmt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260603085254-r7m8oj8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r7m8oj8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7mmmvvk","Type":"NodeParagraph","Properties":{"id":"20260603085254-7mmmvvk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260603085254-d11048b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d11048b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uxnc1eh","Type":"NodeParagraph","Properties":{"id":"20260603085254-uxnc1eh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260603085254-5c4xd3w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5c4xd3w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yj6hfnb","Type":"NodeParagraph","Properties":{"id":"20260603085254-yj6hfnb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260603085254-c2g1sjf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c2g1sjf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f955aid","Type":"NodeParagraph","Properties":{"id":"20260603085254-f955aid","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260603085254-zx4jqkv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zx4jqkv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pploeu7","Type":"NodeParagraph","Properties":{"id":"20260603085254-pploeu7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260603085254-u6dqud3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u6dqud3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-htqvs6m","Type":"NodeParagraph","Properties":{"id":"20260603085254-htqvs6m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260603085254-s3171o4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s3171o4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u85yvw6","Type":"NodeParagraph","Properties":{"id":"20260603085254-u85yvw6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260603085254-gsn48jn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gsn48jn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-riet5d0","Type":"NodeParagraph","Properties":{"id":"20260603085254-riet5d0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260603085254-ok6esxj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ok6esxj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2xkxhxu","Type":"NodeParagraph","Properties":{"id":"20260603085254-2xkxhxu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260603085254-3yeuofk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3yeuofk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gsg2vkg","Type":"NodeParagraph","Properties":{"id":"20260603085254-gsg2vkg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260603085254-f7i4xah","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-f7i4xah","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mcqsgdo","Type":"NodeParagraph","Properties":{"id":"20260603085254-mcqsgdo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260603085254-b1mu7xm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b1mu7xm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-iu50otz","Type":"NodeParagraph","Properties":{"id":"20260603085254-iu50otz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260603085254-y9umy4n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y9umy4n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k28yvwg","Type":"NodeParagraph","Properties":{"id":"20260603085254-k28yvwg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603085254-b4o0itc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b4o0itc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tdc3q82","Type":"NodeParagraph","Properties":{"id":"20260603085254-tdc3q82","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260603085254-y6qiw1g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y6qiw1g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9l81e2q","Type":"NodeParagraph","Properties":{"id":"20260603085254-9l81e2q","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603085254-9p8wn2u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9p8wn2u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rbnyrkw","Type":"NodeParagraph","Properties":{"id":"20260603085254-rbnyrkw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260603085254-bkfkigv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bkfkigv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ckk3lvk","Type":"NodeParagraph","Properties":{"id":"20260603085254-ckk3lvk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260603085254-5s035g1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5s035g1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pt06l54","Type":"NodeParagraph","Properties":{"id":"20260603085254-pt06l54","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260603085254-z4icx3f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-z4icx3f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-aonkxik","Type":"NodeParagraph","Properties":{"id":"20260603085254-aonkxik","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260603085254-r1lmufr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r1lmufr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kwwags5","Type":"NodeParagraph","Properties":{"id":"20260603085254-kwwags5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260603085254-sv0j8l3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sv0j8l3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7dsb4no","Type":"NodeParagraph","Properties":{"id":"20260603085254-7dsb4no","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260603085254-n9k0cui","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n9k0cui","updated":"20260603085254"},"Children":[{"ID":"20260603085254-znd8t7k","Type":"NodeParagraph","Properties":{"id":"20260603085254-znd8t7k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260603085254-19pvahw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-19pvahw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k4vg4gr","Type":"NodeParagraph","Properties":{"id":"20260603085254-k4vg4gr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260603085254-cocan18","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cocan18","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fu1tfwc","Type":"NodeParagraph","Properties":{"id":"20260603085254-fu1tfwc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260603085254-8hjas2f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8hjas2f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h7uceb3","Type":"NodeParagraph","Properties":{"id":"20260603085254-h7uceb3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260603085254-tq5ofav","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tq5ofav","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xcbn7od","Type":"NodeParagraph","Properties":{"id":"20260603085254-xcbn7od","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260603085254-raxotxw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-raxotxw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-01z650w","Type":"NodeParagraph","Properties":{"id":"20260603085254-01z650w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260603085254-dkqyvd0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dkqyvd0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-knxclqg","Type":"NodeParagraph","Properties":{"id":"20260603085254-knxclqg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260603085254-kmuz7xt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kmuz7xt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z2lgde5","Type":"NodeParagraph","Properties":{"id":"20260603085254-z2lgde5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260603085254-dzapc5b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dzapc5b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j6nab36","Type":"NodeParagraph","Properties":{"id":"20260603085254-j6nab36","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260603085254-ggfyiw3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ggfyiw3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-957781e","Type":"NodeParagraph","Properties":{"id":"20260603085254-957781e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260603085254-ds4qqdh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ds4qqdh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ra62l4o","Type":"NodeParagraph","Properties":{"id":"20260603085254-ra62l4o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260603085254-pohnb56","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pohnb56","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zx0v7sk","Type":"NodeParagraph","Properties":{"id":"20260603085254-zx0v7sk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260603085254-3p8mfv7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3p8mfv7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7704kkd","Type":"NodeParagraph","Properties":{"id":"20260603085254-7704kkd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260603085254-w91oaw1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w91oaw1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ags3oye","Type":"NodeParagraph","Properties":{"id":"20260603085254-ags3oye","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260603085254-nlnwzq2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nlnwzq2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5c9vb5x","Type":"NodeParagraph","Properties":{"id":"20260603085254-5c9vb5x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260603085254-lkfaokb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lkfaokb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1oqbiyh","Type":"NodeParagraph","Properties":{"id":"20260603085254-1oqbiyh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260603085254-me8qzsv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-me8qzsv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gwu0a6w","Type":"NodeParagraph","Properties":{"id":"20260603085254-gwu0a6w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260603085254-p1cyv3s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-p1cyv3s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-oe6lyls","Type":"NodeParagraph","Properties":{"id":"20260603085254-oe6lyls","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260603085254-0c8v6wv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0c8v6wv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lcch6x8","Type":"NodeParagraph","Properties":{"id":"20260603085254-lcch6x8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260603085254-ss7f7va","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ss7f7va","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kfnr0zy","Type":"NodeParagraph","Properties":{"id":"20260603085254-kfnr0zy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260603085254-xn4eh9s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xn4eh9s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lalnvz9","Type":"NodeParagraph","Properties":{"id":"20260603085254-lalnvz9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260603085254-bvaq01p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bvaq01p","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5sg81rd","Type":"NodeParagraph","Properties":{"id":"20260603085254-5sg81rd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]}]}]},{"ID":"20260603085254-atbi243","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-atbi243","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4udpg7j","Type":"NodeParagraph","Properties":{"id":"20260603085254-4udpg7j","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。名言与典故必须作为论据服务于论点，不得为了展示库存而强行插入。"}]}]}]}]},{"ID":"20260603085254-a21jnlb","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260603085254-a21jnlb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-htu01yq","Type":"NodeParagraph","Properties":{"id":"20260603085254-htu01yq","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：请严格控制在850字左右，结尾必须留有2-3句极具力量的金句进行收束，不得草率。"}]}]},{"ID":"20260603085254-7h7v9un","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OS4=","Num":9},"Properties":{"id":"20260603085254-7h7v9un","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cr16nni","Type":"NodeParagraph","Properties":{"id":"20260603085254-cr16nni","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260603085254-byd37y8","Type":"NodeList","ListData":{},"Properties":{"id":"20260603085254-byd37y8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4kxz2hl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4kxz2hl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hmoxyeb","Type":"NodeParagraph","Properties":{"id":"20260603085254-hmoxyeb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260603085254-njy2nys","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-njy2nys","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i0d84i8","Type":"NodeParagraph","Properties":{"id":"20260603085254-i0d84i8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]},{"ID":"20260603085254-z9moo1l","Type":"NodeParagraph","Properties":{"id":"20260603085254-z9moo1l","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【作文题目/材料/原文】"},{"Type":"NodeText","Data":"\n（在此处粘贴具体的作文题目、材料或话题，例如：2025年全国一卷关于老舍、艾青、穆旦的材料……）"}]},{"ID":"20260603085254-7hyxt55","Type":"NodeParagraph","Properties":{"id":"20260603085254-7hyxt55","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【逻辑自检与优化指令】"},{"Type":"NodeText","Data":"\n在生成完正文后，请严格执行以下检查步骤，以确保文章的逻辑严密性和考场适用性："}]}]},{"ID":"20260603085254-wjg8gda","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wjg8gda","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n7o9sg1","Type":"NodeParagraph","Properties":{"id":"20260603085254-n7o9sg1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"逻辑回溯：请审视全文的论证链条。是否存在“观点A -\u003e 论据B（其实不支持A）”的逻辑断裂？"}]}]},{"ID":"20260603085254-ip546ke","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ip546ke","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t2pg3jr","Type":"NodeParagraph","Properties":{"id":"20260603085254-t2pg3jr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"隐喻准确性检查（重点）：请检查文中关于“熵增定律”的隐喻（或其他科学原理/心理学效应）是否准确？它是否真正支撑了“自律”或“对抗无序”这一分论点，还是仅仅是一个华丽的辞藻堆砌？"}]}]},{"ID":"20260603085254-bpouifk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bpouifk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mogllyl","Type":"NodeParagraph","Properties":{"id":"20260603085254-mogllyl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"素材去重与更新：检查文中是否误用了“司马迁、李白、爱迪生”等过度使用的陈词滥调？如果是，请替换为更具时代感的素材。"}]}]},{"ID":"20260603085254-r26w6qe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r26w6qe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0xwnolv","Type":"NodeParagraph","Properties":{"id":"20260603085254-0xwnolv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"阅卷视角模拟：如果你是一位拥有20年经验的高考阅卷老师，这篇文章最可能因为什么被扣分（如：偏题、结构混乱、矫情）？请指出并微调。"}]}]}]}]}