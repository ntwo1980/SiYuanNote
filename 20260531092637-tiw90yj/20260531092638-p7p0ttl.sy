7stz","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NS4=","Num":5},"Properties":{"id":"20260605081148-n9g7stz","updated":"20260605081148"},"Children":[{"ID":"20260605081148-puyuwkz","Type":"NodeParagraph","Properties":{"id":"20260605081148-puyuwkz","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"思维与论证（核心技法）"},{"Type":"NodeText","Data":"     ："}]},{"ID":"20260605081148-za271m9","Type":"NodeList","ListData":{},"Properties":{"id":"20260605081148-za271m9","updated":"20260605081148"},"Children":[{"ID":"20260605081148-vrv6xab","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081148-vrv6xab","updated":"20260605081148"},"Children":[{"ID":"20260605081148-0g4hv98","Type":"NodeParagraph","Properties":{"id":"20260605081148-0g4hv98","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"必备论式组合"},{"Type":"NodeText","Data":"：优先使用下列方法中的两种及以上，根据文章需要自然融入，避免刻意拼装。"}]},{"ID":"20260605081148-sc3ws35","Type":"NodeList","ListData":{},"Properties":{"id":"20260605081148-sc3ws35","updated":"20260605081148"},"Children":[{"ID":"20260605081148-lwuor9o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081148-lwuor9o","updated":"20260605081148"},"Children":[{"ID":"20260605081148-scez8k2","Type":"NodeParagraph","Properties":{"id":"20260605081148-scez8k2","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分解论证（拉升与钻洞）"},{"Type":"NodeText","Data":"     ：证明分论点时，注意分论点间的层递关系。可采用“拉升式”（由底层肉身/物质体验升华到高层灵魂/生存层面）或“钻洞式”（由表层社会现象深入挖掘背后的文化基因或心理动因）。"}]}]},{"ID":"20260605081148-sfkihad","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081148-sfkihad","updated":"20260605081148"},"Children":[{"ID":"20260605081148-2hgvgss","Type":"NodeParagraph","Properties":{"id":"20260605081148-2hgvgss","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"举例论证（典型事例）"},{"Type":"NodeText","Data":"     ：选取古今中外典型人物或时事热点，通过具体故事来支撑论点，做到叙议结合，拒绝单纯堆砌素材。"}]}]},{"ID":"20260605081148-udxithb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081148-udxithb","updated":"20260605081148"},"Children":[{"ID":"20260605081148-2p5witl","Type":"NodeParagraph","Properties":{"id":"20260605081148-2p5witl","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"归谬论证（反向推导）"},{"Type":"NodeText","Data":"     ：先提出与论点相反的假定，推导出荒谬或不可接受的后果，从而有力地反证原论点的正确性，增强说服力。"}]}]}]}]},{"ID":"20260605081148-dpu7nu5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081148-dpu7nu5","updated":"20260605081148"},"Children":[{"ID":"20260605081148-y460d3j","Type":"NodeParagraph","Properties":{"id":"20260605081148-y460d3j","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辅助论式拓展"},{"Type":"NodeText","Data":"：可适当穿插使用道理/引证论证（引用经典著作、名人警句）、类比论证（通过相似事物比较类推）或反证法，丰富文章的论证维度。"}]}]},{"ID":"20260605081148-skdc3j3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260605081148-skdc3j3","updated":"20260605081148"},"Children":[{"ID":"20260605081148-nzw7czj","Type":"NodeParagraph","Properties":{"id":"20260605081148-nzw7czj","updated":"20260605081148"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"隐性植入辩证法"},{"Type":"NodeText","Data":"：将辩证法的三大规律(对立同一、量变质变、否定之否定)内化为文章的底层逻辑，但"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁直接出现"},{"Type":"NodeText","Data":"“对立统一”、“量变质变”、“否定之否定”等哲学术语。具体操作如下："}]},{"ID":"20260605081148-jja1bcn","Type":"NodeList","ListData":{},"Properties":{"id":"20260605081148-jja1bcn","updated":"20260605081148"},"Children":[{"ID":"20260605081148-swa3ip9","Type":"NodeLis