然后生。"}]}]},{"ID":"20260603085254-hf6q8zj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hf6q8zj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-brlphnc","Type":"NodeParagraph","Properties":{"id":"20260603085254-brlphnc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603085254-k0jf3sl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k0jf3sl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rnzuyvt","Type":"NodeParagraph","Properties":{"id":"20260603085254-rnzuyvt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260603085254-1e4ethl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1e4ethl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ifvb040","Type":"NodeParagraph","Properties":{"id":"20260603085254-ifvb040","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260603085254-ilxlf2e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ilxlf2e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xvhrp68","Type":"NodeParagraph","Properties":{"id":"20260603085254-xvhrp68","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260603085254-ho4nnw2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ho4nnw2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rjaktey","Type":"NodeParagraph","Properties":{"id":"20260603085254-rjaktey","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260603085254-2klc95z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2klc95z","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i2py18w","Type":"NodeParagraph","Properties":{"id":"20260603085254-i2py18w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260603085254-qsn8t3k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qsn8t3k","updated":"20260603085254"},"Children":[{"ID":"20260603085254-45ezhar","Type":"NodeParagraph","Properties":{"id":"20260603085254-45ezhar","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260603085254-xs4zkuq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xs4zkuq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7z74esv","Type":"NodeParagraph","Properties":{"id":"20260603085254-7z74esv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《美丽心灵》约翰·纳什"}]}]},{"ID":"20260603085254-daesyxf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-daesyxf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3dfloiq","Type":"NodeParagraph","Properties":{"id":"20260603085254-3dfloiq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"西格里夫·萨松：心有猛虎，细嗅蔷薇。"}]}]},{"ID":"20260603085254-u3sxovl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u3sxovl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rrkvgtj","Type":"NodeParagraph","Properties":{"id":"20260603085254-rrkvgtj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260603085254-jqafywz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jqafywz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-by29j7z","Type":"NodeParagraph","Properties":{"id":"20260603085254-by29j7z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260603085254-sj6o2nj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sj6o2nj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8y72mol","Type":"NodeParagraph","Properties":{"id":"20260603085254-8y72mol","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260603085254-sol4weh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sol4weh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-e9zgzsa","Type":"NodeParagraph","Properties":{"id":"20260603085254-e9zgzsa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海明威：一个人可以被毁灭， "},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"但不能被打败。"}]}]},{"ID":"20260603085254-zjju28x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zjju28x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-17agecm","Type":"NodeParagraph","Properties":{"id":"20260603085254-17agecm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"杨绛：生活一半是柴米油盐，一半是星辰大海。"}]}]},{"ID":"20260603085254-9j8pk3b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9j8pk3b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ddcq08j","Type":"NodeParagraph","Properties":{"id":"20260603085254-ddcq08j","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰：世界上只有一种英雄主义，就是在认清生活的真相之后依然热爱生活。"}]}]},{"ID":"20260603085254-aqi4y41","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-aqi4y41","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1aulkq4","Type":"NodeParagraph","Properties":{"id":"20260603085254-1aulkq4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗素：参差多态乃是人类幸福的本源。"}]}]},{"ID":"20260603085254-lcxkm1s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lcxkm1s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bhvjrll","Type":"NodeParagraph","Properties":{"id":"20260603085254-bhvjrll","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260603085254-twrftjs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-twrftjs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jw3rlyf","Type":"NodeParagraph","Properties":{"id":"20260603085254-jw3rlyf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260603085254-etn407y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-etn407y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f304934","Type":"NodeParagraph","Properties":{"id":"20260603085254-f304934","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260603085254-9y647cj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9y647cj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3hi6tsh","Type":"NodeParagraph","Properties":{"id":"20260603085254-3hi6tsh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260603085254-1eulcwd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1eulcwd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k63tigy","Type":"NodeParagraph","Properties":{"id":"20260603085254-k63tigy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260603085254-mcliyrl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mcliyrl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8f5rm35","Type":"NodeParagraph","Properties":{"id":"20260603085254-8f5rm35","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260603085254-gwnpnpb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gwnpnpb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n0qvva3","Type":"NodeParagraph","Properties":{"id":"20260603085254-n0qvva3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260603085254-llwdlin","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-llwdlin","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yc9vzn4","Type":"NodeParagraph","Properties":{"id":"20260603085254-yc9vzn4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260603085254-u1ebx2b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u1ebx2b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hvixrxh","Type":"NodeParagraph","Properties":{"id":"20260603085254-hvixrxh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260603085254-w9g6waa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w9g6waa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-w4f8v0k","Type":"NodeParagraph","Properties":{"id":"20260603085254-w4f8v0k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260603085254-j4hg8o4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-j4hg8o4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ynu3amh","Type":"NodeParagraph","Properties":{"id":"20260603085254-ynu3amh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260603085254-kwfjxuj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kwfjxuj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ulhn0lr","Type":"NodeParagraph","Properties":{"id":"20260603085254-ulhn0lr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260603085254-34zavbx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-34zavbx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t2zacif","Type":"NodeParagraph","Properties":{"id":"20260603085254-t2zacif","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260603085254-6jcukp7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6jcukp7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6v47ax0","Type":"NodeParagraph","Properties":{"id":"20260603085254-6v47ax0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"特鲁多医生墓志铭：医生有时治愈，常常帮助，总是安慰。"}]}]},{"ID":"20260603085254-ckj1sf5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ckj1sf5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-y8x80n2","Type":"NodeParagraph","Properties":{"id":"20260603085254-y8x80n2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260603085254-4cilosq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4cilosq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vib84jx","Type":"NodeParagraph","Properties":{"id":"20260603085254-vib84jx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260603085254-eee3f7g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-eee3f7g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bjoilph","Type":"NodeParagraph","Properties":{"id":"20260603085254-bjoilph","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260603085254-7qc3ldg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7qc3ldg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f7rzxvf","Type":"NodeParagraph","Properties":{"id":"20260603085254-f7rzxvf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260603085254-c8kl9cw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c8kl9cw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ytzqggj","Type":"NodeParagraph","Properties":{"id":"20260603085254-ytzqggj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260603085254-okavt74","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-okavt74","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9e4j03k","Type":"NodeParagraph","Properties":{"id":"20260603085254-9e4j03k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260603085254-rihzbe3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rihzbe3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gj593dv","Type":"NodeParagraph","Properties":{"id":"20260603085254-gj593dv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260603085254-jtcu5g5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jtcu5g5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9dgftw4","Type":"NodeParagraph","Properties":{"id":"20260603085254-9dgftw4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260603085254-b8zrv6m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b8zrv6m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vzuo05p","Type":"NodeParagraph","Properties":{"id":"20260603085254-vzuo05p","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260603085254-vdxncj6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vdxncj6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0kftfpl","Type":"NodeParagraph","Properties":{"id":"20260603085254-0kftfpl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260603085254-jcgqfln","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jcgqfln","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ym6dy49","Type":"NodeParagraph","Properties":{"id":"20260603085254-ym6dy49","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260603085254-1sf2xcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1sf2xcq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t9s2l5g","Type":"NodeParagraph","Properties":{"id":"20260603085254-t9s2l5g","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260603085254-g1wpfhl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g1wpfhl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-svqdg3h","Type":"NodeParagraph","Properties":{"id":"20260603085254-svqdg3h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260603085254-8ntsl58","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8ntsl58","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ol6gxhc","Type":"NodeParagraph","Properties":{"id":"20260603085254-ol6gxhc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260603085254-toxyqbc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-toxyqbc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-o6fq9sq","Type":"NodeParagraph","Properties":{"id":"20260603085254-o6fq9sq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260603085254-9lwbfit","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9lwbfit","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rsqwjst","Type":"NodeParagraph","Properties":{"id":"20260603085254-rsqwjst","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260603085254-n9m8cty","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n9m8cty","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2r923zy","Type":"NodeParagraph","Properties":{"id":"20260603085254-2r923zy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260603085254-4rtgfes","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4rtgfes","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u05sz04","Type":"NodeParagraph","Properties":{"id":"20260603085254-u05sz04","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260603085254-pz3434n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pz3434n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6szl863","Type":"NodeParagraph","Properties":{"id":"20260603085254-6szl863","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260603085254-fsz05r2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fsz05r2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-77sf50u","Type":"NodeParagraph","Properties":{"id":"20260603085254-77sf50u","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260603085254-0ks2m1h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0ks2m1h","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hlxadk9","Type":"NodeParagraph","Properties":{"id":"20260603085254-hlxadk9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260603085254-6i4c6oo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6i4c6oo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-25073uo","Type":"NodeParagraph","Properties":{"id":"20260603085254-25073uo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260603085254-rt4x17w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rt4x17w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ahvxnot","Type":"NodeParagraph","Properties":{"id":"20260603085254-ahvxnot","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260603085254-gocdb3d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gocdb3d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lsvk7md","Type":"NodeParagraph","Properties":{"id":"20260603085254-lsvk7md","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260603085254-m5knbss","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m5knbss","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vz14pq8","Type":"NodeParagraph","Properties":{"id":"20260603085254-vz14pq8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260603085254-54o549l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-54o549l","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qfbgm0i","Type":"NodeParagraph","Properties":{"id":"20260603085254-qfbgm0i","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603085254-dthyt0d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dthyt0d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k457iiu","Type":"NodeParagraph","Properties":{"id":"20260603085254-k457iiu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260603085254-9756hgx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9756hgx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ca508ah","Type":"NodeParagraph","Properties":{"id":"20260603085254-ca508ah","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260603085254-5r3l6xd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5r3l6xd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wu9ggz8","Type":"NodeParagraph","Properties":{"id":"20260603085254-wu9ggz8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260603085254-5kcrgdj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5kcrgdj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kyb6gtn","Type":"NodeParagraph","Properties":{"id":"20260603085254-kyb6gtn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260603085254-f8a40fv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-f8a40fv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mvtb2sh","Type":"NodeParagraph","Properties":{"id":"20260603085254-mvtb2sh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260603085254-a9b1vir","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-a9b1vir","updated":"20260603085254"},"Children":[{"ID":"20260603085254-s66aqk8","Type":"NodeParagraph","Properties":{"id":"20260603085254-s66aqk8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260603085254-xnrkobm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xnrkobm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1jlz8sr","Type":"NodeParagraph","Properties":{"id":"20260603085254-1jlz8sr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260603085254-0qcn6rs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0qcn6rs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gj0aqve","Type":"NodeParagraph","Properties":{"id":"20260603085254-gj0aqve","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260603085254-iblljwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-iblljwm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lzslf0x","Type":"NodeParagraph","Properties":{"id":"20260603085254-lzslf0x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260603085254-1zyqesf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1zyqesf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4uo3i1d","Type":"NodeParagraph","Properties":{"id":"20260603085254-4uo3i1d","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260603085254-fmw0z4i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fmw0z4i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ciq09nb","Type":"NodeParagraph","Properties":{"id":"20260603085254-ciq09nb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603085254-u55eal8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u55eal8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-m4a1ux5","Type":"NodeParagraph","Properties":{"id":"20260603085254-m4a1ux5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260603085254-g9yetsq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g9yetsq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-o7olnyn","Type":"NodeParagraph","Properties":{"id":"20260603085254-o7olnyn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260603085254-csksuri","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-csksuri","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ruz3v9t","Type":"NodeParagraph","Properties":{"id":"20260603085254-ruz3v9t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603085254-ogfokl3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ogfokl3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fhstxke","Type":"NodeParagraph","Properties":{"id":"20260603085254-fhstxke","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260603085254-ayx92to","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ayx92to","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qu9krn6","Type":"NodeParagraph","Properties":{"id":"20260603085254-qu9krn6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260603085254-981xe8p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-981xe8p","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xri054g","Type":"NodeParagraph","Properties":{"id":"20260603085254-xri054g","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260603085254-t1aysvx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t1aysvx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3ga2qe2","Type":"NodeParagraph","Properties":{"id":"20260603085254-3ga2qe2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260603085254-85dhut2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-85dhut2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4j41huz","Type":"NodeParagraph","Properties":{"id":"20260603085254-4j41huz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260603085254-oqmk0ie","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oqmk0ie","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7ipyhys","Type":"NodeParagraph","Properties":{"id":"20260603085254-7ipyhys","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260603085254-i1mfky4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-i1mfky4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qkxiadt","Type":"NodeParagraph","Properties":{"id":"20260603085254-qkxiadt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260603085254-t8z6hmi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t8z6hmi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-42nbpof","Type":"NodeParagraph","Properties":{"id":"20260603085254-42nbpof","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260603085254-4ipwiem","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4ipwiem","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4n2q3hp","Type":"NodeParagraph","Properties":{"id":"20260603085254-4n2q3hp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260603085254-wvuayfe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wvuayfe","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j60z3b6","Type":"NodeParagraph","Properties":{"id":"20260603085254-j60z3b6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260603085254-w8ixg59","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w8ixg59","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qw2zydr","Type":"NodeParagraph","Properties":{"id":"20260603085254-qw2zydr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260603085254-pzmg4ws","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pzmg4ws","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zuu1il3","Type":"NodeParagraph","Properties":{"id":"20260603085254-zuu1il3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603085254-rbmkhpd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rbmkhpd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ymkkrmp","Type":"NodeParagraph","Properties":{"id":"20260603085254-ymkkrmp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260603085254-5qgh5be","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5qgh5be","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xyd1dii","Type":"NodeParagraph","Properties":{"id":"20260603085254-xyd1dii","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260603085254-zy76fhr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zy76fhr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ytgojrt","Type":"NodeParagraph","Properties":{"id":"20260603085254-ytgojrt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260603085254-yb34xh3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yb34xh3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vy4kahg","Type":"NodeParagraph","Properties":{"id":"20260603085254-vy4kahg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260603085254-1n865oz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1n865oz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mvt52yi","Type":"NodeParagraph","Properties":{"id":"20260603085254-mvt52yi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260603085254-y4cnec8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y4cnec8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vsn6re8","Type":"NodeParagraph","Properties":{"id":"20260603085254-vsn6re8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260603085254-pwiox0e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pwiox0e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t9ipb4f","Type":"NodeParagraph","Properties":{"id":"20260603085254-t9ipb4f","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260603085254-3wdb69v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3wdb69v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-picms2j","Type":"NodeParagraph","Properties":{"id":"20260603085254-picms2j","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260603085254-hbxzehf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hbxzehf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3wzc7iw","Type":"NodeParagraph","Properties":{"id":"20260603085254-3wzc7iw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260603085254-iv48q4u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-iv48q4u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5m3wqj4","Type":"NodeParagraph","Properties":{"id":"20260603085254-5m3wqj4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260603085254-t2cnm7w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t2cnm7w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5hj1oz2","Type":"NodeParagraph","Properties":{"id":"20260603085254-5hj1oz2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260603085254-wabnsw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wabnsw9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9962ajc","Type":"NodeParagraph","Properties":{"id":"20260603085254-9962ajc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260603085254-93d9a9e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-93d9a9e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vqpojhg","Type":"NodeParagraph","Properties":{"id":"20260603085254-vqpojhg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260603085254-bgczkaa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bgczkaa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-upr7r0z","Type":"NodeParagraph","Properties":{"id":"20260603085254-upr7r0z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260603085254-ptu8nzn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ptu8nzn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k9fxepm","Type":"NodeParagraph","Properties":{"id":"20260603085254-k9fxepm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260603085254-hlbzgw7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hlbzgw7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-932a7j7","Type":"NodeParagraph","Properties":{"id":"20260603085254-932a7j7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260603085254-guevo2s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-guevo2s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pk15h10","Type":"NodeParagraph","Properties":{"id":"20260603085254-pk15h10","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260603085254-osj2nf4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-osj2nf4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3hxdfcl","Type":"NodeParagraph","Properties":{"id":"20260603085254-3hxdfcl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260603085254-p52bdz8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-p52bdz8","updated":"20260603085254"},"Children":[{"ID":"20260603085254-b3xp0b9","Type":"NodeParagraph","Properties":{"id":"20260603085254-b3xp0b9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260603085254-lyfvfno","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lyfvfno","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mbbg29e","Type":"NodeParagraph","Properties":{"id":"20260603085254-mbbg29e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260603085254-n0puoau","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n0puoau","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2ti1ik0","Type":"NodeParagraph","Properties":{"id":"20260603085254-2ti1ik0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260603085254-gw5bi15","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gw5bi15","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uw3p1mr","Type":"NodeParagraph","Properties":{"id":"20260603085254-uw3p1mr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260603085254-u9poisj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u9poisj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vpndsb1","Type":"NodeParagraph","Properties":{"id":"20260603085254-vpndsb1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260603085254-sx9j9wm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sx9j9wm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1v9yhxn","Type":"NodeParagraph","Properties":{"id":"20260603085254-1v9yhxn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260603085254-uwn1tdq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uwn1tdq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wnzniwa","Type":"NodeParagraph","Properties":{"id":"20260603085254-wnzniwa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260603085254-sx2c4fs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sx2c4fs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-040uzce","Type":"NodeParagraph","Properties":{"id":"20260603085254-040uzce","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260603085254-67xobj9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-67xobj9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7g04oxv","Type":"NodeParagraph","Properties":{"id":"20260603085254-7g04oxv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260603085254-qjrxy6b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qjrxy6b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u2xns7f","Type":"NodeParagraph","Properties":{"id":"20260603085254-u2xns7f","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260603085254-u0lh3wo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u0lh3wo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-eyr7eah","Type":"NodeParagraph","Properties":{"id":"20260603085254-eyr7eah","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260603085254-v54evik","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-v54evik","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2p3rg8a","Type":"NodeParagraph","Properties":{"id":"20260603085254-2p3rg8a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260603085254-go8dm60","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-go8dm60","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4aavxye","Type":"NodeParagraph","Properties":{"id":"20260603085254-4aavxye","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260603085254-deh24mx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-deh24mx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cdacfd7","Type":"NodeParagraph","Properties":{"id":"20260603085254-cdacfd7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260603085254-drn14v4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-drn14v4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cz7mmvt","Type":"NodeParagraph","Properties":{"id":"20260603085254-cz7mmvt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260603085254-l2dvi1f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-l2dvi1f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0xy6h18","Type":"NodeParagraph","Properties":{"id":"20260603085254-0xy6h18","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260603085254-2gycthk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2gycthk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r1dphqn","Type":"NodeParagraph","Properties":{"id":"20260603085254-r1dphqn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260603085254-ctjffz7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ctjffz7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5mx0qje","Type":"NodeParagraph","Properties":{"id":"20260603085254-5mx0qje","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260603085254-h40oldv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h40oldv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yurebhk","Type":"NodeParagraph","Properties":{"id":"20260603085254-yurebhk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260603085254-z2ah3o7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-z2ah3o7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nmpk3ia","Type":"NodeParagraph","Properties":{"id":"20260603085254-nmpk3ia","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260603085254-fqmz7ri","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fqmz7ri","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pb07r07","Type":"NodeParagraph","Properties":{"id":"20260603085254-pb07r07","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260603085254-sd5xcn2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sd5xcn2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9vqeh9y","Type":"NodeParagraph","Properties":{"id":"20260603085254-9vqeh9y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260603085254-tfx2zld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tfx2zld","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9enkzhl","Type":"NodeParagraph","Properties":{"id":"20260603085254-9enkzhl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260603085254-1jicbyp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1jicbyp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5ezbtsz","Type":"NodeParagraph","Properties":{"id":"20260603085254-5ezbtsz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260603085254-49pgp27","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-49pgp27","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fcbvp76","Type":"NodeParagraph","Properties":{"id":"20260603085254-fcbvp76","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260603085254-4hrw1yh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4hrw1yh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rfz1t3u","Type":"NodeParagraph","Properties":{"id":"20260603085254-rfz1t3u","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260603085254-41ie74r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-41ie74r","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7wrg6eo","Type":"NodeParagraph","Properties":{"id":"20260603085254-7wrg6eo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260603085254-b5mrdm5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b5mrdm5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r1a0ym1","Type":"NodeParagraph","Properties":{"id":"20260603085254-r1a0ym1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260603085254-qriyinp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qriyinp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lligfwa","Type":"NodeParagraph","Properties":{"id":"20260603085254-lligfwa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"歌德：才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260603085254-1upudgt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1upudgt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fi30qwt","Type":"NodeParagraph","Properties":{"id":"20260603085254-fi30qwt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260603085254-m01a9vi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m01a9vi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-b22u645","Type":"NodeParagraph","Properties":{"id":"20260603085254-b22u645","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260603085254-cmlqp6n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cmlqp6n","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0488gh1","Type":"NodeParagraph","Properties":{"id":"20260603085254-0488gh1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260603085254-jshvcqo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jshvcqo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pvvlact","Type":"NodeParagraph","Properties":{"id":"20260603085254-pvvlact","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260603085254-11v9e4c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-11v9e4c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-byzu7in","Type":"NodeParagraph","Properties":{"id":"20260603085254-byzu7in","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260603085254-b3h3jpf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b3h3jpf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-67hemwi","Type":"NodeParagraph","Properties":{"id":"20260603085254-67hemwi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260603085254-y4n30km","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-y4n30km","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p0uanmk","Type":"NodeParagraph","Properties":{"id":"20260603085254-p0uanmk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260603085254-6cnxomh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6cnxomh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-sox1sry","Type":"NodeParagraph","Properties":{"id":"20260603085254-sox1sry","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260603085254-e2q3bfh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e2q3bfh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cllfh9c","Type":"NodeParagraph","Properties":{"id":"20260603085254-cllfh9c","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260603085254-zbfwhx3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zbfwhx3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9e7dads","Type":"NodeParagraph","Properties":{"id":"20260603085254-9e7dads","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260603085254-zstozm3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zstozm3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wrr4znr","Type":"NodeParagraph","Properties":{"id":"20260603085254-wrr4znr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260603085254-42xojfz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-42xojfz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-om886b4","Type":"NodeParagraph","Properties":{"id":"20260603085254-om886b4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260603085254-yerdmm5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yerdmm5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-93ehg05","Type":"NodeParagraph","Properties":{"id":"20260603085254-93ehg05","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260603085254-u8gquk4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u8gquk4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-w3vgpw1","Type":"NodeParagraph","Properties":{"id":"20260603085254-w3vgpw1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260603085254-hepu18x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hepu18x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7mb1tt1","Type":"NodeParagraph","Properties":{"id":"20260603085254-7mb1tt1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260603085254-n9gqd7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n9gqd7j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xlnf5zo","Type":"NodeParagraph","Properties":{"id":"20260603085254-xlnf5zo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260603085254-48k4w90","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-48k4w90","updated":"20260603085254"},"Children":[{"ID":"20260603085254-baltgme","Type":"NodeParagraph","Properties":{"id":"20260603085254-baltgme","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260603085254-uf9fu0q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uf9fu0q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2hnes5z","Type":"NodeParagraph","Properties":{"id":"20260603085254-2hnes5z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260603085254-n1ouxzp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n1ouxzp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qxt3ww8","Type":"NodeParagraph","Properties":{"id":"20260603085254-qxt3ww8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260603085254-srsmwto","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-srsmwto","updated":"20260603085254"},"Children":[{"ID":"20260603085254-63ex7zp","Type":"NodeParagraph","Properties":{"id":"20260603085254-63ex7zp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260603085254-bqzjwm4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bqzjwm4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5op6vhq","Type":"NodeParagraph","Properties":{"id":"20260603085254-5op6vhq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260603085254-yy0vd7m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yy0vd7m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t50slkz","Type":"NodeParagraph","Properties":{"id":"20260603085254-t50slkz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260603085254-sfifyxp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sfifyxp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n2w2l9e","Type":"NodeParagraph","Properties":{"id":"20260603085254-n2w2l9e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260603085254-ib1lp8q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ib1lp8q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qmjkywf","Type":"NodeParagraph","Properties":{"id":"20260603085254-qmjkywf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260603085254-fidwcv0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fidwcv0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t57g47o","Type":"NodeParagraph","Properties":{"id":"20260603085254-t57g47o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260603085254-g7dmw7u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g7dmw7u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h5ytcwl","Type":"NodeParagraph","Properties":{"id":"20260603085254-h5ytcwl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260603085254-r1xapz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r1xapz2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lc7ev7n","Type":"NodeParagraph","Properties":{"id":"20260603085254-lc7ev7n","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260603085254-nsjd3ed","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nsjd3ed","updated":"20260603085254"},"Children":[{"ID":"20260603085254-avizp4l","Type":"NodeParagraph","Properties":{"id":"20260603085254-avizp4l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260603085254-mirzutk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mirzutk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xev5fdk","Type":"NodeParagraph","Properties":{"id":"20260603085254-xev5fdk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260603085254-m2j1hnm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m2j1hnm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nwny058","Type":"NodeParagraph","Properties":{"id":"20260603085254-nwny058","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260603085254-6u7ynq9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6u7ynq9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xhwietu","Type":"NodeParagraph","Properties":{"id":"20260603085254-xhwietu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260603085254-81ojg1x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-81ojg1x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p46ya47","Type":"NodeParagraph","Properties":{"id":"20260603085254-p46ya47","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260603085254-dnil8fu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dnil8fu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-45v54ua","Type":"NodeParagraph","Properties":{"id":"20260603085254-45v54ua","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260603085254-t9p1w6x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t9p1w6x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0j7zcpq","Type":"NodeParagraph","Properties":{"id":"20260603085254-0j7zcpq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260603085254-hff5k2m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hff5k2m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j0szp2z","Type":"NodeParagraph","Properties":{"id":"20260603085254-j0szp2z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260603085254-9deop8q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9deop8q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5hefyeo","Type":"NodeParagraph","Properties":{"id":"20260603085254-5hefyeo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260603085254-zo6z06s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zo6z06s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gdk3lok","Type":"NodeParagraph","Properties":{"id":"20260603085254-gdk3lok","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260603085254-wmqwy94","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wmqwy94","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h732uio","Type":"NodeParagraph","Properties":{"id":"20260603085254-h732uio","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260603085254-ff4ux3e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ff4ux3e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dr6zx2v","Type":"NodeParagraph","Properties":{"id":"20260603085254-dr6zx2v","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260603085254-egkxveb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-egkxveb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0abb015","Type":"NodeParagraph","Properties":{"id":"20260603085254-0abb015","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260603085254-zq86c7y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zq86c7y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1dz7289","Type":"NodeParagraph","Properties":{"id":"20260603085254-1dz7289","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260603085254-zahs9bc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zahs9bc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kvcgol0","Type":"NodeParagraph","Properties":{"id":"20260603085254-kvcgol0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260603085254-womitv6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-womitv6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-waliadh","Type":"NodeParagraph","Properties":{"id":"20260603085254-waliadh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260603085254-uvjgob6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uvjgob6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-l901ta9","Type":"NodeParagraph","Properties":{"id":"20260603085254-l901ta9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260603085254-9gdy9ea","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9gdy9ea","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pjp3by1","Type":"NodeParagraph","Properties":{"id":"20260603085254-pjp3by1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260603085254-hx86f08","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hx86f08","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2xbv2lz","Type":"NodeParagraph","Properties":{"id":"20260603085254-2xbv2lz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260603085254-uqq3tgj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uqq3tgj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g3fwdn7","Type":"NodeParagraph","Properties":{"id":"20260603085254-g3fwdn7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260603085254-i3m2cnj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-i3m2cnj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vejo62y","Type":"NodeParagraph","Properties":{"id":"20260603085254-vejo62y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260603085254-2gkjmmp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2gkjmmp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fhlmxpk","Type":"NodeParagraph","Properties":{"id":"20260603085254-fhlmxpk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260603085254-9qpjjlc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9qpjjlc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qt8uujf","Type":"NodeParagraph","Properties":{"id":"20260603085254-qt8uujf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260603085254-mv9mm2g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mv9mm2g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yu3yfbj","Type":"NodeParagraph","Properties":{"id":"20260603085254-yu3yfbj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260603085254-08pf11y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-08pf11y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mvv7z22","Type":"NodeParagraph","Properties":{"id":"20260603085254-mvv7z22","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260603085254-e7xqfmr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e7xqfmr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cy43wxg","Type":"NodeParagraph","Properties":{"id":"20260603085254-cy43wxg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260603085254-j40uh3h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-j40uh3h","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pz9rj31","Type":"NodeParagraph","Properties":{"id":"20260603085254-pz9rj31","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260603085254-o7tv6ev","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-o7tv6ev","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jo7uhfi","Type":"NodeParagraph","Properties":{"id":"20260603085254-jo7uhfi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260603085254-5e6q9w0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5e6q9w0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3rj2e15","Type":"NodeParagraph","Properties":{"id":"20260603085254-3rj2e15","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260603085254-yg48dvp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yg48dvp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-udaliy6","Type":"NodeParagraph","Properties":{"id":"20260603085254-udaliy6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260603085254-wah07ek","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wah07ek","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u0e68xi","Type":"NodeParagraph","Properties":{"id":"20260603085254-u0e68xi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260603085254-lsvrbls","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lsvrbls","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ajkf6sr","Type":"NodeParagraph","Properties":{"id":"20260603085254-ajkf6sr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260603085254-xclwagv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xclwagv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7aimgpp","Type":"NodeParagraph","Properties":{"id":"20260603085254-7aimgpp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260603085254-uifcydp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uifcydp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hx93rlm","Type":"NodeParagraph","Properties":{"id":"20260603085254-hx93rlm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603085254-4g77ay5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4g77ay5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-winfibt","Type":"NodeParagraph","Properties":{"id":"20260603085254-winfibt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260603085254-e59jzqt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e59jzqt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kpilpn1","Type":"NodeParagraph","Properties":{"id":"20260603085254-kpilpn1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260603085254-f7dzogm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-f7dzogm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8uujhui","Type":"NodeParagraph","Properties":{"id":"20260603085254-8uujhui","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260603085254-9yw6dqh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9yw6dqh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6i6ftng","Type":"NodeParagraph","Properties":{"id":"20260603085254-6i6ftng","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260603085254-z38g7wg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-z38g7wg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bxwwz5a","Type":"NodeParagraph","Properties":{"id":"20260603085254-bxwwz5a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260603085254-bnlm3v3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bnlm3v3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hpd3roe","Type":"NodeParagraph","Properties":{"id":"20260603085254-hpd3roe","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260603085254-j6fcwdq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-j6fcwdq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k7uj1y9","Type":"NodeParagraph","Properties":{"id":"20260603085254-k7uj1y9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260603085254-das3b9h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-das3b9h","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4ary7y3","Type":"NodeParagraph","Properties":{"id":"20260603085254-4ary7y3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260603085254-hys6dx3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hys6dx3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7f2huov","Type":"NodeParagraph","Properties":{"id":"20260603085254-7f2huov","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260603085254-71jnriq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-71jnriq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yw0kvfu","Type":"NodeParagraph","Properties":{"id":"20260603085254-yw0kvfu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260603085254-kg4w6us","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kg4w6us","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7wz73z6","Type":"NodeParagraph","Properties":{"id":"20260603085254-7wz73z6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260603085254-xvxv0bp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xvxv0bp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-oc1wr90","Type":"NodeParagraph","Properties":{"id":"20260603085254-oc1wr90","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260603085254-p9boxdm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-p9boxdm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jjhtqtl","Type":"NodeParagraph","Properties":{"id":"20260603085254-jjhtqtl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260603085254-302fjed","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-302fjed","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fskpkwg","Type":"NodeParagraph","Properties":{"id":"20260603085254-fskpkwg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260603085254-vmdouov","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vmdouov","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9i08dhc","Type":"NodeParagraph","Properties":{"id":"20260603085254-9i08dhc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260603085254-65xu4du","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-65xu4du","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ro91eg7","Type":"NodeParagraph","Properties":{"id":"20260603085254-ro91eg7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260603085254-bebj4qk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bebj4qk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yx77q7e","Type":"NodeParagraph","Properties":{"id":"20260603085254-yx77q7e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260603085254-n2mjd31","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n2mjd31","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x623gg5","Type":"NodeParagraph","Properties":{"id":"20260603085254-x623gg5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260603085254-5747p56","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5747p56","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1b5hgz0","Type":"NodeParagraph","Properties":{"id":"20260603085254-1b5hgz0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260603085254-pifplld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pifplld","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nvvfqsv","Type":"NodeParagraph","Properties":{"id":"20260603085254-nvvfqsv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260603085254-q2k2wo1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-q2k2wo1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-eapcbb3","Type":"NodeParagraph","Properties":{"id":"20260603085254-eapcbb3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260603085254-52m0cik","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-52m0cik","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0jozx37","Type":"NodeParagraph","Properties":{"id":"20260603085254-0jozx37","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260603085254-n7tf5c1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n7tf5c1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gu3o5zy","Type":"NodeParagraph","Properties":{"id":"20260603085254-gu3o5zy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260603085254-6sagse3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6sagse3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4k5a6on","Type":"NodeParagraph","Properties":{"id":"20260603085254-4k5a6on","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260603085254-h1nqmev","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h1nqmev","updated":"20260603085254"},"Children":[{"ID":"20260603085254-871ow6t","Type":"NodeParagraph","Properties":{"id":"20260603085254-871ow6t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260603085254-07ok8o4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-07ok8o4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yekp5q9","Type":"NodeParagraph","Properties":{"id":"20260603085254-yekp5q9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260603085254-yc4y0ry","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yc4y0ry","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xsplmq5","Type":"NodeParagraph","Properties":{"id":"20260603085254-xsplmq5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260603085254-ntsbgt5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ntsbgt5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8mbqyjr","Type":"NodeParagraph","Properties":{"id":"20260603085254-8mbqyjr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260603085254-znh0xnk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-znh0xnk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2iibatu","Type":"NodeParagraph","Properties":{"id":"20260603085254-2iibatu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260603085254-7e9an8b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7e9an8b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-c32trj8","Type":"NodeParagraph","Properties":{"id":"20260603085254-c32trj8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260603085254-2106jbd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2106jbd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j51mrxw","Type":"NodeParagraph","Properties":{"id":"20260603085254-j51mrxw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260603085254-yhl3hht","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yhl3hht","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rjh02kx","Type":"NodeParagraph","Properties":{"id":"20260603085254-rjh02kx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260603085254-ua5tl0q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ua5tl0q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lzxl0er","Type":"NodeParagraph","Properties":{"id":"20260603085254-lzxl0er","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260603085254-ic5314i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ic5314i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8kfp70z","Type":"NodeParagraph","Properties":{"id":"20260603085254-8kfp70z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260603085254-knk3kf0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-knk3kf0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rtq947k","Type":"NodeParagraph","Properties":{"id":"20260603085254-rtq947k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260603085254-06bigkg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-06bigkg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-l9unqoi","Type":"NodeParagraph","Properties":{"id":"20260603085254-l9unqoi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260603085254-r18otyn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r18otyn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lkw938v","Type":"NodeParagraph","Properties":{"id":"20260603085254-lkw938v","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260603085254-rxry45a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rxry45a","updated":"20260603085254"},"Children":[{"ID":"20260603085254-io3ha8m","Type":"NodeParagraph","Properties":{"id":"20260603085254-io3ha8m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260603085254-tqgxmks","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tqgxmks","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2x2khqs","Type":"NodeParagraph","Properties":{"id":"20260603085254-2x2khqs","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260603085254-1nwdya1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1nwdya1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2zp9wwy","Type":"NodeParagraph","Properties":{"id":"20260603085254-2zp9wwy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260603085254-j8ylkq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-j8ylkq3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i1d8evo","Type":"NodeParagraph","Properties":{"id":"20260603085254-i1d8evo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260603085254-z8tmopo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-z8tmopo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4ivr52d","Type":"NodeParagraph","Properties":{"id":"20260603085254-4ivr52d","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260603085254-5opsiuk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5opsiuk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hy05q1n","Type":"NodeParagraph","Properties":{"id":"20260603085254-hy05q1n","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260603085254-1yibqv7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1yibqv7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4brohtn","Type":"NodeParagraph","Properties":{"id":"20260603085254-4brohtn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260603085254-jkffmyl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jkffmyl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jmtl4xz","Type":"NodeParagraph","Properties":{"id":"20260603085254-jmtl4xz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260603085254-8kcjqw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8kcjqw9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-exu8khn","Type":"NodeParagraph","Properties":{"id":"20260603085254-exu8khn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260603085254-cr5j2ej","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cr5j2ej","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ty62zjn","Type":"NodeParagraph","Properties":{"id":"20260603085254-ty62zjn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260603085254-r67r7k0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r67r7k0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uiobogb","Type":"NodeParagraph","Properties":{"id":"20260603085254-uiobogb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260603085254-b4m8x43","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b4m8x43","updated":"20260603085254"},"Children":[{"ID":"20260603085254-c2ayqnp","Type":"NodeParagraph","Properties":{"id":"20260603085254-c2ayqnp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260603085254-397aqrj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-397aqrj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vwiuea9","Type":"NodeParagraph","Properties":{"id":"20260603085254-vwiuea9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260603085254-1wd195o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1wd195o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mwn9lql","Type":"NodeParagraph","Properties":{"id":"20260603085254-mwn9lql","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260603085254-zc58h6b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zc58h6b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-spwnhgp","Type":"NodeParagraph","Properties":{"id":"20260603085254-spwnhgp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260603085254-kqny9r6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kqny9r6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hn6sv92","Type":"NodeParagraph","Properties":{"id":"20260603085254-hn6sv92","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260603085254-4tkin1w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4tkin1w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-m67jrkk","Type":"NodeParagraph","Properties":{"id":"20260603085254-m67jrkk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260603085254-49qbjbm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-49qbjbm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dwu1yw1","Type":"NodeParagraph","Properties":{"id":"20260603085254-dwu1yw1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260603085254-53hr7ay","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-53hr7ay","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vl8h4ha","Type":"NodeParagraph","Properties":{"id":"20260603085254-vl8h4ha","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260603085254-vt14x21","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vt14x21","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yid4xnu","Type":"NodeParagraph","Properties":{"id":"20260603085254-yid4xnu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260603085254-1zr4ccr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1zr4ccr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fhnww96","Type":"NodeParagraph","Properties":{"id":"20260603085254-fhnww96","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260603085254-bephdkx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bephdkx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5kr7v3i","Type":"NodeParagraph","Properties":{"id":"20260603085254-5kr7v3i","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260603085254-vh01cuf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vh01cuf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zgegpi7","Type":"NodeParagraph","Properties":{"id":"20260603085254-zgegpi7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260603085254-2rccalw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2rccalw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rd0dor4","Type":"NodeParagraph","Properties":{"id":"20260603085254-rd0dor4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260603085254-4axffhm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4axffhm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-am3xzjg","Type":"NodeParagraph","Properties":{"id":"20260603085254-am3xzjg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260603085254-0syqcyp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0syqcyp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hqs27en","Type":"NodeParagraph","Properties":{"id":"20260603085254-hqs27en","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260603085254-74pu34c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-74pu34c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qoswsec","Type":"NodeParagraph","Properties":{"id":"20260603085254-qoswsec","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260603085254-zj7idd5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zj7idd5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3rd3lgb","Type":"NodeParagraph","Properties":{"id":"20260603085254-3rd3lgb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260603085254-5a402et","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5a402et","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zejxdt6","Type":"NodeParagraph","Properties":{"id":"20260603085254-zejxdt6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260603085254-02rctu7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-02rctu7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zvbtmv6","Type":"NodeParagraph","Properties":{"id":"20260603085254-zvbtmv6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260603085254-pav1u3q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pav1u3q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8q1cq84","Type":"NodeParagraph","Properties":{"id":"20260603085254-8q1cq84","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260603085254-q2punff","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-q2punff","updated":"20260603085254"},"Children":[{"ID":"20260603085254-sc3xysv","Type":"NodeParagraph","Properties":{"id":"20260603085254-sc3xysv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260603085254-0xmcxca","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0xmcxca","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lqtehkq","Type":"NodeParagraph","Properties":{"id":"20260603085254-lqtehkq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260603085254-fakp75m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fakp75m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cllef61","Type":"NodeParagraph","Properties":{"id":"20260603085254-cllef61","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260603085254-nj86usx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nj86usx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-udtu5jy","Type":"NodeParagraph","Properties":{"id":"20260603085254-udtu5jy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260603085254-smivw4z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-smivw4z","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jci4ywz","Type":"NodeParagraph","Properties":{"id":"20260603085254-jci4ywz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260603085254-zdafmrm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zdafmrm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-peqy9v4","Type":"NodeParagraph","Properties":{"id":"20260603085254-peqy9v4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260603085254-0znqnre","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0znqnre","updated":"20260603085254"},"Children":[{"ID":"20260603085254-udz4z1k","Type":"NodeParagraph","Properties":{"id":"20260603085254-udz4z1k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260603085254-7m0wxi1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7m0wxi1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ni1hcrj","Type":"NodeParagraph","Properties":{"id":"20260603085254-ni1hcrj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260603085254-etwq1v4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-etwq1v4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-di64x4b","Type":"NodeParagraph","Properties":{"id":"20260603085254-di64x4b","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260603085254-jaor9zq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jaor9zq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2ureozn","Type":"NodeParagraph","Properties":{"id":"20260603085254-2ureozn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260603085254-18th0ml","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-18th0ml","updated":"20260603085254"},"Children":[{"ID":"20260603085254-00xu4qg","Type":"NodeParagraph","Properties":{"id":"20260603085254-00xu4qg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260603085254-wpy8aup","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wpy8aup","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8axgqf7","Type":"NodeParagraph","Properties":{"id":"20260603085254-8axgqf7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260603085254-tmxo3c4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tmxo3c4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4ujwhm4","Type":"NodeParagraph","Properties":{"id":"20260603085254-4ujwhm4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260603085254-tfnx8lj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tfnx8lj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-maesy1c","Type":"NodeParagraph","Properties":{"id":"20260603085254-maesy1c","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260603085254-nvjm9yp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nvjm9yp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vw47f6o","Type":"NodeParagraph","Properties":{"id":"20260603085254-vw47f6o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260603085254-vmg2oya","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vmg2oya","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8yfgk53","Type":"NodeParagraph","Properties":{"id":"20260603085254-8yfgk53","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260603085254-t20ml7f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t20ml7f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t6rjckv","Type":"NodeParagraph","Properties":{"id":"20260603085254-t6rjckv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260603085254-aol7yze","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-aol7yze","updated":"20260603085254"},"Children":[{"ID":"20260603085254-73v4jaj","Type":"NodeParagraph","Properties":{"id":"20260603085254-73v4jaj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260603085254-6wcor5x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6wcor5x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-i9kpfvv","Type":"NodeParagraph","Properties":{"id":"20260603085254-i9kpfvv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260603085254-uthvq4s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uthvq4s","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wciyykd","Type":"NodeParagraph","Properties":{"id":"20260603085254-wciyykd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260603085254-pma6ehs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pma6ehs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8ihn1sd","Type":"NodeParagraph","Properties":{"id":"20260603085254-8ihn1sd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260603085254-0ja4wm2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0ja4wm2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9js51yh","Type":"NodeParagraph","Properties":{"id":"20260603085254-9js51yh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260603085254-r5euafn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r5euafn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cieim62","Type":"NodeParagraph","Properties":{"id":"20260603085254-cieim62","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260603085254-6spi6a6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6spi6a6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2cxhukj","Type":"NodeParagraph","Properties":{"id":"20260603085254-2cxhukj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260603085254-nn2hu8l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-nn2hu8l","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kal8lyp","Type":"NodeParagraph","Properties":{"id":"20260603085254-kal8lyp","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260603085254-2muedpy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2muedpy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mkfvksx","Type":"NodeParagraph","Properties":{"id":"20260603085254-mkfvksx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260603085254-cpunf0j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cpunf0j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ge9a5so","Type":"NodeParagraph","Properties":{"id":"20260603085254-ge9a5so","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260603085254-ed2tf09","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ed2tf09","updated":"20260603085254"},"Children":[{"ID":"20260603085254-px5r3sh","Type":"NodeParagraph","Properties":{"id":"20260603085254-px5r3sh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260603085254-acos93e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-acos93e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-l792gmt","Type":"NodeParagraph","Properties":{"id":"20260603085254-l792gmt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603085254-mg1iwoj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mg1iwoj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bykdsik","Type":"NodeParagraph","Properties":{"id":"20260603085254-bykdsik","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260603085254-ji7jsaf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ji7jsaf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qibwgsw","Type":"NodeParagraph","Properties":{"id":"20260603085254-qibwgsw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260603085254-kmgg3em","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kmgg3em","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ewwczdm","Type":"NodeParagraph","Properties":{"id":"20260603085254-ewwczdm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260603085254-cgnjjjf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cgnjjjf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-12e05io","Type":"NodeParagraph","Properties":{"id":"20260603085254-12e05io","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260603085254-k7z4yv1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k7z4yv1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-74bqav2","Type":"NodeParagraph","Properties":{"id":"20260603085254-74bqav2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260603085254-v4zyolg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-v4zyolg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pfw3530","Type":"NodeParagraph","Properties":{"id":"20260603085254-pfw3530","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260603085254-082yorx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-082yorx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gougp48","Type":"NodeParagraph","Properties":{"id":"20260603085254-gougp48","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260603085254-yz79ap7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yz79ap7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8oqk8ln","Type":"NodeParagraph","Properties":{"id":"20260603085254-8oqk8ln","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260603085254-a0m8pag","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-a0m8pag","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u2ijt87","Type":"NodeParagraph","Properties":{"id":"20260603085254-u2ijt87","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260603085254-up7sdjz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-up7sdjz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-awxabt5","Type":"NodeParagraph","Properties":{"id":"20260603085254-awxabt5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260603085254-hbbpur7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hbbpur7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8f5zsik","Type":"NodeParagraph","Properties":{"id":"20260603085254-8f5zsik","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260603085254-s3pl7po","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s3pl7po","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zfh8erb","Type":"NodeParagraph","Properties":{"id":"20260603085254-zfh8erb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260603085254-fgvsy1l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fgvsy1l","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lgx34gr","Type":"NodeParagraph","Properties":{"id":"20260603085254-lgx34gr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260603085254-oq6r404","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oq6r404","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pu68iib","Type":"NodeParagraph","Properties":{"id":"20260603085254-pu68iib","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260603085254-m2a0ibc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m2a0ibc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-br4hh03","Type":"NodeParagraph","Properties":{"id":"20260603085254-br4hh03","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260603085254-uno9hf4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uno9hf4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-09mvpy2","Type":"NodeParagraph","Properties":{"id":"20260603085254-09mvpy2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260603085254-bot8s4x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bot8s4x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9ps1vfd","Type":"NodeParagraph","Properties":{"id":"20260603085254-9ps1vfd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260603085254-5omgt8e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5omgt8e","updated":"20260603085254"},"Children":[{"ID":"20260603085254-oyp7uz8","Type":"NodeParagraph","Properties":{"id":"20260603085254-oyp7uz8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260603085254-mkkkc8o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mkkkc8o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-206oh6l","Type":"NodeParagraph","Properties":{"id":"20260603085254-206oh6l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260603085254-zrhqrry","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zrhqrry","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ud93m9i","Type":"NodeParagraph","Properties":{"id":"20260603085254-ud93m9i","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603085254-s5izkbs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s5izkbs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rdvh7np","Type":"NodeParagraph","Properties":{"id":"20260603085254-rdvh7np","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260603085254-7ylvuv6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7ylvuv6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g16qdqw","Type":"NodeParagraph","Properties":{"id":"20260603085254-g16qdqw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260603085254-56oekk6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-56oekk6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-sla0zlv","Type":"NodeParagraph","Properties":{"id":"20260603085254-sla0zlv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260603085254-oou7gvd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oou7gvd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-76bz4jw","Type":"NodeParagraph","Properties":{"id":"20260603085254-76bz4jw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260603085254-dpusgpm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dpusgpm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bwykpi3","Type":"NodeParagraph","Properties":{"id":"20260603085254-bwykpi3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260603085254-wu3cuf1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wu3cuf1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ssvv9we","Type":"NodeParagraph","Properties":{"id":"20260603085254-ssvv9we","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260603085254-sx0rzoi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sx0rzoi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fmlietq","Type":"NodeParagraph","Properties":{"id":"20260603085254-fmlietq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260603085254-sswjeiu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sswjeiu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hrvjv36","Type":"NodeParagraph","Properties":{"id":"20260603085254-hrvjv36","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260603085254-dkpzaxb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dkpzaxb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qks6yn1","Type":"NodeParagraph","Properties":{"id":"20260603085254-qks6yn1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260603085254-wclcht6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wclcht6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-srk0n9l","Type":"NodeParagraph","Properties":{"id":"20260603085254-srk0n9l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260603085254-uxkmnnr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-uxkmnnr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rg1ov21","Type":"NodeParagraph","Properties":{"id":"20260603085254-rg1ov21","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260603085254-jv4jayh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jv4jayh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ag3x55l","Type":"NodeParagraph","Properties":{"id":"20260603085254-ag3x55l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260603085254-6n2e1nb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6n2e1nb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2dbaf13","Type":"NodeParagraph","Properties":{"id":"20260603085254-2dbaf13","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260603085254-ea63jkw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ea63jkw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0r5hoaw","Type":"NodeParagraph","Properties":{"id":"20260603085254-0r5hoaw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260603085254-s9elm6b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s9elm6b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j1gbr2t","Type":"NodeParagraph","Properties":{"id":"20260603085254-j1gbr2t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260603085254-5vqhcsf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5vqhcsf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6ipjdcm","Type":"NodeParagraph","Properties":{"id":"20260603085254-6ipjdcm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260603085254-ne374iw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ne374iw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tnzjztw","Type":"NodeParagraph","Properties":{"id":"20260603085254-tnzjztw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260603085254-rv0j6h3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rv0j6h3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kfkelup","Type":"NodeParagraph","Properties":{"id":"20260603085254-kfkelup","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260603085254-3rb22ct","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3rb22ct","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lc5gbog","Type":"NodeParagraph","Properties":{"id":"20260603085254-lc5gbog","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260603085254-jxiglg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jxiglg6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zipu8u7","Type":"NodeParagraph","Properties":{"id":"20260603085254-zipu8u7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260603085254-2a7u7fy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2a7u7fy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ji3d7rc","Type":"NodeParagraph","Properties":{"id":"20260603085254-ji3d7rc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260603085254-vlos44j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vlos44j","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hq4iulf","Type":"NodeParagraph","Properties":{"id":"20260603085254-hq4iulf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260603085254-5lngvdy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5lngvdy","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x1ffev0","Type":"NodeParagraph","Properties":{"id":"20260603085254-x1ffev0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260603085254-bfcw051","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bfcw051","updated":"20260603085254"},"Children":[{"ID":"20260603085254-letglfo","Type":"NodeParagraph","Properties":{"id":"20260603085254-letglfo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260603085254-rlpghhq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-rlpghhq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-am1pxps","Type":"NodeParagraph","Properties":{"id":"20260603085254-am1pxps","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260603085254-oqzfssx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oqzfssx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vc4nptw","Type":"NodeParagraph","Properties":{"id":"20260603085254-vc4nptw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260603085254-pub22gw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pub22gw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ritd8qa","Type":"NodeParagraph","Properties":{"id":"20260603085254-ritd8qa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260603085254-sa5rms1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sa5rms1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n4kiqky","Type":"NodeParagraph","Properties":{"id":"20260603085254-n4kiqky","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260603085254-qcr315m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qcr315m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r9zjjyr","Type":"NodeParagraph","Properties":{"id":"20260603085254-r9zjjyr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260603085254-o2uagj5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-o2uagj5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-s2ln5fo","Type":"NodeParagraph","Properties":{"id":"20260603085254-s2ln5fo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260603085254-b6qcuzo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-b6qcuzo","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6zb5o74","Type":"NodeParagraph","Properties":{"id":"20260603085254-6zb5o74","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260603085254-311fr83","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-311fr83","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f42can7","Type":"NodeParagraph","Properties":{"id":"20260603085254-f42can7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260603085254-s69fzef","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-s69fzef","updated":"20260603085254"},"Children":[{"ID":"20260603085254-n3kdwyq","Type":"NodeParagraph","Properties":{"id":"20260603085254-n3kdwyq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260603085254-h3kbk0l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h3kbk0l","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9unmku1","Type":"NodeParagraph","Properties":{"id":"20260603085254-9unmku1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260603085254-svrdsr5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-svrdsr5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-32x1r4n","Type":"NodeParagraph","Properties":{"id":"20260603085254-32x1r4n","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260603085254-5u2tra6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-5u2tra6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jsvk75y","Type":"NodeParagraph","Properties":{"id":"20260603085254-jsvk75y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260603085254-3r61r3f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3r61r3f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6y2s6yo","Type":"NodeParagraph","Properties":{"id":"20260603085254-6y2s6yo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260603085254-8rkd9pw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8rkd9pw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9in3b5o","Type":"NodeParagraph","Properties":{"id":"20260603085254-9in3b5o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260603085254-ubabxxl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ubabxxl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-o1dlo0y","Type":"NodeParagraph","Properties":{"id":"20260603085254-o1dlo0y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260603085254-ln5hkw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ln5hkw9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rhirn5h","Type":"NodeParagraph","Properties":{"id":"20260603085254-rhirn5h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260603085254-yeiq79g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yeiq79g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rlc24rz","Type":"NodeParagraph","Properties":{"id":"20260603085254-rlc24rz","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260603085254-jj8dojj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jj8dojj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r66q4ax","Type":"NodeParagraph","Properties":{"id":"20260603085254-r66q4ax","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260603085254-dahhm1g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dahhm1g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fhzl9zg","Type":"NodeParagraph","Properties":{"id":"20260603085254-fhzl9zg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260603085254-tamptvb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-tamptvb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-s0elzj7","Type":"NodeParagraph","Properties":{"id":"20260603085254-s0elzj7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260603085254-qbgtecu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qbgtecu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x3l20q2","Type":"NodeParagraph","Properties":{"id":"20260603085254-x3l20q2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260603085254-yj4z792","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yj4z792","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6unz3dy","Type":"NodeParagraph","Properties":{"id":"20260603085254-6unz3dy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260603085254-v8ok88b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-v8ok88b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dmitxvq","Type":"NodeParagraph","Properties":{"id":"20260603085254-dmitxvq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260603085254-7i546pq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7i546pq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-846bsdr","Type":"NodeParagraph","Properties":{"id":"20260603085254-846bsdr","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260603085254-vks58gm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-vks58gm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fcvga7m","Type":"NodeParagraph","Properties":{"id":"20260603085254-fcvga7m","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260603085254-ibln3nk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ibln3nk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fmiusd1","Type":"NodeParagraph","Properties":{"id":"20260603085254-fmiusd1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260603085254-6pe24h2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6pe24h2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-k2bqfxm","Type":"NodeParagraph","Properties":{"id":"20260603085254-k2bqfxm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260603085254-zq0pqgd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zq0pqgd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7cghinq","Type":"NodeParagraph","Properties":{"id":"20260603085254-7cghinq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260603085254-3mm8zl9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3mm8zl9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u4ae2o0","Type":"NodeParagraph","Properties":{"id":"20260603085254-u4ae2o0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260603085254-e1tam64","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-e1tam64","updated":"20260603085254"},"Children":[{"ID":"20260603085254-o86mkmq","Type":"NodeParagraph","Properties":{"id":"20260603085254-o86mkmq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260603085254-bo2eys9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bo2eys9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4s8ufpw","Type":"NodeParagraph","Properties":{"id":"20260603085254-4s8ufpw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260603085254-zr7wpfz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zr7wpfz","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ex8kohc","Type":"NodeParagraph","Properties":{"id":"20260603085254-ex8kohc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260603085254-upyf9h2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-upyf9h2","updated":"20260603085254"},"Children":[{"ID":"20260603085254-va6z7w8","Type":"NodeParagraph","Properties":{"id":"20260603085254-va6z7w8","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260603085254-atsc0r5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-atsc0r5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t1t6fmo","Type":"NodeParagraph","Properties":{"id":"20260603085254-t1t6fmo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260603085254-kt2n4nv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kt2n4nv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ncwsraw","Type":"NodeParagraph","Properties":{"id":"20260603085254-ncwsraw","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260603085254-2k97fdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2k97fdt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-itvhvt0","Type":"NodeParagraph","Properties":{"id":"20260603085254-itvhvt0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260603085254-z54xhgi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-z54xhgi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lewvndy","Type":"NodeParagraph","Properties":{"id":"20260603085254-lewvndy","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260603085254-luzxs7b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-luzxs7b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lo0qolh","Type":"NodeParagraph","Properties":{"id":"20260603085254-lo0qolh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260603085254-43dvbxt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-43dvbxt","updated":"20260603085254"},"Children":[{"ID":"20260603085254-wsklgsf","Type":"NodeParagraph","Properties":{"id":"20260603085254-wsklgsf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260603085254-bqsvlj6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bqsvlj6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f8rolcc","Type":"NodeParagraph","Properties":{"id":"20260603085254-f8rolcc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260603085254-8jl6hc0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8jl6hc0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uc0m4o0","Type":"NodeParagraph","Properties":{"id":"20260603085254-uc0m4o0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260603085254-itw8hxf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-itw8hxf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ngnvg18","Type":"NodeParagraph","Properties":{"id":"20260603085254-ngnvg18","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260603085254-m84k657","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m84k657","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2x7bplm","Type":"NodeParagraph","Properties":{"id":"20260603085254-2x7bplm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260603085254-iltyauv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-iltyauv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2dy8tvg","Type":"NodeParagraph","Properties":{"id":"20260603085254-2dy8tvg","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260603085254-lrdql9y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lrdql9y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ap76sjq","Type":"NodeParagraph","Properties":{"id":"20260603085254-ap76sjq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260603085254-isjxm2b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-isjxm2b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-8i09hyc","Type":"NodeParagraph","Properties":{"id":"20260603085254-8i09hyc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260603085254-gbrpwih","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gbrpwih","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zay151h","Type":"NodeParagraph","Properties":{"id":"20260603085254-zay151h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260603085254-ihd0rz9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ihd0rz9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5zkeoub","Type":"NodeParagraph","Properties":{"id":"20260603085254-5zkeoub","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260603085254-77fn77k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-77fn77k","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cnygr1w","Type":"NodeParagraph","Properties":{"id":"20260603085254-cnygr1w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260603085254-k05avfb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k05avfb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-38tw6ih","Type":"NodeParagraph","Properties":{"id":"20260603085254-38tw6ih","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260603085254-ju38obw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ju38obw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g29vl56","Type":"NodeParagraph","Properties":{"id":"20260603085254-g29vl56","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260603085254-g51hy4a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-g51hy4a","updated":"20260603085254"},"Children":[{"ID":"20260603085254-u7164fq","Type":"NodeParagraph","Properties":{"id":"20260603085254-u7164fq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260603085254-laonfwx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-laonfwx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-di43n3a","Type":"NodeParagraph","Properties":{"id":"20260603085254-di43n3a","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260603085254-wrvtvwv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wrvtvwv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-z6cay6k","Type":"NodeParagraph","Properties":{"id":"20260603085254-z6cay6k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260603085254-0f3wz1f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0f3wz1f","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ev3p4go","Type":"NodeParagraph","Properties":{"id":"20260603085254-ev3p4go","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260603085254-kc7ii3c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kc7ii3c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uu6p160","Type":"NodeParagraph","Properties":{"id":"20260603085254-uu6p160","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260603085254-f0i4jws","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-f0i4jws","updated":"20260603085254"},"Children":[{"ID":"20260603085254-45ey6bv","Type":"NodeParagraph","Properties":{"id":"20260603085254-45ey6bv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260603085254-dh5i4mu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-dh5i4mu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-aoncj5v","Type":"NodeParagraph","Properties":{"id":"20260603085254-aoncj5v","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260603085254-8aubox5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8aubox5","updated":"20260603085254"},"Children":[{"ID":"20260603085254-kltqsj2","Type":"NodeParagraph","Properties":{"id":"20260603085254-kltqsj2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260603085254-aaeoi8p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-aaeoi8p","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gvno3k6","Type":"NodeParagraph","Properties":{"id":"20260603085254-gvno3k6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260603085254-r6ndcls","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-r6ndcls","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2rn515o","Type":"NodeParagraph","Properties":{"id":"20260603085254-2rn515o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260603085254-ljqj3xs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ljqj3xs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qh6qowa","Type":"NodeParagraph","Properties":{"id":"20260603085254-qh6qowa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260603085254-fyn1un1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fyn1un1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nyjr0bu","Type":"NodeParagraph","Properties":{"id":"20260603085254-nyjr0bu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260603085254-3p267tb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3p267tb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h0saqut","Type":"NodeParagraph","Properties":{"id":"20260603085254-h0saqut","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260603085254-ax59ziw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ax59ziw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-rj1rvcd","Type":"NodeParagraph","Properties":{"id":"20260603085254-rj1rvcd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260603085254-1u5d1wg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1u5d1wg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lthh1vj","Type":"NodeParagraph","Properties":{"id":"20260603085254-lthh1vj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260603085254-k3nqtjs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k3nqtjs","updated":"20260603085254"},"Children":[{"ID":"20260603085254-o1qrkos","Type":"NodeParagraph","Properties":{"id":"20260603085254-o1qrkos","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260603085254-oksnc7t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-oksnc7t","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yv62b6z","Type":"NodeParagraph","Properties":{"id":"20260603085254-yv62b6z","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260603085254-73tvuo7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-73tvuo7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-q969482","Type":"NodeParagraph","Properties":{"id":"20260603085254-q969482","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260603085254-il79mq7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-il79mq7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fgcdcce","Type":"NodeParagraph","Properties":{"id":"20260603085254-fgcdcce","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260603085254-l0clpia","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-l0clpia","updated":"20260603085254"},"Children":[{"ID":"20260603085254-f69tle2","Type":"NodeParagraph","Properties":{"id":"20260603085254-f69tle2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260603085254-9ve2r45","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9ve2r45","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tnasyf6","Type":"NodeParagraph","Properties":{"id":"20260603085254-tnasyf6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260603085254-1wfwxst","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1wfwxst","updated":"20260603085254"},"Children":[{"ID":"20260603085254-krnlr4b","Type":"NodeParagraph","Properties":{"id":"20260603085254-krnlr4b","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260603085254-bmg11wg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bmg11wg","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fqilib2","Type":"NodeParagraph","Properties":{"id":"20260603085254-fqilib2","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260603085254-du9cnpm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-du9cnpm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-cw6d724","Type":"NodeParagraph","Properties":{"id":"20260603085254-cw6d724","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺。"}]}]},{"ID":"20260603085254-8pway1i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8pway1i","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3u2nw3v","Type":"NodeParagraph","Properties":{"id":"20260603085254-3u2nw3v","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260603085254-h497u5r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h497u5r","updated":"20260603085254"},"Children":[{"ID":"20260603085254-hvf6qu9","Type":"NodeParagraph","Properties":{"id":"20260603085254-hvf6qu9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260603085254-8vq8c9v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-8vq8c9v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-iu2dz5n","Type":"NodeParagraph","Properties":{"id":"20260603085254-iu2dz5n","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260603085254-sdbt6xa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sdbt6xa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ayv6xvq","Type":"NodeParagraph","Properties":{"id":"20260603085254-ayv6xvq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260603085254-hhfe4u1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-hhfe4u1","updated":"20260603085254"},"Children":[{"ID":"20260603085254-j25l6e6","Type":"NodeParagraph","Properties":{"id":"20260603085254-j25l6e6","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260603085254-p38waqw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-p38waqw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-dlegcsb","Type":"NodeParagraph","Properties":{"id":"20260603085254-dlegcsb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260603085254-o1xmqfu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-o1xmqfu","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yjpqwqb","Type":"NodeParagraph","Properties":{"id":"20260603085254-yjpqwqb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260603085254-6r4lmmb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6r4lmmb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xdct654","Type":"NodeParagraph","Properties":{"id":"20260603085254-xdct654","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]},{"ID":"20260603085254-zcrcpaa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zcrcpaa","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3tl3aqn","Type":"NodeParagraph","Properties":{"id":"20260603085254-3tl3aqn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260603085254-catswym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-catswym","updated":"20260603085254"},"Children":[{"ID":"20260603085254-37l03m3","Type":"NodeParagraph","Properties":{"id":"20260603085254-37l03m3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260603085254-ayc8lk3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ayc8lk3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5gj2ccm","Type":"NodeParagraph","Properties":{"id":"20260603085254-5gj2ccm","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260603085254-k34bzhl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k34bzhl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p6bkjuo","Type":"NodeParagraph","Properties":{"id":"20260603085254-p6bkjuo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260603085254-me2uolh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-me2uolh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3imb9my","Type":"NodeParagraph","Properties":{"id":"20260603085254-3imb9my","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260603085254-q64tivb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-q64tivb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-y2pvtzq","Type":"NodeParagraph","Properties":{"id":"20260603085254-y2pvtzq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260603085254-k2bvr9d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-k2bvr9d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0m8s2zh","Type":"NodeParagraph","Properties":{"id":"20260603085254-0m8s2zh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260603085254-bmu05kd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bmu05kd","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lwhhtwq","Type":"NodeParagraph","Properties":{"id":"20260603085254-lwhhtwq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260603085254-3kfyrb6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-3kfyrb6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-38drl13","Type":"NodeParagraph","Properties":{"id":"20260603085254-38drl13","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260603085254-x72i7xr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-x72i7xr","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bk8vtip","Type":"NodeParagraph","Properties":{"id":"20260603085254-bk8vtip","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260603085254-wi3mtbm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wi3mtbm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g7ime2y","Type":"NodeParagraph","Properties":{"id":"20260603085254-g7ime2y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260603085254-biowsm9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-biowsm9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ndn2f0t","Type":"NodeParagraph","Properties":{"id":"20260603085254-ndn2f0t","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260603085254-v588o3m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-v588o3m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-uoh3mrf","Type":"NodeParagraph","Properties":{"id":"20260603085254-uoh3mrf","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260603085254-4igpg4g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-4igpg4g","updated":"20260603085254"},"Children":[{"ID":"20260603085254-31ycafo","Type":"NodeParagraph","Properties":{"id":"20260603085254-31ycafo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260603085254-qustztq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-qustztq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7dbk58k","Type":"NodeParagraph","Properties":{"id":"20260603085254-7dbk58k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260603085254-2tc5f1m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2tc5f1m","updated":"20260603085254"},"Children":[{"ID":"20260603085254-h6lz7hv","Type":"NodeParagraph","Properties":{"id":"20260603085254-h6lz7hv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260603085254-ndlnxzp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ndlnxzp","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vq0uw4w","Type":"NodeParagraph","Properties":{"id":"20260603085254-vq0uw4w","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260603085254-w36eqia","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w36eqia","updated":"20260603085254"},"Children":[{"ID":"20260603085254-jaol3ai","Type":"NodeParagraph","Properties":{"id":"20260603085254-jaol3ai","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260603085254-wga5myf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-wga5myf","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7qdxpsi","Type":"NodeParagraph","Properties":{"id":"20260603085254-7qdxpsi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260603085254-fxd96hw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fxd96hw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-qyl5ds4","Type":"NodeParagraph","Properties":{"id":"20260603085254-qyl5ds4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260603085254-idj85rm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-idj85rm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tcbo1a9","Type":"NodeParagraph","Properties":{"id":"20260603085254-tcbo1a9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260603085254-gxjnbzx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gxjnbzx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-x9bh4gq","Type":"NodeParagraph","Properties":{"id":"20260603085254-x9bh4gq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603085254-7bzh0j9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7bzh0j9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-utqw6mj","Type":"NodeParagraph","Properties":{"id":"20260603085254-utqw6mj","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260603085254-h0s9t4b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h0s9t4b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-27vb8as","Type":"NodeParagraph","Properties":{"id":"20260603085254-27vb8as","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603085254-u3xyftx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-u3xyftx","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2iw5w53","Type":"NodeParagraph","Properties":{"id":"20260603085254-2iw5w53","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260603085254-cr48ub6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-cr48ub6","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9m6w0gq","Type":"NodeParagraph","Properties":{"id":"20260603085254-9m6w0gq","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260603085254-frrjrwi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-frrjrwi","updated":"20260603085254"},"Children":[{"ID":"20260603085254-35cuitx","Type":"NodeParagraph","Properties":{"id":"20260603085254-35cuitx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260603085254-lpax7pw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lpax7pw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-posbw0o","Type":"NodeParagraph","Properties":{"id":"20260603085254-posbw0o","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260603085254-jruia1v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jruia1v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5enjjpn","Type":"NodeParagraph","Properties":{"id":"20260603085254-5enjjpn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260603085254-n09es9c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-n09es9c","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3rh5qlv","Type":"NodeParagraph","Properties":{"id":"20260603085254-3rh5qlv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260603085254-in4kffj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-in4kffj","updated":"20260603085254"},"Children":[{"ID":"20260603085254-tschzfn","Type":"NodeParagraph","Properties":{"id":"20260603085254-tschzfn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260603085254-ylsw1vv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ylsw1vv","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p2q0s4p","Type":"NodeParagraph","Properties":{"id":"20260603085254-p2q0s4p","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260603085254-92fztai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-92fztai","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xznlwpn","Type":"NodeParagraph","Properties":{"id":"20260603085254-xznlwpn","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260603085254-7v24nb9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7v24nb9","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fns6gzl","Type":"NodeParagraph","Properties":{"id":"20260603085254-fns6gzl","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260603085254-0ifcl28","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-0ifcl28","updated":"20260603085254"},"Children":[{"ID":"20260603085254-9ihlkfe","Type":"NodeParagraph","Properties":{"id":"20260603085254-9ihlkfe","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260603085254-fkuzafh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-fkuzafh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xsktof7","Type":"NodeParagraph","Properties":{"id":"20260603085254-xsktof7","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260603085254-t88336w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-t88336w","updated":"20260603085254"},"Children":[{"ID":"20260603085254-pqb3qci","Type":"NodeParagraph","Properties":{"id":"20260603085254-pqb3qci","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260603085254-m3okm5u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-m3okm5u","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ywv3r4d","Type":"NodeParagraph","Properties":{"id":"20260603085254-ywv3r4d","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260603085254-zlfy7vm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-zlfy7vm","updated":"20260603085254"},"Children":[{"ID":"20260603085254-0wt98uo","Type":"NodeParagraph","Properties":{"id":"20260603085254-0wt98uo","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260603085254-yqxfpgl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yqxfpgl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-5h631ir","Type":"NodeParagraph","Properties":{"id":"20260603085254-5h631ir","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260603085254-7e0yk96","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-7e0yk96","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6sejryh","Type":"NodeParagraph","Properties":{"id":"20260603085254-6sejryh","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260603085254-gla53ew","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gla53ew","updated":"20260603085254"},"Children":[{"ID":"20260603085254-bcxdjfk","Type":"NodeParagraph","Properties":{"id":"20260603085254-bcxdjfk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260603085254-45lzjyh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-45lzjyh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ghy25g3","Type":"NodeParagraph","Properties":{"id":"20260603085254-ghy25g3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260603085254-lzd300q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-lzd300q","updated":"20260603085254"},"Children":[{"ID":"20260603085254-lwxds6h","Type":"NodeParagraph","Properties":{"id":"20260603085254-lwxds6h","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260603085254-h2cwp3v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h2cwp3v","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4vjq0sd","Type":"NodeParagraph","Properties":{"id":"20260603085254-4vjq0sd","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260603085254-mhiywmb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mhiywmb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t8uz1s4","Type":"NodeParagraph","Properties":{"id":"20260603085254-t8uz1s4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260603085254-6xqb3t4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-6xqb3t4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zyx8l49","Type":"NodeParagraph","Properties":{"id":"20260603085254-zyx8l49","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260603085254-mpwzs3o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-mpwzs3o","updated":"20260603085254"},"Children":[{"ID":"20260603085254-76ddr2i","Type":"NodeParagraph","Properties":{"id":"20260603085254-76ddr2i","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260603085254-1nthvlq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-1nthvlq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ox649hx","Type":"NodeParagraph","Properties":{"id":"20260603085254-ox649hx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260603085254-llgvvh3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-llgvvh3","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6m5rh7y","Type":"NodeParagraph","Properties":{"id":"20260603085254-6m5rh7y","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260603085254-sda5zaw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sda5zaw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r4z9nwi","Type":"NodeParagraph","Properties":{"id":"20260603085254-r4z9nwi","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260603085254-ecqe4gk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ecqe4gk","updated":"20260603085254"},"Children":[{"ID":"20260603085254-4tc4ots","Type":"NodeParagraph","Properties":{"id":"20260603085254-4tc4ots","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]},{"ID":"20260603085254-9vtn7u7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9vtn7u7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-snfjwp3","Type":"NodeParagraph","Properties":{"id":"20260603085254-snfjwp3","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"古人云：“知行合一。”而在现代决策理论中，这一思想被进一步具体化为一种动态更新的过程：人并非先有完备之知，才敢行动，而是在行动中修正认知。正如贝叶斯原理所揭示的——判断并非一成不变，而是在一次次反馈中逼近真实。由此看来，真正的理性，不是避免犯错，而是不断纠错。"}]}]},{"ID":"20260603085254-2veygiq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-2veygiq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-7fntdvt","Type":"NodeParagraph","Properties":{"id":"20260603085254-7fntdvt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"破窗效应：如果环境中的不良现象被放任存在，会诱使人们效仿，甚至变本加厉。"}]}]},{"ID":"20260603085254-c7q6hnh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c7q6hnh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-g8cuji9","Type":"NodeParagraph","Properties":{"id":"20260603085254-g8cuji9","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"锚定效应：人们在做决定时，容易受第一印象或第一条信息的支配。"}]}]},{"ID":"20260603085254-ulpixrq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ulpixrq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-3nvzc8l","Type":"NodeParagraph","Properties":{"id":"20260603085254-3nvzc8l","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"羊群效应：指人们经常受到多数人影响，而跟从大众的思想或行为。"}]}]},{"ID":"20260603085254-bhbhdl7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-bhbhdl7","updated":"20260603085254"},"Children":[{"ID":"20260603085254-e31v40f","Type":"NodeParagraph","Properties":{"id":"20260603085254-e31v40f","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"习得性无助：指人在经历了某种失败或挫折后，产生的放弃努力的悲观心理。"}]}]},{"ID":"20260603085254-xzbr750","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-xzbr750","updated":"20260603085254"},"Children":[{"ID":"20260603085254-962tfd4","Type":"NodeParagraph","Properties":{"id":"20260603085254-962tfd4","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"手表定律：只有一只手表时能知道时间，拥有两只或以上反而无法确定时间。"}]}]},{"ID":"20260603085254-9zi1rse","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-9zi1rse","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zdgsrc5","Type":"NodeParagraph","Properties":{"id":"20260603085254-zdgsrc5","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"鳄鱼法则：当被鳄鱼咬住腿，若用手去解救，手也会被咬。唯一的办法是牺牲那条腿。它揭示了及时止损、果决舍弃的智慧。"}]}]},{"ID":"20260603085254-w17i8dc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-w17i8dc","updated":"20260603085254"},"Children":[{"ID":"20260603085254-6r30r4k","Type":"NodeParagraph","Properties":{"id":"20260603085254-6r30r4k","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"刺猬理论：刺猬天冷时靠拢取暖，但必须保持距离以免刺伤对方。完美诠释了人际交往中“距离产生美”以及分寸感的重要性。"}]}]},{"ID":"20260603085254-o8sptj4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-o8sptj4","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2dozqwk","Type":"NodeParagraph","Properties":{"id":"20260603085254-2dozqwk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"熵增定律：在一个封闭系统中，若无外力做功，系统会自发趋向无序和混乱。人需要主动引入“负熵”（如持续学习、自律），才能对抗生命的无序与懈怠。"}]}]},{"ID":"20260603085254-j0utkha","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-j0utkha","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nb0sswv","Type":"NodeParagraph","Properties":{"id":"20260603085254-nb0sswv","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"氨基酸组合效应：组成人体蛋白的8种氨基酸，只要有一种不足，其他7种就无法合成蛋白质。适合论证团队合作中缺一不可的整体性，或者个人素养的全面性。"}]}]},{"ID":"20260603085254-h26xp4b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-h26xp4b","updated":"20260603085254"},"Children":[{"ID":"20260603085254-2ne0hwt","Type":"NodeParagraph","Properties":{"id":"20260603085254-2ne0hwt","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"幸存者效应：只看到“活下来的人”“成功者”“被看见的案例”，却忽略了那些被淘汰、失败、沉默的大多数，于是容易得出片面甚至错误的结论。"}]}]},{"ID":"20260603085254-ey6duat","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-ey6duat","updated":"20260603085254"},"Children":[{"ID":"20260603085254-vw5g9d0","Type":"NodeParagraph","Properties":{"id":"20260603085254-vw5g9d0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"奥卡姆剃刀：如无必要，勿增实体。"}]}]},{"ID":"20260603085254-pumjcnw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-pumjcnw","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nhervwx","Type":"NodeParagraph","Properties":{"id":"20260603085254-nhervwx","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"墨菲定律：如果有两种或两种以上的方式去做某件事，而其中一种会导致灾难，那么必定会有人选择这种方式。"}]}]},{"ID":"20260603085254-c0knqhn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c0knqhn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-zlrhzm1","Type":"NodeParagraph","Properties":{"id":"20260603085254-zlrhzm1","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"波普尔证伪主义：科学理论的价值不在于被证明为真，而在于能够被不断检验并有可能被证伪，从而在批判中逐步逼近真理。"}]}]},{"ID":"20260603085254-yhbrzzb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-yhbrzzb","updated":"20260603085254"},"Children":[{"ID":"20260603085254-fljch8e","Type":"NodeParagraph","Properties":{"id":"20260603085254-fljch8e","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"皮亚杰建构主义：知识不是接受的，是主动建构的"}]}]},{"ID":"20260603085254-c4r2s1y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-c4r2s1y","updated":"20260603085254"},"Children":[{"ID":"20260603085254-nujj37x","Type":"NodeParagraph","Properties":{"id":"20260603085254-nujj37x","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"怀疑主义：对既有认知保持怀疑"}]}]},{"ID":"20260603085254-jzf2u0x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-jzf2u0x","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ao37tdu","Type":"NodeParagraph","Properties":{"id":"20260603085254-ao37tdu","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"黑格尔辩证法：真理在矛盾和冲突中发展"}]}]},{"ID":"20260603085254-d6cn15d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-d6cn15d","updated":"20260603085254"},"Children":[{"ID":"20260603085254-ggjioau","Type":"NodeParagraph","Properties":{"id":"20260603085254-ggjioau","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"实践论：实践是检验真理的唯一标准"}]}]}]}]},{"ID":"20260603085254-sgxxtns","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-sgxxtns","updated":"20260603085254"},"Children":[{"ID":"20260603085254-mjgvbsb","Type":"NodeParagraph","Properties":{"id":"20260603085254-mjgvbsb","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。"}]}]}]}]},{"ID":"20260603085254-ysqa2eh","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260603085254-ysqa2eh","updated":"20260603085254"},"Children":[{"ID":"20260603085254-t75y26n","Type":"NodeParagraph","Properties":{"id":"20260603085254-t75y26n","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：840至860字"}]}]},{"ID":"20260603085254-9vpqsx0","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260603085254-9vpqsx0","updated":"20260603085254"},"Children":[{"ID":"20260603085254-r2mko58","Type":"NodeParagraph","Properties":{"id":"20260603085254-r2mko58","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260603085254-s2jookq","Type":"NodeList","ListData":{},"Properties":{"id":"20260603085254-s2jookq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-gzv1kth","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-gzv1kth","updated":"20260603085254"},"Children":[{"ID":"20260603085254-xccyhzk","Type":"NodeParagraph","Properties":{"id":"20260603085254-xccyhzk","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260603085254-kjofkxl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603085254-kjofkxl","updated":"20260603085254"},"Children":[{"ID":"20260603085254-p8go2m0","Type":"NodeParagraph","Properties":{"id":"20260603085254-p8go2m0","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]}]}]},{"ID":"20260603085254-r7sd8pa","Type":"NodeParagraph","Properties":{"id":"20260603085254-r7sd8pa","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【作文题目/材料/原文】"},{"Type":"NodeText","Data":"\n（在此处粘贴具体的作文题目、材料或话题，例如：2025年全国一卷关于老舍、艾青、穆旦的材料……）"}]},{"ID":"20260603085254-8niq1wq","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20260603085254-8niq1wq","updated":"20260603085254"},"Children":[{"ID":"20260603085254-yr4n9mn","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20260603085254-yr4n9mn","updated":"20260603085254"},"Children":[{"ID":"20260603085254-1k3vbrc","Type":"NodeParagraph","Properties":{"id":"20260603085254-1k3vbrc","updated":"20260603085254"},"Children":[{"Type":"NodeText","Data":"请根据我提供的【作文题目/材料/原文】，创作或修改一篇符合高考满分标准（60分制）的优秀作文。"}]},{"ID":"20260603085254-y60tclj","Type":"NodeParagraph","Properties":{"id":"20260603085254-y60tclj","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【写作要求与指令】"}]}]},{"ID":"20260603085254-3qqptps","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260603085254-3qqptps","updated":"20260603085254"},"Children":[{"ID":"20260603085254-w9tez44","Type":"NodeParagraph","Properties":{"id":"20260603085254-w9tez44","updated":"20260603085254"},"Children":[{"Type":"NodeTextMark","T