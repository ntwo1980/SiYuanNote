2457"},"Children":[{"ID":"20260603112457-ix696s2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ix696s2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-motd4zv","Type":"NodeParagraph","Properties":{"id":"20260603112457-motd4zv","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分解论证（拉升与钻洞）"},{"Type":"NodeText","Data":"      ：证明分论点时，注意分论点间的层递关系。可采用“拉升式”（由底层肉身/物质体验升华到高层灵魂/生存层面）或“钻洞式”（由表层社会现象深入挖掘背后的文化基因或心理动因）。"}]}]},{"ID":"20260603112457-7bpjjy0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7bpjjy0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mxtvf11","Type":"NodeParagraph","Properties":{"id":"20260603112457-mxtvf11","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"举例论证（典型事例）"},{"Type":"NodeText","Data":"      ：选取古今中外典型人物或时事热点，通过具体故事来支撑论点，做到叙议结合，拒绝单纯堆砌素材。"}]}]},{"ID":"20260603112457-gz9tqwz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gz9tqwz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lqnyrty","Type":"NodeParagraph","Properties":{"id":"20260603112457-lqnyrty","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"归谬论证（反向推导）"},{"Type":"NodeText","Data":"      ：先提出与论点相反的假定，推导出荒谬或不可接受的后果，从而有力地反证原论点的正确性，增强说服力。"}]}]}]}]},{"ID":"20260603112457-78n83zo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-78n83zo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-peuiz0v","Type":"NodeParagraph","Properties":{"id":"20260603112457-peuiz0v","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"隐性植入辩证法"},{"Type":"NodeText","Data":"：将辩证法的三大规律(对立同一、量变质变、否定之否定)之一内化为文章的底层逻辑，但"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁直接出现"},{"Type":"NodeText","Data":"“对立统一”、“量变质变”、“否定之否定”等哲学术语。具体操作如下："}]},{"ID":"20260603112457-dx4rwgx","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-dx4rwgx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k29ryyr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k29ryyr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-exiie59","Type":"NodeParagraph","Properties":{"id":"20260603112457-exiie59","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现矛盾转化"},{"Type":"NodeText","Data":"：分析事物内部的矛盾双方（如危与机、强与弱），阐述它们在特定条件下如何相互依存并向对立面转化。"}]}]},{"ID":"20260603112457-ymh9o93","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ymh9o93","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m16s499","Type":"NodeParagraph","Properties":{"id":"20260603112457-m16s499","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现积累与飞跃"},{"Type":"NodeText","Data":"：论述从微小的积累到质的突破的过程，强调厚积薄发的重要性。"}]}]},{"ID":"20260603112457-9ajle3e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9ajle3e","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kql6q3h","Type":"NodeParagraph","Properties":{"id":"20260603112457-kql6q3h","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现螺旋上升"},{"Type":"NodeText","Data":"：展现事物发展不是简单的循环，而是看似回归原点实则境界提升的曲折前进过程。"}]}]}]}]},{"ID":"20260603112457-zdp7qxs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zdp7qxs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ij1ro8e","Type":"NodeParagraph","Properties":{"id":"20260603112457-ij1ro8e","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辅助论式拓展"},{"Type":"NodeText","Data":"：可适当穿插使用道理/引证论证、类比论证或反证法，丰富文章的论证维度。在进行深层逻辑剖析时，可灵活调用以下思维模型，以增强文章的思辨厚度："}]},{"ID":"20260603112457-ou8sy6h","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-ou8sy6h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jpn6zp4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jpn6zp4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i6n233n","Type":"NodeParagraph","Properties":{"id":"20260603112457-i6n233n","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"社会与心理效应"},{"Type":"NodeText","Data":"：破窗效应、羊群效应、习得性无助、幸存者效应。"}]}]},{"ID":"20260603112457-gsvjxyl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gsvjxyl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6mw4v59","Type":"NodeParagraph","Properties":{"id":"20260603112457-6mw4v59","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"决策与管理智慧"},{"Type":"NodeText","Data":"：锚定效应、手表定律、鳄鱼法则（及时止损）、氨基酸组合效应（整体与部分）。"}]}]},{"ID":"20260603112457-tvrzg9x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tvrzg9x","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3afpr74","Type":"NodeParagraph","Properties":{"id":"20260603112457-3afpr74","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"哲学与科学原理"},{"Type":"NodeText","Data":"：熵增定律（对抗无序）、奥卡姆剃刀（化繁为简）、墨菲定律、波普尔证伪主义、贝叶斯原理（动态认知）、皮亚杰建构主义、黑格尔辩证法、实践论。"}]}]}]}]},{"ID":"20260603112457-uhklica","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uhklica","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bs2im5w","Type":"NodeParagraph","Properties":{"id":"20260603112457-bs2im5w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"使用要求：严禁直接罗列名词或进行枯燥的科学解释。必须将这些原理内化为比喻或隐喻，自然地融入论证中（例如：用“熵增”比喻精神的懈怠，用“鳄鱼法则”比喻壮士断腕的决心）。"}]}]},{"ID":"20260603112457-5rvgxdq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5rvgxdq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j2mxuwm","Type":"NodeParagraph","Properties":{"id":"20260603112457-j2mxuwm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"论据要充分且鲜活，拒绝陈词滥调（避免过度使用司马迁、李白、爱迪生等老套素材）。结合时事热点、历史文化等多维度素材。"}]}]}]}]},{"ID":"20260603112457-b9vxt7g","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260603112457-b9vxt7g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yjvr6kf","Type":"NodeParagraph","Properties":{"id":"20260603112457-yjvr6kf","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"古典底蕴与化用："}]},{"ID":"20260603112457-f0t5s53","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-f0t5s53","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ks71x2b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ks71x2b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dgxtrgc","Type":"NodeParagraph","Properties":{"id":"20260603112457-dgxtrgc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"至少自然嵌入2–3条下面提供的的典故、文章(不必引用原文，文章总结、提炼亦可)、诗词名句、电影，并保证与论证逻辑紧密相关。"}]},{"ID":"20260603112457-eh6y3gc","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-eh6y3gc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-upy69ni","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-upy69ni","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vd8dzay","Type":"NodeParagraph","Properties":{"id":"20260603112457-vd8dzay","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《尚书》五福：寿、福、康宁、攸好德、考终命"}]}]},{"ID":"20260603112457-rv0brb1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rv0brb1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xc4yb7q","Type":"NodeParagraph","Properties":{"id":"20260603112457-xc4yb7q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"鲁迅：无穷的远方，无数的人们，都与我相关。"}]}]},{"ID":"20260603112457-53g4qn5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-53g4qn5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tiebfvw","Type":"NodeParagraph","Properties":{"id":"20260603112457-tiebfvw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260603112457-da3utrf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-da3utrf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-smm5rcl","Type":"NodeParagraph","Properties":{"id":"20260603112457-smm5rcl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603112457-i6uk2om","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i6uk2om","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6ctve4i","Type":"NodeParagraph","Properties":{"id":"20260603112457-6ctve4i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260603112457-mjve1d3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mjve1d3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3h6bq8n","Type":"NodeParagraph","Properties":{"id":"20260603112457-3h6bq8n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260603112457-2brsap2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2brsap2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-knnofvn","Type":"NodeParagraph","Properties":{"id":"20260603112457-knnofvn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260603112457-uta5v57","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uta5v57","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dco1pv1","Type":"NodeParagraph","Properties":{"id":"20260603112457-dco1pv1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260603112457-nlksntt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nlksntt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4sivwy8","Type":"NodeParagraph","Properties":{"id":"20260603112457-4sivwy8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260603112457-wy4ccgr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wy4ccgr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-w3mmu5u","Type":"NodeParagraph","Properties":{"id":"20260603112457-w3mmu5u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260603112457-xr685vb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xr685vb","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5rfqkxo","Type":"NodeParagraph","Properties":{"id":"20260603112457-5rfqkxo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《美丽心灵》约翰·纳什"}]}]},{"ID":"20260603112457-l3zfsn8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l3zfsn8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-izbbdif","Type":"NodeParagraph","Properties":{"id":"20260603112457-izbbdif","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"西格里夫·萨松：心有猛虎，细嗅蔷薇。"}]}]},{"ID":"20260603112457-wq4hxm8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wq4hxm8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ig45yqp","Type":"NodeParagraph","Properties":{"id":"20260603112457-ig45yqp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260603112457-q803jwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q803jwm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0o0fwgw","Type":"NodeParagraph","Properties":{"id":"20260603112457-0o0fwgw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260603112457-o23jim8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o23jim8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a8x9q7h","Type":"NodeParagraph","Properties":{"id":"20260603112457-a8x9q7h","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260603112457-vt3yjim","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vt3yjim","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mlikgh6","Type":"NodeParagraph","Properties":{"id":"20260603112457-mlikgh6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海明威：一个人可以被毁灭， "},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"但不能被打败。"}]}]},{"ID":"20260603112457-f9i24qr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f9i24qr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u4q1z9r","Type":"NodeParagraph","Properties":{"id":"20260603112457-u4q1z9r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"杨绛：生活一半是柴米油盐，一半是星辰大海。"}]}]},{"ID":"20260603112457-2dai4or","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2dai4or","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qlmwkam","Type":"NodeParagraph","Properties":{"id":"20260603112457-qlmwkam","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰：世界上只有一种英雄主义，就是在认清生活的真相之后依然热爱生活。"}]}]},{"ID":"20260603112457-1aiupxj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1aiupxj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ytmtfht","Type":"NodeParagraph","Properties":{"id":"20260603112457-ytmtfht","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗素：参差多态乃是人类幸福的本源。"}]}]},{"ID":"20260603112457-cwhory4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cwhory4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pq4euq2","Type":"NodeParagraph","Properties":{"id":"20260603112457-pq4euq2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260603112457-iq6d9c5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iq6d9c5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s8kjj56","Type":"NodeParagraph","Properties":{"id":"20260603112457-s8kjj56","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260603112457-zfefuyr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zfefuyr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-790g02t","Type":"NodeParagraph","Properties":{"id":"20260603112457-790g02t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260603112457-7sr93ix","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7sr93ix","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l18rqxk","Type":"NodeParagraph","Properties":{"id":"20260603112457-l18rqxk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260603112457-erx9ngz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-erx9ngz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2tjuhnb","Type":"NodeParagraph","Properties":{"id":"20260603112457-2tjuhnb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260603112457-g0n0bf1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g0n0bf1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k8v07m8","Type":"NodeParagraph","Properties":{"id":"20260603112457-k8v07m8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260603112457-q9kyk5c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q9kyk5c","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3bxjtko","Type":"NodeParagraph","Properties":{"id":"20260603112457-3bxjtko","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260603112457-me2mk7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-me2mk7j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ve9svog","Type":"NodeParagraph","Properties":{"id":"20260603112457-ve9svog","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260603112457-54t6d9i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-54t6d9i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8eilhsv","Type":"NodeParagraph","Properties":{"id":"20260603112457-8eilhsv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260603112457-7coxynt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7coxynt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-komg2o7","Type":"NodeParagraph","Properties":{"id":"20260603112457-komg2o7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260603112457-iozbjb0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iozbjb0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7mgxkwd","Type":"NodeParagraph","Properties":{"id":"20260603112457-7mgxkwd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260603112457-m2a7cal","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m2a7cal","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zngljqo","Type":"NodeParagraph","Properties":{"id":"20260603112457-zngljqo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260603112457-bw1za7y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bw1za7y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mg36d3r","Type":"NodeParagraph","Properties":{"id":"20260603112457-mg36d3r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260603112457-4kzpnjs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4kzpnjs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l1cpqo4","Type":"NodeParagraph","Properties":{"id":"20260603112457-l1cpqo4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"特鲁多医生墓志铭：医生有时治愈，常常帮助，总是安慰。"}]}]},{"ID":"20260603112457-bo45n63","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bo45n63","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vdtk62c","Type":"NodeParagraph","Properties":{"id":"20260603112457-vdtk62c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260603112457-uir75s6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uir75s6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xk3y11u","Type":"NodeParagraph","Properties":{"id":"20260603112457-xk3y11u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260603112457-t7bapps","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t7bapps","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x3zmqm2","Type":"NodeParagraph","Properties":{"id":"20260603112457-x3zmqm2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260603112457-j1s5nf5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j1s5nf5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jajriz3","Type":"NodeParagraph","Properties":{"id":"20260603112457-jajriz3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260603112457-th739mf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-th739mf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fgm7o87","Type":"NodeParagraph","Properties":{"id":"20260603112457-fgm7o87","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260603112457-rufiwr9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rufiwr9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cdsjr1i","Type":"NodeParagraph","Properties":{"id":"20260603112457-cdsjr1i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260603112457-vz5art9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vz5art9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9xo9dzb","Type":"NodeParagraph","Properties":{"id":"20260603112457-9xo9dzb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260603112457-we10ej7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-we10ej7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jnylflc","Type":"NodeParagraph","Properties":{"id":"20260603112457-jnylflc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260603112457-r0bykjv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r0bykjv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9uled3g","Type":"NodeParagraph","Properties":{"id":"20260603112457-9uled3g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260603112457-uf0iwld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uf0iwld","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cn8edfq","Type":"NodeParagraph","Properties":{"id":"20260603112457-cn8edfq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260603112457-m623agi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m623agi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ef4aarj","Type":"NodeParagraph","Properties":{"id":"20260603112457-ef4aarj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260603112457-sqe2yvh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-sqe2yvh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tuw5k1t","Type":"NodeParagraph","Properties":{"id":"20260603112457-tuw5k1t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260603112457-69gufru","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-69gufru","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fy1edrv","Type":"NodeParagraph","Properties":{"id":"20260603112457-fy1edrv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260603112457-fljg28y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fljg28y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jmbt14k","Type":"NodeParagraph","Properties":{"id":"20260603112457-jmbt14k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260603112457-65c3t8o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-65c3t8o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kcbjh4j","Type":"NodeParagraph","Properties":{"id":"20260603112457-kcbjh4j","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260603112457-1he3rtg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1he3rtg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ggiib7p","Type":"NodeParagraph","Properties":{"id":"20260603112457-ggiib7p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260603112457-d4fi00s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-d4fi00s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rhrypw4","Type":"NodeParagraph","Properties":{"id":"20260603112457-rhrypw4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260603112457-5roue4j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5roue4j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lvbmbz8","Type":"NodeParagraph","Properties":{"id":"20260603112457-lvbmbz8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨果：在逆境中，把俯视墓穴的悲痛，转换为仰望星空的情感。"}]}]},{"ID":"20260603112457-q43323k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q43323k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ps5pkfa","Type":"NodeParagraph","Properties":{"id":"20260603112457-ps5pkfa","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260603112457-qfsr0za","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qfsr0za","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4jqgiol","Type":"NodeParagraph","Properties":{"id":"20260603112457-4jqgiol","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260603112457-4auafnk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4auafnk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-86qhk0u","Type":"NodeParagraph","Properties":{"id":"20260603112457-86qhk0u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260603112457-64oiu2o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-64oiu2o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vlnnb6t","Type":"NodeParagraph","Properties":{"id":"20260603112457-vlnnb6t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260603112457-dndbby8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dndbby8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zggg0av","Type":"NodeParagraph","Properties":{"id":"20260603112457-zggg0av","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260603112457-q8e6f9k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q8e6f9k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lfbr05m","Type":"NodeParagraph","Properties":{"id":"20260603112457-lfbr05m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260603112457-2ck0d7a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2ck0d7a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mh7emgo","Type":"NodeParagraph","Properties":{"id":"20260603112457-mh7emgo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260603112457-71v2qt3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-71v2qt3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2t1n0bu","Type":"NodeParagraph","Properties":{"id":"20260603112457-2t1n0bu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260603112457-fuo7blc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fuo7blc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xw87tve","Type":"NodeParagraph","Properties":{"id":"20260603112457-xw87tve","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260603112457-bdxmyor","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bdxmyor","updated":"20260603112457"},"Children":[{"ID":"20260603112457-au5cck8","Type":"NodeParagraph","Properties":{"id":"20260603112457-au5cck8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260603112457-s7l0glv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s7l0glv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-usx60lh","Type":"NodeParagraph","Properties":{"id":"20260603112457-usx60lh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260603112457-2ejjlz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2ejjlz2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-e71aona","Type":"NodeParagraph","Properties":{"id":"20260603112457-e71aona","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260603112457-ihg23sk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ihg23sk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ahp6f8q","Type":"NodeParagraph","Properties":{"id":"20260603112457-ahp6f8q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603112457-pdl0nmx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pdl0nmx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o52faos","Type":"NodeParagraph","Properties":{"id":"20260603112457-o52faos","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260603112457-6e3mifh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6e3mifh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6m4wek9","Type":"NodeParagraph","Properties":{"id":"20260603112457-6m4wek9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260603112457-t2yw71y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t2yw71y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pm7p1pd","Type":"NodeParagraph","Properties":{"id":"20260603112457-pm7p1pd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260603112457-bumbnhj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bumbnhj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zpmaz02","Type":"NodeParagraph","Properties":{"id":"20260603112457-zpmaz02","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260603112457-xpli638","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xpli638","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rqqnmog","Type":"NodeParagraph","Properties":{"id":"20260603112457-rqqnmog","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260603112457-b9vsh32","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-b9vsh32","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ip1dahk","Type":"NodeParagraph","Properties":{"id":"20260603112457-ip1dahk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260603112457-j8mi7w1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j8mi7w1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z506izb","Type":"NodeParagraph","Properties":{"id":"20260603112457-z506izb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260603112457-mlw3m3e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mlw3m3e","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6phgc87","Type":"NodeParagraph","Properties":{"id":"20260603112457-6phgc87","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260603112457-uu370v6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uu370v6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5afrtnz","Type":"NodeParagraph","Properties":{"id":"20260603112457-5afrtnz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260603112457-ry46yq8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ry46yq8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l87a0ul","Type":"NodeParagraph","Properties":{"id":"20260603112457-l87a0ul","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260603112457-oh1fgcy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oh1fgcy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a2t15xz","Type":"NodeParagraph","Properties":{"id":"20260603112457-a2t15xz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603112457-i0prd5y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i0prd5y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ung1q7c","Type":"NodeParagraph","Properties":{"id":"20260603112457-ung1q7c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260603112457-szws6b8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-szws6b8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7dg5snr","Type":"NodeParagraph","Properties":{"id":"20260603112457-7dg5snr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260603112457-futi57q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-futi57q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qbhwypv","Type":"NodeParagraph","Properties":{"id":"20260603112457-qbhwypv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603112457-4q9kwi5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4q9kwi5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2pii6b3","Type":"NodeParagraph","Properties":{"id":"20260603112457-2pii6b3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260603112457-9arg956","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9arg956","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lykwfut","Type":"NodeParagraph","Properties":{"id":"20260603112457-lykwfut","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260603112457-dpe2viw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dpe2viw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u9ib7ly","Type":"NodeParagraph","Properties":{"id":"20260603112457-u9ib7ly","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260603112457-ck7ijfj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ck7ijfj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5wlpzoy","Type":"NodeParagraph","Properties":{"id":"20260603112457-5wlpzoy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260603112457-txpmitw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-txpmitw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qi4c3g9","Type":"NodeParagraph","Properties":{"id":"20260603112457-qi4c3g9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260603112457-l4n7slk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l4n7slk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fc9wp7z","Type":"NodeParagraph","Properties":{"id":"20260603112457-fc9wp7z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260603112457-1ncheb2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1ncheb2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-et0q7a2","Type":"NodeParagraph","Properties":{"id":"20260603112457-et0q7a2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260603112457-5dsjjkf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5dsjjkf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-n69fkos","Type":"NodeParagraph","Properties":{"id":"20260603112457-n69fkos","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260603112457-rrzm98k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rrzm98k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xh4505n","Type":"NodeParagraph","Properties":{"id":"20260603112457-xh4505n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260603112457-qeugfbh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qeugfbh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vjoz0as","Type":"NodeParagraph","Properties":{"id":"20260603112457-vjoz0as","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260603112457-j6wk8v1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j6wk8v1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l68w5vt","Type":"NodeParagraph","Properties":{"id":"20260603112457-l68w5vt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260603112457-r1k7p7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r1k7p7j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qxhndxl","Type":"NodeParagraph","Properties":{"id":"20260603112457-qxhndxl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603112457-z43knrh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z43knrh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hn27crd","Type":"NodeParagraph","Properties":{"id":"20260603112457-hn27crd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260603112457-b606sb0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-b606sb0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o4va6is","Type":"NodeParagraph","Properties":{"id":"20260603112457-o4va6is","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260603112457-5fmt9fm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5fmt9fm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-57nfeqo","Type":"NodeParagraph","Properties":{"id":"20260603112457-57nfeqo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260603112457-o3pxn2o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o3pxn2o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9g98opv","Type":"NodeParagraph","Properties":{"id":"20260603112457-9g98opv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260603112457-uyzm9r0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uyzm9r0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dnv2r4d","Type":"NodeParagraph","Properties":{"id":"20260603112457-dnv2r4d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260603112457-0q85yvp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0q85yvp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-t0xgf7g","Type":"NodeParagraph","Properties":{"id":"20260603112457-t0xgf7g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260603112457-cu27bas","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cu27bas","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z9rpmc5","Type":"NodeParagraph","Properties":{"id":"20260603112457-z9rpmc5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260603112457-kz73s5w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kz73s5w","updated":"20260603112457"},"Children":[{"ID":"20260603112457-79cbukk","Type":"NodeParagraph","Properties":{"id":"20260603112457-79cbukk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260603112457-k071ans","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k071ans","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eybvfk1","Type":"NodeParagraph","Properties":{"id":"20260603112457-eybvfk1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260603112457-600eck5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-600eck5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5p9ssam","Type":"NodeParagraph","Properties":{"id":"20260603112457-5p9ssam","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260603112457-yha39g3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yha39g3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1djcm1w","Type":"NodeParagraph","Properties":{"id":"20260603112457-1djcm1w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260603112457-c3rwj12","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c3rwj12","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2nhoc0l","Type":"NodeParagraph","Properties":{"id":"20260603112457-2nhoc0l","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260603112457-s5pagyk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s5pagyk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z8ver81","Type":"NodeParagraph","Properties":{"id":"20260603112457-z8ver81","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260603112457-xlfw4f1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xlfw4f1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4wre75k","Type":"NodeParagraph","Properties":{"id":"20260603112457-4wre75k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260603112457-6mdgz6h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6mdgz6h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jpfx69s","Type":"NodeParagraph","Properties":{"id":"20260603112457-jpfx69s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260603112457-hmdzx3k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hmdzx3k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2mcwk4t","Type":"NodeParagraph","Properties":{"id":"20260603112457-2mcwk4t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260603112457-jpjfip0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jpjfip0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-at67ry0","Type":"NodeParagraph","Properties":{"id":"20260603112457-at67ry0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260603112457-u80lisu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u80lisu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-iz0yjmw","Type":"NodeParagraph","Properties":{"id":"20260603112457-iz0yjmw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260603112457-vuvwz0l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vuvwz0l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9bs5uts","Type":"NodeParagraph","Properties":{"id":"20260603112457-9bs5uts","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260603112457-hov7b1j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hov7b1j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y2h9tsu","Type":"NodeParagraph","Properties":{"id":"20260603112457-y2h9tsu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260603112457-ql9pcqk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ql9pcqk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wq49uym","Type":"NodeParagraph","Properties":{"id":"20260603112457-wq49uym","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260603112457-7l5s7cm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7l5s7cm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qhd38wh","Type":"NodeParagraph","Properties":{"id":"20260603112457-qhd38wh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260603112457-1mf2gid","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1mf2gid","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oi7kvwp","Type":"NodeParagraph","Properties":{"id":"20260603112457-oi7kvwp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260603112457-xardpn8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xardpn8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p0vfsc4","Type":"NodeParagraph","Properties":{"id":"20260603112457-p0vfsc4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260603112457-1xs7l2h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1xs7l2h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2ynjbh7","Type":"NodeParagraph","Properties":{"id":"20260603112457-2ynjbh7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260603112457-n205pzn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-n205pzn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zkoz5k4","Type":"NodeParagraph","Properties":{"id":"20260603112457-zkoz5k4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260603112457-lci0vjy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lci0vjy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cy8yheo","Type":"NodeParagraph","Properties":{"id":"20260603112457-cy8yheo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260603112457-53rko0r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-53rko0r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ohryk4a","Type":"NodeParagraph","Properties":{"id":"20260603112457-ohryk4a","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260603112457-hzruyzw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hzruyzw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vu4qc6l","Type":"NodeParagraph","Properties":{"id":"20260603112457-vu4qc6l","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260603112457-jlsrtkr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jlsrtkr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wpf6161","Type":"NodeParagraph","Properties":{"id":"20260603112457-wpf6161","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260603112457-mg0usgs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mg0usgs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o7xyis9","Type":"NodeParagraph","Properties":{"id":"20260603112457-o7xyis9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260603112457-ru15ftu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ru15ftu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-07wknjj","Type":"NodeParagraph","Properties":{"id":"20260603112457-07wknjj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260603112457-n5jnbur","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-n5jnbur","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4469xg0","Type":"NodeParagraph","Properties":{"id":"20260603112457-4469xg0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260603112457-jjqnabq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jjqnabq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4b9fgw8","Type":"NodeParagraph","Properties":{"id":"20260603112457-4b9fgw8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260603112457-367v4hg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-367v4hg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zkntxqb","Type":"NodeParagraph","Properties":{"id":"20260603112457-zkntxqb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260603112457-c01kpup","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c01kpup","updated":"20260603112457"},"Children":[{"ID":"20260603112457-f7mwp5q","Type":"NodeParagraph","Properties":{"id":"20260603112457-f7mwp5q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260603112457-1usgvxm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1usgvxm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ay74hz5","Type":"NodeParagraph","Properties":{"id":"20260603112457-ay74hz5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260603112457-bc19ld7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bc19ld7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qydnoad","Type":"NodeParagraph","Properties":{"id":"20260603112457-qydnoad","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260603112457-s5uhbs5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s5uhbs5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h1kxj0f","Type":"NodeParagraph","Properties":{"id":"20260603112457-h1kxj0f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260603112457-qc5br4d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qc5br4d","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g85c8wy","Type":"NodeParagraph","Properties":{"id":"20260603112457-g85c8wy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260603112457-j0hsg9w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j0hsg9w","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ylb8whd","Type":"NodeParagraph","Properties":{"id":"20260603112457-ylb8whd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260603112457-pnqvws1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pnqvws1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7jx6xwc","Type":"NodeParagraph","Properties":{"id":"20260603112457-7jx6xwc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260603112457-anvv7oz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-anvv7oz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-10dp9z8","Type":"NodeParagraph","Properties":{"id":"20260603112457-10dp9z8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260603112457-k47kenv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k47kenv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-um3civw","Type":"NodeParagraph","Properties":{"id":"20260603112457-um3civw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260603112457-2zr3t3w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2zr3t3w","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bqkqoum","Type":"NodeParagraph","Properties":{"id":"20260603112457-bqkqoum","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260603112457-hnzrhum","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hnzrhum","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oy9329t","Type":"NodeParagraph","Properties":{"id":"20260603112457-oy9329t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260603112457-poxuq0t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-poxuq0t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5y7dpb5","Type":"NodeParagraph","Properties":{"id":"20260603112457-5y7dpb5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"歌德：才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260603112457-zkrb042","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zkrb042","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gatkt0k","Type":"NodeParagraph","Properties":{"id":"20260603112457-gatkt0k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260603112457-ftsnn0r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ftsnn0r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gl0y85b","Type":"NodeParagraph","Properties":{"id":"20260603112457-gl0y85b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260603112457-xzht9a4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xzht9a4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hk8rd0s","Type":"NodeParagraph","Properties":{"id":"20260603112457-hk8rd0s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260603112457-wkdatec","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wkdatec","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yu8vdld","Type":"NodeParagraph","Properties":{"id":"20260603112457-yu8vdld","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260603112457-7u9iahd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7u9iahd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dlcqbx7","Type":"NodeParagraph","Properties":{"id":"20260603112457-dlcqbx7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260603112457-12hkjb0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-12hkjb0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b3hvtwp","Type":"NodeParagraph","Properties":{"id":"20260603112457-b3hvtwp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260603112457-ryifpfz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ryifpfz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k6l8jmf","Type":"NodeParagraph","Properties":{"id":"20260603112457-k6l8jmf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260603112457-8dxxx0s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8dxxx0s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z65iycd","Type":"NodeParagraph","Properties":{"id":"20260603112457-z65iycd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260603112457-kx0zbak","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kx0zbak","updated":"20260603112457"},"Children":[{"ID":"20260603112457-27c8r2m","Type":"NodeParagraph","Properties":{"id":"20260603112457-27c8r2m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260603112457-om2ckax","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-om2ckax","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gdzk3mx","Type":"NodeParagraph","Properties":{"id":"20260603112457-gdzk3mx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260603112457-inzrwzz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-inzrwzz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kevwsdr","Type":"NodeParagraph","Properties":{"id":"20260603112457-kevwsdr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260603112457-8v2iw94","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8v2iw94","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lfnlhd8","Type":"NodeParagraph","Properties":{"id":"20260603112457-lfnlhd8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260603112457-zbkvles","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zbkvles","updated":"20260603112457"},"Children":[{"ID":"20260603112457-47jnuft","Type":"NodeParagraph","Properties":{"id":"20260603112457-47jnuft","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260603112457-ttebh7q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ttebh7q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ldiipat","Type":"NodeParagraph","Properties":{"id":"20260603112457-ldiipat","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260603112457-dctu4fh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dctu4fh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gn7fusi","Type":"NodeParagraph","Properties":{"id":"20260603112457-gn7fusi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260603112457-qm0yxn0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qm0yxn0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-znfq7rw","Type":"NodeParagraph","Properties":{"id":"20260603112457-znfq7rw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260603112457-6z6ya41","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6z6ya41","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gdfyenn","Type":"NodeParagraph","Properties":{"id":"20260603112457-gdfyenn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260603112457-fjdsz3i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fjdsz3i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b0d6yi0","Type":"NodeParagraph","Properties":{"id":"20260603112457-b0d6yi0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260603112457-c0fta0y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c0fta0y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-trkd434","Type":"NodeParagraph","Properties":{"id":"20260603112457-trkd434","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260603112457-61fdg96","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-61fdg96","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gl86btl","Type":"NodeParagraph","Properties":{"id":"20260603112457-gl86btl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260603112457-9o5gpc8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9o5gpc8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mrcwdjh","Type":"NodeParagraph","Properties":{"id":"20260603112457-mrcwdjh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260603112457-5ek1y4b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5ek1y4b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kcikzhi","Type":"NodeParagraph","Properties":{"id":"20260603112457-kcikzhi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260603112457-vuqg5xw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vuqg5xw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a4xboj7","Type":"NodeParagraph","Properties":{"id":"20260603112457-a4xboj7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260603112457-m7p1t71","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m7p1t71","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y734zzc","Type":"NodeParagraph","Properties":{"id":"20260603112457-y734zzc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260603112457-fa5pfjy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fa5pfjy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4w1cngd","Type":"NodeParagraph","Properties":{"id":"20260603112457-4w1cngd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260603112457-e0tje9v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-e0tje9v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b3ptjtc","Type":"NodeParagraph","Properties":{"id":"20260603112457-b3ptjtc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260603112457-p54c220","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p54c220","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lfl6end","Type":"NodeParagraph","Properties":{"id":"20260603112457-lfl6end","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260603112457-wpxh645","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wpxh645","updated":"20260603112457"},"Children":[{"ID":"20260603112457-39qcaxm","Type":"NodeParagraph","Properties":{"id":"20260603112457-39qcaxm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260603112457-hlu4rdm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hlu4rdm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y746bbt","Type":"NodeParagraph","Properties":{"id":"20260603112457-y746bbt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260603112457-tzh4iwn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tzh4iwn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0ky87ut","Type":"NodeParagraph","Properties":{"id":"20260603112457-0ky87ut","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260603112457-dxwpdaw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dxwpdaw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6ji88b1","Type":"NodeParagraph","Properties":{"id":"20260603112457-6ji88b1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260603112457-o0ew04g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o0ew04g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rou7dt6","Type":"NodeParagraph","Properties":{"id":"20260603112457-rou7dt6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260603112457-ec5s3lq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ec5s3lq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tn5ewmv","Type":"NodeParagraph","Properties":{"id":"20260603112457-tn5ewmv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260603112457-2k96njf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2k96njf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-n5sjn0c","Type":"NodeParagraph","Properties":{"id":"20260603112457-n5sjn0c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260603112457-cbzxgji","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cbzxgji","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rwa6icl","Type":"NodeParagraph","Properties":{"id":"20260603112457-rwa6icl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260603112457-3thvkkd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3thvkkd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u7tr0yj","Type":"NodeParagraph","Properties":{"id":"20260603112457-u7tr0yj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260603112457-7c7i3zg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7c7i3zg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6mamhgb","Type":"NodeParagraph","Properties":{"id":"20260603112457-6mamhgb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260603112457-h95s53z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-h95s53z","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i30j0l5","Type":"NodeParagraph","Properties":{"id":"20260603112457-i30j0l5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260603112457-cywfiy1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cywfiy1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-30je8rs","Type":"NodeParagraph","Properties":{"id":"20260603112457-30je8rs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260603112457-py799ax","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-py799ax","updated":"20260603112457"},"Children":[{"ID":"20260603112457-34do58e","Type":"NodeParagraph","Properties":{"id":"20260603112457-34do58e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260603112457-8j65ain","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8j65ain","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8jjgrz6","Type":"NodeParagraph","Properties":{"id":"20260603112457-8jjgrz6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260603112457-4czaz5p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4czaz5p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ik4fwb5","Type":"NodeParagraph","Properties":{"id":"20260603112457-ik4fwb5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260603112457-pjtwls6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pjtwls6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bgcbrlj","Type":"NodeParagraph","Properties":{"id":"20260603112457-bgcbrlj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260603112457-2xma421","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2xma421","updated":"20260603112457"},"Children":[{"ID":"20260603112457-c0q6wh1","Type":"NodeParagraph","Properties":{"id":"20260603112457-c0q6wh1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260603112457-6exh91g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6exh91g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ccfqwww","Type":"NodeParagraph","Properties":{"id":"20260603112457-ccfqwww","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260603112457-5u7h5hj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5u7h5hj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-otqm5rv","Type":"NodeParagraph","Properties":{"id":"20260603112457-otqm5rv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260603112457-greefqh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-greefqh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xmhlaat","Type":"NodeParagraph","Properties":{"id":"20260603112457-xmhlaat","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260603112457-irjaela","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-irjaela","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k8wyh7q","Type":"NodeParagraph","Properties":{"id":"20260603112457-k8wyh7q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260603112457-1dipin4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1dipin4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yzlvbxd","Type":"NodeParagraph","Properties":{"id":"20260603112457-yzlvbxd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260603112457-pr21846","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pr21846","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kxtwlku","Type":"NodeParagraph","Properties":{"id":"20260603112457-kxtwlku","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260603112457-9p1oqcd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9p1oqcd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bizs351","Type":"NodeParagraph","Properties":{"id":"20260603112457-bizs351","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260603112457-xy9mtx4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xy9mtx4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sl2d648","Type":"NodeParagraph","Properties":{"id":"20260603112457-sl2d648","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260603112457-99kf7vh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-99kf7vh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nx0gg5g","Type":"NodeParagraph","Properties":{"id":"20260603112457-nx0gg5g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260603112457-iy40ws9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iy40ws9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yslq41x","Type":"NodeParagraph","Properties":{"id":"20260603112457-yslq41x","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260603112457-as5vkud","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-as5vkud","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5qcqqz8","Type":"NodeParagraph","Properties":{"id":"20260603112457-5qcqqz8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260603112457-qptr1tx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qptr1tx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jg68eo7","Type":"NodeParagraph","Properties":{"id":"20260603112457-jg68eo7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260603112457-pp2853h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pp2853h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nybv466","Type":"NodeParagraph","Properties":{"id":"20260603112457-nybv466","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260603112457-jbnsvly","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jbnsvly","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zg9p7i5","Type":"NodeParagraph","Properties":{"id":"20260603112457-zg9p7i5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260603112457-8okk7wk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8okk7wk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fxsp9xt","Type":"NodeParagraph","Properties":{"id":"20260603112457-fxsp9xt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260603112457-vl6ne8z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vl6ne8z","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9qceelx","Type":"NodeParagraph","Properties":{"id":"20260603112457-9qceelx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260603112457-4tnh9i3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4tnh9i3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ec2pbyp","Type":"NodeParagraph","Properties":{"id":"20260603112457-ec2pbyp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603112457-rdnyi48","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rdnyi48","updated":"20260603112457"},"Children":[{"ID":"20260603112457-devyvyf","Type":"NodeParagraph","Properties":{"id":"20260603112457-devyvyf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260603112457-rzwaxui","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rzwaxui","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vxo6vui","Type":"NodeParagraph","Properties":{"id":"20260603112457-vxo6vui","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260603112457-dtl3ebl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dtl3ebl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p2kuxpi","Type":"NodeParagraph","Properties":{"id":"20260603112457-p2kuxpi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260603112457-dylrlmo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dylrlmo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-osq1hj2","Type":"NodeParagraph","Properties":{"id":"20260603112457-osq1hj2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260603112457-v1z2wdj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v1z2wdj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0lhxop2","Type":"NodeParagraph","Properties":{"id":"20260603112457-0lhxop2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260603112457-lfi6v0f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lfi6v0f","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1yew5bt","Type":"NodeParagraph","Properties":{"id":"20260603112457-1yew5bt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260603112457-zv8u8ks","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zv8u8ks","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fbu0rwu","Type":"NodeParagraph","Properties":{"id":"20260603112457-fbu0rwu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260603112457-qjlu45e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qjlu45e","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ah0kzxo","Type":"NodeParagraph","Properties":{"id":"20260603112457-ah0kzxo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260603112457-vfggvn3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vfggvn3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cvqlg6e","Type":"NodeParagraph","Properties":{"id":"20260603112457-cvqlg6e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260603112457-eld2ymh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-eld2ymh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vc35cjk","Type":"NodeParagraph","Properties":{"id":"20260603112457-vc35cjk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260603112457-5nqroel","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5nqroel","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fyi36xq","Type":"NodeParagraph","Properties":{"id":"20260603112457-fyi36xq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260603112457-byq749o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-byq749o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jlg6tbe","Type":"NodeParagraph","Properties":{"id":"20260603112457-jlg6tbe","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260603112457-t4fewtf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t4fewtf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r2xswhv","Type":"NodeParagraph","Properties":{"id":"20260603112457-r2xswhv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260603112457-gvsiqnj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gvsiqnj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nrgo1kw","Type":"NodeParagraph","Properties":{"id":"20260603112457-nrgo1kw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260603112457-z2n2jr1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z2n2jr1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y9qhyg0","Type":"NodeParagraph","Properties":{"id":"20260603112457-y9qhyg0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260603112457-0frwh52","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0frwh52","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gyo9c1u","Type":"NodeParagraph","Properties":{"id":"20260603112457-gyo9c1u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260603112457-keoywhc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-keoywhc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nuxfrfz","Type":"NodeParagraph","Properties":{"id":"20260603112457-nuxfrfz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260603112457-plo75q0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-plo75q0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-urneqfc","Type":"NodeParagraph","Properties":{"id":"20260603112457-urneqfc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260603112457-j13gure","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j13gure","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j2iiwnh","Type":"NodeParagraph","Properties":{"id":"20260603112457-j2iiwnh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260603112457-ba6qmk2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ba6qmk2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kj7nfpf","Type":"NodeParagraph","Properties":{"id":"20260603112457-kj7nfpf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260603112457-l4ved9z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l4ved9z","updated":"20260603112457"},"Children":[{"ID":"20260603112457-etgeasq","Type":"NodeParagraph","Properties":{"id":"20260603112457-etgeasq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260603112457-ni05atc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ni05atc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vw6wbhd","Type":"NodeParagraph","Properties":{"id":"20260603112457-vw6wbhd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260603112457-k52vba6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k52vba6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mfnrjdc","Type":"NodeParagraph","Properties":{"id":"20260603112457-mfnrjdc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260603112457-34ra75x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-34ra75x","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z956ilz","Type":"NodeParagraph","Properties":{"id":"20260603112457-z956ilz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260603112457-682y86w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-682y86w","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xvq1tlx","Type":"NodeParagraph","Properties":{"id":"20260603112457-xvq1tlx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260603112457-6bghdq1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6bghdq1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-isszdt7","Type":"NodeParagraph","Properties":{"id":"20260603112457-isszdt7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260603112457-yv8zbs3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yv8zbs3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hp4ll44","Type":"NodeParagraph","Properties":{"id":"20260603112457-hp4ll44","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260603112457-85f8prw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-85f8prw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a288ms4","Type":"NodeParagraph","Properties":{"id":"20260603112457-a288ms4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260603112457-gog51e4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gog51e4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9f3j292","Type":"NodeParagraph","Properties":{"id":"20260603112457-9f3j292","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260603112457-1e97wao","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1e97wao","updated":"20260603112457"},"Children":[{"ID":"20260603112457-67559nk","Type":"NodeParagraph","Properties":{"id":"20260603112457-67559nk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260603112457-px13b2a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-px13b2a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pehktmp","Type":"NodeParagraph","Properties":{"id":"20260603112457-pehktmp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260603112457-6pd1m9y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6pd1m9y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lt4sjca","Type":"NodeParagraph","Properties":{"id":"20260603112457-lt4sjca","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260603112457-ielga8x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ielga8x","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g41ic55","Type":"NodeParagraph","Properties":{"id":"20260603112457-g41ic55","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260603112457-tshxj4k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tshxj4k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u5vqyw4","Type":"NodeParagraph","Properties":{"id":"20260603112457-u5vqyw4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260603112457-vukofiu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vukofiu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qctngcq","Type":"NodeParagraph","Properties":{"id":"20260603112457-qctngcq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260603112457-rudtzab","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rudtzab","updated":"20260603112457"},"Children":[{"ID":"20260603112457-57j2uta","Type":"NodeParagraph","Properties":{"id":"20260603112457-57j2uta","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260603112457-y56pxv6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y56pxv6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gjq9qpz","Type":"NodeParagraph","Properties":{"id":"20260603112457-gjq9qpz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260603112457-3a9noy1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3a9noy1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nizhsfb","Type":"NodeParagraph","Properties":{"id":"20260603112457-nizhsfb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260603112457-vfem71m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vfem71m","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4p3bbat","Type":"NodeParagraph","Properties":{"id":"20260603112457-4p3bbat","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260603112457-buvve8r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-buvve8r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mmrfe49","Type":"NodeParagraph","Properties":{"id":"20260603112457-mmrfe49","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260603112457-rk6g4ru","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rk6g4ru","updated":"20260603112457"},"Children":[{"ID":"20260603112457-939pjkw","Type":"NodeParagraph","Properties":{"id":"20260603112457-939pjkw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260603112457-3iog4nr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3iog4nr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vzib0v2","Type":"NodeParagraph","Properties":{"id":"20260603112457-vzib0v2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260603112457-9222try","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9222try","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uwbvu0t","Type":"NodeParagraph","Properties":{"id":"20260603112457-uwbvu0t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260603112457-zk4w4v9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zk4w4v9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-khllf80","Type":"NodeParagraph","Properties":{"id":"20260603112457-khllf80","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260603112457-qfzwzc6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qfzwzc6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s2pqzyl","Type":"NodeParagraph","Properties":{"id":"20260603112457-s2pqzyl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260603112457-4fvalk7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4fvalk7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d7w03or","Type":"NodeParagraph","Properties":{"id":"20260603112457-d7w03or","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260603112457-l6gcjgi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l6gcjgi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-t3ku6nq","Type":"NodeParagraph","Properties":{"id":"20260603112457-t3ku6nq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260603112457-mnkqx93","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mnkqx93","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0mgto6p","Type":"NodeParagraph","Properties":{"id":"20260603112457-0mgto6p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260603112457-br95lef","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-br95lef","updated":"20260603112457"},"Children":[{"ID":"20260603112457-juhfqnh","Type":"NodeParagraph","Properties":{"id":"20260603112457-juhfqnh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260603112457-1fapwz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1fapwz2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p9n9ost","Type":"NodeParagraph","Properties":{"id":"20260603112457-p9n9ost","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260603112457-7uwg9dv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7uwg9dv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r39ddcn","Type":"NodeParagraph","Properties":{"id":"20260603112457-r39ddcn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260603112457-stkdxob","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-stkdxob","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m26szth","Type":"NodeParagraph","Properties":{"id":"20260603112457-m26szth","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260603112457-aylbxqy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-aylbxqy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-e4l15ew","Type":"NodeParagraph","Properties":{"id":"20260603112457-e4l15ew","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260603112457-m9zxufc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m9zxufc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vr6kq4d","Type":"NodeParagraph","Properties":{"id":"20260603112457-vr6kq4d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260603112457-kq8fu4r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kq8fu4r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bapqc85","Type":"NodeParagraph","Properties":{"id":"20260603112457-bapqc85","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260603112457-78w1pkg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-78w1pkg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-c8vgbro","Type":"NodeParagraph","Properties":{"id":"20260603112457-c8vgbro","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260603112457-s1sorl7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s1sorl7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jq1fyc6","Type":"NodeParagraph","Properties":{"id":"20260603112457-jq1fyc6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260603112457-onua1ww","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-onua1ww","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kflhs7b","Type":"NodeParagraph","Properties":{"id":"20260603112457-kflhs7b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260603112457-6tg1itt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6tg1itt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v3ug12q","Type":"NodeParagraph","Properties":{"id":"20260603112457-v3ug12q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260603112457-0183zc1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0183zc1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x3tkdqc","Type":"NodeParagraph","Properties":{"id":"20260603112457-x3tkdqc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260603112457-tlnej2w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tlnej2w","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bsfe31r","Type":"NodeParagraph","Properties":{"id":"20260603112457-bsfe31r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260603112457-87smu8o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-87smu8o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5ctw8p5","Type":"NodeParagraph","Properties":{"id":"20260603112457-5ctw8p5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260603112457-0d0gedd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0d0gedd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g1tdkut","Type":"NodeParagraph","Properties":{"id":"20260603112457-g1tdkut","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260603112457-27xsxp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-27xsxp1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-34hcpfo","Type":"NodeParagraph","Properties":{"id":"20260603112457-34hcpfo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260603112457-8xo5l5p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8xo5l5p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rdqxb31","Type":"NodeParagraph","Properties":{"id":"20260603112457-rdqxb31","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260603112457-baofz7d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-baofz7d","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k3g05id","Type":"NodeParagraph","Properties":{"id":"20260603112457-k3g05id","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260603112457-k1wg3le","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k1wg3le","updated":"20260603112457"},"Children":[{"ID":"20260603112457-koqxzgv","Type":"NodeParagraph","Properties":{"id":"20260603112457-koqxzgv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260603112457-mpmggud","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mpmggud","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k060yr8","Type":"NodeParagraph","Properties":{"id":"20260603112457-k060yr8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260603112457-0gl582r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0gl582r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oo3gy6q","Type":"NodeParagraph","Properties":{"id":"20260603112457-oo3gy6q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260603112457-2eccife","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2eccife","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6b4r1ps","Type":"NodeParagraph","Properties":{"id":"20260603112457-6b4r1ps","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260603112457-axt99lz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-axt99lz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7p7em79","Type":"NodeParagraph","Properties":{"id":"20260603112457-7p7em79","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260603112457-wlwo0fu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wlwo0fu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xgxgd9x","Type":"NodeParagraph","Properties":{"id":"20260603112457-xgxgd9x","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260603112457-yx3e7s2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yx3e7s2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2wv7h6j","Type":"NodeParagraph","Properties":{"id":"20260603112457-2wv7h6j","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260603112457-5a4zwqe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5a4zwqe","updated":"20260603112457"},"Children":[{"ID":"20260603112457-th10d0f","Type":"NodeParagraph","Properties":{"id":"20260603112457-th10d0f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260603112457-gpl6tpt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gpl6tpt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gsk6d3d","Type":"NodeParagraph","Properties":{"id":"20260603112457-gsk6d3d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260603112457-6dkjtu1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6dkjtu1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0l1kbq7","Type":"NodeParagraph","Properties":{"id":"20260603112457-0l1kbq7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260603112457-u5q5825","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u5q5825","updated":"20260603112457"},"Children":[{"ID":"20260603112457-t1ttkdn","Type":"NodeParagraph","Properties":{"id":"20260603112457-t1ttkdn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260603112457-v7xp2hl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v7xp2hl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x9flanx","Type":"NodeParagraph","Properties":{"id":"20260603112457-x9flanx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260603112457-2g9wmwv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2g9wmwv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-stdb09s","Type":"NodeParagraph","Properties":{"id":"20260603112457-stdb09s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260603112457-1qte4rt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1qte4rt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kj3w7fs","Type":"NodeParagraph","Properties":{"id":"20260603112457-kj3w7fs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260603112457-yjfho36","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yjfho36","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dgehflo","Type":"NodeParagraph","Properties":{"id":"20260603112457-dgehflo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260603112457-sk92wnt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-sk92wnt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qag97ex","Type":"NodeParagraph","Properties":{"id":"20260603112457-qag97ex","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260603112457-8yzqs4r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8yzqs4r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l3fise6","Type":"NodeParagraph","Properties":{"id":"20260603112457-l3fise6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260603112457-jdk84bl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jdk84bl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7ymeb3o","Type":"NodeParagraph","Properties":{"id":"20260603112457-7ymeb3o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260603112457-f5txbmy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f5txbmy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b3v4noo","Type":"NodeParagraph","Properties":{"id":"20260603112457-b3v4noo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260603112457-ij1bpri","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ij1bpri","updated":"20260603112457"},"Children":[{"ID":"20260603112457-voo59s8","Type":"NodeParagraph","Properties":{"id":"20260603112457-voo59s8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260603112457-zukyq6m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zukyq6m","updated":"20260603112457"},"Children":[{"ID":"20260603112457-92yxkat","Type":"NodeParagraph","Properties":{"id":"20260603112457-92yxkat","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260603112457-5vy0jwk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5vy0jwk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5zijcp5","Type":"NodeParagraph","Properties":{"id":"20260603112457-5zijcp5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260603112457-ngxq422","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ngxq422","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4mpuwo1","Type":"NodeParagraph","Properties":{"id":"20260603112457-4mpuwo1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260603112457-z30ylhz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z30ylhz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1odslrm","Type":"NodeParagraph","Properties":{"id":"20260603112457-1odslrm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260603112457-4bb6bai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4bb6bai","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3tuh70t","Type":"NodeParagraph","Properties":{"id":"20260603112457-3tuh70t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260603112457-0qnvm1k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0qnvm1k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-msghdl1","Type":"NodeParagraph","Properties":{"id":"20260603112457-msghdl1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260603112457-b503zle","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-b503zle","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fe22apv","Type":"NodeParagraph","Properties":{"id":"20260603112457-fe22apv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260603112457-jbmpdlh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jbmpdlh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vh7twos","Type":"NodeParagraph","Properties":{"id":"20260603112457-vh7twos","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260603112457-y87cum2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y87cum2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3jkjpaa","Type":"NodeParagraph","Properties":{"id":"20260603112457-3jkjpaa","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260603112457-yndh06i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yndh06i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0h7r3yp","Type":"NodeParagraph","Properties":{"id":"20260603112457-0h7r3yp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260603112457-7wz2p8a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7wz2p8a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eb4r3sg","Type":"NodeParagraph","Properties":{"id":"20260603112457-eb4r3sg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603112457-naul9bi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-naul9bi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kd63xr2","Type":"NodeParagraph","Properties":{"id":"20260603112457-kd63xr2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260603112457-hej2tbc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hej2tbc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kzsmxnl","Type":"NodeParagraph","Properties":{"id":"20260603112457-kzsmxnl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260603112457-yqpxo8h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yqpxo8h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zr1m4v9","Type":"NodeParagraph","Properties":{"id":"20260603112457-zr1m4v9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260603112457-qfp03xg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qfp03xg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b7l7vd4","Type":"NodeParagraph","Properties":{"id":"20260603112457-b7l7vd4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260603112457-tlpd63j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tlpd63j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-w9xzq1h","Type":"NodeParagraph","Properties":{"id":"20260603112457-w9xzq1h","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260603112457-j9535z5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j9535z5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hkjj98o","Type":"NodeParagraph","Properties":{"id":"20260603112457-hkjj98o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260603112457-22rtn10","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-22rtn10","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vy8ihoj","Type":"NodeParagraph","Properties":{"id":"20260603112457-vy8ihoj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260603112457-q80w5h4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q80w5h4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eoxlo8l","Type":"NodeParagraph","Properties":{"id":"20260603112457-eoxlo8l","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260603112457-e7ge73f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-e7ge73f","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8xcrnrk","Type":"NodeParagraph","Properties":{"id":"20260603112457-8xcrnrk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260603112457-y5y7p57","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y5y7p57","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hdbgjw8","Type":"NodeParagraph","Properties":{"id":"20260603112457-hdbgjw8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260603112457-mk55yw0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mk55yw0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-us4eusd","Type":"NodeParagraph","Properties":{"id":"20260603112457-us4eusd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260603112457-99cvlqa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-99cvlqa","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jdmzk1d","Type":"NodeParagraph","Properties":{"id":"20260603112457-jdmzk1d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260603112457-iyvpleu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iyvpleu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k7wy5wp","Type":"NodeParagraph","Properties":{"id":"20260603112457-k7wy5wp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260603112457-d1uj3cs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-d1uj3cs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9tlsjcy","Type":"NodeParagraph","Properties":{"id":"20260603112457-9tlsjcy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260603112457-q11ru4j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q11ru4j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ynuj4fi","Type":"NodeParagraph","Properties":{"id":"20260603112457-ynuj4fi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260603112457-bh8g3ez","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bh8g3ez","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b7k0bob","Type":"NodeParagraph","Properties":{"id":"20260603112457-b7k0bob","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260603112457-fen4n45","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fen4n45","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rkcg8k5","Type":"NodeParagraph","Properties":{"id":"20260603112457-rkcg8k5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260603112457-sc0hwhg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-sc0hwhg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ejuil6s","Type":"NodeParagraph","Properties":{"id":"20260603112457-ejuil6s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260603112457-1gha2up","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1gha2up","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2q18ca0","Type":"NodeParagraph","Properties":{"id":"20260603112457-2q18ca0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260603112457-v4j5wwp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v4j5wwp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s4fz0jh","Type":"NodeParagraph","Properties":{"id":"20260603112457-s4fz0jh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603112457-t9ap29b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t9ap29b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z4xog0b","Type":"NodeParagraph","Properties":{"id":"20260603112457-z4xog0b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260603112457-5xlu9gx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5xlu9gx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v2tfn2m","Type":"NodeParagraph","Properties":{"id":"20260603112457-v2tfn2m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260603112457-ppwwbn5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ppwwbn5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l4wsq5j","Type":"NodeParagraph","Properties":{"id":"20260603112457-l4wsq5j","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260603112457-gojc78u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gojc78u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rr4b2bz","Type":"NodeParagraph","Properties":{"id":"20260603112457-rr4b2bz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260603112457-itled2r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-itled2r","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kw208a4","Type":"NodeParagraph","Properties":{"id":"20260603112457-kw208a4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260603112457-mdq86fx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mdq86fx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h6myr9d","Type":"NodeParagraph","Properties":{"id":"20260603112457-h6myr9d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260603112457-rlwi8fz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rlwi8fz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sicjchc","Type":"NodeParagraph","Properties":{"id":"20260603112457-sicjchc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260603112457-xdwfgc3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xdwfgc3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lcnramo","Type":"NodeParagraph","Properties":{"id":"20260603112457-lcnramo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260603112457-jnx6286","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jnx6286","updated":"20260603112457"},"Children":[{"ID":"20260603112457-230dk25","Type":"NodeParagraph","Properties":{"id":"20260603112457-230dk25","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260603112457-6h2yhta","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6h2yhta","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m43uboe","Type":"NodeParagraph","Properties":{"id":"20260603112457-m43uboe","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260603112457-028n5vq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-028n5vq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jhy5z9r","Type":"NodeParagraph","Properties":{"id":"20260603112457-jhy5z9r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260603112457-tqbciws","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tqbciws","updated":"20260603112457"},"Children":[{"ID":"20260603112457-q5jeur8","Type":"NodeParagraph","Properties":{"id":"20260603112457-q5jeur8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260603112457-ckboff8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ckboff8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5eu8qah","Type":"NodeParagraph","Properties":{"id":"20260603112457-5eu8qah","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260603112457-bsyh2ip","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bsyh2ip","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dj1w3j9","Type":"NodeParagraph","Properties":{"id":"20260603112457-dj1w3j9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260603112457-085mcgj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-085mcgj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-va8q19t","Type":"NodeParagraph","Properties":{"id":"20260603112457-va8q19t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260603112457-kcygqxd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kcygqxd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x8h8u8m","Type":"NodeParagraph","Properties":{"id":"20260603112457-x8h8u8m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260603112457-5rxj3ef","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5rxj3ef","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tjxw61m","Type":"NodeParagraph","Properties":{"id":"20260603112457-tjxw61m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260603112457-94gga7g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-94gga7g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mh2oynp","Type":"NodeParagraph","Properties":{"id":"20260603112457-mh2oynp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260603112457-7sa7u0g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7sa7u0g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1wklq7w","Type":"NodeParagraph","Properties":{"id":"20260603112457-1wklq7w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260603112457-46gb28i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-46gb28i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yc0mg9v","Type":"NodeParagraph","Properties":{"id":"20260603112457-yc0mg9v","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260603112457-klimfuw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-klimfuw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0iwpr0d","Type":"NodeParagraph","Properties":{"id":"20260603112457-0iwpr0d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260603112457-o9ds5pl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o9ds5pl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v97mc03","Type":"NodeParagraph","Properties":{"id":"20260603112457-v97mc03","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260603112457-hhsg8qw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hhsg8qw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3zwrhf2","Type":"NodeParagraph","Properties":{"id":"20260603112457-3zwrhf2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260603112457-y8ajouf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y8ajouf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-t0eaaiy","Type":"NodeParagraph","Properties":{"id":"20260603112457-t0eaaiy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260603112457-xe5d3ck","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xe5d3ck","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d0mykan","Type":"NodeParagraph","Properties":{"id":"20260603112457-d0mykan","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260603112457-pt7kuk7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pt7kuk7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h4p0cdf","Type":"NodeParagraph","Properties":{"id":"20260603112457-h4p0cdf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260603112457-o3yn2by","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o3yn2by","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6a140jr","Type":"NodeParagraph","Properties":{"id":"20260603112457-6a140jr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260603112457-eo8g9ge","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-eo8g9ge","updated":"20260603112457"},"Children":[{"ID":"20260603112457-04bopsd","Type":"NodeParagraph","Properties":{"id":"20260603112457-04bopsd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260603112457-5cmq8ce","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5cmq8ce","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h0j8001","Type":"NodeParagraph","Properties":{"id":"20260603112457-h0j8001","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260603112457-luu75vc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-luu75vc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u3nvduv","Type":"NodeParagraph","Properties":{"id":"20260603112457-u3nvduv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260603112457-melnno7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-melnno7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ohf72dg","Type":"NodeParagraph","Properties":{"id":"20260603112457-ohf72dg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260603112457-0afnflx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0afnflx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4uvd03h","Type":"NodeParagraph","Properties":{"id":"20260603112457-4uvd03h","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260603112457-k8y37k5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k8y37k5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-scbs2m9","Type":"NodeParagraph","Properties":{"id":"20260603112457-scbs2m9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260603112457-e0561in","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-e0561in","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6694zdl","Type":"NodeParagraph","Properties":{"id":"20260603112457-6694zdl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260603112457-5dzrjwz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5dzrjwz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7a1t3fl","Type":"NodeParagraph","Properties":{"id":"20260603112457-7a1t3fl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260603112457-a0s26ew","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-a0s26ew","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eq7prb0","Type":"NodeParagraph","Properties":{"id":"20260603112457-eq7prb0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260603112457-fytsg9v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fytsg9v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-un0pnwj","Type":"NodeParagraph","Properties":{"id":"20260603112457-un0pnwj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260603112457-dn4a6kv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dn4a6kv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yhpqrpu","Type":"NodeParagraph","Properties":{"id":"20260603112457-yhpqrpu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260603112457-m0iye4u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m0iye4u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mrkchwj","Type":"NodeParagraph","Properties":{"id":"20260603112457-mrkchwj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260603112457-vsjb79e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vsjb79e","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a243fy7","Type":"NodeParagraph","Properties":{"id":"20260603112457-a243fy7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260603112457-5w06y2o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5w06y2o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-snmcn59","Type":"NodeParagraph","Properties":{"id":"20260603112457-snmcn59","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260603112457-ck32bc9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ck32bc9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8rgsue6","Type":"NodeParagraph","Properties":{"id":"20260603112457-8rgsue6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260603112457-9swufku","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9swufku","updated":"20260603112457"},"Children":[{"ID":"20260603112457-spr8ba6","Type":"NodeParagraph","Properties":{"id":"20260603112457-spr8ba6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260603112457-di8ah97","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-di8ah97","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r367tw2","Type":"NodeParagraph","Properties":{"id":"20260603112457-r367tw2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260603112457-y9p45b0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y9p45b0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r3q7bfp","Type":"NodeParagraph","Properties":{"id":"20260603112457-r3q7bfp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260603112457-2bgjfgu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2bgjfgu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-09tgq04","Type":"NodeParagraph","Properties":{"id":"20260603112457-09tgq04","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260603112457-e9v8cy1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-e9v8cy1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lvxv3a4","Type":"NodeParagraph","Properties":{"id":"20260603112457-lvxv3a4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260603112457-72pdu0s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-72pdu0s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ovg7705","Type":"NodeParagraph","Properties":{"id":"20260603112457-ovg7705","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260603112457-64v13lr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-64v13lr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qluttfn","Type":"NodeParagraph","Properties":{"id":"20260603112457-qluttfn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260603112457-j7jlo0z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j7jlo0z","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d4vrhtx","Type":"NodeParagraph","Properties":{"id":"20260603112457-d4vrhtx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260603112457-fdplvfi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fdplvfi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ud4q9np","Type":"NodeParagraph","Properties":{"id":"20260603112457-ud4q9np","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260603112457-ccxhzdd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ccxhzdd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rtsttmq","Type":"NodeParagraph","Properties":{"id":"20260603112457-rtsttmq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260603112457-0ogs079","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0ogs079","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jrj1ghx","Type":"NodeParagraph","Properties":{"id":"20260603112457-jrj1ghx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260603112457-rm0no1v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rm0no1v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nfakfb2","Type":"NodeParagraph","Properties":{"id":"20260603112457-nfakfb2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260603112457-3zz8fl3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3zz8fl3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z2u38a0","Type":"NodeParagraph","Properties":{"id":"20260603112457-z2u38a0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260603112457-d8c0s30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-d8c0s30","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8vwu5gv","Type":"NodeParagraph","Properties":{"id":"20260603112457-8vwu5gv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260603112457-z9wtm32","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z9wtm32","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b4c4hiu","Type":"NodeParagraph","Properties":{"id":"20260603112457-b4c4hiu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260603112457-bz0t4t3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bz0t4t3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-q6m02h8","Type":"NodeParagraph","Properties":{"id":"20260603112457-q6m02h8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260603112457-s2q3uds","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s2q3uds","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dw30819","Type":"NodeParagraph","Properties":{"id":"20260603112457-dw30819","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260603112457-qpa9l4e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qpa9l4e","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j18njtd","Type":"NodeParagraph","Properties":{"id":"20260603112457-j18njtd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260603112457-66fsev2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-66fsev2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vh4cbs1","Type":"NodeParagraph","Properties":{"id":"20260603112457-vh4cbs1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260603112457-v2loir8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v2loir8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9mgjolm","Type":"NodeParagraph","Properties":{"id":"20260603112457-9mgjolm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260603112457-pigutjh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pigutjh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2sepvk6","Type":"NodeParagraph","Properties":{"id":"20260603112457-2sepvk6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260603112457-qa9pa1i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qa9pa1i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rkoc2kc","Type":"NodeParagraph","Properties":{"id":"20260603112457-rkoc2kc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260603112457-2crcnpl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2crcnpl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8t5gc3n","Type":"NodeParagraph","Properties":{"id":"20260603112457-8t5gc3n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260603112457-7a5jr9l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7a5jr9l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ksa8gos","Type":"NodeParagraph","Properties":{"id":"20260603112457-ksa8gos","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260603112457-3hnfa9v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3hnfa9v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u2kmc2x","Type":"NodeParagraph","Properties":{"id":"20260603112457-u2kmc2x","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260603112457-5omrw0j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5omrw0j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eumqsq7","Type":"NodeParagraph","Properties":{"id":"20260603112457-eumqsq7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260603112457-u3e9708","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u3e9708","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cwropjd","Type":"NodeParagraph","Properties":{"id":"20260603112457-cwropjd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260603112457-hig2bkd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hig2bkd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-waa92ft","Type":"NodeParagraph","Properties":{"id":"20260603112457-waa92ft","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260603112457-vhprm59","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vhprm59","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v7gxa5w","Type":"NodeParagraph","Properties":{"id":"20260603112457-v7gxa5w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260603112457-0bacwu5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0bacwu5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-w2skqaj","Type":"NodeParagraph","Properties":{"id":"20260603112457-w2skqaj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260603112457-pt1cxbf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pt1cxbf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vgo2ef9","Type":"NodeParagraph","Properties":{"id":"20260603112457-vgo2ef9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260603112457-ncdzqdd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ncdzqdd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-my9nczf","Type":"NodeParagraph","Properties":{"id":"20260603112457-my9nczf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260603112457-0mnphz9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0mnphz9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-111o39n","Type":"NodeParagraph","Properties":{"id":"20260603112457-111o39n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260603112457-l36l2e6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l36l2e6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d4emx43","Type":"NodeParagraph","Properties":{"id":"20260603112457-d4emx43","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260603112457-i0jmjxm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i0jmjxm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g3zspqt","Type":"NodeParagraph","Properties":{"id":"20260603112457-g3zspqt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260603112457-iwm0l3u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iwm0l3u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wwkak52","Type":"NodeParagraph","Properties":{"id":"20260603112457-wwkak52","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260603112457-edarohi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-edarohi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m7fby95","Type":"NodeParagraph","Properties":{"id":"20260603112457-m7fby95","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260603112457-6sbazlg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6sbazlg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fbhfikt","Type":"NodeParagraph","Properties":{"id":"20260603112457-fbhfikt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260603112457-ctxku91","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ctxku91","updated":"20260603112457"},"Children":[{"ID":"20260603112457-09pby2j","Type":"NodeParagraph","Properties":{"id":"20260603112457-09pby2j","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260603112457-0qxop12","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0qxop12","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cy2tkbj","Type":"NodeParagraph","Properties":{"id":"20260603112457-cy2tkbj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260603112457-r4ivnvs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r4ivnvs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2u7laes","Type":"NodeParagraph","Properties":{"id":"20260603112457-2u7laes","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260603112457-ck3y0ai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ck3y0ai","updated":"20260603112457"},"Children":[{"ID":"20260603112457-taoy7kf","Type":"NodeParagraph","Properties":{"id":"20260603112457-taoy7kf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260603112457-8ii6ln1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8ii6ln1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0hlc8t0","Type":"NodeParagraph","Properties":{"id":"20260603112457-0hlc8t0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260603112457-1po8rzc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1po8rzc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dafct9y","Type":"NodeParagraph","Properties":{"id":"20260603112457-dafct9y","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260603112457-xys0a0s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xys0a0s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-907hf6f","Type":"NodeParagraph","Properties":{"id":"20260603112457-907hf6f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260603112457-6zn1kwu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6zn1kwu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uzgkb0g","Type":"NodeParagraph","Properties":{"id":"20260603112457-uzgkb0g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260603112457-bsirswv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bsirswv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dppja48","Type":"NodeParagraph","Properties":{"id":"20260603112457-dppja48","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260603112457-2z6frlw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2z6frlw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xwl1y56","Type":"NodeParagraph","Properties":{"id":"20260603112457-xwl1y56","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260603112457-1evgjmw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1evgjmw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2ukajcd","Type":"NodeParagraph","Properties":{"id":"20260603112457-2ukajcd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260603112457-ctklhkc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ctklhkc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cyhhqoa","Type":"NodeParagraph","Properties":{"id":"20260603112457-cyhhqoa","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260603112457-71c8byn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-71c8byn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0j8ki9b","Type":"NodeParagraph","Properties":{"id":"20260603112457-0j8ki9b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260603112457-poee597","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-poee597","updated":"20260603112457"},"Children":[{"ID":"20260603112457-irdabl2","Type":"NodeParagraph","Properties":{"id":"20260603112457-irdabl2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260603112457-zuj3lse","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zuj3lse","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1dd70p4","Type":"NodeParagraph","Properties":{"id":"20260603112457-1dd70p4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260603112457-n557i0p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-n557i0p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-homxta5","Type":"NodeParagraph","Properties":{"id":"20260603112457-homxta5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260603112457-ko7tlkc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ko7tlkc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jqnf7rg","Type":"NodeParagraph","Properties":{"id":"20260603112457-jqnf7rg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260603112457-rfl5ax8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rfl5ax8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-17sg6xl","Type":"NodeParagraph","Properties":{"id":"20260603112457-17sg6xl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260603112457-87iwj7o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-87iwj7o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tm84y5x","Type":"NodeParagraph","Properties":{"id":"20260603112457-tm84y5x","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺。"}]}]},{"ID":"20260603112457-701xdw1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-701xdw1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gv0ciwb","Type":"NodeParagraph","Properties":{"id":"20260603112457-gv0ciwb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260603112457-jadcdy6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jadcdy6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0pptnmn","Type":"NodeParagraph","Properties":{"id":"20260603112457-0pptnmn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260603112457-lujgjuj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lujgjuj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-095pvok","Type":"NodeParagraph","Properties":{"id":"20260603112457-095pvok","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260603112457-uh5suw0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uh5suw0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ei9au4m","Type":"NodeParagraph","Properties":{"id":"20260603112457-ei9au4m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260603112457-pl0gtov","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pl0gtov","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bwi85wu","Type":"NodeParagraph","Properties":{"id":"20260603112457-bwi85wu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260603112457-ex5xymk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ex5xymk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cmzmwvf","Type":"NodeParagraph","Properties":{"id":"20260603112457-cmzmwvf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260603112457-kenlx47","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kenlx47","updated":"20260603112457"},"Children":[{"ID":"20260603112457-keh0y6z","Type":"NodeParagraph","Properties":{"id":"20260603112457-keh0y6z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260603112457-c5v65qa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c5v65qa","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k696twg","Type":"NodeParagraph","Properties":{"id":"20260603112457-k696twg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]},{"ID":"20260603112457-jg0tuf8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jg0tuf8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zc9e9kt","Type":"NodeParagraph","Properties":{"id":"20260603112457-zc9e9kt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260603112457-l0chns0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l0chns0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tmszboj","Type":"NodeParagraph","Properties":{"id":"20260603112457-tmszboj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260603112457-enn7oao","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-enn7oao","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yo322pm","Type":"NodeParagraph","Properties":{"id":"20260603112457-yo322pm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260603112457-005w1yp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-005w1yp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0288veq","Type":"NodeParagraph","Properties":{"id":"20260603112457-0288veq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260603112457-lxve76f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lxve76f","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o4z3724","Type":"NodeParagraph","Properties":{"id":"20260603112457-o4z3724","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260603112457-0me9n76","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0me9n76","updated":"20260603112457"},"Children":[{"ID":"20260603112457-14brivf","Type":"NodeParagraph","Properties":{"id":"20260603112457-14brivf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260603112457-pgw65ko","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pgw65ko","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tvsekzy","Type":"NodeParagraph","Properties":{"id":"20260603112457-tvsekzy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260603112457-0q6s79p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0q6s79p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uytlhct","Type":"NodeParagraph","Properties":{"id":"20260603112457-uytlhct","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260603112457-bwyooo7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bwyooo7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p25yxan","Type":"NodeParagraph","Properties":{"id":"20260603112457-p25yxan","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260603112457-jahm3vf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jahm3vf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9xoamka","Type":"NodeParagraph","Properties":{"id":"20260603112457-9xoamka","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260603112457-q6ol1oz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q6ol1oz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7lofkj5","Type":"NodeParagraph","Properties":{"id":"20260603112457-7lofkj5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260603112457-r5h2nvu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r5h2nvu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hf7opjv","Type":"NodeParagraph","Properties":{"id":"20260603112457-hf7opjv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260603112457-g3av6dr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g3av6dr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2syoyyg","Type":"NodeParagraph","Properties":{"id":"20260603112457-2syoyyg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260603112457-wnpdidl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wnpdidl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s8scvp0","Type":"NodeParagraph","Properties":{"id":"20260603112457-s8scvp0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260603112457-h2ridvi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-h2ridvi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-utg7li8","Type":"NodeParagraph","Properties":{"id":"20260603112457-utg7li8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260603112457-asgj3f7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-asgj3f7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7560yls","Type":"NodeParagraph","Properties":{"id":"20260603112457-7560yls","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260603112457-rgp6nru","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rgp6nru","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rdfexyo","Type":"NodeParagraph","Properties":{"id":"20260603112457-rdfexyo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260603112457-cq0ztbj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cq0ztbj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9qcrulw","Type":"NodeParagraph","Properties":{"id":"20260603112457-9qcrulw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260603112457-53cav2a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-53cav2a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j3v347n","Type":"NodeParagraph","Properties":{"id":"20260603112457-j3v347n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260603112457-wg104sx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wg104sx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-491o8zt","Type":"NodeParagraph","Properties":{"id":"20260603112457-491o8zt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260603112457-24nz7y5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-24nz7y5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-psiv9jp","Type":"NodeParagraph","Properties":{"id":"20260603112457-psiv9jp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260603112457-v78xq0v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v78xq0v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3ul5v32","Type":"NodeParagraph","Properties":{"id":"20260603112457-3ul5v32","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603112457-of06kpl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-of06kpl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k82bvum","Type":"NodeParagraph","Properties":{"id":"20260603112457-k82bvum","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260603112457-qu8kupr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qu8kupr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-owh4jm4","Type":"NodeParagraph","Properties":{"id":"20260603112457-owh4jm4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603112457-nw8qh7o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nw8qh7o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gx9qxfq","Type":"NodeParagraph","Properties":{"id":"20260603112457-gx9qxfq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260603112457-cykk5tm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cykk5tm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2ethlc3","Type":"NodeParagraph","Properties":{"id":"20260603112457-2ethlc3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260603112457-1t17tp7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1t17tp7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4f7na3p","Type":"NodeParagraph","Properties":{"id":"20260603112457-4f7na3p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"韩愈 《庄子与惠子游于濠梁之上》"}]}]},{"ID":"20260603112457-jp6d1wz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jp6d1wz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-om0oo7g","Type":"NodeParagraph","Properties":{"id":"20260603112457-om0oo7g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260603112457-5wg42a9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5wg42a9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3qnkkaq","Type":"NodeParagraph","Properties":{"id":"20260603112457-3qnkkaq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260603112457-g6gcg3b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g6gcg3b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3ofztip","Type":"NodeParagraph","Properties":{"id":"20260603112457-3ofztip","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260603112457-nj4ir9q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nj4ir9q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ni7idnx","Type":"NodeParagraph","Properties":{"id":"20260603112457-ni7idnx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260603112457-b8q1gng","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-b8q1gng","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zfj5em9","Type":"NodeParagraph","Properties":{"id":"20260603112457-zfj5em9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260603112457-q8kacwj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q8kacwj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qgw0rf8","Type":"NodeParagraph","Properties":{"id":"20260603112457-qgw0rf8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260603112457-rndnlno","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rndnlno","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gzq6ndt","Type":"NodeParagraph","Properties":{"id":"20260603112457-gzq6ndt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260603112457-0fbjoff","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0fbjoff","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ysnblin","Type":"NodeParagraph","Properties":{"id":"20260603112457-ysnblin","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260603112457-8sipzuu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8sipzuu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ygtu6d5","Type":"NodeParagraph","Properties":{"id":"20260603112457-ygtu6d5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260603112457-hhhq6n9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hhhq6n9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vh6ahbs","Type":"NodeParagraph","Properties":{"id":"20260603112457-vh6ahbs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260603112457-ayy5qnz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ayy5qnz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dk9oca2","Type":"NodeParagraph","Properties":{"id":"20260603112457-dk9oca2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260603112457-9zfqn7q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9zfqn7q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ed8x96n","Type":"NodeParagraph","Properties":{"id":"20260603112457-ed8x96n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260603112457-jwr4es4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jwr4es4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dpies60","Type":"NodeParagraph","Properties":{"id":"20260603112457-dpies60","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260603112457-6yw3gdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6yw3gdt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-349x33c","Type":"NodeParagraph","Properties":{"id":"20260603112457-349x33c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260603112457-q1v4npw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q1v4npw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4yiufxl","Type":"NodeParagraph","Properties":{"id":"20260603112457-4yiufxl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260603112457-nlo68vq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nlo68vq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kyuzrb0","Type":"NodeParagraph","Properties":{"id":"20260603112457-kyuzrb0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260603112457-0tb5wzh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0tb5wzh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3m8ua13","Type":"NodeParagraph","Properties":{"id":"20260603112457-3m8ua13","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260603112457-xorof57","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xorof57","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xbt0c5d","Type":"NodeParagraph","Properties":{"id":"20260603112457-xbt0c5d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260603112457-0pe5xtv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0pe5xtv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uuzsj06","Type":"NodeParagraph","Properties":{"id":"20260603112457-uuzsj06","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260603112457-tb678kj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tb678kj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lrcd4wd","Type":"NodeParagraph","Properties":{"id":"20260603112457-lrcd4wd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260603112457-oulfdo0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oulfdo0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2zneadq","Type":"NodeParagraph","Properties":{"id":"20260603112457-2zneadq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260603112457-39vc13n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-39vc13n","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rb4z5mq","Type":"NodeParagraph","Properties":{"id":"20260603112457-rb4z5mq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260603112457-dyqwl96","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dyqwl96","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7kw04l2","Type":"NodeParagraph","Properties":{"id":"20260603112457-7kw04l2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260603112457-629d2lc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-629d2lc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-n28kb63","Type":"NodeParagraph","Properties":{"id":"20260603112457-n28kb63","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260603112457-h5wwhtr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-h5wwhtr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0ivonk2","Type":"NodeParagraph","Properties":{"id":"20260603112457-0ivonk2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260603112457-opce464","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-opce464","updated":"20260603112457"},"Children":[{"ID":"20260603112457-70dia2o","Type":"NodeParagraph","Properties":{"id":"20260603112457-70dia2o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]}]}]},{"ID":"20260603112457-473837g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-473837g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-97jwrqg","Type":"NodeParagraph","Properties":{"id":"20260603112457-97jwrqg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。名言与典故必须作为论据服务于论点，不得为了展示库存而强行插入。"}]}]}]}]},{"ID":"20260603112457-zfl5d71","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260603112457-zfl5d71","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z0fzrom","Type":"NodeParagraph","Properties":{"id":"20260603112457-z0fzrom","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：请严格控制在850字左右，结尾必须留有2-3句极具力量的金句进行收束，不得草率。"}]}]},{"ID":"20260603112457-wlfqq6c","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OS4=","Num":9},"Properties":{"id":"20260603112457-wlfqq6c","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v538r5h","Type":"NodeParagraph","Properties":{"id":"20260603112457-v538r5h","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260603112457-e8s7eoy","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-e8s7eoy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0ubyd12","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0ubyd12","updated":"20260603112457"},"Children":[{"ID":"20260603