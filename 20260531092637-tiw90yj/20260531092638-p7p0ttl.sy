"},"Children":[{"ID":"20260601165036-5qcf98s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5qcf98s","updated":"20260601165036"},"Children":[{"ID":"20260601165036-t5btqnr","Type":"NodeParagraph","Properties":{"id":"20260601165036-t5btqnr","updated":"20260601165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分解论证（拉升与钻洞）"},{"Type":"NodeText","Data":"  ：证明分论点时，注意分论点间的层递关系。可采用“拉升式”（由底层肉身/物质体验升华到高层灵魂/生存层面）或“钻洞式”（由表层社会现象深入挖掘背后的文化基因或心理动因）。"}]}]},{"ID":"20260601165036-mv0kfiw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-mv0kfiw","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8jz24tz","Type":"NodeParagraph","Properties":{"id":"20260601165036-8jz24tz","updated":"20260601165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"举例论证（典型事例）"},{"Type":"NodeText","Data":"  ：选取古今中外典型人物或时事热点，通过具体故事来支撑论点，做到叙议结合，拒绝单纯堆砌素材。"}]}]},{"ID":"20260601165036-s9qpmds","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-s9qpmds","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5gzc2z5","Type":"NodeParagraph","Properties":{"id":"20260601165036-5gzc2z5","updated":"20260601165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"归谬论证（反向推导）"},{"Type":"NodeText","Data":"  ：先提出与论点相反的假定，推导出荒谬或不可接受的后果，从而有力地反证原论点的正确性，增强说服力。"}]}]}]}]},{"ID":"20260601165036-qkf54pj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-qkf54pj","updated":"20260601165036"},"Children":[{"ID":"20260601165036-go724qa","Type":"NodeParagraph","Properties":{"id":"20260601165036-go724qa","updated":"20260601165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辅助论式拓展"},{"Type":"NodeText","Data":"：可适当穿插使用道理/引证论证（引用经典著作、名人警句）、类比论证（通过相似事物比较类推）或反证法，丰富文章的论证维度。