01165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现螺旋上升"},{"Type":"NodeText","Data":"：展现事物发展不是简单的循环，而是看似回归原点实则境界提升的曲折前进过程。"}]}]}]}]},{"ID":"20260601165036-rtpklk6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rtpklk6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-p9lp2fp","Type":"NodeParagraph","Properties":{"id":"20260601165036-p9lp2fp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"论据要充分且鲜活，拒绝陈词滥调（避免过度使用司马迁、李白、爱迪生等老套素材）。结合时事热点、历史文化等多维度素材。"}]}]}]}]},{"ID":"20260601165036-1i1oj09","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ni4=","Num":6},"Properties":{"id":"20260601165036-1i1oj09","updated":"20260602171432"},"Children":[{"ID":"20260601165036-49ugydy","Type":"NodeParagraph","Properties":{"id":"20260601165036-49ugydy","updated":"20260601165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"古典底蕴与化用："}]},{"ID":"20260601165036-xsty1ir","Type":"NodeList","ListData":{},"Properties":{"id":"20260601165036-xsty1ir","updated":"20260602171432"},"Children":[{"ID":"20260601165036-q39if5a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-q39if5a","updated":"20260602171432"},"Children":[{"ID":"20260601165036-ke58qob","Type":"NodeParagraph","Properties":{"id":"20260601165036-ke58qob","updated":"20260602164137"},"Children":[{"Type":"NodeText","Data":"至少自然嵌入2–3条下面提供的的典故、文章(不必引用原文，文章总结、提炼亦可)、诗词名句、电影，并保证与论证逻辑紧密相关。"}]},{"ID":"20260601165036-2lzbzs4","Type":"NodeList","ListData":{},"Properties":{"id":"20260601165036-2lzbzs4","updated":"20260602171432"},"Children":[{"ID":"20260601165036-emxql76","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-emxql76","updated":"20260601165036"},"Children":[{"ID":"20260601165036-djupuec","Type":"NodeParagraph","Properties":{"id":"20260601165036-djupuec","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"《尚书》五福：寿、福、康宁、攸好德、考终命"}]}]},{"ID":"20260601165036-6a3xd41","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6a3xd41","updated":"20260601165036"},"Children":[{"ID":"20260601165036-hj7ukcq","Type":"NodeParagraph","Properties":{"id":"20260601165036-hj7ukcq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"鲁迅：无穷的远方，无数的人们，都与我相关。"}]}]},{"ID":"20260601165036-mr1yip9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-mr1yip9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ltx4sfz","Type":"NodeParagraph","Properties":{"id":"20260601165036-ltx4sfz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260601165036-pftlcoo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-pftlcoo","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jg0odk4","Type":"NodeParagraph","Properties":{"id":"20260601165036-jg0odk4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260601165036-zvhwbj9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zvhwbj9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-28u8t3h","Type":"NodeParagraph","Properties":{"id":"20260601165036-28u8t3h","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260602083926-ptbn7mf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602083926-ptbn7mf","updated":"20260602083926"},"Children":[{"ID":"20260602083926-w84b8fe","Type":"NodeParagraph","Properties":{"id":"20260602083926-w84b8fe","updated":"20260602083927"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260601165036-a41ukvw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-a41ukvw","updated":"20260601165036"},"Children":[{"ID":"20260601165036-chdolso","Type":"NodeParagraph","Properties":{"id":"20260601165036-chdolso","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260601165036-u3al36h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u3al36h","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1ry6914","Type":"NodeParagraph","Properties":{"id":"20260601165036-1ry6914","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260601165036-bcangsb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-bcangsb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-290nx0m","Type":"NodeParagraph","Properties":{"id":"20260601165036-290nx0m","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260601165036-p1m5wbr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-p1m5wbr","updated":"20260601165036"},"Children":[{"ID":"20260601165036-t42lzh7","Type":"NodeParagraph","Properties":{"id":"20260601165036-t42lzh7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260601165542-aa0l6d6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165542-aa0l6d6","updated":"20260601165542"},"Children":[{"ID":"20260601165542-8hau5gt","Type":"NodeParagraph","Properties":{"id":"20260601165542-8hau5gt","updated":"20260601165602"},"Children":[{"Type":"NodeText","Data":"《美丽心灵》约翰·纳什"}]}]},{"ID":"20260601165756-yzw127e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165756-yzw127e","updated":"20260601165756"},"Children":[{"ID":"20260601165756-rflwf9g","Type":"NodeParagraph","Properties":{"id":"20260601165756-rflwf9g","updated":"20260601165844"},"Children":[{"Type":"NodeText","Data":"西格里夫·萨松：心有猛虎，细嗅蔷薇。"}]}]},{"ID":"20260601165036-g7255y2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-g7255y2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2auuosu","Type":"NodeParagraph","Properties":{"id":"20260601165036-2auuosu","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260601165036-tul691v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tul691v","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3ar1meq","Type":"NodeParagraph","Properties":{"id":"20260601165036-3ar1meq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260601165036-4kndznc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4kndznc","updated":"20260601165036"},"Children":[{"ID":"20260601165036-q4njgvz","Type":"NodeParagraph","Properties":{"id":"20260601165036-q4njgvz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260601170025-av7s2e6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601170025-av7s2e6","updated":"20260601170025"},"Children":[{"ID":"20260601170025-4pmyjx6","Type":"NodeParagraph","Properties":{"id":"20260601170025-4pmyjx6","updated":"20260601170031"},"Children":[{"Type":"NodeText","Data":"海明威：一个人可以被毁灭， "},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"但不能被打败。"}]}]},{"ID":"20260601165950-opamjes","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165950-opamjes","updated":"20260601165950"},"Children":[{"ID":"20260601165950-xm99epi","Type":"NodeParagraph","Properties":{"id":"20260601165950-xm99epi","updated":"20260601170000"},"Children":[{"Type":"NodeText","Data":"杨绛：生活一半是柴米油盐，一半是星辰大海。"}]}]},{"ID":"20260601165500-5urn9wp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165500-5urn9wp","updated":"20260601165500"},"Children":[{"ID":"20260601165500-7a1wn29","Type":"NodeParagraph","Properties":{"id":"20260601165500-7a1wn29","updated":"20260601165505"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰：世界上只有一种英雄主义，就是在认清生活的真相之后依然热爱生活。"}]}]},{"ID":"20260601165429-wyoxvms","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165429-wyoxvms","updated":"20260601165429"},"Children":[{"ID":"20260601165429-snv2202","Type":"NodeParagraph","Properties":{"id":"20260601165429-snv2202","updated":"20260601165442"},"Children":[{"Type":"NodeText","Data":"罗素：参差多态乃是人类幸福的本源。"}]}]},{"ID":"20260601165036-jste0w7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jste0w7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-srhpzf0","Type":"NodeParagraph","Properties":{"id":"20260601165036-srhpzf0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260601165036-yjedonx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-yjedonx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-yycxhfy","Type":"NodeParagraph","Properties":{"id":"20260601165036-yycxhfy","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260601165036-tzxwre4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tzxwre4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4kpdl5j","Type":"NodeParagraph","Properties":{"id":"20260601165036-4kpdl5j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260601165036-9ujpb80","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9ujpb80","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tjw0ofr","Type":"NodeParagraph","Properties":{"id":"20260601165036-tjw0ofr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260601165036-m38kjmi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-m38kjmi","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bu31bkl","Type":"NodeParagraph","Properties":{"id":"20260601165036-bu31bkl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260601165036-x8suj3c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-x8suj3c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6axp4y0","Type":"NodeParagraph","Properties":{"id":"20260601165036-6axp4y0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260601165036-11uj4ct","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-11uj4ct","updated":"20260601165036"},"Children":[{"ID":"20260601165036-d4gschl","Type":"NodeParagraph","Properties":{"id":"20260601165036-d4gschl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260601165036-ya0w0q2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ya0w0q2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pt7u81m","Type":"NodeParagraph","Properties":{"id":"20260601165036-pt7u81m","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260601165036-t04oxxr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t04oxxr","updated":"20260601165036"},"Children":[{"ID":"20260601165036-93pg4ta","Type":"NodeParagraph","Properties":{"id":"20260601165036-93pg4ta","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260601165036-9uvllk4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9uvllk4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-eqlrucz","Type":"NodeParagraph","Properties":{"id":"20260601165036-eqlrucz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260601165036-t4gah1v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t4gah1v","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7vzzrcg","Type":"NodeParagraph","Properties":{"id":"20260601165036-7vzzrcg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260601165036-yt24nd4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-yt24nd4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-c2mhdmx","Type":"NodeParagraph","Properties":{"id":"20260601165036-c2mhdmx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260601165036-82f2zqq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-82f2zqq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-b2fx5i6","Type":"NodeParagraph","Properties":{"id":"20260601165036-b2fx5i6","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260601170325-gmqg0xi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601170325-gmqg0xi","updated":"20260601170413"},"Children":[{"ID":"20260601170325-3zcb4rs","Type":"NodeParagraph","Properties":{"id":"20260601170325-3zcb4rs","updated":"20260601170413"},"Children":[{"Type":"NodeText","Data":"特鲁多医生墓志铭：医生有时治愈，常常帮助，总是安慰。"}]}]},{"ID":"20260601165036-3mrxl9t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3mrxl9t","updated":"20260601165036"},"Children":[{"ID":"20260601165036-a084qsk","Type":"NodeParagraph","Properties":{"id":"20260601165036-a084qsk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260601165036-tnxlq7c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tnxlq7c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-fm3wagd","Type":"NodeParagraph","Properties":{"id":"20260601165036-fm3wagd","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260601165036-if6og5j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-if6og5j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-uyj0sv4","Type":"NodeParagraph","Properties":{"id":"20260601165036-uyj0sv4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260601165036-oin9i0r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-oin9i0r","updated":"20260601165036"},"Children":[{"ID":"20260601165036-wbqf2jb","Type":"NodeParagraph","Properties":{"id":"20260601165036-wbqf2jb","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260601165036-07l5sus","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-07l5sus","updated":"20260601165036"},"Children":[{"ID":"20260601165036-k85p39x","Type":"NodeParagraph","Properties":{"id":"20260601165036-k85p39x","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260601165036-84c9cci","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-84c9cci","updated":"20260601165036"},"Children":[{"ID":"20260601165036-d4dz0u4","Type":"NodeParagraph","Properties":{"id":"20260601165036-d4dz0u4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260601165036-h6yi4t1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-h6yi4t1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8o2g41f","Type":"NodeParagraph","Properties":{"id":"20260601165036-8o2g41f","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260601165036-d5al0x1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-d5al0x1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8fmqnhj","Type":"NodeParagraph","Properties":{"id":"20260601165036-8fmqnhj","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260601165036-s8csx00","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-s8csx00","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5x713kg","Type":"NodeParagraph","Properties":{"id":"20260601165036-5x713kg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260601165036-odl1vfn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-odl1vfn","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7j1x7n0","Type":"NodeParagraph","Properties":{"id":"20260601165036-7j1x7n0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260601165036-h30vnx6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-h30vnx6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-00ycdyy","Type":"NodeParagraph","Properties":{"id":"20260601165036-00ycdyy","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260601165036-9oafntx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9oafntx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ejsdxxq","Type":"NodeParagraph","Properties":{"id":"20260601165036-ejsdxxq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260601165036-za82k2u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-za82k2u","updated":"20260601165036"},"Children":[{"ID":"20260601165036-x4p5pk9","Type":"NodeParagraph","Properties":{"id":"20260601165036-x4p5pk9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260601165036-r66zmka","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-r66zmka","updated":"20260601165036"},"Children":[{"ID":"20260601165036-62mtz4n","Type":"NodeParagraph","Properties":{"id":"20260601165036-62mtz4n","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260601165036-w9avug8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-w9avug8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8sc5tky","Type":"NodeParagraph","Properties":{"id":"20260601165036-8sc5tky","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260601165036-7s52he2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7s52he2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-s8marsi","Type":"NodeParagraph","Properties":{"id":"20260601165036-s8marsi","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260601165036-1hz9ff2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1hz9ff2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-itpcmzw","Type":"NodeParagraph","Properties":{"id":"20260601165036-itpcmzw","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260601165036-czv1en2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-czv1en2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-o19rox1","Type":"NodeParagraph","Properties":{"id":"20260601165036-o19rox1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260601165036-edtlwsd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-edtlwsd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qp3hzd3","Type":"NodeParagraph","Properties":{"id":"20260601165036-qp3hzd3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260601165036-wyznvju","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wyznvju","updated":"20260601165036"},"Children":[{"ID":"20260601165036-854jcro","Type":"NodeParagraph","Properties":{"id":"20260601165036-854jcro","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260601165036-wkyvueq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wkyvueq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-eebfk6t","Type":"NodeParagraph","Properties":{"id":"20260601165036-eebfk6t","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260601165036-zm25aw8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zm25aw8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-v0x9zrl","Type":"NodeParagraph","Properties":{"id":"20260601165036-v0x9zrl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260601165036-1e86nxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1e86nxh","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4wpcu71","Type":"NodeParagraph","Properties":{"id":"20260601165036-4wpcu71","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260601165036-m73q7zj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-m73q7zj","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xgigwk1","Type":"NodeParagraph","Properties":{"id":"20260601165036-xgigwk1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260601165036-x6g8x7d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-x6g8x7d","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vepalz0","Type":"NodeParagraph","Properties":{"id":"20260601165036-vepalz0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260601165036-9td48r6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9td48r6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-po0xxmh","Type":"NodeParagraph","Properties":{"id":"20260601165036-po0xxmh","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260601165036-wk0onew","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wk0onew","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vbqz95w","Type":"NodeParagraph","Properties":{"id":"20260601165036-vbqz95w","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260601165036-dbo0qfq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dbo0qfq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-e3xmjy3","Type":"NodeParagraph","Properties":{"id":"20260601165036-e3xmjy3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260601165036-s6gc42c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-s6gc42c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nxuzkb3","Type":"NodeParagraph","Properties":{"id":"20260601165036-nxuzkb3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260601165036-tf6k9f5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tf6k9f5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kvinxwx","Type":"NodeParagraph","Properties":{"id":"20260601165036-kvinxwx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260601165036-xltg7a3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-xltg7a3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-o95ocgp","Type":"NodeParagraph","Properties":{"id":"20260601165036-o95ocgp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260601165036-nz75h4e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nz75h4e","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7aerf8s","Type":"NodeParagraph","Properties":{"id":"20260601165036-7aerf8s","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260601165036-4jqvvpg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4jqvvpg","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lnbjnvd","Type":"NodeParagraph","Properties":{"id":"20260601165036-lnbjnvd","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260601165036-wubxrx9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wubxrx9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-f8jifv7","Type":"NodeParagraph","Properties":{"id":"20260601165036-f8jifv7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260601165036-9d7egtz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9d7egtz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-s0e6rbl","Type":"NodeParagraph","Properties":{"id":"20260601165036-s0e6rbl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260601165036-o8kuk3r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-o8kuk3r","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6rzkzzk","Type":"NodeParagraph","Properties":{"id":"20260601165036-6rzkzzk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260601165036-x1wnvz7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-x1wnvz7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0ss3b4b","Type":"NodeParagraph","Properties":{"id":"20260601165036-0ss3b4b","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260601165036-hdnypcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-hdnypcq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-u58pelk","Type":"NodeParagraph","Properties":{"id":"20260601165036-u58pelk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260601165036-o3ec7o0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-o3ec7o0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tmgq785","Type":"NodeParagraph","Properties":{"id":"20260601165036-tmgq785","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260601165036-tvjwnsc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tvjwnsc","updated":"20260601165036"},"Children":[{"ID":"20260601165036-srnsv5n","Type":"NodeParagraph","Properties":{"id":"20260601165036-srnsv5n","updated":"20260602084316"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260601165036-gljcj4m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gljcj4m","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xx111jx","Type":"NodeParagraph","Properties":{"id":"20260601165036-xx111jx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260601165036-srccexv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-srccexv","updated":"20260601165036"},"Children":[{"ID":"20260601165036-cjp4u81","Type":"NodeParagraph","Properties":{"id":"20260601165036-cjp4u81","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260601165036-86bgvhd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-86bgvhd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-29mrday","Type":"NodeParagraph","Properties":{"id":"20260601165036-29mrday","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260601165036-eenkev3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-eenkev3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bsqqpce","Type":"NodeParagraph","Properties":{"id":"20260601165036-bsqqpce","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260601165036-fhbfkf0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-fhbfkf0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-eaa667u","Type":"NodeParagraph","Properties":{"id":"20260601165036-eaa667u","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260601165036-i7is8hf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-i7is8hf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-adopw1v","Type":"NodeParagraph","Properties":{"id":"20260601165036-adopw1v","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260601165036-89swnds","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-89swnds","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6h4e1ip","Type":"NodeParagraph","Properties":{"id":"20260601165036-6h4e1ip","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260601165036-2b6g689","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-2b6g689","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dcwxcz6","Type":"NodeParagraph","Properties":{"id":"20260601165036-dcwxcz6","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260601165036-dtzan8m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dtzan8m","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5jr2ols","Type":"NodeParagraph","Properties":{"id":"20260601165036-5jr2ols","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260601165036-raat65z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-raat65z","updated":"20260601165036"},"Children":[{"ID":"20260601165036-br2adbb","Type":"NodeParagraph","Properties":{"id":"20260601165036-br2adbb","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260601165036-p0dbnla","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-p0dbnla","updated":"20260601165036"},"Children":[{"ID":"20260601165036-255r8ne","Type":"NodeParagraph","Properties":{"id":"20260601165036-255r8ne","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260601165036-82j35u5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-82j35u5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-p3tnoy0","Type":"NodeParagraph","Properties":{"id":"20260601165036-p3tnoy0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260601165036-de0119c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-de0119c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0ibvrye","Type":"NodeParagraph","Properties":{"id":"20260601165036-0ibvrye","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260601165036-3a0j2ee","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3a0j2ee","updated":"20260601165036"},"Children":[{"ID":"20260601165036-22pq4r8","Type":"NodeParagraph","Properties":{"id":"20260601165036-22pq4r8","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260601165036-ehxxhmk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ehxxhmk","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0inniub","Type":"NodeParagraph","Properties":{"id":"20260601165036-0inniub","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260601165036-6d1w94s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6d1w94s","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zx2xk8h","Type":"NodeParagraph","Properties":{"id":"20260601165036-zx2xk8h","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260601165036-tk5ds1u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tk5ds1u","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sav8t19","Type":"NodeParagraph","Properties":{"id":"20260601165036-sav8t19","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260601165036-rba56vq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rba56vq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pc792z4","Type":"NodeParagraph","Properties":{"id":"20260601165036-pc792z4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260601165036-hy6s1h0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-hy6s1h0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lh27tau","Type":"NodeParagraph","Properties":{"id":"20260601165036-lh27tau","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260601165036-4u0309h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4u0309h","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pbqwcua","Type":"NodeParagraph","Properties":{"id":"20260601165036-pbqwcua","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260601165036-gv60ec0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gv60ec0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-v09zdv0","Type":"NodeParagraph","Properties":{"id":"20260601165036-v09zdv0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260601165036-5ap4dny","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5ap4dny","updated":"20260601165036"},"Children":[{"ID":"20260601165036-io7wq9n","Type":"NodeParagraph","Properties":{"id":"20260601165036-io7wq9n","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260601165036-85gjnxs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-85gjnxs","updated":"20260601165036"},"Children":[{"ID":"20260601165036-w2jnruf","Type":"NodeParagraph","Properties":{"id":"20260601165036-w2jnruf","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260601165036-j61ynvq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j61ynvq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vapsg74","Type":"NodeParagraph","Properties":{"id":"20260601165036-vapsg74","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260601165036-lvy1tg0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lvy1tg0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xx85y6l","Type":"NodeParagraph","Properties":{"id":"20260601165036-xx85y6l","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260601165036-9h99c3f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9h99c3f","updated":"20260601165036"},"Children":[{"ID":"20260601165036-c9trf4j","Type":"NodeParagraph","Properties":{"id":"20260601165036-c9trf4j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260601165036-u8sibbw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u8sibbw","updated":"20260601165036"},"Children":[{"ID":"20260601165036-b8mdqvr","Type":"NodeParagraph","Properties":{"id":"20260601165036-b8mdqvr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260601165036-gaiapnf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gaiapnf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sv8pz19","Type":"NodeParagraph","Properties":{"id":"20260601165036-sv8pz19","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260601165036-wf6nwjr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wf6nwjr","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3vnn3bn","Type":"NodeParagraph","Properties":{"id":"20260601165036-3vnn3bn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260601165036-ad0btm7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ad0btm7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9iq4kd5","Type":"NodeParagraph","Properties":{"id":"20260601165036-9iq4kd5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260601165036-k4tr5z7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-k4tr5z7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-gw4flnk","Type":"NodeParagraph","Properties":{"id":"20260601165036-gw4flnk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260601165036-7t4dfoz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7t4dfoz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-gw2avmk","Type":"NodeParagraph","Properties":{"id":"20260601165036-gw2avmk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260601165036-mu45frz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-mu45frz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2tyhi45","Type":"NodeParagraph","Properties":{"id":"20260601165036-2tyhi45","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260601165036-cvs65z4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-cvs65z4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-fnxgl9y","Type":"NodeParagraph","Properties":{"id":"20260601165036-fnxgl9y","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260601165036-i2f8cbb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-i2f8cbb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ij7e1vl","Type":"NodeParagraph","Properties":{"id":"20260601165036-ij7e1vl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260601165036-7o99snt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7o99snt","updated":"20260601165036"},"Children":[{"ID":"20260601165036-viztdjr","Type":"NodeParagraph","Properties":{"id":"20260601165036-viztdjr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260601165036-n5zgbdf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-n5zgbdf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-86k3bsi","Type":"NodeParagraph","Properties":{"id":"20260601165036-86k3bsi","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260601165036-aymq6h7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-aymq6h7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dr6aj7j","Type":"NodeParagraph","Properties":{"id":"20260601165036-dr6aj7j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260601165036-kebcfkm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-kebcfkm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0x8tvfn","Type":"NodeParagraph","Properties":{"id":"20260601165036-0x8tvfn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260601165036-nr4yee9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nr4yee9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qhdiupm","Type":"NodeParagraph","Properties":{"id":"20260601165036-qhdiupm","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260601165036-ngn9pww","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ngn9pww","updated":"20260601165036"},"Children":[{"ID":"20260601165036-whkysv1","Type":"NodeParagraph","Properties":{"id":"20260601165036-whkysv1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260601165036-zdw7gmk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zdw7gmk","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zhb47zv","Type":"NodeParagraph","Properties":{"id":"20260601165036-zhb47zv","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260601165036-jfivq8m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jfivq8m","updated":"20260601165036"},"Children":[{"ID":"20260601165036-cmtgnky","Type":"NodeParagraph","Properties":{"id":"20260601165036-cmtgnky","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260601165036-15foqx8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-15foqx8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-e5r8s6x","Type":"NodeParagraph","Properties":{"id":"20260601165036-e5r8s6x","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260601165036-oogpv0n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-oogpv0n","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ki1w8xc","Type":"NodeParagraph","Properties":{"id":"20260601165036-ki1w8xc","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260601165036-j02h5c8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j02h5c8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zaxhqec","Type":"NodeParagraph","Properties":{"id":"20260601165036-zaxhqec","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260601165036-zxi3ntf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zxi3ntf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0i3mr2a","Type":"NodeParagraph","Properties":{"id":"20260601165036-0i3mr2a","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260601165036-gu3kagp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gu3kagp","updated":"20260601165036"},"Children":[{"ID":"20260601165036-k7hf2c8","Type":"NodeParagraph","Properties":{"id":"20260601165036-k7hf2c8","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260601165036-sjuj9xp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sjuj9xp","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bpjiqqe","Type":"NodeParagraph","Properties":{"id":"20260601165036-bpjiqqe","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260601165036-u9oko5j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u9oko5j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sz1u8pz","Type":"NodeParagraph","Properties":{"id":"20260601165036-sz1u8pz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260601165036-ow530iv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ow530iv","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dobnq6r","Type":"NodeParagraph","Properties":{"id":"20260601165036-dobnq6r","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260601165036-b1p5z9y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-b1p5z9y","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jzkuu77","Type":"NodeParagraph","Properties":{"id":"20260601165036-jzkuu77","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260601165036-j5zgo0o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j5zgo0o","updated":"20260601165036"},"Children":[{"ID":"20260601165036-gdydxly","Type":"NodeParagraph","Properties":{"id":"20260601165036-gdydxly","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260601165036-shn4uk6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-shn4uk6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7wbwjnf","Type":"NodeParagraph","Properties":{"id":"20260601165036-7wbwjnf","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260601165036-f7hk2fx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-f7hk2fx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0dii9n2","Type":"NodeParagraph","Properties":{"id":"20260601165036-0dii9n2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260601165036-10cd0vx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-10cd0vx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-iafq699","Type":"NodeParagraph","Properties":{"id":"20260601165036-iafq699","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260601165036-wxrmtpy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wxrmtpy","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xvsahuf","Type":"NodeParagraph","Properties":{"id":"20260601165036-xvsahuf","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260601165036-0jwolem","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0jwolem","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vppeei6","Type":"NodeParagraph","Properties":{"id":"20260601165036-vppeei6","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260601165036-y4m4v0h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-y4m4v0h","updated":"20260601165036"},"Children":[{"ID":"20260601165036-r4csu8n","Type":"NodeParagraph","Properties":{"id":"20260601165036-r4csu8n","updated":"20260601170129"},"Children":[{"Type":"NodeText","Data":"汪国真：没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260601165036-kxmcvza","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-kxmcvza","updated":"20260601165036"},"Children":[{"ID":"20260601165036-v84wo40","Type":"NodeParagraph","Properties":{"id":"20260601165036-v84wo40","updated":"20260601170143"},"Children":[{"Type":"NodeText","Data":"歌德：才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260601165036-47kzw2o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-47kzw2o","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qlyo74w","Type":"NodeParagraph","Properties":{"id":"20260601165036-qlyo74w","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260601165036-ebbyc56","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ebbyc56","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6zvoa8n","Type":"NodeParagraph","Properties":{"id":"20260601165036-6zvoa8n","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260601165036-itdms1o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-itdms1o","updated":"20260601165036"},"Children":[{"ID":"20260601165036-suwaphh","Type":"NodeParagraph","Properties":{"id":"20260601165036-suwaphh","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260601165036-u7wxw0d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u7wxw0d","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7ds3qov","Type":"NodeParagraph","Properties":{"id":"20260601165036-7ds3qov","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260601165036-6cjcm73","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6cjcm73","updated":"20260601165036"},"Children":[{"ID":"20260601165036-r2qybds","Type":"NodeParagraph","Properties":{"id":"20260601165036-r2qybds","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260601165036-gb4oclr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gb4oclr","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ozhur9j","Type":"NodeParagraph","Properties":{"id":"20260601165036-ozhur9j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260601165036-wsdyq4f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wsdyq4f","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7i75507","Type":"NodeParagraph","Properties":{"id":"20260601165036-7i75507","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260601165036-j7ctarx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j7ctarx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4k60qx4","Type":"NodeParagraph","Properties":{"id":"20260601165036-4k60qx4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260601165036-zapd2x3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zapd2x3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-48dke18","Type":"NodeParagraph","Properties":{"id":"20260601165036-48dke18","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260601165036-dvz5hol","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dvz5hol","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1ltc4x6","Type":"NodeParagraph","Properties":{"id":"20260601165036-1ltc4x6","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260601165036-z44rafa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-z44rafa","updated":"20260601165036"},"Children":[{"ID":"20260601165036-r624ljl","Type":"NodeParagraph","Properties":{"id":"20260601165036-r624ljl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260601165036-bi56yd9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-bi56yd9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-b20mgny","Type":"NodeParagraph","Properties":{"id":"20260601165036-b20mgny","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260601165036-vd32xml","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-vd32xml","updated":"20260601165036"},"Children":[{"ID":"20260601165036-mgscz7e","Type":"NodeParagraph","Properties":{"id":"20260601165036-mgscz7e","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260601165036-4abozad","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4abozad","updated":"20260601165036"},"Children":[{"ID":"20260601165036-drcew55","Type":"NodeParagraph","Properties":{"id":"20260601165036-drcew55","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260601165036-49h4acz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-49h4acz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-he5p9bo","Type":"NodeParagraph","Properties":{"id":"20260601165036-he5p9bo","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260601165036-n2tqwwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-n2tqwwm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xo4bajg","Type":"NodeParagraph","Properties":{"id":"20260601165036-xo4bajg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260601165036-956or1d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-956or1d","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9rfdb9i","Type":"NodeParagraph","Properties":{"id":"20260601165036-9rfdb9i","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260601165036-h42slbq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-h42slbq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vw4p2fe","Type":"NodeParagraph","Properties":{"id":"20260601165036-vw4p2fe","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260601165036-kwt1mmm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-kwt1mmm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5yo2ixt","Type":"NodeParagraph","Properties":{"id":"20260601165036-5yo2ixt","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260601165036-9hbd8wl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9hbd8wl","updated":"20260601165036"},"Children":[{"ID":"20260601165036-54fsg6p","Type":"NodeParagraph","Properties":{"id":"20260601165036-54fsg6p","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260601165036-c0y1rj0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-c0y1rj0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-927e0al","Type":"NodeParagraph","Properties":{"id":"20260601165036-927e0al","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260601165036-dr6jnj4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dr6jnj4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-rpsmvg1","Type":"NodeParagraph","Properties":{"id":"20260601165036-rpsmvg1","updated":"20260602084253"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260601165036-g44r7dz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-g44r7dz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-cf73g38","Type":"NodeParagraph","Properties":{"id":"20260601165036-cf73g38","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260601165036-a4o5jmc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-a4o5jmc","updated":"20260601165036"},"Children":[{"ID":"20260601165036-howi7g8","Type":"NodeParagraph","Properties":{"id":"20260601165036-howi7g8","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260601165036-95l5g62","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-95l5g62","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bmwvb7h","Type":"NodeParagraph","Properties":{"id":"20260601165036-bmwvb7h","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260601165036-is27uky","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-is27uky","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7vn192n","Type":"NodeParagraph","Properties":{"id":"20260601165036-7vn192n","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260601165036-7yy6yrd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7yy6yrd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-78jbm99","Type":"NodeParagraph","Properties":{"id":"20260601165036-78jbm99","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260601165036-onm4ydx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-onm4ydx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5m3jrig","Type":"NodeParagraph","Properties":{"id":"20260601165036-5m3jrig","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260601165036-8mdvhip","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-8mdvhip","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dldowmg","Type":"NodeParagraph","Properties":{"id":"20260601165036-dldowmg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260601165036-8gzg0gd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-8gzg0gd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-gxfe0ga","Type":"NodeParagraph","Properties":{"id":"20260601165036-gxfe0ga","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260601165036-yovw3tp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-yovw3tp","updated":"20260601165036"},"Children":[{"ID":"20260601165036-cagbd2v","Type":"NodeParagraph","Properties":{"id":"20260601165036-cagbd2v","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260601165036-aa8yczh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-aa8yczh","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1n9fx0h","Type":"NodeParagraph","Properties":{"id":"20260601165036-1n9fx0h","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260601165036-35ymviz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-35ymviz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ewpyln7","Type":"NodeParagraph","Properties":{"id":"20260601165036-ewpyln7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260601165036-qt5sqyu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-qt5sqyu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-q50wd8v","Type":"NodeParagraph","Properties":{"id":"20260601165036-q50wd8v","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260601165036-m79hmc1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-m79hmc1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kyltwyb","Type":"NodeParagraph","Properties":{"id":"20260601165036-kyltwyb","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260601165036-c0l6dp9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-c0l6dp9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3beuvlm","Type":"NodeParagraph","Properties":{"id":"20260601165036-3beuvlm","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260601165036-jdwbrlz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jdwbrlz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4s8ff3d","Type":"NodeParagraph","Properties":{"id":"20260601165036-4s8ff3d","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260601165036-fvlsajl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-fvlsajl","updated":"20260601165036"},"Children":[{"ID":"20260601165036-eyku0dp","Type":"NodeParagraph","Properties":{"id":"20260601165036-eyku0dp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260601165036-lg2wjnf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lg2wjnf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3zvo7pl","Type":"NodeParagraph","Properties":{"id":"20260601165036-3zvo7pl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260601165036-324es24","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-324es24","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qr9022m","Type":"NodeParagraph","Properties":{"id":"20260601165036-qr9022m","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260601165036-wm7110m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wm7110m","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2lyt4br","Type":"NodeParagraph","Properties":{"id":"20260601165036-2lyt4br","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260601165036-i1628er","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-i1628er","updated":"20260601165036"},"Children":[{"ID":"20260601165036-wc4pbm7","Type":"NodeParagraph","Properties":{"id":"20260601165036-wc4pbm7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260601165036-rv5fq2j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rv5fq2j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-k2te0ls","Type":"NodeParagraph","Properties":{"id":"20260601165036-k2te0ls","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260601165036-428jswq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-428jswq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ikhg5ko","Type":"NodeParagraph","Properties":{"id":"20260601165036-ikhg5ko","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260601165036-taif28j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-taif28j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1if6dyl","Type":"NodeParagraph","Properties":{"id":"20260601165036-1if6dyl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260601165036-id5scvy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-id5scvy","updated":"20260601165036"},"Children":[{"ID":"20260601165036-39y537c","Type":"NodeParagraph","Properties":{"id":"20260601165036-39y537c","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260601165036-e60tpza","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-e60tpza","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dofhs50","Type":"NodeParagraph","Properties":{"id":"20260601165036-dofhs50","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260601165036-4ujw397","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4ujw397","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1vhjygz","Type":"NodeParagraph","Properties":{"id":"20260601165036-1vhjygz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260601165036-g3eewqg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-g3eewqg","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6lmwakt","Type":"NodeParagraph","Properties":{"id":"20260601165036-6lmwakt","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260601165036-abgh8um","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-abgh8um","updated":"20260601165036"},"Children":[{"ID":"20260601165036-d9wt4yq","Type":"NodeParagraph","Properties":{"id":"20260601165036-d9wt4yq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260601165036-stdzsg4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-stdzsg4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nmt1qyl","Type":"NodeParagraph","Properties":{"id":"20260601165036-nmt1qyl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260601165036-zufzjy3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zufzjy3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ij7169r","Type":"NodeParagraph","Properties":{"id":"20260601165036-ij7169r","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260601165036-t31dozc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t31dozc","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jx67mwk","Type":"NodeParagraph","Properties":{"id":"20260601165036-jx67mwk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260601165036-cnomroq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-cnomroq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3x62dnx","Type":"NodeParagraph","Properties":{"id":"20260601165036-3x62dnx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260601165036-e7ejr4n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-e7ejr4n","updated":"20260601165036"},"Children":[{"ID":"20260601165036-t5cxei7","Type":"NodeParagraph","Properties":{"id":"20260601165036-t5cxei7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260601165036-re632kt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-re632kt","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sb674ee","Type":"NodeParagraph","Properties":{"id":"20260601165036-sb674ee","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260601165036-iyh39xe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-iyh39xe","updated":"20260601165036"},"Children":[{"ID":"20260601165036-m6e0bwu","Type":"NodeParagraph","Properties":{"id":"20260601165036-m6e0bwu","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260601165036-c74d7x0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-c74d7x0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-wpwvcex","Type":"NodeParagraph","Properties":{"id":"20260601165036-wpwvcex","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260601165036-r888c69","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-r888c69","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4f0y6p9","Type":"NodeParagraph","Properties":{"id":"20260601165036-4f0y6p9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260601165036-t10z53k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t10z53k","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pgw05aw","Type":"NodeParagraph","Properties":{"id":"20260601165036-pgw05aw","updated":"20260602084232"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260601165036-4a5pg08","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4a5pg08","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vuwaotp","Type":"NodeParagraph","Properties":{"id":"20260601165036-vuwaotp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260601165036-w7xugp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-w7xugp1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-yjln1ru","Type":"NodeParagraph","Properties":{"id":"20260601165036-yjln1ru","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260601165036-tvky8gi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tvky8gi","updated":"20260601165036"},"Children":[{"ID":"20260601165036-93gg8bm","Type":"NodeParagraph","Properties":{"id":"20260601165036-93gg8bm","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260601165036-w8iirl9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-w8iirl9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-58wtwns","Type":"NodeParagraph","Properties":{"id":"20260601165036-58wtwns","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260601165036-u09jfc4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u09jfc4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vzb0jd4","Type":"NodeParagraph","Properties":{"id":"20260601165036-vzb0jd4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260601165036-vwk6d53","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-vwk6d53","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8zd1i5q","Type":"NodeParagraph","Properties":{"id":"20260601165036-8zd1i5q","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260601165036-qw6ehid","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-qw6ehid","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0hxgv8k","Type":"NodeParagraph","Properties":{"id":"20260601165036-0hxgv8k","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260601165036-jk1xxl2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jk1xxl2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bgrndrv","Type":"NodeParagraph","Properties":{"id":"20260601165036-bgrndrv","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260601165036-xff9qho","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-xff9qho","updated":"20260601165036"},"Children":[{"ID":"20260601165036-m2i0053","Type":"NodeParagraph","Properties":{"id":"20260601165036-m2i0053","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260601165036-ri4wli9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ri4wli9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-fthsx7k","Type":"NodeParagraph","Properties":{"id":"20260601165036-fthsx7k","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260601165036-giodvrn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-giodvrn","updated":"20260601165036"},"Children":[{"ID":"20260601165036-czz9225","Type":"NodeParagraph","Properties":{"id":"20260601165036-czz9225","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260601165036-ntcvf6g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ntcvf6g","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lobqtub","Type":"NodeParagraph","Properties":{"id":"20260601165036-lobqtub","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260601165036-f91qvbv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-f91qvbv","updated":"20260601165036"},"Children":[{"ID":"20260601165036-fctscph","Type":"NodeParagraph","Properties":{"id":"20260601165036-fctscph","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260601165036-01oxbmu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-01oxbmu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-c1i7yhs","Type":"NodeParagraph","Properties":{"id":"20260601165036-c1i7yhs","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260601165036-czbyltr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-czbyltr","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6wecp08","Type":"NodeParagraph","Properties":{"id":"20260601165036-6wecp08","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260601165036-2mddxqc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-2mddxqc","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2mj79lp","Type":"NodeParagraph","Properties":{"id":"20260601165036-2mj79lp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260601165036-4k9y6a2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4k9y6a2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9wsnmsn","Type":"NodeParagraph","Properties":{"id":"20260601165036-9wsnmsn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260601165036-0fnah8d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0fnah8d","updated":"20260601165036"},"Children":[{"ID":"20260601165036-88h17n2","Type":"NodeParagraph","Properties":{"id":"20260601165036-88h17n2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260601165036-z0z5dpx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-z0z5dpx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-y63hgt2","Type":"NodeParagraph","Properties":{"id":"20260601165036-y63hgt2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260601165036-bwstv4f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-bwstv4f","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zvpo5n5","Type":"NodeParagraph","Properties":{"id":"20260601165036-zvpo5n5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260601165036-jdq4rxx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jdq4rxx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-u4n9qij","Type":"NodeParagraph","Properties":{"id":"20260601165036-u4n9qij","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260601165036-urus71s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-urus71s","updated":"20260601165036"},"Children":[{"ID":"20260601165036-myvr8we","Type":"NodeParagraph","Properties":{"id":"20260601165036-myvr8we","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260601165036-aflbew3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-aflbew3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2wfl7w5","Type":"NodeParagraph","Properties":{"id":"20260601165036-2wfl7w5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260601165036-16oz7j2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-16oz7j2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6aedqy3","Type":"NodeParagraph","Properties":{"id":"20260601165036-6aedqy3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260601165036-xw9ohj7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-xw9ohj7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3nmpqj3","Type":"NodeParagraph","Properties":{"id":"20260601165036-3nmpqj3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260601165036-7h53ml9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7h53ml9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0pee0yr","Type":"NodeParagraph","Properties":{"id":"20260601165036-0pee0yr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260601165036-q6qrpxy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-q6qrpxy","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3q30sfi","Type":"NodeParagraph","Properties":{"id":"20260601165036-3q30sfi","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260601165036-4pj85x5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4pj85x5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-l9d8tbe","Type":"NodeParagraph","Properties":{"id":"20260601165036-l9d8tbe","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260601165036-vitad62","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-vitad62","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0ipsnsw","Type":"NodeParagraph","Properties":{"id":"20260601165036-0ipsnsw","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260601165036-2efh734","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-2efh734","updated":"20260601165036"},"Children":[{"ID":"20260601165036-uqo5136","Type":"NodeParagraph","Properties":{"id":"20260601165036-uqo5136","updated":"20260602084214"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260601165036-1zb12tl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1zb12tl","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nz16a4t","Type":"NodeParagraph","Properties":{"id":"20260601165036-nz16a4t","updated":"20260602084223"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260601165036-nrbm26c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nrbm26c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-y4tl97k","Type":"NodeParagraph","Properties":{"id":"20260601165036-y4tl97k","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260601165036-c75gk7v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-c75gk7v","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4o4dffc","Type":"NodeParagraph","Properties":{"id":"20260601165036-4o4dffc","updated":"20260602084200"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260601165036-eipa1k1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-eipa1k1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-guff1s3","Type":"NodeParagraph","Properties":{"id":"20260601165036-guff1s3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260601165036-sh32x4p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sh32x4p","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kxwac5a","Type":"NodeParagraph","Properties":{"id":"20260601165036-kxwac5a","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260601165036-3yc8vf5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3yc8vf5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zv9gwrc","Type":"NodeParagraph","Properties":{"id":"20260601165036-zv9gwrc","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260601165036-gongz7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gongz7j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0eyqcus","Type":"NodeParagraph","Properties":{"id":"20260601165036-0eyqcus","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260601165036-5ppwd04","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5ppwd04","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sfe952j","Type":"NodeParagraph","Properties":{"id":"20260601165036-sfe952j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260601165036-t3xalg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t3xalg6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3w5476h","Type":"NodeParagraph","Properties":{"id":"20260601165036-3w5476h","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260601165036-dch53nz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dch53nz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qq35b2k","Type":"NodeParagraph","Properties":{"id":"20260601165036-qq35b2k","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260601165036-y878mf2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-y878mf2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8411vu0","Type":"NodeParagraph","Properties":{"id":"20260601165036-8411vu0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260601165036-7lyg7wb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7lyg7wb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qbenap2","Type":"NodeParagraph","Properties":{"id":"20260601165036-qbenap2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260601165036-3rnu8po","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3rnu8po","updated":"20260601165036"},"Children":[{"ID":"20260601165036-53lsdbq","Type":"NodeParagraph","Properties":{"id":"20260601165036-53lsdbq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260601165036-t1yg22c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t1yg22c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-o9xhcy9","Type":"NodeParagraph","Properties":{"id":"20260601165036-o9xhcy9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260601165036-rqoltg0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rqoltg0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-oqvmz6f","Type":"NodeParagraph","Properties":{"id":"20260601165036-oqvmz6f","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260601165036-2ebse7s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-2ebse7s","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2fiql5l","Type":"NodeParagraph","Properties":{"id":"20260601165036-2fiql5l","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260601165036-pwpn05c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-pwpn05c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5ryhf0j","Type":"NodeParagraph","Properties":{"id":"20260601165036-5ryhf0j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260601165036-c5gsjku","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-c5gsjku","updated":"20260601165036"},"Children":[{"ID":"20260601165036-a6o5t64","Type":"NodeParagraph","Properties":{"id":"20260601165036-a6o5t64","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260601165036-7kqujqo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7kqujqo","updated":"20260601165036"},"Children":[{"ID":"20260601165036-o2q1zt8","Type":"NodeParagraph","Properties":{"id":"20260601165036-o2q1zt8","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260601165036-k3vl7l1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-k3vl7l1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vg4klof","Type":"NodeParagraph","Properties":{"id":"20260601165036-vg4klof","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260601165036-1lhkpy5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1lhkpy5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-b05z52o","Type":"NodeParagraph","Properties":{"id":"20260601165036-b05z52o","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260601165036-38mwt7s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-38mwt7s","updated":"20260601165036"},"Children":[{"ID":"20260601165036-842gutj","Type":"NodeParagraph","Properties":{"id":"20260601165036-842gutj","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260601165036-iob4e3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-iob4e3x","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9hvuaxq","Type":"NodeParagraph","Properties":{"id":"20260601165036-9hvuaxq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260601165036-p8oympd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-p8oympd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4w9uljx","Type":"NodeParagraph","Properties":{"id":"20260601165036-4w9uljx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260601165036-azfadhu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-azfadhu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-psnw14r","Type":"NodeParagraph","Properties":{"id":"20260601165036-psnw14r","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260601165036-a35cmml","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-a35cmml","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qesdmwn","Type":"NodeParagraph","Properties":{"id":"20260601165036-qesdmwn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260601165036-vqa06n1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-vqa06n1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-f59l2c1","Type":"NodeParagraph","Properties":{"id":"20260601165036-f59l2c1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260601165036-x9s4cid","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-x9s4cid","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lk0lcu2","Type":"NodeParagraph","Properties":{"id":"20260601165036-lk0lcu2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260601165036-9bn5slx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9bn5slx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nivf4cp","Type":"NodeParagraph","Properties":{"id":"20260601165036-nivf4cp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260601165036-ik3dq5n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ik3dq5n","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1focm27","Type":"NodeParagraph","Properties":{"id":"20260601165036-1focm27","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260601165036-8v9dtbd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-8v9dtbd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-e7t9md9","Type":"NodeParagraph","Properties":{"id":"20260601165036-e7t9md9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260601165036-0kfg7u1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0kfg7u1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-mjsubep","Type":"NodeParagraph","Properties":{"id":"20260601165036-mjsubep","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260601165036-kq9zzzq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-kq9zzzq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3wws57u","Type":"NodeParagraph","Properties":{"id":"20260601165036-3wws57u","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260601165036-ixrzi6c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ixrzi6c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-q97aryh","Type":"NodeParagraph","Properties":{"id":"20260601165036-q97aryh","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260601165036-sbruv3n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sbruv3n","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vx6k1j5","Type":"NodeParagraph","Properties":{"id":"20260601165036-vx6k1j5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260601165036-xjcpxxc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-xjcpxxc","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dvegzbw","Type":"NodeParagraph","Properties":{"id":"20260601165036-dvegzbw","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260601165036-nws3f1u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nws3f1u","updated":"20260601165036"},"Children":[{"ID":"20260601165036-aunpgaj","Type":"NodeParagraph","Properties":{"id":"20260601165036-aunpgaj","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260601165036-q4kfc24","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-q4kfc24","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tclb1y9","Type":"NodeParagraph","Properties":{"id":"20260601165036-tclb1y9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260601165036-lnd7xqs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lnd7xqs","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pbxk939","Type":"NodeParagraph","Properties":{"id":"20260601165036-pbxk939","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260601165036-ur7bihx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ur7bihx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4bchzym","Type":"NodeParagraph","Properties":{"id":"20260601165036-4bchzym","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260601165036-k53be21","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-k53be21","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2tp3hlf","Type":"NodeParagraph","Properties":{"id":"20260601165036-2tp3hlf","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260601165036-wn1osua","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wn1osua","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jodeoek","Type":"NodeParagraph","Properties":{"id":"20260601165036-jodeoek","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260601165036-8o2c5ff","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-8o2c5ff","updated":"20260601165036"},"Children":[{"ID":"20260601165036-x35fuhg","Type":"NodeParagraph","Properties":{"id":"20260601165036-x35fuhg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260601165036-nsi61qx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nsi61qx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xbqs34v","Type":"NodeParagraph","Properties":{"id":"20260601165036-xbqs34v","updated":"20260602084141"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260601165036-ytf5zea","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ytf5zea","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6zadkpz","Type":"NodeParagraph","Properties":{"id":"20260601165036-6zadkpz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260601165036-qmpg2w4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-qmpg2w4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nodavux","Type":"NodeParagraph","Properties":{"id":"20260601165036-nodavux","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260601165036-616wqyz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-616wqyz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tajnwhf","Type":"NodeParagraph","Properties":{"id":"20260601165036-tajnwhf","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260601165036-1pvjedq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1pvjedq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tdhsdk7","Type":"NodeParagraph","Properties":{"id":"20260601165036-tdhsdk7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260601165036-h6p77pv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-h6p77pv","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bryns7c","Type":"NodeParagraph","Properties":{"id":"20260601165036-bryns7c","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260601165036-0r9ad4p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0r9ad4p","updated":"20260601165036"},"Children":[{"ID":"20260601165036-agtxzk3","Type":"NodeParagraph","Properties":{"id":"20260601165036-agtxzk3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260601165036-7bprdr0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7bprdr0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-czm50rg","Type":"NodeParagraph","Properties":{"id":"20260601165036-czm50rg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260601165036-ytxys96","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ytxys96","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pwdqh9b","Type":"NodeParagraph","Properties":{"id":"20260601165036-pwdqh9b","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260601165036-cxw28pe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-cxw28pe","updated":"20260601165036"},"Children":[{"ID":"20260601165036-hkpf0fd","Type":"NodeParagraph","Properties":{"id":"20260601165036-hkpf0fd","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260601165036-nuff7m9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nuff7m9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xd27l23","Type":"NodeParagraph","Properties":{"id":"20260601165036-xd27l23","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260601165036-ft85iau","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ft85iau","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bmcuiuy","Type":"NodeParagraph","Properties":{"id":"20260601165036-bmcuiuy","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260601165036-zcho163","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zcho163","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xnu4wml","Type":"NodeParagraph","Properties":{"id":"20260601165036-xnu4wml","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260601165036-ci0fyvs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ci0fyvs","updated":"20260601165036"},"Children":[{"ID":"20260601165036-u7dam9w","Type":"NodeParagraph","Properties":{"id":"20260601165036-u7dam9w","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260601165036-0taldw2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0taldw2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ba4f5b5","Type":"NodeParagraph","Properties":{"id":"20260601165036-ba4f5b5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260601165036-prfgm7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-prfgm7j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6vfrvpi","Type":"NodeParagraph","Properties":{"id":"20260601165036-6vfrvpi","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260601165036-a75616l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-a75616l","updated":"20260601165036"},"Children":[{"ID":"20260601165036-s2zpupx","Type":"NodeParagraph","Properties":{"id":"20260601165036-s2zpupx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260601165036-4l7it3j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4l7it3j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-wrbusmg","Type":"NodeParagraph","Properties":{"id":"20260601165036-wrbusmg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260601165036-5m7tg04","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5m7tg04","updated":"20260601165036"},"Children":[{"ID":"20260601165036-guklhn2","Type":"NodeParagraph","Properties":{"id":"20260601165036-guklhn2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260601165036-dbgct80","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dbgct80","updated":"20260601165036"},"Children":[{"ID":"20260601165036-h1smkx4","Type":"NodeParagraph","Properties":{"id":"20260601165036-h1smkx4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260601165036-o6tmdp4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-o6tmdp4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kjjgzw9","Type":"NodeParagraph","Properties":{"id":"20260601165036-kjjgzw9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260601165036-oz5hso2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-oz5hso2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vg0nnoc","Type":"NodeParagraph","Properties":{"id":"20260601165036-vg0nnoc","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260601165036-z8ud7yz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-z8ud7yz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-myk20uz","Type":"NodeParagraph","Properties":{"id":"20260601165036-myk20uz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260601165036-sydtbl3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sydtbl3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3ls11cv","Type":"NodeParagraph","Properties":{"id":"20260601165036-3ls11cv","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260601165036-g9swzln","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-g9swzln","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kd5s4tn","Type":"NodeParagraph","Properties":{"id":"20260601165036-kd5s4tn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260601165036-dqwyjox","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-dqwyjox","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ro9ldc6","Type":"NodeParagraph","Properties":{"id":"20260601165036-ro9ldc6","updated":"20260602084128"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260601165036-rato0c6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rato0c6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qs2ddjg","Type":"NodeParagraph","Properties":{"id":"20260601165036-qs2ddjg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260601165036-uutdkia","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-uutdkia","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7av58ol","Type":"NodeParagraph","Properties":{"id":"20260601165036-7av58ol","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260601165036-ofqvxiz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ofqvxiz","updated":"20260601165036"},"Children":[{"ID":"20260601165036-wsmb036","Type":"NodeParagraph","Properties":{"id":"20260601165036-wsmb036","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260601165036-1mo2lu0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1mo2lu0","updated":"20260601165036"},"Children":[{"ID":"20260601165036-e4ixxaq","Type":"NodeParagraph","Properties":{"id":"20260601165036-e4ixxaq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260601165036-fsbhpeu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-fsbhpeu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-uveo2xn","Type":"NodeParagraph","Properties":{"id":"20260601165036-uveo2xn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260601165036-95e1fuk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-95e1fuk","updated":"20260601165036"},"Children":[{"ID":"20260601165036-x78r9p2","Type":"NodeParagraph","Properties":{"id":"20260601165036-x78r9p2","updated":"20260602084110"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260601165036-uoay12c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-uoay12c","updated":"20260601165036"},"Children":[{"ID":"20260601165036-m2h3hwx","Type":"NodeParagraph","Properties":{"id":"20260601165036-m2h3hwx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260601165036-ukzep4q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ukzep4q","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5r942c3","Type":"NodeParagraph","Properties":{"id":"20260601165036-5r942c3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260601165036-fn5kk2u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-fn5kk2u","updated":"20260601165036"},"Children":[{"ID":"20260601165036-em7xqyh","Type":"NodeParagraph","Properties":{"id":"20260601165036-em7xqyh","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260601165036-ubz5zur","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ubz5zur","updated":"20260601165036"},"Children":[{"ID":"20260601165036-rzco6at","Type":"NodeParagraph","Properties":{"id":"20260601165036-rzco6at","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260601165036-oz6flym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-oz6flym","updated":"20260601165036"},"Children":[{"ID":"20260601165036-egyl4il","Type":"NodeParagraph","Properties":{"id":"20260601165036-egyl4il","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260601165036-l9zalgw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-l9zalgw","updated":"20260601165036"},"Children":[{"ID":"20260601165036-wkyi8t0","Type":"NodeParagraph","Properties":{"id":"20260601165036-wkyi8t0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260601165036-z5th178","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-z5th178","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0cm3pet","Type":"NodeParagraph","Properties":{"id":"20260601165036-0cm3pet","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260601165036-ryis5yi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ryis5yi","updated":"20260601165036"},"Children":[{"ID":"20260601165036-60t7mob","Type":"NodeParagraph","Properties":{"id":"20260601165036-60t7mob","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260601165036-ingtrib","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ingtrib","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nup8enf","Type":"NodeParagraph","Properties":{"id":"20260601165036-nup8enf","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260601165036-19chkxf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-19chkxf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-iawj267","Type":"NodeParagraph","Properties":{"id":"20260601165036-iawj267","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260601165036-wnxhf73","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wnxhf73","updated":"20260601165036"},"Children":[{"ID":"20260601165036-hdpm1x0","Type":"NodeParagraph","Properties":{"id":"20260601165036-hdpm1x0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260601165036-9jxltdd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-9jxltdd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xhctgqo","Type":"NodeParagraph","Properties":{"id":"20260601165036-xhctgqo","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260601165036-aqrdpxe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-aqrdpxe","updated":"20260601165036"},"Children":[{"ID":"20260601165036-r6o23x0","Type":"NodeParagraph","Properties":{"id":"20260601165036-r6o23x0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260601165036-r0mci5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-r0mci5l","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dcvrzsg","Type":"NodeParagraph","Properties":{"id":"20260601165036-dcvrzsg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260601165036-8zf929n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-8zf929n","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2k1o99f","Type":"NodeParagraph","Properties":{"id":"20260601165036-2k1o99f","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260601165036-av6146r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-av6146r","updated":"20260601165036"},"Children":[{"ID":"20260601165036-snzk9jz","Type":"NodeParagraph","Properties":{"id":"20260601165036-snzk9jz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260601165036-34hzozt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-34hzozt","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kit3989","Type":"NodeParagraph","Properties":{"id":"20260601165036-kit3989","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260601165036-wqtut3v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wqtut3v","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5ev5m3m","Type":"NodeParagraph","Properties":{"id":"20260601165036-5ev5m3m","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260601165036-g4yigoq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-g4yigoq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-fltqekp","Type":"NodeParagraph","Properties":{"id":"20260601165036-fltqekp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260601165036-td9grfu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-td9grfu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-38ow2p5","Type":"NodeParagraph","Properties":{"id":"20260601165036-38ow2p5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260601165036-ue8op4z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ue8op4z","updated":"20260601165036"},"Children":[{"ID":"20260601165036-aihwake","Type":"NodeParagraph","Properties":{"id":"20260601165036-aihwake","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260601165036-pzpt7f5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-pzpt7f5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dv52fh3","Type":"NodeParagraph","Properties":{"id":"20260601165036-dv52fh3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260601165036-lkrwbi6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lkrwbi6","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ln253yd","Type":"NodeParagraph","Properties":{"id":"20260601165036-ln253yd","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260601165036-kfxpy30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-kfxpy30","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lipr7oe","Type":"NodeParagraph","Properties":{"id":"20260601165036-lipr7oe","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260601165036-j9pnu5r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j9pnu5r","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bxszusx","Type":"NodeParagraph","Properties":{"id":"20260601165036-bxszusx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260601165036-5qj2rzx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5qj2rzx","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0a90yiw","Type":"NodeParagraph","Properties":{"id":"20260601165036-0a90yiw","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260601165036-pa390fe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-pa390fe","updated":"20260601165036"},"Children":[{"ID":"20260601165036-67ci962","Type":"NodeParagraph","Properties":{"id":"20260601165036-67ci962","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260601165036-6zp1j8e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6zp1j8e","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xngbf9t","Type":"NodeParagraph","Properties":{"id":"20260601165036-xngbf9t","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260601165036-5lxraty","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5lxraty","updated":"20260601165036"},"Children":[{"ID":"20260601165036-c7d1qr2","Type":"NodeParagraph","Properties":{"id":"20260601165036-c7d1qr2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260601165036-h3d63gl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-h3d63gl","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ld5gknq","Type":"NodeParagraph","Properties":{"id":"20260601165036-ld5gknq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260601165036-sv9emo2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sv9emo2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-690uhr5","Type":"NodeParagraph","Properties":{"id":"20260601165036-690uhr5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260601165036-t9ei6oo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-t9ei6oo","updated":"20260601165036"},"Children":[{"ID":"20260601165036-c3m3h4n","Type":"NodeParagraph","Properties":{"id":"20260601165036-c3m3h4n","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260601165036-3cl1sdm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3cl1sdm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8bfzrpr","Type":"NodeParagraph","Properties":{"id":"20260601165036-8bfzrpr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260601165036-u066r5p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u066r5p","updated":"20260601165036"},"Children":[{"ID":"20260601165036-624n0fc","Type":"NodeParagraph","Properties":{"id":"20260601165036-624n0fc","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260601165036-mq841i1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-mq841i1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-2j5c8hv","Type":"NodeParagraph","Properties":{"id":"20260601165036-2j5c8hv","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260601165036-vxmd9ir","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-vxmd9ir","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0acfsiw","Type":"NodeParagraph","Properties":{"id":"20260601165036-0acfsiw","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260601165036-ocscjtf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ocscjtf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-px6wfh0","Type":"NodeParagraph","Properties":{"id":"20260601165036-px6wfh0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260601165036-p8eiz1v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-p8eiz1v","updated":"20260601165036"},"Children":[{"ID":"20260601165036-g7ku8hr","Type":"NodeParagraph","Properties":{"id":"20260601165036-g7ku8hr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260601165036-2poro1h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-2poro1h","updated":"20260601165036"},"Children":[{"ID":"20260601165036-u2hsze7","Type":"NodeParagraph","Properties":{"id":"20260601165036-u2hsze7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260601165036-ae0nyqf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ae0nyqf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-o0shhcc","Type":"NodeParagraph","Properties":{"id":"20260601165036-o0shhcc","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260601165036-rqnbs37","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rqnbs37","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jr7t9d7","Type":"NodeParagraph","Properties":{"id":"20260601165036-jr7t9d7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260601165036-d7rtd6j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-d7rtd6j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bdzm2i2","Type":"NodeParagraph","Properties":{"id":"20260601165036-bdzm2i2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260601165036-wr2s1oe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wr2s1oe","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vli6tqu","Type":"NodeParagraph","Properties":{"id":"20260601165036-vli6tqu","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260601165036-7tbn6ex","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7tbn6ex","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8v4meh4","Type":"NodeParagraph","Properties":{"id":"20260601165036-8v4meh4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260601165036-beiifrp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-beiifrp","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7lqmo92","Type":"NodeParagraph","Properties":{"id":"20260601165036-7lqmo92","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260601165036-32hez7p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-32hez7p","updated":"20260601165036"},"Children":[{"ID":"20260601165036-n3lxppb","Type":"NodeParagraph","Properties":{"id":"20260601165036-n3lxppb","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260601165036-p0qg8p2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-p0qg8p2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-oozczmg","Type":"NodeParagraph","Properties":{"id":"20260601165036-oozczmg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260601165036-7p4dmn8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-7p4dmn8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3k0q8li","Type":"NodeParagraph","Properties":{"id":"20260601165036-3k0q8li","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260601165036-maff78b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-maff78b","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7eufazq","Type":"NodeParagraph","Properties":{"id":"20260601165036-7eufazq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260601165036-6oiqnaw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6oiqnaw","updated":"20260601165036"},"Children":[{"ID":"20260601165036-x6dyn7v","Type":"NodeParagraph","Properties":{"id":"20260601165036-x6dyn7v","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260601165036-1yv59s8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1yv59s8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-hlrxrdi","Type":"NodeParagraph","Properties":{"id":"20260601165036-hlrxrdi","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260601165036-2smyurd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-2smyurd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-nro991h","Type":"NodeParagraph","Properties":{"id":"20260601165036-nro991h","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260601165036-0cus5uu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0cus5uu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-abollnv","Type":"NodeParagraph","Properties":{"id":"20260601165036-abollnv","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260601165036-5ge0ud7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5ge0ud7","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qxfgul4","Type":"NodeParagraph","Properties":{"id":"20260601165036-qxfgul4","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260601165036-w6bllm3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-w6bllm3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9qazycu","Type":"NodeParagraph","Properties":{"id":"20260601165036-9qazycu","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260601165036-iq9lzc1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-iq9lzc1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4yvnwsq","Type":"NodeParagraph","Properties":{"id":"20260601165036-4yvnwsq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260601165036-tdqjjvb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tdqjjvb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-e7ics2p","Type":"NodeParagraph","Properties":{"id":"20260601165036-e7ics2p","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260601165036-iei2xw2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-iei2xw2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-n3dgcmm","Type":"NodeParagraph","Properties":{"id":"20260601165036-n3dgcmm","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260601165036-panvdlr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-panvdlr","updated":"20260601165036"},"Children":[{"ID":"20260601165036-r2nakqc","Type":"NodeParagraph","Properties":{"id":"20260601165036-r2nakqc","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260601165036-ufbi42h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ufbi42h","updated":"20260601165036"},"Children":[{"ID":"20260601165036-a5nm424","Type":"NodeParagraph","Properties":{"id":"20260601165036-a5nm424","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260601165036-lx9ax3p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lx9ax3p","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6qvzmx6","Type":"NodeParagraph","Properties":{"id":"20260601165036-6qvzmx6","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260601165036-8pawo1t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-8pawo1t","updated":"20260601165036"},"Children":[{"ID":"20260601165036-p3954lo","Type":"NodeParagraph","Properties":{"id":"20260601165036-p3954lo","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260601165036-movk2wk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-movk2wk","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1ngdrby","Type":"NodeParagraph","Properties":{"id":"20260601165036-1ngdrby","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260601165036-5f3gtba","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5f3gtba","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3a373tp","Type":"NodeParagraph","Properties":{"id":"20260601165036-3a373tp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260601165036-j1s3cpg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j1s3cpg","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jbxl3l9","Type":"NodeParagraph","Properties":{"id":"20260601165036-jbxl3l9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260601165036-d5ulaym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-d5ulaym","updated":"20260601165036"},"Children":[{"ID":"20260601165036-61yvkr0","Type":"NodeParagraph","Properties":{"id":"20260601165036-61yvkr0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260601165036-xlenhex","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-xlenhex","updated":"20260601165036"},"Children":[{"ID":"20260601165036-hosrhqa","Type":"NodeParagraph","Properties":{"id":"20260601165036-hosrhqa","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260601165036-mwgt39g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-mwgt39g","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7sp2mo3","Type":"NodeParagraph","Properties":{"id":"20260601165036-7sp2mo3","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260601165036-3pqjthj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3pqjthj","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qv6b9my","Type":"NodeParagraph","Properties":{"id":"20260601165036-qv6b9my","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260601165036-4shrezu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-4shrezu","updated":"20260601165036"},"Children":[{"ID":"20260601165036-w5ka4um","Type":"NodeParagraph","Properties":{"id":"20260601165036-w5ka4um","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260601165036-qyysgz1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-qyysgz1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-t44voqn","Type":"NodeParagraph","Properties":{"id":"20260601165036-t44voqn","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260601165036-gcssmg4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gcssmg4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jn2dzci","Type":"NodeParagraph","Properties":{"id":"20260601165036-jn2dzci","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260601165036-13q4ykm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-13q4ykm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5eurbpl","Type":"NodeParagraph","Properties":{"id":"20260601165036-5eurbpl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260601165036-62cjbcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-62cjbcq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bqvz8j1","Type":"NodeParagraph","Properties":{"id":"20260601165036-bqvz8j1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260601165036-ql5r275","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ql5r275","updated":"20260601165036"},"Children":[{"ID":"20260601165036-74puau0","Type":"NodeParagraph","Properties":{"id":"20260601165036-74puau0","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260601165036-pg5g9r4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-pg5g9r4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-z6wx5ac","Type":"NodeParagraph","Properties":{"id":"20260601165036-z6wx5ac","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260601165036-s8vu97u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-s8vu97u","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zesdt8u","Type":"NodeParagraph","Properties":{"id":"20260601165036-zesdt8u","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260601165036-lsui14e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lsui14e","updated":"20260601165036"},"Children":[{"ID":"20260601165036-plsstv1","Type":"NodeParagraph","Properties":{"id":"20260601165036-plsstv1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260601165036-w2piloe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-w2piloe","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4rbjdij","Type":"NodeParagraph","Properties":{"id":"20260601165036-4rbjdij","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260601165036-sbj4dko","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sbj4dko","updated":"20260601165036"},"Children":[{"ID":"20260601165036-oqhmitq","Type":"NodeParagraph","Properties":{"id":"20260601165036-oqhmitq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260601165036-c2xwaq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-c2xwaq3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-jgiw8gj","Type":"NodeParagraph","Properties":{"id":"20260601165036-jgiw8gj","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260601165036-wutgh30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wutgh30","updated":"20260601165036"},"Children":[{"ID":"20260601165036-xgg0ltd","Type":"NodeParagraph","Properties":{"id":"20260601165036-xgg0ltd","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260601165036-3ufbvlp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3ufbvlp","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kdavr2y","Type":"NodeParagraph","Properties":{"id":"20260601165036-kdavr2y","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260601165036-qmtimd8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-qmtimd8","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vptn493","Type":"NodeParagraph","Properties":{"id":"20260601165036-vptn493","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260601165036-5pxyk7k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5pxyk7k","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7hu02c9","Type":"NodeParagraph","Properties":{"id":"20260601165036-7hu02c9","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260601165036-arc0jdb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-arc0jdb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3ly87op","Type":"NodeParagraph","Properties":{"id":"20260601165036-3ly87op","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260601165036-41qddom","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-41qddom","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8zq1zeq","Type":"NodeParagraph","Properties":{"id":"20260601165036-8zq1zeq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260601165036-nynn99m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nynn99m","updated":"20260601165036"},"Children":[{"ID":"20260601165036-unhidu8","Type":"NodeParagraph","Properties":{"id":"20260601165036-unhidu8","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260601165036-wtx03f9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wtx03f9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ch5ghbo","Type":"NodeParagraph","Properties":{"id":"20260601165036-ch5ghbo","updated":"20260602084055"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260601165036-84rzc5i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-84rzc5i","updated":"20260601165036"},"Children":[{"ID":"20260601165036-6l199ln","Type":"NodeParagraph","Properties":{"id":"20260601165036-6l199ln","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260601165036-cx5wyla","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-cx5wyla","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ymjaca5","Type":"NodeParagraph","Properties":{"id":"20260601165036-ymjaca5","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260601165036-vwp7x32","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-vwp7x32","updated":"20260601165036"},"Children":[{"ID":"20260601165036-fluflc7","Type":"NodeParagraph","Properties":{"id":"20260601165036-fluflc7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260601165036-fe3jjks","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-fe3jjks","updated":"20260601165036"},"Children":[{"ID":"20260601165036-l0qkxo1","Type":"NodeParagraph","Properties":{"id":"20260601165036-l0qkxo1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260601165036-79kq8ku","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-79kq8ku","updated":"20260601165036"},"Children":[{"ID":"20260601165036-oc8idla","Type":"NodeParagraph","Properties":{"id":"20260601165036-oc8idla","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260601165036-gco812r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gco812r","updated":"20260601165036"},"Children":[{"ID":"20260601165036-96m6db6","Type":"NodeParagraph","Properties":{"id":"20260601165036-96m6db6","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260601165036-l1sq2zf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-l1sq2zf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qd6d9tp","Type":"NodeParagraph","Properties":{"id":"20260601165036-qd6d9tp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260601165036-cys9ml1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-cys9ml1","updated":"20260601165036"},"Children":[{"ID":"20260601165036-mefxruz","Type":"NodeParagraph","Properties":{"id":"20260601165036-mefxruz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260601165036-yqa1oie","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-yqa1oie","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dpu2ykg","Type":"NodeParagraph","Properties":{"id":"20260601165036-dpu2ykg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260601165036-i15dilv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-i15dilv","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0j5nsgp","Type":"NodeParagraph","Properties":{"id":"20260601165036-0j5nsgp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260601165036-lsi7f0j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lsi7f0j","updated":"20260601165036"},"Children":[{"ID":"20260601165036-akz3bey","Type":"NodeParagraph","Properties":{"id":"20260601165036-akz3bey","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260601165036-r44kgdm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-r44kgdm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-82wswub","Type":"NodeParagraph","Properties":{"id":"20260601165036-82wswub","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260601165036-1mdcbk4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1mdcbk4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tk2w9ke","Type":"NodeParagraph","Properties":{"id":"20260601165036-tk2w9ke","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260601165036-rqn8wcd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-rqn8wcd","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ikcj2hd","Type":"NodeParagraph","Properties":{"id":"20260601165036-ikcj2hd","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260601165036-cpuew4x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-cpuew4x","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sxq5xws","Type":"NodeParagraph","Properties":{"id":"20260601165036-sxq5xws","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260601165036-1tkhdxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1tkhdxh","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1kd1w08","Type":"NodeParagraph","Properties":{"id":"20260601165036-1kd1w08","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260601165036-13luzc9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-13luzc9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ex7ltqk","Type":"NodeParagraph","Properties":{"id":"20260601165036-ex7ltqk","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260601165036-0bewqb5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0bewqb5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7xqye6g","Type":"NodeParagraph","Properties":{"id":"20260601165036-7xqye6g","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260601165036-okg1san","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-okg1san","updated":"20260601165036"},"Children":[{"ID":"20260601165036-mzekr2v","Type":"NodeParagraph","Properties":{"id":"20260601165036-mzekr2v","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260601165036-j7g1d64","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j7g1d64","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ek0r4em","Type":"NodeParagraph","Properties":{"id":"20260601165036-ek0r4em","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260601165036-wwa0fw2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wwa0fw2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-3kv9ew1","Type":"NodeParagraph","Properties":{"id":"20260601165036-3kv9ew1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260601165036-gbupf87","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-gbupf87","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qgznafz","Type":"NodeParagraph","Properties":{"id":"20260601165036-qgznafz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260601165036-jkcdm4v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jkcdm4v","updated":"20260601165036"},"Children":[{"ID":"20260601165036-acor3ie","Type":"NodeParagraph","Properties":{"id":"20260601165036-acor3ie","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260601165036-5nfut3f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5nfut3f","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lo2wpdp","Type":"NodeParagraph","Properties":{"id":"20260601165036-lo2wpdp","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺。"}]}]},{"ID":"20260601165036-wpwexv4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wpwexv4","updated":"20260601165036"},"Children":[{"ID":"20260601165036-j6pa1zx","Type":"NodeParagraph","Properties":{"id":"20260601165036-j6pa1zx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260601165036-5o45c30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-5o45c30","updated":"20260601165036"},"Children":[{"ID":"20260601165036-18jmp80","Type":"NodeParagraph","Properties":{"id":"20260601165036-18jmp80","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260601165036-wn1ddou","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wn1ddou","updated":"20260601165036"},"Children":[{"ID":"20260601165036-usig81t","Type":"NodeParagraph","Properties":{"id":"20260601165036-usig81t","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260601165036-xzfirtq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-xzfirtq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-g0pxb8s","Type":"NodeParagraph","Properties":{"id":"20260601165036-g0pxb8s","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260601165036-oufz3ra","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-oufz3ra","updated":"20260601165036"},"Children":[{"ID":"20260601165036-5mzb5sb","Type":"NodeParagraph","Properties":{"id":"20260601165036-5mzb5sb","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260601165036-s7bsxgg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-s7bsxgg","updated":"20260601165036"},"Children":[{"ID":"20260601165036-7an6nlm","Type":"NodeParagraph","Properties":{"id":"20260601165036-7an6nlm","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260601165036-1o6j36d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-1o6j36d","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ff92c9e","Type":"NodeParagraph","Properties":{"id":"20260601165036-ff92c9e","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260601165036-jq8r3rb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-jq8r3rb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-evcv6pq","Type":"NodeParagraph","Properties":{"id":"20260601165036-evcv6pq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]},{"ID":"20260601165036-376hqmi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-376hqmi","updated":"20260601165036"},"Children":[{"ID":"20260601165036-44089zm","Type":"NodeParagraph","Properties":{"id":"20260601165036-44089zm","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260601165036-e0hs46r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-e0hs46r","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tlxgppi","Type":"NodeParagraph","Properties":{"id":"20260601165036-tlxgppi","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260602084028-33arnb8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084028-33arnb8","updated":"20260601165036"},"Children":[{"ID":"20260602084028-8bitol7","Type":"NodeParagraph","Properties":{"id":"20260602084028-8bitol7","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260602084028-wpqxqvd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084028-wpqxqvd","updated":"20260601165036"},"Children":[{"ID":"20260602084028-4f85umy","Type":"NodeParagraph","Properties":{"id":"20260602084028-4f85umy","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260602084028-yethu14","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084028-yethu14","updated":"20260602084028"},"Children":[{"ID":"20260602084028-wqerfkz","Type":"NodeParagraph","Properties":{"id":"20260602084028-wqerfkz","updated":"20260602083946"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260602084028-b7lhaok","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084028-b7lhaok","updated":"20260602084028"},"Children":[{"ID":"20260602084028-6cuf7cd","Type":"NodeParagraph","Properties":{"id":"20260602084028-6cuf7cd","updated":"20260602083956"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260602084028-hfq393j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084028-hfq393j","updated":"20260602084028"},"Children":[{"ID":"20260602084028-f8b1lyh","Type":"NodeParagraph","Properties":{"id":"20260602084028-f8b1lyh","updated":"20260602084013"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260602084046-q5s71km","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084046-q5s71km","updated":"20260602084046"},"Children":[{"ID":"20260602084046-zfcu3rk","Type":"NodeParagraph","Properties":{"id":"20260602084046-zfcu3rk","updated":"20260602084049"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260602084101-gg24tql","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084101-gg24tql","updated":"20260602084101"},"Children":[{"ID":"20260602084101-oxsxz3o","Type":"NodeParagraph","Properties":{"id":"20260602084101-oxsxz3o","updated":"20260602084101"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260602084117-ahhdtxy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084117-ahhdtxy","updated":"20260602084117"},"Children":[{"ID":"20260602084117-kmkt2p5","Type":"NodeParagraph","Properties":{"id":"20260602084117-kmkt2p5","updated":"20260602084118"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260602084359-q9x8h05","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084359-q9x8h05","updated":"20260602084359"},"Children":[{"ID":"20260602084359-mccpb8f","Type":"NodeParagraph","Properties":{"id":"20260602084359-mccpb8f","updated":"20260602084403"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260602084403-6iruwpp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084403-6iruwpp","updated":"20260602084403"},"Children":[{"ID":"20260602084403-1h54xh0","Type":"NodeParagraph","Properties":{"id":"20260602084403-1h54xh0","updated":"20260602084404"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260602084405-939eqnc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084405-939eqnc","updated":"20260602084405"},"Children":[{"ID":"20260602084405-pmr7tio","Type":"NodeParagraph","Properties":{"id":"20260602084405-pmr7tio","updated":"20260602084406"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260602084407-b7tzdzz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084407-b7tzdzz","updated":"20260602084407"},"Children":[{"ID":"20260602084407-0w857ou","Type":"NodeParagraph","Properties":{"id":"20260602084407-0w857ou","updated":"20260602084408"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260602084408-c7awn1b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084408-c7awn1b","updated":"20260602084408"},"Children":[{"ID":"20260602084408-a9ud6iz","Type":"NodeParagraph","Properties":{"id":"20260602084408-a9ud6iz","updated":"20260602084410"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260602084411-qauu7k1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084411-qauu7k1","updated":"20260602084411"},"Children":[{"ID":"20260602084411-gqbxd8f","Type":"NodeParagraph","Properties":{"id":"20260602084411-gqbxd8f","updated":"20260602084412"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260602084413-ountlcv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084413-ountlcv","updated":"20260602084413"},"Children":[{"ID":"20260602084413-5y8hqvg","Type":"NodeParagraph","Properties":{"id":"20260602084413-5y8hqvg","updated":"20260602084414"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260602084415-xdz7f42","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084415-xdz7f42","updated":"20260602084415"},"Children":[{"ID":"20260602084415-r8ypha2","Type":"NodeParagraph","Properties":{"id":"20260602084415-r8ypha2","updated":"20260602084416"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260602084416-gxuk1qt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084416-gxuk1qt","updated":"20260602084416"},"Children":[{"ID":"20260602084416-dmv4giz","Type":"NodeParagraph","Properties":{"id":"20260602084416-dmv4giz","updated":"20260602084417"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260602084418-gwnbkdb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084418-gwnbkdb","updated":"20260602084418"},"Children":[{"ID":"20260602084418-fd2o9zl","Type":"NodeParagraph","Properties":{"id":"20260602084418-fd2o9zl","updated":"20260602084419"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260602084420-0hhe6tx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084420-0hhe6tx","updated":"20260602084420"},"Children":[{"ID":"20260602084420-kfn83s1","Type":"NodeParagraph","Properties":{"id":"20260602084420-kfn83s1","updated":"20260602084421"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260602084421-brqbv6l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084421-brqbv6l","updated":"20260602084421"},"Children":[{"ID":"20260602084421-ezah656","Type":"NodeParagraph","Properties":{"id":"20260602084421-ezah656","updated":"20260602084423"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260602084424-221d8j4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084424-221d8j4","updated":"20260602084424"},"Children":[{"ID":"20260602084424-4beu8k3","Type":"NodeParagraph","Properties":{"id":"20260602084424-4beu8k3","updated":"20260602084425"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260602084426-a0vcvfb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084426-a0vcvfb","updated":"20260602084426"},"Children":[{"ID":"20260602084426-4nz46gh","Type":"NodeParagraph","Properties":{"id":"20260602084426-4nz46gh","updated":"20260602084432"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260602084432-fvlkuif","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084432-fvlkuif","updated":"20260602084432"},"Children":[{"ID":"20260602084432-2b6pxnx","Type":"NodeParagraph","Properties":{"id":"20260602084432-2b6pxnx","updated":"20260602084436"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260602084453-tin5fyg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084453-tin5fyg","updated":"20260602084453"},"Children":[{"ID":"20260602084453-h2lnvaa","Type":"NodeParagraph","Properties":{"id":"20260602084453-h2lnvaa","updated":"20260602084453"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260602165717-quj88ey","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602165717-quj88ey","updated":"20260602165726"},"Children":[{"ID":"20260602165717-ykcx1jv","Type":"NodeParagraph","Properties":{"id":"20260602165717-ykcx1jv","updated":"20260602165726"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260602084447-2yuvv3o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602084447-2yuvv3o","updated":"20260602084447"},"Children":[{"ID":"20260602084447-ddcb5kw","Type":"NodeParagraph","Properties":{"id":"20260602084447-ddcb5kw","updated":"20260602084447"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260601165036-tsc4fq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-tsc4fq3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-tup1g45","Type":"NodeParagraph","Properties":{"id":"20260601165036-tup1g45","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260601165036-aawthym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-aawthym","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9gljftr","Type":"NodeParagraph","Properties":{"id":"20260601165036-9gljftr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260601165036-u8qu2fq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-u8qu2fq","updated":"20260601165036"},"Children":[{"ID":"20260601165036-j1wq7wz","Type":"NodeParagraph","Properties":{"id":"20260601165036-j1wq7wz","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260601165036-13zdx21","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-13zdx21","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ehl6ujo","Type":"NodeParagraph","Properties":{"id":"20260601165036-ehl6ujo","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260601165036-uqh0lnf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-uqh0lnf","updated":"20260601165036"},"Children":[{"ID":"20260601165036-8f4hmnx","Type":"NodeParagraph","Properties":{"id":"20260601165036-8f4hmnx","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260601165036-3lb5dxb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3lb5dxb","updated":"20260601165036"},"Children":[{"ID":"20260601165036-bx8vtqh","Type":"NodeParagraph","Properties":{"id":"20260601165036-bx8vtqh","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260601165036-nyshyfi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-nyshyfi","updated":"20260601165036"},"Children":[{"ID":"20260601165036-d3lfzif","Type":"NodeParagraph","Properties":{"id":"20260601165036-d3lfzif","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260601165036-3fj6gya","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3fj6gya","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dfdakfl","Type":"NodeParagraph","Properties":{"id":"20260601165036-dfdakfl","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260601165036-av0lfer","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-av0lfer","updated":"20260601165036"},"Children":[{"ID":"20260601165036-gmlimoa","Type":"NodeParagraph","Properties":{"id":"20260601165036-gmlimoa","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260601165036-6mq5kva","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6mq5kva","updated":"20260601165036"},"Children":[{"ID":"20260601165036-qym26w2","Type":"NodeParagraph","Properties":{"id":"20260601165036-qym26w2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260601165036-0u69os5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-0u69os5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pj9ac1q","Type":"NodeParagraph","Properties":{"id":"20260601165036-pj9ac1q","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260601165036-j2p03ax","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-j2p03ax","updated":"20260601165036"},"Children":[{"ID":"20260601165036-asrm7ed","Type":"NodeParagraph","Properties":{"id":"20260601165036-asrm7ed","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260601165036-a6qu1re","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-a6qu1re","updated":"20260601165036"},"Children":[{"ID":"20260601165036-vjlu0wq","Type":"NodeParagraph","Properties":{"id":"20260601165036-vjlu0wq","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260601165036-lrts0v5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lrts0v5","updated":"20260601165036"},"Children":[{"ID":"20260601165036-pcqhcu1","Type":"NodeParagraph","Properties":{"id":"20260601165036-pcqhcu1","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260601165036-wup3tzi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-wup3tzi","updated":"20260601165036"},"Children":[{"ID":"20260601165036-eow37t8","Type":"NodeParagraph","Properties":{"id":"20260601165036-eow37t8","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260601165036-3yo55tk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-3yo55tk","updated":"20260601165036"},"Children":[{"ID":"20260601165036-ta6yue2","Type":"NodeParagraph","Properties":{"id":"20260601165036-ta6yue2","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260601165036-6ica3bw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-6ica3bw","updated":"20260601165036"},"Children":[{"ID":"20260601165036-kxeiilr","Type":"NodeParagraph","Properties":{"id":"20260601165036-kxeiilr","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260601165036-sfjfxdh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-sfjfxdh","updated":"20260601165036"},"Children":[{"ID":"20260601165036-0g9xtql","Type":"NodeParagraph","Properties":{"id":"20260601165036-0g9xtql","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260601165036-a1o46sy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-a1o46sy","updated":"20260601165036"},"Children":[{"ID":"20260601165036-lrvephg","Type":"NodeParagraph","Properties":{"id":"20260601165036-lrvephg","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260601165036-yoiqlvm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-yoiqlvm","updated":"20260601165036"},"Children":[{"ID":"20260601165036-zf8z05o","Type":"NodeParagraph","Properties":{"id":"20260601165036-zf8z05o","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260601165036-isw2m3w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-isw2m3w","updated":"20260601165036"},"Children":[{"ID":"20260601165036-sahe320","Type":"NodeParagraph","Properties":{"id":"20260601165036-sahe320","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260601165036-zri6l90","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-zri6l90","updated":"20260601165036"},"Children":[{"ID":"20260601165036-9nj1a1a","Type":"NodeParagraph","Properties":{"id":"20260601165036-9nj1a1a","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260601165036-46u9cm2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-46u9cm2","updated":"20260601165036"},"Children":[{"ID":"20260601165036-mbowm9p","Type":"NodeParagraph","Properties":{"id":"20260601165036-mbowm9p","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260601165036-lipo41p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-lipo41p","updated":"20260601165036"},"Children":[{"ID":"20260601165036-1nh9s8m","Type":"NodeParagraph","Properties":{"id":"20260601165036-1nh9s8m","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]},{"ID":"20260602163241-1wmclm5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602163241-1wmclm5","updated":"20260602163241"},"Children":[{"ID":"20260602163241-dj0fq20","Type":"NodeParagraph","Properties":{"id":"20260602163241-dj0fq20","updated":"20260602163456"},"Children":[{"Type":"NodeText","Data":"古人云：“知行合一。”而在现代决策理论中，这一思想被进一步具体化为一种动态更新的过程：人并非先有完备之知，才敢行动，而是在行动中修正认知。正如贝叶斯原理所揭示的——判断并非一成不变，而是在一次次反馈中逼近真实。由此看来，真正的理性，不是避免犯错，而是不断纠错。"}]}]},{"ID":"20260602170210-ya6g0yp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170210-ya6g0yp","updated":"20260602170210"},"Children":[{"ID":"20260602170210-zo1p9k7","Type":"NodeParagraph","Properties":{"id":"20260602170210-zo1p9k7","updated":"20260602170220"},"Children":[{"Type":"NodeText","Data":"破窗效应：如果环境中的不良现象被放任存在，会诱使人们效仿，甚至变本加厉。"}]}]},{"ID":"20260602170228-nq1qlbx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170228-nq1qlbx","updated":"20260602170228"},"Children":[{"ID":"20260602170228-n97aff2","Type":"NodeParagraph","Properties":{"id":"20260602170228-n97aff2","updated":"20260602170232"},"Children":[{"Type":"NodeText","Data":"锚定效应：人们在做决定时，容易受第一印象或第一条信息的支配。"}]}]},{"ID":"20260602170239-dhnojn2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170239-dhnojn2","updated":"20260602170239"},"Children":[{"ID":"20260602170239-sprpne4","Type":"NodeParagraph","Properties":{"id":"20260602170239-sprpne4","updated":"20260602170244"},"Children":[{"Type":"NodeText","Data":"羊群效应：指人们经常受到多数人影响，而跟从大众的思想或行为。"}]}]},{"ID":"20260602170251-pgoh4b7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170251-pgoh4b7","updated":"20260602170251"},"Children":[{"ID":"20260602170251-3d6yu7p","Type":"NodeParagraph","Properties":{"id":"20260602170251-3d6yu7p","updated":"20260602170255"},"Children":[{"Type":"NodeText","Data":"习得性无助：指人在经历了某种失败或挫折后，产生的放弃努力的悲观心理。"}]}]},{"ID":"20260602170304-nsq3s23","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170304-nsq3s23","updated":"20260602170304"},"Children":[{"ID":"20260602170304-j6aeibe","Type":"NodeParagraph","Properties":{"id":"20260602170304-j6aeibe","updated":"20260602170308"},"Children":[{"Type":"NodeText","Data":"手表定律：只有一只手表时能知道时间，拥有两只或以上反而无法确定时间。"}]}]},{"ID":"20260602170326-mi4xk7u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170326-mi4xk7u","updated":"20260602170326"},"Children":[{"ID":"20260602170326-r8hz04f","Type":"NodeParagraph","Properties":{"id":"20260602170326-r8hz04f","updated":"20260602170333"},"Children":[{"Type":"NodeText","Data":"鳄鱼法则：当被鳄鱼咬住腿，若用手去解救，手也会被咬。唯一的办法是牺牲那条腿。它揭示了及时止损、果决舍弃的智慧。"}]}]},{"ID":"20260602170342-991wtnl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170342-991wtnl","updated":"20260602170342"},"Children":[{"ID":"20260602170343-dudbea4","Type":"NodeParagraph","Properties":{"id":"20260602170343-dudbea4","updated":"20260602170351"},"Children":[{"Type":"NodeText","Data":"刺猬理论：刺猬天冷时靠拢取暖，但必须保持距离以免刺伤对方。完美诠释了人际交往中“距离产生美”以及分寸感的重要性。"}]}]},{"ID":"20260602170400-9fwnnv8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170400-9fwnnv8","updated":"20260602170400"},"Children":[{"ID":"20260602170400-cezjueq","Type":"NodeParagraph","Properties":{"id":"20260602170400-cezjueq","updated":"20260602170420"},"Children":[{"Type":"NodeText","Data":"熵增定律：在一个封闭系统中，若无外力做功，系统会自发趋向无序和混乱。人需要主动引入“负熵”（如持续学习、自律），才能对抗生命的无序与懈怠。"}]}]},{"ID":"20260602170433-lixuby3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170433-lixuby3","updated":"20260602170510"},"Children":[{"ID":"20260602170433-vg8f3wf","Type":"NodeParagraph","Properties":{"id":"20260602170433-vg8f3wf","updated":"20260602170510"},"Children":[{"Type":"NodeText","Data":"氨基酸组合效应：组成人体蛋白的8种氨基酸，只要有一种不足，其他7种就无法合成蛋白质。适合论证团队合作中缺一不可的整体性，或者个人素养的全面性。"}]}]},{"ID":"20260602170635-gopiqma","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170635-gopiqma","updated":"20260602170635"},"Children":[{"ID":"20260602170635-ajlo8sb","Type":"NodeParagraph","Properties":{"id":"20260602170635-ajlo8sb","updated":"20260602170645"},"Children":[{"Type":"NodeText","Data":"幸存者效应：只看到“活下来的人”“成功者”“被看见的案例”，却忽略了那些被淘汰、失败、沉默的大多数，于是容易得出片面甚至错误的结论。"}]}]},{"ID":"20260602170707-cychhx6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170707-cychhx6","updated":"20260602170707"},"Children":[{"ID":"20260602170707-ztlvk06","Type":"NodeParagraph","Properties":{"id":"20260602170707-ztlvk06","updated":"20260602170830"},"Children":[{"Type":"NodeText","Data":"奥卡姆剃刀：如无必要，勿增实体。"}]}]},{"ID":"20260602170831-qjzvn0o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602170831-qjzvn0o","updated":"20260602170856"},"Children":[{"ID":"20260602170831-12p9okb","Type":"NodeParagraph","Properties":{"id":"20260602170831-12p9okb","updated":"20260602170856"},"Children":[{"Type":"NodeText","Data":"墨菲定律：如果有两种或两种以上的方式去做某件事，而其中一种会导致灾难，那么必定会有人选择这种方式。"}]}]},{"ID":"20260602171208-ksz7k51","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602171208-ksz7k51","updated":"20260602171208"},"Children":[{"ID":"20260602171208-64itzf9","Type":"NodeParagraph","Properties":{"id":"20260602171208-64itzf9","updated":"20260602171226"},"Children":[{"Type":"NodeText","Data":"波普尔证伪主义：科学理论的价值不在于被证明为真，而在于能够被不断检验并有可能被证伪，从而在批判中逐步逼近真理。"}]}]},{"ID":"20260602171307-bvbyopl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602171307-bvbyopl","updated":"20260602171307"},"Children":[{"ID":"20260602171307-ussjpch","Type":"NodeParagraph","Properties":{"id":"20260602171307-ussjpch","updated":"20260602171318"},"Children":[{"Type":"NodeText","Data":"皮亚杰建构主义：知识不是接受的，是主动建构的"}]}]},{"ID":"20260602171342-c6cjze7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602171342-c6cjze7","updated":"20260602171342"},"Children":[{"ID":"20260602171342-k1ig1gb","Type":"NodeParagraph","Properties":{"id":"20260602171342-k1ig1gb","updated":"20260602171348"},"Children":[{"Type":"NodeText","Data":"怀疑主义：对既有认知保持怀疑"}]}]},{"ID":"20260602171357-0m1ao0e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602171357-0m1ao0e","updated":"20260602171432"},"Children":[{"ID":"20260602171357-y0939qq","Type":"NodeParagraph","Properties":{"id":"20260602171357-y0939qq","updated":"20260602171432"},"Children":[{"Type":"NodeText","Data":"黑格尔辩证法：真理在矛盾和冲突中发展"}]}]},{"ID":"20260602171409-u3eroel","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260602171409-u3eroel","updated":"20260602171420"},"Children":[{"ID":"20260602171409-4109op0","Type":"NodeParagraph","Properties":{"id":"20260602171409-4109op0","updated":"20260602171420"},"Children":[{"Type":"NodeText","Data":"实践论：实践是检验真理的唯一标准"}]}]}]}]},{"ID":"20260601165036-ekxk1r3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165036-ekxk1r3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-dhp9u5j","Type":"NodeParagraph","Properties":{"id":"20260601165036-dhp9u5j","updated":"20260601165036"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。"}]}]}]}]},{"ID":"20260601165036-6s8myy3","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260601165036-6s8myy3","updated":"20260601165036"},"Children":[{"ID":"20260601165036-u7sf9s6","Type":"NodeParagraph","Properties":{"id":"20260601165036-u7sf9s6","updated":"20260601165036"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：840至860字"}]}]},{"ID":"20260601165208-276jdlm","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260601165208-276jdlm","updated":"20260601165208"},"Children":[{"ID":"20260601165208-r1hv48y","Type":"NodeParagraph","Properties":{"id":"20260601165208-r1hv48y","updated":"20260601165215"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260601165248-xv72sp7","Type":"NodeList","ListData":{},"Properties":{"id":"20260601165248-xv72sp7","updated":"20260601165248"},"Children":[{"ID":"20260601165248-hmk17cq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601165248-hmk17cq","updated":"20260601165248"},"Children":[{"ID":"20260601165224-wf2c3bc","Type":"NodeParagraph","Properties":{"id":"20260601165224-wf2c3bc","updated":"20260601165248"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]}]},{"ID":"20260601165036-edfo9q9","Type":"NodeList","ListData":{},"Properties":{"id":"20260601165036-edfo9q9","updated":"20260601165036"},"Children":[{"ID":"20260601165036-4eo203o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"2026