","TextMarkType":"strong","TextMarkTextContent":"设问"},{"Type":"NodeText","Data":"：用于段落开头或转折处，通过自问自答引发阅卷者思考，自然引出下文的深层剖析；"}]}]},{"ID":"20260603084231-d55hbst","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-d55hbst","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dcagmi7","Type":"NodeParagraph","Properties":{"id":"20260603084231-dcagmi7","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"反问"},{"Type":"NodeText","Data":"：用于论证高潮或结尾升华时，以无疑而问的强烈语气增强文章的论辩色彩与感染力，直击人心。"}]}]}]}]},{"ID":"20260603084231-blz3g7w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-blz3g7w","updated":"20260603084231"},"Children":[{"ID":"20260603084231-23yg7pq","Type":"NodeParagraph","Properties":{"id":"20260603084231-23yg7pq","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"善用修辞增添底蕴"},{"Type":"NodeText","Data":"：巧妙运用比喻、引用、化用古诗词等手法，避免辞藻堆砌，力求语言的精准与文学性。"}]}]}]}]},{"ID":"20260603084231-zg83lsi","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NS4=","Num":5},"Properties":{"id":"20260603084231-zg83lsi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ohzs59m","Type":"NodeParagraph","Properties":{"id":"20260603084231-ohzs59m","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"规避AI痕迹"},{"Type":"NodeText","Data":"："}]},{"ID":"20260603084231-9aa8rwt","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-9aa8rwt","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qo6zbz3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qo6zbz3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-218x3q9","Type":"NodeParagraph","Properties":{"id":"20260603084231-218x3q9","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁"},{"Type":"NodeText","Data":"使用空洞的排比句堆砌（如“梦想是……梦想是……”）。"}]}]},{"ID":"20260603084231-zoibjnu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zoibjnu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-90v3txp","Type":"NodeParagraph","Properties":{"id":"20260603084231-90v3txp","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁"},{"Type":"NodeText","Data":"使用“综上所述”、“总而言之”、“随着时代的发展”等刻板的AI常用过渡词。"}]}]},{"ID":"20260603084231-ztoqgcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ztoqgcq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7l54par","Type":"NodeParagraph","Properties":{"id":"20260603084231-7l54par","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"允许表达中有轻微的个性化跳跃或情感化的重复强调，使文章更具“人味”和真情实感。"}]}]}]}]},{"ID":"20260603084231-9jynxdt","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ni4=","Num":6},"Properties":{"id":"20260603084231-9jynxdt","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8tp6pjp","Type":"NodeParagraph","Properties":{"id":"20260603084231-8tp6pjp","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"思维与论证（核心技法）"},{"Type":"NodeText","Data":"   ："}]},{"ID":"20260603084231-hu4amo4","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-hu4amo4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-eydy4sx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-eydy4sx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-w2xehpk","Type":"NodeParagraph","Properties":{"id":"20260603084231-w2xehpk","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"必备论式组合"},{"Type":"NodeText","Data":"：优先使用下列方法中的两种及以上，根据文章需要自然融入，避免刻意拼装。"}]},{"ID":"20260603084231-4pg9tzw","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-4pg9tzw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-wwg3j8f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wwg3j8f","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xhcvgia","Type":"NodeParagraph","Properties":{"id":"20260603084231-xhcvgia","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分解论证（拉升与钻洞）"},{"Type":"NodeText","Data":"   ：证明分论点时，注意分论点间的层递关系。可采用“拉升式”（由底层肉身/物质体验升华到高层灵魂/生存层面）或“钻洞式”（由表层社会现象深入挖掘背后的文化基因或心理动因）。"}]}]},{"ID":"20260603084231-j3qrnpi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-j3qrnpi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-n8giy45","Type":"NodeParagraph","Properties":{"id":"20260603084231-n8giy45","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"举例论证（典型事例）"},{"Type":"NodeText","Data":"   ：选取古今中外典型人物或时事热点，通过具体故事来支撑论点，做到叙议结合，拒绝单纯堆砌素材。"}]}]},{"ID":"20260603084231-85dix6g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-85dix6g","updated":"20260603084231"},"Children":[{"ID":"20260603084231-y0cn88z","Type":"NodeParagraph","Properties":{"id":"20260603084231-y0cn88z","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"归谬论证（反向推导）"},{"Type":"NodeText","Data":"   ：先提出与论点相反的假定，推导出荒谬或不可接受的后果，从而有力地反证原论点的正确性，增强说服力。"}]}]}]}]},{"ID":"20260603084231-airsmqh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-airsmqh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-c2qkw7g","Type":"NodeParagraph","Properties":{"id":"20260603084231-c2qkw7g","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"隐性植入辩证法"},{"Type":"NodeText","Data":"：将辩证法的三大规律(对立同一、量变质变、否定之否定)之一内化为文章的底层逻辑，但"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁直接出现"},{"Type":"NodeText","Data":"“对立统一”、“量变质变”、“否定之否定”等哲学术语。具体操作如下："}]},{"ID":"20260603084231-gvmpgst","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-gvmpgst","updated":"20260603084231"},"Children":[{"ID":"20260603084231-40vnebi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-40vnebi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-74c4g52","Type":"NodeParagraph","Properties":{"id":"20260603084231-74c4g52","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现矛盾转化"},{"Type":"NodeText","Data":"：分析事物内部的矛盾双方（如危与机、强与弱），阐述它们在特定条件下如何相互依存并向对立面转化。"}]}]},{"ID":"20260603084231-8tzc4w1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8tzc4w1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-twoxzz7","Type":"NodeParagraph","Properties":{"id":"20260603084231-twoxzz7","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现积累与飞跃"},{"Type":"NodeText","Data":"：论述从微小的积累到质的突破的过程，强调厚积薄发的重要性。"}]}]},{"ID":"20260603084231-liuhmp2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-liuhmp2","updated":"20260603084231"},"Children":[{"ID":"20260603084231-59oy5gd","Type":"NodeParagraph","Properties":{"id":"20260603084231-59oy5gd","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现螺旋上升"},{"Type":"NodeText","Data":"：展现事物发展不是简单的循环，而是看似回归原点实则境界提升的曲折前进过程。"}]}]}]}]},{"ID":"20260603084231-rpnlc3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rpnlc3x","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1311322","Type":"NodeParagraph","Properties":{"id":"20260603084231-1311322","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辅助论式拓展"},{"Type":"NodeText","Data":"：可适当穿插使用道理/引证论证、类比论证或反证法，丰富文章的论证维度。在进行深层逻辑剖析时，可灵活调用以下思维模型，以增强文章的思辨厚度："}]},{"ID":"20260603084231-2rzcyra","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-2rzcyra","updated":"20260603084231"},"Children":[{"ID":"20260603084231-x241urc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-x241urc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-f42y0zw","Type":"NodeParagraph","Properties":{"id":"20260603084231-f42y0zw","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"社会与心理效应"},{"Type":"NodeText","Data":"：破窗效应、羊群效应、习得性无助、幸存者效应。"}]}]},{"ID":"20260603084231-e09tzvr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e09tzvr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ftz0l7j","Type":"NodeParagraph","Properties":{"id":"20260603084231-ftz0l7j","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"决策与管理智慧"},{"Type":"NodeText","Data":"：锚定效应、手表定律、鳄鱼法则（及时止损）、氨基酸组合效应（整体与部分）。"}]}]},{"ID":"20260603084231-e31jqgq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e31jqgq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-b4d40m8","Type":"NodeParagraph","Properties":{"id":"20260603084231-b4d40m8","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"哲学与科学原理"},{"Type":"NodeText","Data":"：熵增定律（对抗无序）、奥卡姆剃刀（化繁为简）、墨菲定律、波普尔证伪主义、贝叶斯原理（动态认知）、皮亚杰建构主义、黑格尔辩证法、实践论。"}]}]}]}]},{"ID":"20260603084231-0f4kl6t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0f4kl6t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3fkzwpk","Type":"NodeParagraph","Properties":{"id":"20260603084231-3fkzwpk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"使用要求：严禁直接罗列名词或进行枯燥的科学解释。必须将这些原理内化为比喻或隐喻，自然地融入论证中（例如：用“熵增”比喻精神的懈怠，用“鳄鱼法则”比喻壮士断腕的决心）。"}]}]},{"ID":"20260603084231-x2exfpp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-x2exfpp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-d8a5th2","Type":"NodeParagraph","Properties":{"id":"20260603084231-d8a5th2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"论据要充分且鲜活，拒绝陈词滥调（避免过度使用司马迁、李白、爱迪生等老套素材）。结合时事热点、历史文化等多维度素材。"}]}]}]}]},{"ID":"20260603084231-1bvwdlo","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260603084231-1bvwdlo","updated":"20260603084231"},"Children":[{"ID":"20260603084231-02hxpeu","Type":"NodeParagraph","Properties":{"id":"20260603084231-02hxpeu","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"古典底蕴与化用："}]},{"ID":"20260603084231-5g4qdsg","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-5g4qdsg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rk465hw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rk465hw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uoy5uwv","Type":"NodeParagraph","Properties":{"id":"20260603084231-uoy5uwv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"至少自然嵌入2–3条下面提供的的典故、文章(不必引用原文，文章总结、提炼亦可)、诗词名句、电影，并保证与论证逻辑紧密相关。"}]},{"ID":"20260603084231-8lqdw43","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-8lqdw43","updated":"20260603084231"},"Children":[{"ID":"20260603084231-b5rsf7i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-b5rsf7i","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1taq6xo","Type":"NodeParagraph","Properties":{"id":"20260603084231-1taq6xo","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"《尚书》五福：寿、福、康宁、攸好德、考终命"}]}]},{"ID":"20260603084231-e2crab2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e2crab2","updated":"20260603084231"},"Children":[{"ID":"20260603084231-roaz4zr","Type":"NodeParagraph","Properties":{"id":"20260603084231-roaz4zr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"鲁迅：无穷的远方，无数的人们，都与我相关。"}]}]},{"ID":"20260603084231-58q74z0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-58q74z0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nn7vurx","Type":"NodeParagraph","Properties":{"id":"20260603084231-nn7vurx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260603084231-kd1178f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kd1178f","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uh0t2em","Type":"NodeParagraph","Properties":{"id":"20260603084231-uh0t2em","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603084231-4035jpi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4035jpi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4qulrkc","Type":"NodeParagraph","Properties":{"id":"20260603084231-4qulrkc","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260603084231-54g5hcj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-54g5hcj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2ylo63p","Type":"NodeParagraph","Properties":{"id":"20260603084231-2ylo63p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260603084231-89b4qzu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-89b4qzu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-k21dnup","Type":"NodeParagraph","Properties":{"id":"20260603084231-k21dnup","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260603084231-f5jas8t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-f5jas8t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6samm0c","Type":"NodeParagraph","Properties":{"id":"20260603084231-6samm0c","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260603084231-s72gcrm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-s72gcrm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zw5umgb","Type":"NodeParagraph","Properties":{"id":"20260603084231-zw5umgb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260603084231-vmfptq8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vmfptq8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ucu8zva","Type":"NodeParagraph","Properties":{"id":"20260603084231-ucu8zva","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260603084231-7wywwvx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7wywwvx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kzcf29k","Type":"NodeParagraph","Properties":{"id":"20260603084231-kzcf29k","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"《美丽心灵》约翰·纳什"}]}]},{"ID":"20260603084231-88pzm0x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-88pzm0x","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3vdf7tf","Type":"NodeParagraph","Properties":{"id":"20260603084231-3vdf7tf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"西格里夫·萨松：心有猛虎，细嗅蔷薇。"}]}]},{"ID":"20260603084231-x6yeipu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-x6yeipu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hrvkbil","Type":"NodeParagraph","Properties":{"id":"20260603084231-hrvkbil","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260603084231-u9q5wkj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-u9q5wkj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-px70uwr","Type":"NodeParagraph","Properties":{"id":"20260603084231-px70uwr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260603084231-swwr0ri","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-swwr0ri","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ybfb5y1","Type":"NodeParagraph","Properties":{"id":"20260603084231-ybfb5y1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260603084231-naro2u4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-naro2u4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i5033sd","Type":"NodeParagraph","Properties":{"id":"20260603084231-i5033sd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"海明威：一个人可以被毁灭， "},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"但不能被打败。"}]}]},{"ID":"20260603084231-swk9b6o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-swk9b6o","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ccp9uov","Type":"NodeParagraph","Properties":{"id":"20260603084231-ccp9uov","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"杨绛：生活一半是柴米油盐，一半是星辰大海。"}]}]},{"ID":"20260603084231-boy0yb0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-boy0yb0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jtc1jyn","Type":"NodeParagraph","Properties":{"id":"20260603084231-jtc1jyn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰：世界上只有一种英雄主义，就是在认清生活的真相之后依然热爱生活。"}]}]},{"ID":"20260603084231-mhvt8ns","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mhvt8ns","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3qaydb9","Type":"NodeParagraph","Properties":{"id":"20260603084231-3qaydb9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"罗素：参差多态乃是人类幸福的本源。"}]}]},{"ID":"20260603084231-uxny9sc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-uxny9sc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-g36pynz","Type":"NodeParagraph","Properties":{"id":"20260603084231-g36pynz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260603084231-45jah1b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-45jah1b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-eoifbww","Type":"NodeParagraph","Properties":{"id":"20260603084231-eoifbww","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260603084231-3swlak7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-3swlak7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zu3auaz","Type":"NodeParagraph","Properties":{"id":"20260603084231-zu3auaz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260603084231-3mgejue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-3mgejue","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5fhoc5a","Type":"NodeParagraph","Properties":{"id":"20260603084231-5fhoc5a","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260603084231-ny1ses1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ny1ses1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mel8ztk","Type":"NodeParagraph","Properties":{"id":"20260603084231-mel8ztk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260603084231-cmk20nl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-cmk20nl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-soaa2lr","Type":"NodeParagraph","Properties":{"id":"20260603084231-soaa2lr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260603084231-m37hiq6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m37hiq6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cgnis6t","Type":"NodeParagraph","Properties":{"id":"20260603084231-cgnis6t","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260603084231-05uia6h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-05uia6h","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pwb9nyy","Type":"NodeParagraph","Properties":{"id":"20260603084231-pwb9nyy","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260603084231-mpc9puj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mpc9puj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-npu5qcs","Type":"NodeParagraph","Properties":{"id":"20260603084231-npu5qcs","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260603084231-rhgaza1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rhgaza1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3tr8hs8","Type":"NodeParagraph","Properties":{"id":"20260603084231-3tr8hs8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260603084231-5jts3ep","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5jts3ep","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hlav77k","Type":"NodeParagraph","Properties":{"id":"20260603084231-hlav77k","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260603084231-jqruyaz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jqruyaz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kh5ijre","Type":"NodeParagraph","Properties":{"id":"20260603084231-kh5ijre","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260603084231-j2r0y7r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-j2r0y7r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-gf3cze9","Type":"NodeParagraph","Properties":{"id":"20260603084231-gf3cze9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260603084231-w0ao9co","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-w0ao9co","updated":"20260603084231"},"Children":[{"ID":"20260603084231-a05hw8j","Type":"NodeParagraph","Properties":{"id":"20260603084231-a05hw8j","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"特鲁多医生墓志铭：医生有时治愈，常常帮助，总是安慰。"}]}]},{"ID":"20260603084231-tzapyn3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tzapyn3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9zf2d7s","Type":"NodeParagraph","Properties":{"id":"20260603084231-9zf2d7s","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260603084231-yl78pnn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-yl78pnn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-lq5rdkd","Type":"NodeParagraph","Properties":{"id":"20260603084231-lq5rdkd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260603084231-g6j5wu4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-g6j5wu4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-fvdm34c","Type":"NodeParagraph","Properties":{"id":"20260603084231-fvdm34c","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260603084231-09rxxqi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-09rxxqi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-w10hu4o","Type":"NodeParagraph","Properties":{"id":"20260603084231-w10hu4o","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260603084231-8s7k0eu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8s7k0eu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3je23jb","Type":"NodeParagraph","Properties":{"id":"20260603084231-3je23jb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260603084231-e1jpo5b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e1jpo5b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-n31kk8d","Type":"NodeParagraph","Properties":{"id":"20260603084231-n31kk8d","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260603084231-sdm2boi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-sdm2boi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-l28f6zg","Type":"NodeParagraph","Properties":{"id":"20260603084231-l28f6zg","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260603084231-stipstv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-stipstv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-z55bcfw","Type":"NodeParagraph","Properties":{"id":"20260603084231-z55bcfw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260603084231-0a0zglm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0a0zglm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ygbe5w9","Type":"NodeParagraph","Properties":{"id":"20260603084231-ygbe5w9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260603084231-9ig6qpq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9ig6qpq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ahup9jv","Type":"NodeParagraph","Properties":{"id":"20260603084231-ahup9jv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260603084231-rjhusvv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rjhusvv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uyqyn94","Type":"NodeParagraph","Properties":{"id":"20260603084231-uyqyn94","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260603084231-ihqbyi5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ihqbyi5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-48lwnu0","Type":"NodeParagraph","Properties":{"id":"20260603084231-48lwnu0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260603084231-wpgkrzc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wpgkrzc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-yj1n7jd","Type":"NodeParagraph","Properties":{"id":"20260603084231-yj1n7jd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260603084231-nv8xlab","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-nv8xlab","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7j4t7qn","Type":"NodeParagraph","Properties":{"id":"20260603084231-7j4t7qn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260603084231-vbtbmhq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vbtbmhq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mk60nbk","Type":"NodeParagraph","Properties":{"id":"20260603084231-mk60nbk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260603084231-jkkq2ap","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jkkq2ap","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nrusc0u","Type":"NodeParagraph","Properties":{"id":"20260603084231-nrusc0u","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260603084231-jcn2hva","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jcn2hva","updated":"20260603084231"},"Children":[{"ID":"20260603084231-a3y5oyh","Type":"NodeParagraph","Properties":{"id":"20260603084231-a3y5oyh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260603084231-zxmexix","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zxmexix","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pqe9p18","Type":"NodeParagraph","Properties":{"id":"20260603084231-pqe9p18","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260603084231-67vqx3a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-67vqx3a","updated":"20260603084231"},"Children":[{"ID":"20260603084231-gie5xug","Type":"NodeParagraph","Properties":{"id":"20260603084231-gie5xug","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260603084231-0m6cwe3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0m6cwe3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-smwmxkk","Type":"NodeParagraph","Properties":{"id":"20260603084231-smwmxkk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260603084231-n85cejm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-n85cejm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xz3uxs6","Type":"NodeParagraph","Properties":{"id":"20260603084231-xz3uxs6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260603084231-7p08tex","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7p08tex","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jcp1erh","Type":"NodeParagraph","Properties":{"id":"20260603084231-jcp1erh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260603084231-gybclon","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gybclon","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ssnddtt","Type":"NodeParagraph","Properties":{"id":"20260603084231-ssnddtt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260603084231-nt6j7zq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-nt6j7zq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-npb4tip","Type":"NodeParagraph","Properties":{"id":"20260603084231-npb4tip","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260603084231-ongej7i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ongej7i","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3xmmak3","Type":"NodeParagraph","Properties":{"id":"20260603084231-3xmmak3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260603084231-m2ilhu6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m2ilhu6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-594lvh7","Type":"NodeParagraph","Properties":{"id":"20260603084231-594lvh7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260603084231-r42voxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-r42voxh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-46tvobx","Type":"NodeParagraph","Properties":{"id":"20260603084231-46tvobx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603084231-m08nah3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m08nah3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-08lctjq","Type":"NodeParagraph","Properties":{"id":"20260603084231-08lctjq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260603084231-5oce8ai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5oce8ai","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jjb5r51","Type":"NodeParagraph","Properties":{"id":"20260603084231-jjb5r51","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260603084231-vqsqbz6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vqsqbz6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-n84we7w","Type":"NodeParagraph","Properties":{"id":"20260603084231-n84we7w","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260603084231-jylickq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jylickq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nypb00q","Type":"NodeParagraph","Properties":{"id":"20260603084231-nypb00q","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260603084231-tkuz7sc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tkuz7sc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8t27ndu","Type":"NodeParagraph","Properties":{"id":"20260603084231-8t27ndu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260603084231-8jnofad","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8jnofad","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jc4nikq","Type":"NodeParagraph","Properties":{"id":"20260603084231-jc4nikq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260603084231-hdusojh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-hdusojh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qailhm8","Type":"NodeParagraph","Properties":{"id":"20260603084231-qailhm8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260603084231-2uv76fh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2uv76fh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-asry3fv","Type":"NodeParagraph","Properties":{"id":"20260603084231-asry3fv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260603084231-j7wkqg0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-j7wkqg0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kmxk8ky","Type":"NodeParagraph","Properties":{"id":"20260603084231-kmxk8ky","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260603084231-pzy7lre","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pzy7lre","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qqadvvk","Type":"NodeParagraph","Properties":{"id":"20260603084231-qqadvvk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260603084231-gs858c5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gs858c5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-y9irpx1","Type":"NodeParagraph","Properties":{"id":"20260603084231-y9irpx1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603084231-lik1aio","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lik1aio","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qr7f3ek","Type":"NodeParagraph","Properties":{"id":"20260603084231-qr7f3ek","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260603084231-8vx8f9p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8vx8f9p","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1e1kwkn","Type":"NodeParagraph","Properties":{"id":"20260603084231-1e1kwkn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260603084231-5fh7axw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5fh7axw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nlbm6kf","Type":"NodeParagraph","Properties":{"id":"20260603084231-nlbm6kf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603084231-d3dlk9g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-d3dlk9g","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9y3b0zc","Type":"NodeParagraph","Properties":{"id":"20260603084231-9y3b0zc","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260603084231-jivt40o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jivt40o","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rpwoxvx","Type":"NodeParagraph","Properties":{"id":"20260603084231-rpwoxvx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260603084231-9lbm8ce","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9lbm8ce","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uq7uvc9","Type":"NodeParagraph","Properties":{"id":"20260603084231-uq7uvc9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260603084231-kjusfw0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kjusfw0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-c6q2le7","Type":"NodeParagraph","Properties":{"id":"20260603084231-c6q2le7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260603084231-s0zhjbb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-s0zhjbb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-t6zk8kf","Type":"NodeParagraph","Properties":{"id":"20260603084231-t6zk8kf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260603084231-2li6ux1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2li6ux1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ocg82w6","Type":"NodeParagraph","Properties":{"id":"20260603084231-ocg82w6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260603084231-ga61y5w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ga61y5w","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1bhr4qf","Type":"NodeParagraph","Properties":{"id":"20260603084231-1bhr4qf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260603084231-08wc79v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-08wc79v","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1mxk0ma","Type":"NodeParagraph","Properties":{"id":"20260603084231-1mxk0ma","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260603084231-b8bsfcj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-b8bsfcj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-b99lvfx","Type":"NodeParagraph","Properties":{"id":"20260603084231-b99lvfx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260603084231-gzi86zk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gzi86zk","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sc007q6","Type":"NodeParagraph","Properties":{"id":"20260603084231-sc007q6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260603084231-qhzef6y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qhzef6y","updated":"20260603084231"},"Children":[{"ID":"20260603084231-tg4ltk8","Type":"NodeParagraph","Properties":{"id":"20260603084231-tg4ltk8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260603084231-x5kt4e4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-x5kt4e4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-weov8oz","Type":"NodeParagraph","Properties":{"id":"20260603084231-weov8oz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603084231-0eeqiym","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0eeqiym","updated":"20260603084231"},"Children":[{"ID":"20260603084231-239ugjk","Type":"NodeParagraph","Properties":{"id":"20260603084231-239ugjk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260603084231-025obex","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-025obex","updated":"20260603084231"},"Children":[{"ID":"20260603084231-onrg6ip","Type":"NodeParagraph","Properties":{"id":"20260603084231-onrg6ip","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260603084231-lankpq8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lankpq8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-r8su5ru","Type":"NodeParagraph","Properties":{"id":"20260603084231-r8su5ru","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260603084231-gvh43s1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gvh43s1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nczrs1w","Type":"NodeParagraph","Properties":{"id":"20260603084231-nczrs1w","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260603084231-de95jxg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-de95jxg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mhmpq5x","Type":"NodeParagraph","Properties":{"id":"20260603084231-mhmpq5x","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260603084231-tig75qd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tig75qd","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sded0co","Type":"NodeParagraph","Properties":{"id":"20260603084231-sded0co","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260603084231-ukde3x1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ukde3x1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9t03s3f","Type":"NodeParagraph","Properties":{"id":"20260603084231-9t03s3f","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260603084231-ojgyujs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ojgyujs","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rf21t4g","Type":"NodeParagraph","Properties":{"id":"20260603084231-rf21t4g","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260603084231-pf9qlnl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pf9qlnl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-s5f3wyv","Type":"NodeParagraph","Properties":{"id":"20260603084231-s5f3wyv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260603084231-v0ohj0i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-v0ohj0i","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jqobuj7","Type":"NodeParagraph","Properties":{"id":"20260603084231-jqobuj7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260603084231-t2gvh54","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-t2gvh54","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4csoqa8","Type":"NodeParagraph","Properties":{"id":"20260603084231-4csoqa8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260603084231-r4knkt5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-r4knkt5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nucklb8","Type":"NodeParagraph","Properties":{"id":"20260603084231-nucklb8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260603084231-ntu2s0t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ntu2s0t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ncqf9ju","Type":"NodeParagraph","Properties":{"id":"20260603084231-ncqf9ju","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260603084231-q5g2ah3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-q5g2ah3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2jm05yt","Type":"NodeParagraph","Properties":{"id":"20260603084231-2jm05yt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260603084231-1kyph95","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-1kyph95","updated":"20260603084231"},"Children":[{"ID":"20260603084231-x9b79ai","Type":"NodeParagraph","Properties":{"id":"20260603084231-x9b79ai","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260603084231-i7y8jtm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-i7y8jtm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sqgklf7","Type":"NodeParagraph","Properties":{"id":"20260603084231-sqgklf7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260603084231-1su3n3t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-1su3n3t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-u8j9k2t","Type":"NodeParagraph","Properties":{"id":"20260603084231-u8j9k2t","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260603084231-4jwb1a6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4jwb1a6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o8nmpnd","Type":"NodeParagraph","Properties":{"id":"20260603084231-o8nmpnd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260603084231-dabp630","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dabp630","updated":"20260603084231"},"Children":[{"ID":"20260603084231-23esbu7","Type":"NodeParagraph","Properties":{"id":"20260603084231-23esbu7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260603084231-jwtl7k4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jwtl7k4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qyl2g91","Type":"NodeParagraph","Properties":{"id":"20260603084231-qyl2g91","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260603084231-gjbqpqt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gjbqpqt","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7owr9ja","Type":"NodeParagraph","Properties":{"id":"20260603084231-7owr9ja","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260603084231-s7jsrqj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-s7jsrqj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8symaqj","Type":"NodeParagraph","Properties":{"id":"20260603084231-8symaqj","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260603084231-bbeijkr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-bbeijkr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-k6utk6q","Type":"NodeParagraph","Properties":{"id":"20260603084231-k6utk6q","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260603084231-2chqtq9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2chqtq9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5nkn695","Type":"NodeParagraph","Properties":{"id":"20260603084231-5nkn695","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260603084231-dgozik1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dgozik1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2qxeexy","Type":"NodeParagraph","Properties":{"id":"20260603084231-2qxeexy","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260603084231-j3n172z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-j3n172z","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2vuwt3a","Type":"NodeParagraph","Properties":{"id":"20260603084231-2vuwt3a","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260603084231-j2p3n4r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-j2p3n4r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ha9y5z1","Type":"NodeParagraph","Properties":{"id":"20260603084231-ha9y5z1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260603084231-dceislw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dceislw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bxgzpt7","Type":"NodeParagraph","Properties":{"id":"20260603084231-bxgzpt7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260603084231-mhadtyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mhadtyb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-c1s6g5h","Type":"NodeParagraph","Properties":{"id":"20260603084231-c1s6g5h","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260603084231-gmh2gon","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gmh2gon","updated":"20260603084231"},"Children":[{"ID":"20260603084231-r5vsazk","Type":"NodeParagraph","Properties":{"id":"20260603084231-r5vsazk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260603084231-323wumx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-323wumx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-t83fvof","Type":"NodeParagraph","Properties":{"id":"20260603084231-t83fvof","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260603084231-9lny9lj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9lny9lj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-puoitq1","Type":"NodeParagraph","Properties":{"id":"20260603084231-puoitq1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260603084231-zrn4rk8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zrn4rk8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xfmt1xd","Type":"NodeParagraph","Properties":{"id":"20260603084231-xfmt1xd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260603084231-gol3tp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gol3tp1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cj4puql","Type":"NodeParagraph","Properties":{"id":"20260603084231-cj4puql","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260603084231-0nl50y6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0nl50y6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6f0hjy7","Type":"NodeParagraph","Properties":{"id":"20260603084231-6f0hjy7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260603084231-87668yw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-87668yw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6qtczly","Type":"NodeParagraph","Properties":{"id":"20260603084231-6qtczly","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260603084231-qvl806k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qvl806k","updated":"20260603084231"},"Children":[{"ID":"20260603084231-wo9aqse","Type":"NodeParagraph","Properties":{"id":"20260603084231-wo9aqse","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260603084231-n4ma34g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-n4ma34g","updated":"20260603084231"},"Children":[{"ID":"20260603084231-k45fodx","Type":"NodeParagraph","Properties":{"id":"20260603084231-k45fodx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260603084231-uwqypzv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-uwqypzv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0mi5ai9","Type":"NodeParagraph","Properties":{"id":"20260603084231-0mi5ai9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260603084231-qas10h6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qas10h6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-adkskus","Type":"NodeParagraph","Properties":{"id":"20260603084231-adkskus","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260603084231-dum20dx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dum20dx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3s3lsnk","Type":"NodeParagraph","Properties":{"id":"20260603084231-3s3lsnk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260603084231-apm3qhp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-apm3qhp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-m9vg7f0","Type":"NodeParagraph","Properties":{"id":"20260603084231-m9vg7f0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260603084231-m04vvr9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m04vvr9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4guu824","Type":"NodeParagraph","Properties":{"id":"20260603084231-4guu824","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260603084231-kqp0zup","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kqp0zup","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nx2ysp1","Type":"NodeParagraph","Properties":{"id":"20260603084231-nx2ysp1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260603084231-g2y86zl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-g2y86zl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-oh7cbn3","Type":"NodeParagraph","Properties":{"id":"20260603084231-oh7cbn3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260603084231-rl13ykx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rl13ykx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0gdoj8o","Type":"NodeParagraph","Properties":{"id":"20260603084231-0gdoj8o","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"汪国真：没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260603084231-vaenwcu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vaenwcu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-j8grd1p","Type":"NodeParagraph","Properties":{"id":"20260603084231-j8grd1p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"歌德：才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260603084231-32lr292","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-32lr292","updated":"20260603084231"},"Children":[{"ID":"20260603084231-24d09a5","Type":"NodeParagraph","Properties":{"id":"20260603084231-24d09a5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260603084231-e1h4gat","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e1h4gat","updated":"20260603084231"},"Children":[{"ID":"20260603084231-wg2clxp","Type":"NodeParagraph","Properties":{"id":"20260603084231-wg2clxp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260603084231-jzocdun","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jzocdun","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ovueqbi","Type":"NodeParagraph","Properties":{"id":"20260603084231-ovueqbi","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260603084231-5d78ky9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5d78ky9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cqrosro","Type":"NodeParagraph","Properties":{"id":"20260603084231-cqrosro","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260603084231-fxhqfxr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-fxhqfxr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rbl6753","Type":"NodeParagraph","Properties":{"id":"20260603084231-rbl6753","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260603084231-b1kwa7f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-b1kwa7f","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6vq0cwm","Type":"NodeParagraph","Properties":{"id":"20260603084231-6vq0cwm","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260603084231-y2kabm3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y2kabm3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-k1zhzy8","Type":"NodeParagraph","Properties":{"id":"20260603084231-k1zhzy8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260603084231-d93xcq1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-d93xcq1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-la3jy5a","Type":"NodeParagraph","Properties":{"id":"20260603084231-la3jy5a","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260603084231-7rd7a9x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7rd7a9x","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pf37rks","Type":"NodeParagraph","Properties":{"id":"20260603084231-pf37rks","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260603084231-l1nqfnq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-l1nqfnq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1b6l8h9","Type":"NodeParagraph","Properties":{"id":"20260603084231-1b6l8h9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260603084231-pz8umxd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pz8umxd","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4yy07oa","Type":"NodeParagraph","Properties":{"id":"20260603084231-4yy07oa","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260603084231-p13jfxd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-p13jfxd","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ir1dplh","Type":"NodeParagraph","Properties":{"id":"20260603084231-ir1dplh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260603084231-4biam7n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4biam7n","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hzhymt7","Type":"NodeParagraph","Properties":{"id":"20260603084231-hzhymt7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260603084231-09ywfi9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-09ywfi9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rtsoyxi","Type":"NodeParagraph","Properties":{"id":"20260603084231-rtsoyxi","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260603084231-9oe5tv5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9oe5tv5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-c9tiggf","Type":"NodeParagraph","Properties":{"id":"20260603084231-c9tiggf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260603084231-4hfq1bp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4hfq1bp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-niiyynk","Type":"NodeParagraph","Properties":{"id":"20260603084231-niiyynk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260603084231-wx6peu5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wx6peu5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dshrhrn","Type":"NodeParagraph","Properties":{"id":"20260603084231-dshrhrn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260603084231-ab6cnl9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ab6cnl9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hc02a2t","Type":"NodeParagraph","Properties":{"id":"20260603084231-hc02a2t","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260603084231-473lpjh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-473lpjh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-p8niq94","Type":"NodeParagraph","Properties":{"id":"20260603084231-p8niq94","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260603084231-q6kybtz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-q6kybtz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ma4qmp8","Type":"NodeParagraph","Properties":{"id":"20260603084231-ma4qmp8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260603084231-7gp31qc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7gp31qc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kczzv6z","Type":"NodeParagraph","Properties":{"id":"20260603084231-kczzv6z","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260603084231-ize83y0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ize83y0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-89pxw9d","Type":"NodeParagraph","Properties":{"id":"20260603084231-89pxw9d","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260603084231-6skj02n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-6skj02n","updated":"20260603084231"},"Children":[{"ID":"20260603084231-gyiqkkb","Type":"NodeParagraph","Properties":{"id":"20260603084231-gyiqkkb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260603084231-xifftr1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xifftr1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pxp33e0","Type":"NodeParagraph","Properties":{"id":"20260603084231-pxp33e0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260603084231-xmmmnwg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xmmmnwg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5wigseb","Type":"NodeParagraph","Properties":{"id":"20260603084231-5wigseb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260603084231-rvmb7nm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rvmb7nm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-a4du4i5","Type":"NodeParagraph","Properties":{"id":"20260603084231-a4du4i5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260603084231-n16lwts","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-n16lwts","updated":"20260603084231"},"Children":[{"ID":"20260603084231-x638dsy","Type":"NodeParagraph","Properties":{"id":"20260603084231-x638dsy","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260603084231-f4nav1q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-f4nav1q","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8ipm50n","Type":"NodeParagraph","Properties":{"id":"20260603084231-8ipm50n","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260603084231-umw87g8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-umw87g8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-560g9at","Type":"NodeParagraph","Properties":{"id":"20260603084231-560g9at","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260603084231-83h1hj7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-83h1hj7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mi8hcdt","Type":"NodeParagraph","Properties":{"id":"20260603084231-mi8hcdt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260603084231-co5ht94","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-co5ht94","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dnjn9l6","Type":"NodeParagraph","Properties":{"id":"20260603084231-dnjn9l6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260603084231-asyoqzx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-asyoqzx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7mbciep","Type":"NodeParagraph","Properties":{"id":"20260603084231-7mbciep","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260603084231-iiwk15o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-iiwk15o","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8j2vy1m","Type":"NodeParagraph","Properties":{"id":"20260603084231-8j2vy1m","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260603084231-ymnri3q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ymnri3q","updated":"20260603084231"},"Children":[{"ID":"20260603084231-97434n1","Type":"NodeParagraph","Properties":{"id":"20260603084231-97434n1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260603084231-ys8rhhn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ys8rhhn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-re5autw","Type":"NodeParagraph","Properties":{"id":"20260603084231-re5autw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260603084231-78mzkw4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-78mzkw4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bntbs60","Type":"NodeParagraph","Properties":{"id":"20260603084231-bntbs60","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260603084231-ylkag5b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ylkag5b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ottie55","Type":"NodeParagraph","Properties":{"id":"20260603084231-ottie55","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260603084231-z0d9p0l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-z0d9p0l","updated":"20260603084231"},"Children":[{"ID":"20260603084231-66rkwrb","Type":"NodeParagraph","Properties":{"id":"20260603084231-66rkwrb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260603084231-kfjjkg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kfjjkg6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-tkz1rna","Type":"NodeParagraph","Properties":{"id":"20260603084231-tkz1rna","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260603084231-u2wvwzn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-u2wvwzn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xqrvfjz","Type":"NodeParagraph","Properties":{"id":"20260603084231-xqrvfjz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260603084231-jxpttgl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jxpttgl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bhpmwr2","Type":"NodeParagraph","Properties":{"id":"20260603084231-bhpmwr2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260603084231-vdqx0l3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vdqx0l3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-lhq25sg","Type":"NodeParagraph","Properties":{"id":"20260603084231-lhq25sg","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260603084231-y4n5zku","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y4n5zku","updated":"20260603084231"},"Children":[{"ID":"20260603084231-vbm6t4r","Type":"NodeParagraph","Properties":{"id":"20260603084231-vbm6t4r","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260603084231-27r8m1v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-27r8m1v","updated":"20260603084231"},"Children":[{"ID":"20260603084231-w9keayb","Type":"NodeParagraph","Properties":{"id":"20260603084231-w9keayb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260603084231-awtzx73","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-awtzx73","updated":"20260603084231"},"Children":[{"ID":"20260603084231-za7vfu5","Type":"NodeParagraph","Properties":{"id":"20260603084231-za7vfu5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260603084231-kzw6e7t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kzw6e7t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-455jeds","Type":"NodeParagraph","Properties":{"id":"20260603084231-455jeds","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260603084231-guwkk5r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-guwkk5r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sk2d3mg","Type":"NodeParagraph","Properties":{"id":"20260603084231-sk2d3mg","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260603084231-uvxx943","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-uvxx943","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i7n1di3","Type":"NodeParagraph","Properties":{"id":"20260603084231-i7n1di3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260603084231-0ie379g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0ie379g","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7ls9t6p","Type":"NodeParagraph","Properties":{"id":"20260603084231-7ls9t6p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260603084231-j6ylvwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-j6ylvwm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-yzzq5id","Type":"NodeParagraph","Properties":{"id":"20260603084231-yzzq5id","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260603084231-b3ruqen","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-b3ruqen","updated":"20260603084231"},"Children":[{"ID":"20260603084231-15id4y2","Type":"NodeParagraph","Properties":{"id":"20260603084231-15id4y2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260603084231-u59ax0m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-u59ax0m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kp80k6p","Type":"NodeParagraph","Properties":{"id":"20260603084231-kp80k6p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260603084231-lhgmzyl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lhgmzyl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ny8dzp7","Type":"NodeParagraph","Properties":{"id":"20260603084231-ny8dzp7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260603084231-whvd2nv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-whvd2nv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4g57gku","Type":"NodeParagraph","Properties":{"id":"20260603084231-4g57gku","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260603084231-9cnpx03","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9cnpx03","updated":"20260603084231"},"Children":[{"ID":"20260603084231-owiynl0","Type":"NodeParagraph","Properties":{"id":"20260603084231-owiynl0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260603084231-0bv861o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0bv861o","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zj9xfs2","Type":"NodeParagraph","Properties":{"id":"20260603084231-zj9xfs2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260603084231-u5z56fj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-u5z56fj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6sau9ws","Type":"NodeParagraph","Properties":{"id":"20260603084231-6sau9ws","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260603084231-68u1m2i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-68u1m2i","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i03va1e","Type":"NodeParagraph","Properties":{"id":"20260603084231-i03va1e","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260603084231-7mx7222","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7mx7222","updated":"20260603084231"},"Children":[{"ID":"20260603084231-q86azmd","Type":"NodeParagraph","Properties":{"id":"20260603084231-q86azmd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260603084231-6rmdbdm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-6rmdbdm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-w56z2jt","Type":"NodeParagraph","Properties":{"id":"20260603084231-w56z2jt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260603084231-kv9omxy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kv9omxy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-u64mw8b","Type":"NodeParagraph","Properties":{"id":"20260603084231-u64mw8b","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603084231-gbif934","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gbif934","updated":"20260603084231"},"Children":[{"ID":"20260603084231-lbin9b8","Type":"NodeParagraph","Properties":{"id":"20260603084231-lbin9b8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260603084231-i645q04","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-i645q04","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pxg0jqe","Type":"NodeParagraph","Properties":{"id":"20260603084231-pxg0jqe","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260603084231-42limzn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-42limzn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-wpev467","Type":"NodeParagraph","Properties":{"id":"20260603084231-wpev467","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260603084231-l1u1fxg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-l1u1fxg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xoix9qr","Type":"NodeParagraph","Properties":{"id":"20260603084231-xoix9qr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260603084231-hsjdm30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-hsjdm30","updated":"20260603084231"},"Children":[{"ID":"20260603084231-x832dzy","Type":"NodeParagraph","Properties":{"id":"20260603084231-x832dzy","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260603084231-bd05s58","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-bd05s58","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o71sd2a","Type":"NodeParagraph","Properties":{"id":"20260603084231-o71sd2a","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260603084231-favz9sg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-favz9sg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cvvfmcl","Type":"NodeParagraph","Properties":{"id":"20260603084231-cvvfmcl","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260603084231-9n0qz6z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9n0qz6z","updated":"20260603084231"},"Children":[{"ID":"20260603084231-luvcjvo","Type":"NodeParagraph","Properties":{"id":"20260603084231-luvcjvo","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260603084231-jhrbn3d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jhrbn3d","updated":"20260603084231"},"Children":[{"ID":"20260603084231-y5jd04k","Type":"NodeParagraph","Properties":{"id":"20260603084231-y5jd04k","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260603084231-4vy1ufo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4vy1ufo","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1rw6499","Type":"NodeParagraph","Properties":{"id":"20260603084231-1rw6499","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260603084231-c6bvau5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-c6bvau5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3rlc557","Type":"NodeParagraph","Properties":{"id":"20260603084231-3rlc557","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260603084231-sx4hg9k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-sx4hg9k","updated":"20260603084231"},"Children":[{"ID":"20260603084231-l6vqoqq","Type":"NodeParagraph","Properties":{"id":"20260603084231-l6vqoqq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260603084231-a1r6poh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-a1r6poh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1t56562","Type":"NodeParagraph","Properties":{"id":"20260603084231-1t56562","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260603084231-y4t3ha1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y4t3ha1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hvig52h","Type":"NodeParagraph","Properties":{"id":"20260603084231-hvig52h","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260603084231-vxyz22c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vxyz22c","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8vz9280","Type":"NodeParagraph","Properties":{"id":"20260603084231-8vz9280","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260603084231-rfk6zdf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rfk6zdf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6noj0i5","Type":"NodeParagraph","Properties":{"id":"20260603084231-6noj0i5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260603084231-dvsu7gs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dvsu7gs","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o5e5fu3","Type":"NodeParagraph","Properties":{"id":"20260603084231-o5e5fu3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260603084231-r6rkyvn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-r6rkyvn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5184ekj","Type":"NodeParagraph","Properties":{"id":"20260603084231-5184ekj","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260603084231-ipwgp0m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ipwgp0m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1gzme11","Type":"NodeParagraph","Properties":{"id":"20260603084231-1gzme11","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260603084231-7mgg31j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7mgg31j","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ftpgglv","Type":"NodeParagraph","Properties":{"id":"20260603084231-ftpgglv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260603084231-ax4ced1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ax4ced1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-wh0r0ee","Type":"NodeParagraph","Properties":{"id":"20260603084231-wh0r0ee","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260603084231-wtdp2bs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wtdp2bs","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xtj74ce","Type":"NodeParagraph","Properties":{"id":"20260603084231-xtj74ce","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260603084231-q3ikddv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-q3ikddv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rzpr79d","Type":"NodeParagraph","Properties":{"id":"20260603084231-rzpr79d","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260603084231-9etvp45","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9etvp45","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2n7c74e","Type":"NodeParagraph","Properties":{"id":"20260603084231-2n7c74e","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260603084231-on1a86r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-on1a86r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-becbyvv","Type":"NodeParagraph","Properties":{"id":"20260603084231-becbyvv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260603084231-y90ftec","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y90ftec","updated":"20260603084231"},"Children":[{"ID":"20260603084231-45q9tbx","Type":"NodeParagraph","Properties":{"id":"20260603084231-45q9tbx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260603084231-cf7ifuo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-cf7ifuo","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qc8q5sw","Type":"NodeParagraph","Properties":{"id":"20260603084231-qc8q5sw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260603084231-7hk1umb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7hk1umb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7iatkce","Type":"NodeParagraph","Properties":{"id":"20260603084231-7iatkce","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260603084231-qlufjp7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qlufjp7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1aevc1z","Type":"NodeParagraph","Properties":{"id":"20260603084231-1aevc1z","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260603084231-sjjex6q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-sjjex6q","updated":"20260603084231"},"Children":[{"ID":"20260603084231-h4rhfo7","Type":"NodeParagraph","Properties":{"id":"20260603084231-h4rhfo7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260603084231-9x2qwgt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9x2qwgt","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zbmps19","Type":"NodeParagraph","Properties":{"id":"20260603084231-zbmps19","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260603084231-6jcroro","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-6jcroro","updated":"20260603084231"},"Children":[{"ID":"20260603084231-l6n9svm","Type":"NodeParagraph","Properties":{"id":"20260603084231-l6n9svm","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260603084231-0coi632","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0coi632","updated":"20260603084231"},"Children":[{"ID":"20260603084231-e37nlxh","Type":"NodeParagraph","Properties":{"id":"20260603084231-e37nlxh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260603084231-ayy5yzl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ayy5yzl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9sxtf88","Type":"NodeParagraph","Properties":{"id":"20260603084231-9sxtf88","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260603084231-e2fla6r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e2fla6r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-z58lro9","Type":"NodeParagraph","Properties":{"id":"20260603084231-z58lro9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260603084231-0ogfjx8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0ogfjx8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-fbh29c2","Type":"NodeParagraph","Properties":{"id":"20260603084231-fbh29c2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260603084231-m69bmxa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m69bmxa","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uz3p0bu","Type":"NodeParagraph","Properties":{"id":"20260603084231-uz3p0bu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260603084231-0h8gvn4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-0h8gvn4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-oomaq7z","Type":"NodeParagraph","Properties":{"id":"20260603084231-oomaq7z","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260603084231-9w120nx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9w120nx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hvh6a5v","Type":"NodeParagraph","Properties":{"id":"20260603084231-hvh6a5v","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260603084231-kdnnpij","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kdnnpij","updated":"20260603084231"},"Children":[{"ID":"20260603084231-k5nahtn","Type":"NodeParagraph","Properties":{"id":"20260603084231-k5nahtn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260603084231-32362vb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-32362vb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-p6mm543","Type":"NodeParagraph","Properties":{"id":"20260603084231-p6mm543","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260603084231-azd0i1q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-azd0i1q","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5dioeqq","Type":"NodeParagraph","Properties":{"id":"20260603084231-5dioeqq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260603084231-yhfmadi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-yhfmadi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-l65u3x9","Type":"NodeParagraph","Properties":{"id":"20260603084231-l65u3x9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260603084231-evxp1dy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-evxp1dy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o0jadfc","Type":"NodeParagraph","Properties":{"id":"20260603084231-o0jadfc","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260603084231-45wu0l5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-45wu0l5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-1fir7ur","Type":"NodeParagraph","Properties":{"id":"20260603084231-1fir7ur","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260603084231-5fcyz62","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5fcyz62","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mrov133","Type":"NodeParagraph","Properties":{"id":"20260603084231-mrov133","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260603084231-5w7m1ep","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5w7m1ep","updated":"20260603084231"},"Children":[{"ID":"20260603084231-a0hopa4","Type":"NodeParagraph","Properties":{"id":"20260603084231-a0hopa4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260603084231-3vl0e0v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-3vl0e0v","updated":"20260603084231"},"Children":[{"ID":"20260603084231-us6tjrp","Type":"NodeParagraph","Properties":{"id":"20260603084231-us6tjrp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260603084231-ek5t7jc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ek5t7jc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9n6xmod","Type":"NodeParagraph","Properties":{"id":"20260603084231-9n6xmod","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260603084231-xrbtiyx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xrbtiyx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jlfxwh9","Type":"NodeParagraph","Properties":{"id":"20260603084231-jlfxwh9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260603084231-l9y3n6m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-l9y3n6m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9suapqk","Type":"NodeParagraph","Properties":{"id":"20260603084231-9suapqk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260603084231-ni5k1i8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ni5k1i8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5tgu19y","Type":"NodeParagraph","Properties":{"id":"20260603084231-5tgu19y","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260603084231-bfw3fgc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-bfw3fgc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ralythq","Type":"NodeParagraph","Properties":{"id":"20260603084231-ralythq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260603084231-oyj7z3o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-oyj7z3o","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3oa0v3x","Type":"NodeParagraph","Properties":{"id":"20260603084231-3oa0v3x","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260603084231-tdxcysp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tdxcysp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cunz0uu","Type":"NodeParagraph","Properties":{"id":"20260603084231-cunz0uu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260603084231-knfk4im","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-knfk4im","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ndwpexg","Type":"NodeParagraph","Properties":{"id":"20260603084231-ndwpexg","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260603084231-ntr08vm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ntr08vm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-vf7wqib","Type":"NodeParagraph","Properties":{"id":"20260603084231-vf7wqib","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260603084231-63tmsoa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-63tmsoa","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3ioqazb","Type":"NodeParagraph","Properties":{"id":"20260603084231-3ioqazb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260603084231-awnbiqc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-awnbiqc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7een8k9","Type":"NodeParagraph","Properties":{"id":"20260603084231-7een8k9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260603084231-nvclb2j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-nvclb2j","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qru58wi","Type":"NodeParagraph","Properties":{"id":"20260603084231-qru58wi","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260603084231-ba1cgoq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ba1cgoq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ta367ds","Type":"NodeParagraph","Properties":{"id":"20260603084231-ta367ds","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260603084231-jstmn2n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jstmn2n","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qhnnx4c","Type":"NodeParagraph","Properties":{"id":"20260603084231-qhnnx4c","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260603084231-zff77ac","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zff77ac","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2wbo30q","Type":"NodeParagraph","Properties":{"id":"20260603084231-2wbo30q","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260603084231-rnggjxc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rnggjxc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-toe9zvm","Type":"NodeParagraph","Properties":{"id":"20260603084231-toe9zvm","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260603084231-ozrlpf5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ozrlpf5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ux8maeu","Type":"NodeParagraph","Properties":{"id":"20260603084231-ux8maeu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260603084231-e0a8tkc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-e0a8tkc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8xdgbaj","Type":"NodeParagraph","Properties":{"id":"20260603084231-8xdgbaj","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260603084231-303ol7f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-303ol7f","updated":"20260603084231"},"Children":[{"ID":"20260603084231-madbsol","Type":"NodeParagraph","Properties":{"id":"20260603084231-madbsol","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260603084231-mo1qce1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mo1qce1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-y3aez2g","Type":"NodeParagraph","Properties":{"id":"20260603084231-y3aez2g","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260603084231-lfo5xyo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lfo5xyo","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ugbscam","Type":"NodeParagraph","Properties":{"id":"20260603084231-ugbscam","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260603084231-7vfhxxf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7vfhxxf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9gme9ra","Type":"NodeParagraph","Properties":{"id":"20260603084231-9gme9ra","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260603084231-69zoh2u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-69zoh2u","updated":"20260603084231"},"Children":[{"ID":"20260603084231-issu4px","Type":"NodeParagraph","Properties":{"id":"20260603084231-issu4px","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260603084231-m89vqq2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m89vqq2","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ptb7jfr","Type":"NodeParagraph","Properties":{"id":"20260603084231-ptb7jfr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260603084231-wp9gvk7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wp9gvk7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2b7m2wl","Type":"NodeParagraph","Properties":{"id":"20260603084231-2b7m2wl","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260603084231-h5fw4xz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-h5fw4xz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sdca02k","Type":"NodeParagraph","Properties":{"id":"20260603084231-sdca02k","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260603084231-5ydu66k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5ydu66k","updated":"20260603084231"},"Children":[{"ID":"20260603084231-eqhyoh8","Type":"NodeParagraph","Properties":{"id":"20260603084231-eqhyoh8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260603084231-aybxyf3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-aybxyf3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0vedj2p","Type":"NodeParagraph","Properties":{"id":"20260603084231-0vedj2p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260603084231-h14l97z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-h14l97z","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cshzjie","Type":"NodeParagraph","Properties":{"id":"20260603084231-cshzjie","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260603084231-8cpscf5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8cpscf5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-g2836jz","Type":"NodeParagraph","Properties":{"id":"20260603084231-g2836jz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260603084231-qqtsg56","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qqtsg56","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i9cqvn9","Type":"NodeParagraph","Properties":{"id":"20260603084231-i9cqvn9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260603084231-plczoae","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-plczoae","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kj9xpjp","Type":"NodeParagraph","Properties":{"id":"20260603084231-kj9xpjp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260603084231-3vgqb8r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-3vgqb8r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-tiw0lff","Type":"NodeParagraph","Properties":{"id":"20260603084231-tiw0lff","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260603084231-kvcu4et","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kvcu4et","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kuadwas","Type":"NodeParagraph","Properties":{"id":"20260603084231-kuadwas","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260603084231-379bqax","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-379bqax","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5ljxbo2","Type":"NodeParagraph","Properties":{"id":"20260603084231-5ljxbo2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260603084231-pxpmozx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pxpmozx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bgyzbbp","Type":"NodeParagraph","Properties":{"id":"20260603084231-bgyzbbp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260603084231-tc5783k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tc5783k","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zsdo4pe","Type":"NodeParagraph","Properties":{"id":"20260603084231-zsdo4pe","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260603084231-i096u5b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-i096u5b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nppypu0","Type":"NodeParagraph","Properties":{"id":"20260603084231-nppypu0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260603084231-jqyni6d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-jqyni6d","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ol87kjq","Type":"NodeParagraph","Properties":{"id":"20260603084231-ol87kjq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260603084231-mq52hs9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mq52hs9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i1ly0kh","Type":"NodeParagraph","Properties":{"id":"20260603084231-i1ly0kh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260603084231-s3rjdt6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-s3rjdt6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pr5eg4p","Type":"NodeParagraph","Properties":{"id":"20260603084231-pr5eg4p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260603084231-wyr8gye","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wyr8gye","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uepnnuz","Type":"NodeParagraph","Properties":{"id":"20260603084231-uepnnuz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260603084231-naanopr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-naanopr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uwwbydw","Type":"NodeParagraph","Properties":{"id":"20260603084231-uwwbydw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260603084231-lzocmxw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lzocmxw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ki53yv3","Type":"NodeParagraph","Properties":{"id":"20260603084231-ki53yv3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260603084231-ft22yo5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ft22yo5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-u6e9cly","Type":"NodeParagraph","Properties":{"id":"20260603084231-u6e9cly","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260603084231-ejxbk83","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ejxbk83","updated":"20260603084231"},"Children":[{"ID":"20260603084231-e00ir5v","Type":"NodeParagraph","Properties":{"id":"20260603084231-e00ir5v","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260603084231-qj4ga8a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qj4ga8a","updated":"20260603084231"},"Children":[{"ID":"20260603084231-pfmq9mc","Type":"NodeParagraph","Properties":{"id":"20260603084231-pfmq9mc","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260603084231-4vluc6n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4vluc6n","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5ze6g99","Type":"NodeParagraph","Properties":{"id":"20260603084231-5ze6g99","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260603084231-auds666","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-auds666","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5vy6ps9","Type":"NodeParagraph","Properties":{"id":"20260603084231-5vy6ps9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260603084231-bi4ct9f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-bi4ct9f","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zxaj6c6","Type":"NodeParagraph","Properties":{"id":"20260603084231-zxaj6c6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603084231-y2z113r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y2z113r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cn91ooh","Type":"NodeParagraph","Properties":{"id":"20260603084231-cn91ooh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260603084231-87g6ntl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-87g6ntl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-47zizlt","Type":"NodeParagraph","Properties":{"id":"20260603084231-47zizlt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260603084231-i2gnv3a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-i2gnv3a","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zniglid","Type":"NodeParagraph","Properties":{"id":"20260603084231-zniglid","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260603084231-okof9rh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-okof9rh","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rcknuw4","Type":"NodeParagraph","Properties":{"id":"20260603084231-rcknuw4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260603084231-iz6k50y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-iz6k50y","updated":"20260603084231"},"Children":[{"ID":"20260603084231-od5hvah","Type":"NodeParagraph","Properties":{"id":"20260603084231-od5hvah","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260603084231-6zo8ow1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-6zo8ow1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-f8um3am","Type":"NodeParagraph","Properties":{"id":"20260603084231-f8um3am","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260603084231-wrya7sr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wrya7sr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-n8y70ip","Type":"NodeParagraph","Properties":{"id":"20260603084231-n8y70ip","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260603084231-p7zuy57","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-p7zuy57","updated":"20260603084231"},"Children":[{"ID":"20260603084231-snyi0t4","Type":"NodeParagraph","Properties":{"id":"20260603084231-snyi0t4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260603084231-8vvi2vp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8vvi2vp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-epw5ko4","Type":"NodeParagraph","Properties":{"id":"20260603084231-epw5ko4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260603084231-fyt9p17","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-fyt9p17","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0yhdwym","Type":"NodeParagraph","Properties":{"id":"20260603084231-0yhdwym","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260603084231-arnzfto","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-arnzfto","updated":"20260603084231"},"Children":[{"ID":"20260603084231-itwwt8f","Type":"NodeParagraph","Properties":{"id":"20260603084231-itwwt8f","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260603084231-uzi8jhy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-uzi8jhy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-d95u7ib","Type":"NodeParagraph","Properties":{"id":"20260603084231-d95u7ib","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260603084231-la4q2kw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-la4q2kw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nwo1nhw","Type":"NodeParagraph","Properties":{"id":"20260603084231-nwo1nhw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260603084231-nqnddpn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-nqnddpn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ktv7orh","Type":"NodeParagraph","Properties":{"id":"20260603084231-ktv7orh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260603084231-8reh604","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8reh604","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9cbroz2","Type":"NodeParagraph","Properties":{"id":"20260603084231-9cbroz2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260603084231-i7zfk4s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-i7zfk4s","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dndxqex","Type":"NodeParagraph","Properties":{"id":"20260603084231-dndxqex","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260603084231-l5ba0bv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-l5ba0bv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-he4go95","Type":"NodeParagraph","Properties":{"id":"20260603084231-he4go95","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260603084231-ine166o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ine166o","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xd06oqp","Type":"NodeParagraph","Properties":{"id":"20260603084231-xd06oqp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260603084231-xxs5tf8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xxs5tf8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dptx381","Type":"NodeParagraph","Properties":{"id":"20260603084231-dptx381","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260603084231-zmvfziw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zmvfziw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-u4aiuf6","Type":"NodeParagraph","Properties":{"id":"20260603084231-u4aiuf6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603084231-r2qhi0w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-r2qhi0w","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xi7yh3i","Type":"NodeParagraph","Properties":{"id":"20260603084231-xi7yh3i","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260603084231-y3tkk8w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y3tkk8w","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6cnnsfx","Type":"NodeParagraph","Properties":{"id":"20260603084231-6cnnsfx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260603084231-8qgjgi2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8qgjgi2","updated":"20260603084231"},"Children":[{"ID":"20260603084231-otwbugn","Type":"NodeParagraph","Properties":{"id":"20260603084231-otwbugn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260603084231-pia78gs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pia78gs","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3dhsb93","Type":"NodeParagraph","Properties":{"id":"20260603084231-3dhsb93","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260603084231-ciy92ba","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ciy92ba","updated":"20260603084231"},"Children":[{"ID":"20260603084231-y9xhkcv","Type":"NodeParagraph","Properties":{"id":"20260603084231-y9xhkcv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260603084231-9txv897","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9txv897","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8n4p5kt","Type":"NodeParagraph","Properties":{"id":"20260603084231-8n4p5kt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260603084231-x7ajoke","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-x7ajoke","updated":"20260603084231"},"Children":[{"ID":"20260603084231-gq6wei2","Type":"NodeParagraph","Properties":{"id":"20260603084231-gq6wei2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260603084231-ai4h6xg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ai4h6xg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cip35tm","Type":"NodeParagraph","Properties":{"id":"20260603084231-cip35tm","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260603084231-fk0b7m1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-fk0b7m1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bh9htzt","Type":"NodeParagraph","Properties":{"id":"20260603084231-bh9htzt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260603084231-2zklu9w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2zklu9w","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i4g8af9","Type":"NodeParagraph","Properties":{"id":"20260603084231-i4g8af9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260603084231-zp0gwn1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zp0gwn1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3s93jlw","Type":"NodeParagraph","Properties":{"id":"20260603084231-3s93jlw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260603084231-t2qrcad","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-t2qrcad","updated":"20260603084231"},"Children":[{"ID":"20260603084231-phqfy83","Type":"NodeParagraph","Properties":{"id":"20260603084231-phqfy83","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260603084231-oegfasr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-oegfasr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-tjpp029","Type":"NodeParagraph","Properties":{"id":"20260603084231-tjpp029","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260603084231-2t8t9ka","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2t8t9ka","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i4rutyg","Type":"NodeParagraph","Properties":{"id":"20260603084231-i4rutyg","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260603084231-h82nc4p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-h82nc4p","updated":"20260603084231"},"Children":[{"ID":"20260603084231-s1sclml","Type":"NodeParagraph","Properties":{"id":"20260603084231-s1sclml","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260603084231-ocwlqiw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ocwlqiw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cuhq46b","Type":"NodeParagraph","Properties":{"id":"20260603084231-cuhq46b","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260603084231-gl51xqx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gl51xqx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hyn4wom","Type":"NodeParagraph","Properties":{"id":"20260603084231-hyn4wom","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260603084231-6uq19u4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-6uq19u4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ijal9hk","Type":"NodeParagraph","Properties":{"id":"20260603084231-ijal9hk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260603084231-cis1h0v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-cis1h0v","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4kcqmcp","Type":"NodeParagraph","Properties":{"id":"20260603084231-4kcqmcp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260603084231-nwtyew0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-nwtyew0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-co4xf0h","Type":"NodeParagraph","Properties":{"id":"20260603084231-co4xf0h","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260603084231-4yofmu7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4yofmu7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bs7y329","Type":"NodeParagraph","Properties":{"id":"20260603084231-bs7y329","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260603084231-lv29dyz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lv29dyz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rr231cr","Type":"NodeParagraph","Properties":{"id":"20260603084231-rr231cr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260603084231-dyd94b0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dyd94b0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-725wxz4","Type":"NodeParagraph","Properties":{"id":"20260603084231-725wxz4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260603084231-6ibj1br","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-6ibj1br","updated":"20260603084231"},"Children":[{"ID":"20260603084231-13bif4l","Type":"NodeParagraph","Properties":{"id":"20260603084231-13bif4l","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260603084231-c9zhhal","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-c9zhhal","updated":"20260603084231"},"Children":[{"ID":"20260603084231-iozaqv7","Type":"NodeParagraph","Properties":{"id":"20260603084231-iozaqv7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260603084231-tixwz4l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tixwz4l","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kuuf1re","Type":"NodeParagraph","Properties":{"id":"20260603084231-kuuf1re","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260603084231-8zh9y5u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8zh9y5u","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6ke7hrp","Type":"NodeParagraph","Properties":{"id":"20260603084231-6ke7hrp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260603084231-1c3fkpa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-1c3fkpa","updated":"20260603084231"},"Children":[{"ID":"20260603084231-i3bgkll","Type":"NodeParagraph","Properties":{"id":"20260603084231-i3bgkll","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260603084231-yaahfjo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-yaahfjo","updated":"20260603084231"},"Children":[{"ID":"20260603084231-l9ff5xm","Type":"NodeParagraph","Properties":{"id":"20260603084231-l9ff5xm","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260603084231-iauuwin","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-iauuwin","updated":"20260603084231"},"Children":[{"ID":"20260603084231-s6t0cp3","Type":"NodeParagraph","Properties":{"id":"20260603084231-s6t0cp3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260603084231-ecvgc6k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ecvgc6k","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rn9opqd","Type":"NodeParagraph","Properties":{"id":"20260603084231-rn9opqd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260603084231-rn2qkiq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rn2qkiq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4rir4hr","Type":"NodeParagraph","Properties":{"id":"20260603084231-4rir4hr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260603084231-uxd0f3s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-uxd0f3s","updated":"20260603084231"},"Children":[{"ID":"20260603084231-osl9gs4","Type":"NodeParagraph","Properties":{"id":"20260603084231-osl9gs4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260603084231-pjam1kb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pjam1kb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o5cwoe6","Type":"NodeParagraph","Properties":{"id":"20260603084231-o5cwoe6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260603084231-ili53xy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ili53xy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xtee06x","Type":"NodeParagraph","Properties":{"id":"20260603084231-xtee06x","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260603084231-vkn8moa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vkn8moa","updated":"20260603084231"},"Children":[{"ID":"20260603084231-kvnvzye","Type":"NodeParagraph","Properties":{"id":"20260603084231-kvnvzye","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260603084231-a4x6dhu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-a4x6dhu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-xxpyvqv","Type":"NodeParagraph","Properties":{"id":"20260603084231-xxpyvqv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260603084231-ctwunsu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ctwunsu","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uncegnn","Type":"NodeParagraph","Properties":{"id":"20260603084231-uncegnn","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260603084231-4uj2lev","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4uj2lev","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mo9za3p","Type":"NodeParagraph","Properties":{"id":"20260603084231-mo9za3p","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260603084231-hwe9itb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-hwe9itb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-w32elji","Type":"NodeParagraph","Properties":{"id":"20260603084231-w32elji","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260603084231-xppgtab","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xppgtab","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o9w9q7f","Type":"NodeParagraph","Properties":{"id":"20260603084231-o9w9q7f","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260603084231-ox29eqx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ox29eqx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-m54dmzr","Type":"NodeParagraph","Properties":{"id":"20260603084231-m54dmzr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260603084231-ulkvdrg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ulkvdrg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ld701e0","Type":"NodeParagraph","Properties":{"id":"20260603084231-ld701e0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260603084231-f3bmdcz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-f3bmdcz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6dcoy2g","Type":"NodeParagraph","Properties":{"id":"20260603084231-6dcoy2g","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260603084231-qhmg2xz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qhmg2xz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-c7uxk2r","Type":"NodeParagraph","Properties":{"id":"20260603084231-c7uxk2r","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260603084231-ryaxtyw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ryaxtyw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3vvlz4u","Type":"NodeParagraph","Properties":{"id":"20260603084231-3vvlz4u","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260603084231-5hmmhew","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5hmmhew","updated":"20260603084231"},"Children":[{"ID":"20260603084231-arlsvh1","Type":"NodeParagraph","Properties":{"id":"20260603084231-arlsvh1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260603084231-f2nm4hc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-f2nm4hc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dyubtai","Type":"NodeParagraph","Properties":{"id":"20260603084231-dyubtai","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260603084231-45e1e3h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-45e1e3h","updated":"20260603084231"},"Children":[{"ID":"20260603084231-h7wxpex","Type":"NodeParagraph","Properties":{"id":"20260603084231-h7wxpex","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260603084231-m6ieexm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-m6ieexm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5ilpoww","Type":"NodeParagraph","Properties":{"id":"20260603084231-5ilpoww","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260603084231-vnlwwjq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vnlwwjq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6ksfw3v","Type":"NodeParagraph","Properties":{"id":"20260603084231-6ksfw3v","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260603084231-4vcwxoe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4vcwxoe","updated":"20260603084231"},"Children":[{"ID":"20260603084231-3mr39kf","Type":"NodeParagraph","Properties":{"id":"20260603084231-3mr39kf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260603084231-x5mjxjt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-x5mjxjt","updated":"20260603084231"},"Children":[{"ID":"20260603084231-799bpny","Type":"NodeParagraph","Properties":{"id":"20260603084231-799bpny","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260603084231-t51w2cv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-t51w2cv","updated":"20260603084231"},"Children":[{"ID":"20260603084231-wf285g1","Type":"NodeParagraph","Properties":{"id":"20260603084231-wf285g1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260603084231-38hw8rc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-38hw8rc","updated":"20260603084231"},"Children":[{"ID":"20260603084231-szwrv1m","Type":"NodeParagraph","Properties":{"id":"20260603084231-szwrv1m","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260603084231-keex1it","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-keex1it","updated":"20260603084231"},"Children":[{"ID":"20260603084231-vwdedwt","Type":"NodeParagraph","Properties":{"id":"20260603084231-vwdedwt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260603084231-hmy08sy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-hmy08sy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uohbwxh","Type":"NodeParagraph","Properties":{"id":"20260603084231-uohbwxh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260603084231-a7c0unk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-a7c0unk","updated":"20260603084231"},"Children":[{"ID":"20260603084231-g5j01w9","Type":"NodeParagraph","Properties":{"id":"20260603084231-g5j01w9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260603084231-kbz3yq0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kbz3yq0","updated":"20260603084231"},"Children":[{"ID":"20260603084231-shyillk","Type":"NodeParagraph","Properties":{"id":"20260603084231-shyillk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260603084231-4biukmw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4biukmw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-d9w26ti","Type":"NodeParagraph","Properties":{"id":"20260603084231-d9w26ti","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260603084231-zyedz3y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zyedz3y","updated":"20260603084231"},"Children":[{"ID":"20260603084231-n1q4ad4","Type":"NodeParagraph","Properties":{"id":"20260603084231-n1q4ad4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260603084231-mqi30wa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mqi30wa","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bi88l3u","Type":"NodeParagraph","Properties":{"id":"20260603084231-bi88l3u","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260603084231-tj1ia81","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-tj1ia81","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8sst0kq","Type":"NodeParagraph","Properties":{"id":"20260603084231-8sst0kq","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260603084231-7wzwh4m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7wzwh4m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-u4yns6c","Type":"NodeParagraph","Properties":{"id":"20260603084231-u4yns6c","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260603084231-4if8c5m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4if8c5m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4r1u0nz","Type":"NodeParagraph","Properties":{"id":"20260603084231-4r1u0nz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260603084231-bhu6bnj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-bhu6bnj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-bga6ggd","Type":"NodeParagraph","Properties":{"id":"20260603084231-bga6ggd","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260603084231-bvnvqei","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-bvnvqei","updated":"20260603084231"},"Children":[{"ID":"20260603084231-yc8jg3f","Type":"NodeParagraph","Properties":{"id":"20260603084231-yc8jg3f","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260603084231-n22qxh1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-n22qxh1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0guus8z","Type":"NodeParagraph","Properties":{"id":"20260603084231-0guus8z","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260603084231-46otorf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-46otorf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hfzrbvw","Type":"NodeParagraph","Properties":{"id":"20260603084231-hfzrbvw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260603084231-05gpd0b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-05gpd0b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-z9kxt8v","Type":"NodeParagraph","Properties":{"id":"20260603084231-z9kxt8v","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260603084231-lthn7qf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lthn7qf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ekiuevb","Type":"NodeParagraph","Properties":{"id":"20260603084231-ekiuevb","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260603084231-7ooqk0i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7ooqk0i","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zgnaoxj","Type":"NodeParagraph","Properties":{"id":"20260603084231-zgnaoxj","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260603084231-ki599n9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ki599n9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8hlwhrl","Type":"NodeParagraph","Properties":{"id":"20260603084231-8hlwhrl","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260603084231-mlwn1cb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mlwn1cb","updated":"20260603084231"},"Children":[{"ID":"20260603084231-lqlmf5r","Type":"NodeParagraph","Properties":{"id":"20260603084231-lqlmf5r","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260603084231-k5r4k2b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-k5r4k2b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o3tua2u","Type":"NodeParagraph","Properties":{"id":"20260603084231-o3tua2u","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260603084231-vs58smi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vs58smi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0tftphz","Type":"NodeParagraph","Properties":{"id":"20260603084231-0tftphz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260603084231-b8c1lts","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-b8c1lts","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2qzi9w6","Type":"NodeParagraph","Properties":{"id":"20260603084231-2qzi9w6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260603084231-hz520zl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-hz520zl","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9btew74","Type":"NodeParagraph","Properties":{"id":"20260603084231-9btew74","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260603084231-pvoh75b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pvoh75b","updated":"20260603084231"},"Children":[{"ID":"20260603084231-s3f2mwk","Type":"NodeParagraph","Properties":{"id":"20260603084231-s3f2mwk","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260603084231-85yqg48","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-85yqg48","updated":"20260603084231"},"Children":[{"ID":"20260603084231-30qxshz","Type":"NodeParagraph","Properties":{"id":"20260603084231-30qxshz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260603084231-hglpspf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-hglpspf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7jjvtz9","Type":"NodeParagraph","Properties":{"id":"20260603084231-7jjvtz9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260603084231-fsg180t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-fsg180t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nv2qaid","Type":"NodeParagraph","Properties":{"id":"20260603084231-nv2qaid","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260603084231-5olgb4v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5olgb4v","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qh99m91","Type":"NodeParagraph","Properties":{"id":"20260603084231-qh99m91","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260603084231-rydi36c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rydi36c","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7e8xwqu","Type":"NodeParagraph","Properties":{"id":"20260603084231-7e8xwqu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260603084231-cqmt8mk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-cqmt8mk","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9sahe8a","Type":"NodeParagraph","Properties":{"id":"20260603084231-9sahe8a","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260603084231-osm8w3p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-osm8w3p","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9uuq3ic","Type":"NodeParagraph","Properties":{"id":"20260603084231-9uuq3ic","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260603084231-08du6zk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-08du6zk","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dmuh6x7","Type":"NodeParagraph","Properties":{"id":"20260603084231-dmuh6x7","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260603084231-ldms1rr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ldms1rr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-fwjqeb0","Type":"NodeParagraph","Properties":{"id":"20260603084231-fwjqeb0","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260603084231-5gscgcj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5gscgcj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-jcjasrv","Type":"NodeParagraph","Properties":{"id":"20260603084231-jcjasrv","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260603084231-iwskozf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-iwskozf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-s1smqwy","Type":"NodeParagraph","Properties":{"id":"20260603084231-s1smqwy","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260603084231-k9b2fqm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-k9b2fqm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-q483jpu","Type":"NodeParagraph","Properties":{"id":"20260603084231-q483jpu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260603084231-mlfkyzd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-mlfkyzd","updated":"20260603084231"},"Children":[{"ID":"20260603084231-uhktq1s","Type":"NodeParagraph","Properties":{"id":"20260603084231-uhktq1s","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260603084231-g7zcgf8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-g7zcgf8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7vyi5mx","Type":"NodeParagraph","Properties":{"id":"20260603084231-7vyi5mx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260603084231-4ibmcs1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4ibmcs1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-510zn4b","Type":"NodeParagraph","Properties":{"id":"20260603084231-510zn4b","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260603084231-u1q17o3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-u1q17o3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-b5pd5x1","Type":"NodeParagraph","Properties":{"id":"20260603084231-b5pd5x1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260603084231-o4vsfk4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-o4vsfk4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-tw11wlr","Type":"NodeParagraph","Properties":{"id":"20260603084231-tw11wlr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260603084231-kjw0gdz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kjw0gdz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mjjlg68","Type":"NodeParagraph","Properties":{"id":"20260603084231-mjjlg68","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260603084231-qhmwp9t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-qhmwp9t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7q7ungr","Type":"NodeParagraph","Properties":{"id":"20260603084231-7q7ungr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260603084231-l9lb30h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-l9lb30h","updated":"20260603084231"},"Children":[{"ID":"20260603084231-te00zdr","Type":"NodeParagraph","Properties":{"id":"20260603084231-te00zdr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺。"}]}]},{"ID":"20260603084231-5kvcgch","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5kvcgch","updated":"20260603084231"},"Children":[{"ID":"20260603084231-igxdame","Type":"NodeParagraph","Properties":{"id":"20260603084231-igxdame","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260603084231-kqyu1j8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kqyu1j8","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ti7cr22","Type":"NodeParagraph","Properties":{"id":"20260603084231-ti7cr22","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260603084231-2dkcpmj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2dkcpmj","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6ukmsnr","Type":"NodeParagraph","Properties":{"id":"20260603084231-6ukmsnr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260603084231-a7w43re","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-a7w43re","updated":"20260603084231"},"Children":[{"ID":"20260603084231-21909d1","Type":"NodeParagraph","Properties":{"id":"20260603084231-21909d1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260603084231-093ogh6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-093ogh6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-y2nptvp","Type":"NodeParagraph","Properties":{"id":"20260603084231-y2nptvp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260603084231-8ptq6q7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8ptq6q7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-s7pe6r4","Type":"NodeParagraph","Properties":{"id":"20260603084231-s7pe6r4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260603084231-unalb75","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-unalb75","updated":"20260603084231"},"Children":[{"ID":"20260603084231-19klb6t","Type":"NodeParagraph","Properties":{"id":"20260603084231-19klb6t","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260603084231-n7mt3rp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-n7mt3rp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-b4010ph","Type":"NodeParagraph","Properties":{"id":"20260603084231-b4010ph","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]},{"ID":"20260603084231-zc0el21","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zc0el21","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ujs0bce","Type":"NodeParagraph","Properties":{"id":"20260603084231-ujs0bce","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260603084231-9kkdikz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9kkdikz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8jsfr54","Type":"NodeParagraph","Properties":{"id":"20260603084231-8jsfr54","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260603084231-p8boym3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-p8boym3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-a6lz82k","Type":"NodeParagraph","Properties":{"id":"20260603084231-a6lz82k","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260603084231-oxg71iy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-oxg71iy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-149kz5d","Type":"NodeParagraph","Properties":{"id":"20260603084231-149kz5d","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260603084231-p5c917x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-p5c917x","updated":"20260603084231"},"Children":[{"ID":"20260603084231-di2yui5","Type":"NodeParagraph","Properties":{"id":"20260603084231-di2yui5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260603084231-pnlisr1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-pnlisr1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-6cc3j2h","Type":"NodeParagraph","Properties":{"id":"20260603084231-6cc3j2h","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260603084231-8kwgkue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-8kwgkue","updated":"20260603084231"},"Children":[{"ID":"20260603084231-810cqan","Type":"NodeParagraph","Properties":{"id":"20260603084231-810cqan","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260603084231-5egn9qy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5egn9qy","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2zq5h9e","Type":"NodeParagraph","Properties":{"id":"20260603084231-2zq5h9e","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260603084231-cwxafis","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-cwxafis","updated":"20260603084231"},"Children":[{"ID":"20260603084231-7wulmui","Type":"NodeParagraph","Properties":{"id":"20260603084231-7wulmui","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260603084231-izsaej3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-izsaej3","updated":"20260603084231"},"Children":[{"ID":"20260603084231-81capoi","Type":"NodeParagraph","Properties":{"id":"20260603084231-81capoi","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260603084231-rh7ux2p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-rh7ux2p","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sxvj5q1","Type":"NodeParagraph","Properties":{"id":"20260603084231-sxvj5q1","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260603084231-028zcob","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-028zcob","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rx04abx","Type":"NodeParagraph","Properties":{"id":"20260603084231-rx04abx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260603084231-k66iak5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-k66iak5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zypd3e4","Type":"NodeParagraph","Properties":{"id":"20260603084231-zypd3e4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260603084231-w5osqo4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-w5osqo4","updated":"20260603084231"},"Children":[{"ID":"20260603084231-5hhunlx","Type":"NodeParagraph","Properties":{"id":"20260603084231-5hhunlx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260603084231-ukukg5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ukukg5l","updated":"20260603084231"},"Children":[{"ID":"20260603084231-blz6qzm","Type":"NodeParagraph","Properties":{"id":"20260603084231-blz6qzm","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260603084231-5xpc3mm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5xpc3mm","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0felhui","Type":"NodeParagraph","Properties":{"id":"20260603084231-0felhui","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260603084231-z2q0843","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-z2q0843","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4gbezt4","Type":"NodeParagraph","Properties":{"id":"20260603084231-4gbezt4","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260603084231-at0qhdp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-at0qhdp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-cyhjgvr","Type":"NodeParagraph","Properties":{"id":"20260603084231-cyhjgvr","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260603084231-agpfsmn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-agpfsmn","updated":"20260603084231"},"Children":[{"ID":"20260603084231-tsbal00","Type":"NodeParagraph","Properties":{"id":"20260603084231-tsbal00","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260603084231-5tvsju7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5tvsju7","updated":"20260603084231"},"Children":[{"ID":"20260603084231-nguz2qz","Type":"NodeParagraph","Properties":{"id":"20260603084231-nguz2qz","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260603084231-lmsty6m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-lmsty6m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-lcf7y37","Type":"NodeParagraph","Properties":{"id":"20260603084231-lcf7y37","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260603084231-awd1s0q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-awd1s0q","updated":"20260603084231"},"Children":[{"ID":"20260603084231-n54b78i","Type":"NodeParagraph","Properties":{"id":"20260603084231-n54b78i","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603084231-ube02bw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-ube02bw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-obgn91e","Type":"NodeParagraph","Properties":{"id":"20260603084231-obgn91e","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260603084231-nxy33f1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-nxy33f1","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dcpmx4q","Type":"NodeParagraph","Properties":{"id":"20260603084231-dcpmx4q","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603084231-9d805xx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-9d805xx","updated":"20260603084231"},"Children":[{"ID":"20260603084231-riormwj","Type":"NodeParagraph","Properties":{"id":"20260603084231-riormwj","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260603084231-k5aafnp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-k5aafnp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-rsquok8","Type":"NodeParagraph","Properties":{"id":"20260603084231-rsquok8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260603084231-7ee5a9c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7ee5a9c","updated":"20260603084231"},"Children":[{"ID":"20260603084231-2nbldh6","Type":"NodeParagraph","Properties":{"id":"20260603084231-2nbldh6","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260603084231-2h5zyfz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-2h5zyfz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ud0h4tp","Type":"NodeParagraph","Properties":{"id":"20260603084231-ud0h4tp","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260603084231-obhu35v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-obhu35v","updated":"20260603084231"},"Children":[{"ID":"20260603084231-o7fq41x","Type":"NodeParagraph","Properties":{"id":"20260603084231-o7fq41x","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260603084231-y260ib6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-y260ib6","updated":"20260603084231"},"Children":[{"ID":"20260603084231-z62x9di","Type":"NodeParagraph","Properties":{"id":"20260603084231-z62x9di","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260603084231-dbnkjv2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dbnkjv2","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ckntkmj","Type":"NodeParagraph","Properties":{"id":"20260603084231-ckntkmj","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260603084231-o6iql0t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-o6iql0t","updated":"20260603084231"},"Children":[{"ID":"20260603084231-0ax3vzt","Type":"NodeParagraph","Properties":{"id":"20260603084231-0ax3vzt","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260603084231-dfm402j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-dfm402j","updated":"20260603084231"},"Children":[{"ID":"20260603084231-9jnqwon","Type":"NodeParagraph","Properties":{"id":"20260603084231-9jnqwon","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260603084231-t0tvrwi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-t0tvrwi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-fsvsjlw","Type":"NodeParagraph","Properties":{"id":"20260603084231-fsvsjlw","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260603084231-h9ulmhi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-h9ulmhi","updated":"20260603084231"},"Children":[{"ID":"20260603084231-oias2z3","Type":"NodeParagraph","Properties":{"id":"20260603084231-oias2z3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260603084231-4daw05z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-4daw05z","updated":"20260603084231"},"Children":[{"ID":"20260603084231-266sdg3","Type":"NodeParagraph","Properties":{"id":"20260603084231-266sdg3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260603084231-xf89aq5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xf89aq5","updated":"20260603084231"},"Children":[{"ID":"20260603084231-z8chedf","Type":"NodeParagraph","Properties":{"id":"20260603084231-z8chedf","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260603084231-xeuylin","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xeuylin","updated":"20260603084231"},"Children":[{"ID":"20260603084231-qfsoroh","Type":"NodeParagraph","Properties":{"id":"20260603084231-qfsoroh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260603084231-cgr9u27","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-cgr9u27","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ztbsatx","Type":"NodeParagraph","Properties":{"id":"20260603084231-ztbsatx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260603084231-7cr6885","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7cr6885","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hb5jk5l","Type":"NodeParagraph","Properties":{"id":"20260603084231-hb5jk5l","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260603084231-do9nnxw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-do9nnxw","updated":"20260603084231"},"Children":[{"ID":"20260603084231-4dti1nc","Type":"NodeParagraph","Properties":{"id":"20260603084231-4dti1nc","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260603084231-d22qemd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-d22qemd","updated":"20260603084231"},"Children":[{"ID":"20260603084231-85w89h2","Type":"NodeParagraph","Properties":{"id":"20260603084231-85w89h2","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260603084231-vmg69wk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vmg69wk","updated":"20260603084231"},"Children":[{"ID":"20260603084231-04gbw6o","Type":"NodeParagraph","Properties":{"id":"20260603084231-04gbw6o","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260603084231-fsjkd2m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-fsjkd2m","updated":"20260603084231"},"Children":[{"ID":"20260603084231-ib1bxd3","Type":"NodeParagraph","Properties":{"id":"20260603084231-ib1bxd3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260603084231-vl4t5to","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-vl4t5to","updated":"20260603084231"},"Children":[{"ID":"20260603084231-dxjwpj3","Type":"NodeParagraph","Properties":{"id":"20260603084231-dxjwpj3","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260603084231-sgxtucz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-sgxtucz","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8e7zaf5","Type":"NodeParagraph","Properties":{"id":"20260603084231-8e7zaf5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260603084231-yfw8hkr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-yfw8hkr","updated":"20260603084231"},"Children":[{"ID":"20260603084231-gpczngl","Type":"NodeParagraph","Properties":{"id":"20260603084231-gpczngl","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260603084231-kd0y6tp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-kd0y6tp","updated":"20260603084231"},"Children":[{"ID":"20260603084231-8xdjc24","Type":"NodeParagraph","Properties":{"id":"20260603084231-8xdjc24","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260603084231-wj670qf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-wj670qf","updated":"20260603084231"},"Children":[{"ID":"20260603084231-yztvcux","Type":"NodeParagraph","Properties":{"id":"20260603084231-yztvcux","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260603084231-yxa1feo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-yxa1feo","updated":"20260603084231"},"Children":[{"ID":"20260603084231-j0vxrab","Type":"NodeParagraph","Properties":{"id":"20260603084231-j0vxrab","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260603084231-7f6fx2p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-7f6fx2p","updated":"20260603084231"},"Children":[{"ID":"20260603084231-fy55r1k","Type":"NodeParagraph","Properties":{"id":"20260603084231-fy55r1k","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260603084231-f3gozbd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-f3gozbd","updated":"20260603084231"},"Children":[{"ID":"20260603084231-szjhcss","Type":"NodeParagraph","Properties":{"id":"20260603084231-szjhcss","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]}]}]},{"ID":"20260603084231-gdmnhvg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-gdmnhvg","updated":"20260603084231"},"Children":[{"ID":"20260603084231-hkocyxe","Type":"NodeParagraph","Properties":{"id":"20260603084231-hkocyxe","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。名言与典故必须作为论据服务于论点，不得为了展示库存而强行插入。"}]}]}]}]},{"ID":"20260603084231-hjt6lnq","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260603084231-hjt6lnq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-mel1neg","Type":"NodeParagraph","Properties":{"id":"20260603084231-mel1neg","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：请严格控制在850字左右，结尾必须留有2-3句极具力量的金句进行收束，不得草率。"}]}]},{"ID":"20260603084231-fkgd4xq","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OS4=","Num":9},"Properties":{"id":"20260603084231-fkgd4xq","updated":"20260603084231"},"Children":[{"ID":"20260603084231-z0fd1kh","Type":"NodeParagraph","Properties":{"id":"20260603084231-z0fd1kh","updated":"20260603084231"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260603084231-agr251l","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-agr251l","updated":"20260603084231"},"Children":[{"ID":"20260603084231-c22coft","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-c22coft","updated":"20260603084231"},"Children":[{"ID":"20260603084231-16gmtu8","Type":"NodeParagraph","Properties":{"id":"20260603084231-16gmtu8","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260603084231-d5p2pio","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-d5p2pio","updated":"20260603084231"},"Children":[{"ID":"20260603084231-twyowi9","Type":"NodeParagraph","Properties":{"id":"20260603084231-twyowi9","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]}]}]},{"ID":"20260603084231-t9n1cz5","Type":"NodeParagraph","Properties":{"id":"20260603084231-t9n1cz5","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【作文题目/材料/原文】"},{"Type":"NodeText","Data":"\n（在此处粘贴具体的作文题目、材料或话题，例如：2025年全国一卷关于老舍、艾青、穆旦的材料……）"}]},{"ID":"20260603084231-2fyunhx","Type":"NodeParagraph","Properties":{"id":"20260603084231-2fyunhx","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【逻辑自检与优化指令】"},{"Type":"NodeText","Data":"\n在生成完正文后，请严格执行以下检查步骤，以确保文章的逻辑严密性和考场适用性："}]},{"ID":"20260603084231-c7ngn23","Type":"NodeList","ListData":{},"Properties":{"id":"20260603084231-c7ngn23","updated":"20260603084231"},"Children":[{"ID":"20260603084231-zs1ep0r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-zs1ep0r","updated":"20260603084231"},"Children":[{"ID":"20260603084231-grxbdim","Type":"NodeParagraph","Properties":{"id":"20260603084231-grxbdim","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"逻辑回溯：请审视全文的论证链条。是否存在“观点A -\u003e 论据B（其实不支持A）”的逻辑断裂？"}]}]},{"ID":"20260603084231-5i2pp63","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-5i2pp63","updated":"20260603084231"},"Children":[{"ID":"20260603084231-sb1lohu","Type":"NodeParagraph","Properties":{"id":"20260603084231-sb1lohu","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"隐喻准确性检查（重点）：请检查文中关于“熵增定律”的隐喻（或其他科学原理/心理学效应）是否准确？它是否真正支撑了“自律”或“对抗无序”这一分论点，还是仅仅是一个华丽的辞藻堆砌？"}]}]},{"ID":"20260603084231-h99sl0h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-h99sl0h","updated":"20260603084231"},"Children":[{"ID":"20260603084231-plrn7vh","Type":"NodeParagraph","Properties":{"id":"20260603084231-plrn7vh","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"素材去重与更新：检查文中是否误用了“司马迁、李白、爱迪生”等过度使用的陈词滥调？如果是，请替换为更具时代感的素材。"}]}]},{"ID":"20260603084231-xkd27j9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603084231-xkd27j9","updated":"20260603084231"},"Children":[{"ID":"20260603084231-70a94ks","Type":"NodeParagraph","Properties":{"id":"20260603084231-70a94ks","updated":"20260603084231"},"Children":[{"Type":"NodeText","Data":"阅卷视角模拟：如果你是一位拥有20年经验的高考阅卷老师，这篇文章最可能因为什么被扣分（如：偏题、结构混乱、矫情）？请指出并微调。"}]}]}]}]}