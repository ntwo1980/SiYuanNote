odeParagraph","Properties":{"id":"20260601154516-6065bc3","updated":"20260601154926"},"Children":[{"Type":"NodeText","Data":"优先使用的典故、文章、诗词名句"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"："}]},{"ID":"20260601154237-ach6mms","Type":"NodeList","ListData":{},"Properties":{"id":"20260601154237-ach6mms","updated":"20260601161721"},"Children":[{"ID":"20260601154237-225k5vs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-225k5vs","updated":"20260531093730"},"Children":[{"ID":"20260601154237-ma698ak","Type":"NodeParagraph","Properties":{"id":"20260601154237-ma698ak","updated":"20260531093730"},"Children":[{"Type":"NodeText","Data":"《尚书》五福：寿、福、康宁、攸好德、考终命"}]}]},{"ID":"20260601154237-nk9f4wg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-nk9f4wg","updated":"20260601123925"},"Children":[{"ID":"20260601154237-ybokfff","Type":"NodeParagraph","Properties":{"id":"20260601154237-ybokfff","updated":"20260601125848"},"Children":[{"Type":"NodeText","Data":"鲁迅：无穷的远方，无数的人们，都与我相关。"}]}]},{"ID":"20260601154237-jqlerih","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jqlerih","updated":"20260601082421"},"Children":[{"ID":"20260601154237-7h9oxwj","Type":"NodeParagraph","Properties":{"id":"20260601154237-7h9oxwj","updated":"20260601082427"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260601154237-q447tar","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-q447tar","updated":"20260601082439"},"Children":[{"ID":"20260601154237-83vq9yx","Type":"NodeParagraph","Properties":{"id":"20260601154237-83vq9yx","updated":"20260601082439"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260601154237-oj1tjak","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oj1tjak","updated":"20260601161721"},"Children":[{"ID":"20260601154237-cpd9vtu","Type":"NodeParagraph","Properties":{"id":"20260601154237-cpd9vtu","updated":"20260601161721"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260601154237-xkz9wpx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xkz9wpx","updated":"20260601082520"},"Children":[{"ID":"20260601154237-b7cus7y","Type":"NodeParagraph","Properties":{"id":"20260601154237-b7cus7y","updated":"20260601082521"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260601154237-6cmjhrl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6cmjhrl","updated":"20260601082542"},"Children":[{"ID":"20260601154237-rzezeqd","Type":"NodeParagraph","Properties":{"id":"20260601154237-rzezeqd","updated":"20260601082545"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260601154237-fz2ek6s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fz2ek6s","updated":"20260601082611"},"Children":[{"ID":"20260601154237-g4u506g","Type":"NodeParagraph","Properties":{"id":"20260601154237-g4u506g","updated":"20260601082615"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260601154237-5ghud53","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5ghud53","updated":"20260601161706"},"Children":[{"ID":"20260601154237-fn5kyim","Type":"NodeParagraph","Properties":{"id":"20260601154237-fn5kyim","updated":"20260601161706"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260601154237-bx9dulx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bx9dulx","updated":"20260601161649"},"Children":[{"ID":"20260601154237-8g1ogc7","Type":"NodeParagraph","Properties":{"id":"20260601154237-8g1ogc7","updated":"20260601161649"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260601154237-boomzo5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-boomzo5","updated":"20260601161609"},"Children":[{"ID":"20260601154237-ph0hf02","Type":"NodeParagraph","Properties":{"id":"20260601154237-ph0hf02","updated":"20260601161609"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260601154237-i0vthws","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-i0vthws","updated":"20260601161555"},"Children":[{"ID":"20260601154237-4kr2frn","Type":"NodeParagraph","Properties":{"id":"20260601154237-4kr2frn","updated":"20260601161555"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260601154237-wmkq97e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wmkq97e","updated":"20260601161549"},"Children":[{"ID":"20260601154237-dl6ch5r","Type":"NodeParagraph","Properties":{"id":"20260601154237-dl6ch5r","updated":"20260601161549"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260601154237-f8laq82","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-f8laq82","updated":"20260601082922"},"Children":[{"ID":"20260601154237-fn61u3v","Type":"NodeParagraph","Properties":{"id":"20260601154237-fn61u3v","updated":"20260601082923"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260601154237-trrpg1u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-trrpg1u","updated":"20260601082938"},"Children":[{"ID":"20260601154237-gi4fmnp","Type":"NodeParagraph","Properties":{"id":"20260601154237-gi4fmnp","updated":"20260601082938"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260601154237-9bdow32","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9bdow32","updated":"20260601083002"},"Children":[{"ID":"20260601154237-qw4uyzu","Type":"NodeParagraph","Properties":{"id":"20260601154237-qw4uyzu","updated":"20260601083002"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260601154237-i4v1qkj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-i4v1qkj","updated":"20260601161528"},"Children":[{"ID":"20260601154237-0vprle6","Type":"NodeParagraph","Properties":{"id":"20260601154237-0vprle6","updated":"20260601161528"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260601154237-bttf6ic","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bttf6ic","updated":"20260601083050"},"Children":[{"ID":"20260601154237-61qv30h","Type":"NodeParagraph","Properties":{"id":"20260601154237-61qv30h","updated":"20260601083050"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260601154237-12um395","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-12um395","updated":"20260601161539"},"Children":[{"ID":"20260601154237-ixsl0g3","Type":"NodeParagraph","Properties":{"id":"20260601154237-ixsl0g3","updated":"20260601161539"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260601154237-yv3t9gc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yv3t9gc","updated":"20260601083127"},"Children":[{"ID":"20260601154237-mxwgijq","Type":"NodeParagraph","Properties":{"id":"20260601154237-mxwgijq","updated":"20260601083130"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260601154237-3klams1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3klams1","updated":"20260601083249"},"Children":[{"ID":"20260601154237-h7t6vmy","Type":"NodeParagraph","Properties":{"id":"20260601154237-h7t6vmy","updated":"20260601083250"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260601154237-816m17y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-816m17y","updated":"20260601083305"},"Children":[{"ID":"20260601154237-yi6v1jf","Type":"NodeParagraph","Properties":{"id":"20260601154237-yi6v1jf","updated":"20260601083305"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260601154237-qwcwgjs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qwcwgjs","updated":"20260601083357"},"Children":[{"ID":"20260601154237-lol430n","Type":"NodeParagraph","Properties":{"id":"20260601154237-lol430n","updated":"20260601083400"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260601154237-nc6hjao","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-nc6hjao","updated":"20260601083417"},"Children":[{"ID":"20260601154237-ri2ea63","Type":"NodeParagraph","Properties":{"id":"20260601154237-ri2ea63","updated":"20260601083420"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260601154237-iotjuf2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-iotjuf2","updated":"20260601083608"},"Children":[{"ID":"20260601154237-jswz1eq","Type":"NodeParagraph","Properties":{"id":"20260601154237-jswz1eq","updated":"20260601083611"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260601154237-79g9x0t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-79g9x0t","updated":"20260601132550"},"Children":[{"ID":"20260601154237-s8dtrao","Type":"NodeParagraph","Properties":{"id":"20260601154237-s8dtrao","updated":"20260601132550"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260601154237-q5sopxm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-q5sopxm","updated":"20260601083705"},"Children":[{"ID":"20260601154237-m4n3xxr","Type":"NodeParagraph","Properties":{"id":"20260601154237-m4n3xxr","updated":"20260601083710"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260601154237-pog93m2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-pog93m2","updated":"20260601161509"},"Children":[{"ID":"20260601154237-stdzj60","Type":"NodeParagraph","Properties":{"id":"20260601154237-stdzj60","updated":"20260601161509"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260601154237-vophhqz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vophhqz","updated":"20260601083741"},"Children":[{"ID":"20260601154237-tenzgp8","Type":"NodeParagraph","Properties":{"id":"20260601154237-tenzgp8","updated":"20260601083744"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260601154237-hbnqol2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hbnqol2","updated":"20260601083753"},"Children":[{"ID":"20260601154237-21vmtqr","Type":"NodeParagraph","Properties":{"id":"20260601154237-21vmtqr","updated":"20260601083756"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260601154237-w9pznpz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-w9pznpz","updated":"20260601083808"},"Children":[{"ID":"20260601154237-5d6e838","Type":"NodeParagraph","Properties":{"id":"20260601154237-5d6e838","updated":"20260601083811"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260601154237-wgsyv8z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wgsyv8z","updated":"20260601083823"},"Children":[{"ID":"20260601154237-51j9qve","Type":"NodeParagraph","Properties":{"id":"20260601154237-51j9qve","updated":"20260601083824"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260601154237-q5361uz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-q5361uz","updated":"20260601083834"},"Children":[{"ID":"20260601154237-o1zavo6","Type":"NodeParagraph","Properties":{"id":"20260601154237-o1zavo6","updated":"20260601083839"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260601154237-x8xv5qk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-x8xv5qk","updated":"20260601083851"},"Children":[{"ID":"20260601154237-9it1bfe","Type":"NodeParagraph","Properties":{"id":"20260601154237-9it1bfe","updated":"20260601083854"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260601154237-s71rsuf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-s71rsuf","updated":"20260601083903"},"Children":[{"ID":"20260601154237-9h5j9sy","Type":"NodeParagraph","Properties":{"id":"20260601154237-9h5j9sy","updated":"20260601083906"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260601154237-9jai4gn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9jai4gn","updated":"20260601083926"},"Children":[{"ID":"20260601154237-xn6j5qe","Type":"NodeParagraph","Properties":{"id":"20260601154237-xn6j5qe","updated":"20260601083930"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260601154237-bnpy87y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bnpy87y","updated":"20260601083941"},"Children":[{"ID":"20260601154237-9pjwqoc","Type":"NodeParagraph","Properties":{"id":"20260601154237-9pjwqoc","updated":"20260601083944"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260601154237-amadm1w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-amadm1w","updated":"20260601083953"},"Children":[{"ID":"20260601154237-vd5bttn","Type":"NodeParagraph","Properties":{"id":"20260601154237-vd5bttn","updated":"20260601083957"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260601154237-jdj2ma8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jdj2ma8","updated":"20260601084016"},"Children":[{"ID":"20260601154237-yfae13k","Type":"NodeParagraph","Properties":{"id":"20260601154237-yfae13k","updated":"20260601084020"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260601154237-mxq176h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mxq176h","updated":"20260601084044"},"Children":[{"ID":"20260601154237-wa48hh2","Type":"NodeParagraph","Properties":{"id":"20260601154237-wa48hh2","updated":"20260601084048"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260601154237-gptojrt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gptojrt","updated":"20260601084059"},"Children":[{"ID":"20260601154237-tca5n37","Type":"NodeParagraph","Properties":{"id":"20260601154237-tca5n37","updated":"20260601084103"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260601154237-0tuqvt0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0tuqvt0","updated":"20260601084126"},"Children":[{"ID":"20260601154237-snpezmk","Type":"NodeParagraph","Properties":{"id":"20260601154237-snpezmk","updated":"20260601084126"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260601154237-5o9x1a3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5o9x1a3","updated":"20260601161449"},"Children":[{"ID":"20260601154237-w1gq1r7","Type":"NodeParagraph","Properties":{"id":"20260601154237-w1gq1r7","updated":"20260601161449"},"Children":[{"Type":"NodeText","Data":"雨果：人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260601154237-yvertew","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yvertew","updated":"20260601084201"},"Children":[{"ID":"20260601154237-uzpls83","Type":"NodeParagraph","Properties":{"id":"20260601154237-uzpls83","updated":"20260601084204"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260601154237-w8u0bs1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-w8u0bs1","updated":"20260601084215"},"Children":[{"ID":"20260601154237-mvqwk4u","Type":"NodeParagraph","Properties":{"id":"20260601154237-mvqwk4u","updated":"20260601084215"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260601154237-7jizcz5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7jizcz5","updated":"20260601084225"},"Children":[{"ID":"20260601154237-299dwaa","Type":"NodeParagraph","Properties":{"id":"20260601154237-299dwaa","updated":"20260601084225"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260601154237-ljapnt1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ljapnt1","updated":"20260601084240"},"Children":[{"ID":"20260601154237-z1gqkkc","Type":"NodeParagraph","Properties":{"id":"20260601154237-z1gqkkc","updated":"20260601084243"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260601154237-tqc471q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-tqc471q","updated":"20260601084244"},"Children":[{"ID":"20260601154237-3nyis8e","Type":"NodeParagraph","Properties":{"id":"20260601154237-3nyis8e","updated":"20260601084256"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260601154237-wupigti","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wupigti","updated":"20260601084307"},"Children":[{"ID":"20260601154237-6rp6sng","Type":"NodeParagraph","Properties":{"id":"20260601154237-6rp6sng","updated":"20260601084307"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260601154237-k1tkyn9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k1tkyn9","updated":"20260601084316"},"Children":[{"ID":"20260601154237-9jdgy7p","Type":"NodeParagraph","Properties":{"id":"20260601154237-9jdgy7p","updated":"20260601084323"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260601154237-qiqbr8e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qiqbr8e","updated":"20260601084336"},"Children":[{"ID":"20260601154237-5livtfa","Type":"NodeParagraph","Properties":{"id":"20260601154237-5livtfa","updated":"20260601084340"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260601154237-5d95wr0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5d95wr0","updated":"20260601084341"},"Children":[{"ID":"20260601154237-ep6iugt","Type":"NodeParagraph","Properties":{"id":"20260601154237-ep6iugt","updated":"20260601084350"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260601154237-kc3j76a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-kc3j76a","updated":"20260601084400"},"Children":[{"ID":"20260601154237-dsx6t47","Type":"NodeParagraph","Properties":{"id":"20260601154237-dsx6t47","updated":"20260601084403"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260601154237-gcz48wt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gcz48wt","updated":"20260601084411"},"Children":[{"ID":"20260601154237-606l39n","Type":"NodeParagraph","Properties":{"id":"20260601154237-606l39n","updated":"20260601084412"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260601154237-0oqph1p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0oqph1p","updated":"20260601084422"},"Children":[{"ID":"20260601154237-u3hkmay","Type":"NodeParagraph","Properties":{"id":"20260601154237-u3hkmay","updated":"20260601084432"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260601154237-vvshyt7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vvshyt7","updated":"20260601084445"},"Children":[{"ID":"20260601154237-l44ccr9","Type":"NodeParagraph","Properties":{"id":"20260601154237-l44ccr9","updated":"20260601084450"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260601154237-m7677ub","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-m7677ub","updated":"20260601084503"},"Children":[{"ID":"20260601154237-mnqsvnq","Type":"NodeParagraph","Properties":{"id":"20260601154237-mnqsvnq","updated":"20260601084503"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260601154237-7lqkutl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7lqkutl","updated":"20260601084525"},"Children":[{"ID":"20260601154237-1tpu7hh","Type":"NodeParagraph","Properties":{"id":"20260601154237-1tpu7hh","updated":"20260601084536"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260601154237-s1n7g2l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-s1n7g2l","updated":"20260601084547"},"Children":[{"ID":"20260601154237-5rtu03k","Type":"NodeParagraph","Properties":{"id":"20260601154237-5rtu03k","updated":"20260601084547"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260601154237-qb8ehpw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qb8ehpw","updated":"20260601084556"},"Children":[{"ID":"20260601154237-iway9yf","Type":"NodeParagraph","Properties":{"id":"20260601154237-iway9yf","updated":"20260601084556"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260601154237-991qzlq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-991qzlq","updated":"20260601084607"},"Children":[{"ID":"20260601154237-0frfxpr","Type":"NodeParagraph","Properties":{"id":"20260601154237-0frfxpr","updated":"20260601084610"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260601154237-89y5mdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-89y5mdt","updated":"20260601084627"},"Children":[{"ID":"20260601154237-6hjccyr","Type":"NodeParagraph","Properties":{"id":"20260601154237-6hjccyr","updated":"20260601084627"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260601154237-uc7xvw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-uc7xvw9","updated":"20260601084643"},"Children":[{"ID":"20260601154237-8fdebrz","Type":"NodeParagraph","Properties":{"id":"20260601154237-8fdebrz","updated":"20260601084643"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260601154237-wmeu9he","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wmeu9he","updated":"20260601084702"},"Children":[{"ID":"20260601154237-np7yjgy","Type":"NodeParagraph","Properties":{"id":"20260601154237-np7yjgy","updated":"20260601084702"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260601154237-68c8o22","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-68c8o22","updated":"20260601084712"},"Children":[{"ID":"20260601154237-jwax0oe","Type":"NodeParagraph","Properties":{"id":"20260601154237-jwax0oe","updated":"20260601084718"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260601154237-ebhn26c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ebhn26c","updated":"20260601084719"},"Children":[{"ID":"20260601154237-3lhfl5v","Type":"NodeParagraph","Properties":{"id":"20260601154237-3lhfl5v","updated":"20260601084734"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260601154237-qc9gexe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qc9gexe","updated":"20260601084743"},"Children":[{"ID":"20260601154237-qxm51je","Type":"NodeParagraph","Properties":{"id":"20260601154237-qxm51je","updated":"20260601084745"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260601154237-vseumht","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vseumht","updated":"20260601084746"},"Children":[{"ID":"20260601154237-w394p3h","Type":"NodeParagraph","Properties":{"id":"20260601154237-w394p3h","updated":"20260601084757"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260601154237-tggq80w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-tggq80w","updated":"20260601084758"},"Children":[{"ID":"20260601154237-q0xqi68","Type":"NodeParagraph","Properties":{"id":"20260601154237-q0xqi68","updated":"20260601084816"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260601154237-s2bgd30","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-s2bgd30","updated":"20260601084832"},"Children":[{"ID":"20260601154237-oxmy309","Type":"NodeParagraph","Properties":{"id":"20260601154237-oxmy309","updated":"20260601084832"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260601154237-iumyaa4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-iumyaa4","updated":"20260601084844"},"Children":[{"ID":"20260601154237-ccjh590","Type":"NodeParagraph","Properties":{"id":"20260601154237-ccjh590","updated":"20260601084844"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260601154237-hfwe1i7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hfwe1i7","updated":"20260601084921"},"Children":[{"ID":"20260601154237-zkqzx5u","Type":"NodeParagraph","Properties":{"id":"20260601154237-zkqzx5u","updated":"20260601084921"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260601154237-6xk2rcp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6xk2rcp","updated":"20260601084934"},"Children":[{"ID":"20260601154237-utuf1ok","Type":"NodeParagraph","Properties":{"id":"20260601154237-utuf1ok","updated":"20260601084934"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260601154237-sc620cm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-sc620cm","updated":"20260601084948"},"Children":[{"ID":"20260601154237-wt456c8","Type":"NodeParagraph","Properties":{"id":"20260601154237-wt456c8","updated":"20260601084951"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260601154237-6nwe1d5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6nwe1d5","updated":"20260601161304"},"Children":[{"ID":"20260601154237-tktw4oe","Type":"NodeParagraph","Properties":{"id":"20260601154237-tktw4oe","updated":"20260601161304"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260601154237-a4kyw7k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-a4kyw7k","updated":"20260601085037"},"Children":[{"ID":"20260601154237-f3y8x92","Type":"NodeParagraph","Properties":{"id":"20260601154237-f3y8x92","updated":"20260601085038"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260601154237-rnbmra5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-rnbmra5","updated":"20260601085049"},"Children":[{"ID":"20260601154237-v6lhl89","Type":"NodeParagraph","Properties":{"id":"20260601154237-v6lhl89","updated":"20260601085049"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260601154237-kkrgbze","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-kkrgbze","updated":"20260601085058"},"Children":[{"ID":"20260601154237-0ylr2hs","Type":"NodeParagraph","Properties":{"id":"20260601154237-0ylr2hs","updated":"20260601085102"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260601154237-hhst42t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hhst42t","updated":"20260601085115"},"Children":[{"ID":"20260601154237-rjikvtp","Type":"NodeParagraph","Properties":{"id":"20260601154237-rjikvtp","updated":"20260601085115"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260601154237-vmlutzt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vmlutzt","updated":"20260601085125"},"Children":[{"ID":"20260601154237-oefo4l5","Type":"NodeParagraph","Properties":{"id":"20260601154237-oefo4l5","updated":"20260601085128"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260601154237-ph7ugq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ph7ugq3","updated":"20260601085139"},"Children":[{"ID":"20260601154237-9src8fw","Type":"NodeParagraph","Properties":{"id":"20260601154237-9src8fw","updated":"20260601085141"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260601154237-1yicqou","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1yicqou","updated":"20260601161249"},"Children":[{"ID":"20260601154237-35kdake","Type":"NodeParagraph","Properties":{"id":"20260601154237-35kdake","updated":"20260601161249"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260601154237-9z4nlk2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9z4nlk2","updated":"20260601161236"},"Children":[{"ID":"20260601154237-ddcqx4u","Type":"NodeParagraph","Properties":{"id":"20260601154237-ddcqx4u","updated":"20260601161236"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260601154237-xou6r2t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xou6r2t","updated":"20260601085239"},"Children":[{"ID":"20260601154237-6m158mk","Type":"NodeParagraph","Properties":{"id":"20260601154237-6m158mk","updated":"20260601085259"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260601154237-z74rxue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-z74rxue","updated":"20260601085309"},"Children":[{"ID":"20260601154237-ysjm8pq","Type":"NodeParagraph","Properties":{"id":"20260601154237-ysjm8pq","updated":"20260601085313"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260601154237-i56rwgq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-i56rwgq","updated":"20260601085324"},"Children":[{"ID":"20260601154237-qfhw7j5","Type":"NodeParagraph","Properties":{"id":"20260601154237-qfhw7j5","updated":"20260601085327"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260601154237-xuu2yo0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xuu2yo0","updated":"20260601085342"},"Children":[{"ID":"20260601154237-0pyzohz","Type":"NodeParagraph","Properties":{"id":"20260601154237-0pyzohz","updated":"20260601085342"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260601154237-svsij5g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-svsij5g","updated":"20260601085356"},"Children":[{"ID":"20260601154237-tniozth","Type":"NodeParagraph","Properties":{"id":"20260601154237-tniozth","updated":"20260601085356"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260601154237-6m7kijx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6m7kijx","updated":"20260601085425"},"Children":[{"ID":"20260601154237-18dmobz","Type":"NodeParagraph","Properties":{"id":"20260601154237-18dmobz","updated":"20260601085427"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260601154237-4g9ykcy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4g9ykcy","updated":"20260601085442"},"Children":[{"ID":"20260601154237-zq0yhfb","Type":"NodeParagraph","Properties":{"id":"20260601154237-zq0yhfb","updated":"20260601085457"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260601154237-ist88tg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ist88tg","updated":"20260601161217"},"Children":[{"ID":"20260601154237-kpt6xb1","Type":"NodeParagraph","Properties":{"id":"20260601154237-kpt6xb1","updated":"20260601161217"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260601154237-389dire","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-389dire","updated":"20260601161202"},"Children":[{"ID":"20260601154237-l5rlg8m","Type":"NodeParagraph","Properties":{"id":"20260601154237-l5rlg8m","updated":"20260601161202"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260601154237-a6s9nfb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-a6s9nfb","updated":"20260601085539"},"Children":[{"ID":"20260601154237-s3av0rb","Type":"NodeParagraph","Properties":{"id":"20260601154237-s3av0rb","updated":"20260601085543"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260601154237-z0t319h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-z0t319h","updated":"20260601085551"},"Children":[{"ID":"20260601154237-nods5ow","Type":"NodeParagraph","Properties":{"id":"20260601154237-nods5ow","updated":"20260601085552"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260601154237-2ldhkjh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2ldhkjh","updated":"20260601085603"},"Children":[{"ID":"20260601154237-qgnvnrg","Type":"NodeParagraph","Properties":{"id":"20260601154237-qgnvnrg","updated":"20260601085608"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260601154237-sryfgzl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-sryfgzl","updated":"20260601085609"},"Children":[{"ID":"20260601154237-0wpisu3","Type":"NodeParagraph","Properties":{"id":"20260601154237-0wpisu3","updated":"20260601085653"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260601154237-zikbjfc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-zikbjfc","updated":"20260601085709"},"Children":[{"ID":"20260601154237-qup2ac5","Type":"NodeParagraph","Properties":{"id":"20260601154237-qup2ac5","updated":"20260601085719"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260601154237-caf7fom","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-caf7fom","updated":"20260601085739"},"Children":[{"ID":"20260601154237-xxgkzn3","Type":"NodeParagraph","Properties":{"id":"20260601154237-xxgkzn3","updated":"20260601085739"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260601154237-e9u0jeb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-e9u0jeb","updated":"20260601085753"},"Children":[{"ID":"20260601154237-t9qeqq3","Type":"NodeParagraph","Properties":{"id":"20260601154237-t9qeqq3","updated":"20260601085753"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260601154237-jhi6jxj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jhi6jxj","updated":"20260601161149"},"Children":[{"ID":"20260601154237-2f5uhiw","Type":"NodeParagraph","Properties":{"id":"20260601154237-2f5uhiw","updated":"20260601161149"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260601154237-5bcq5d7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5bcq5d7","updated":"20260601085819"},"Children":[{"ID":"20260601154237-ip3bhvd","Type":"NodeParagraph","Properties":{"id":"20260601154237-ip3bhvd","updated":"20260601085823"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260601154237-j6h1h3m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-j6h1h3m","updated":"20260601085833"},"Children":[{"ID":"20260601154237-mxrvxfk","Type":"NodeParagraph","Properties":{"id":"20260601154237-mxrvxfk","updated":"20260601085837"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260601154237-weiz7kc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-weiz7kc","updated":"20260601085845"},"Children":[{"ID":"20260601154237-v82ltrv","Type":"NodeParagraph","Properties":{"id":"20260601154237-v82ltrv","updated":"20260601085845"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260601154237-mq0at1k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mq0at1k","updated":"20260601085856"},"Children":[{"ID":"20260601154237-7otiulz","Type":"NodeParagraph","Properties":{"id":"20260601154237-7otiulz","updated":"20260601085856"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260601154237-gem2po5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gem2po5","updated":"20260601085911"},"Children":[{"ID":"20260601154237-nhybftd","Type":"NodeParagraph","Properties":{"id":"20260601154237-nhybftd","updated":"20260601085911"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260601154237-fik144o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fik144o","updated":"20260601161130"},"Children":[{"ID":"20260601154237-uhvoxmm","Type":"NodeParagraph","Properties":{"id":"20260601154237-uhvoxmm","updated":"20260601161130"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260601154237-j90gt4c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-j90gt4c","updated":"20260601090127"},"Children":[{"ID":"20260601154237-wf8q4iw","Type":"NodeParagraph","Properties":{"id":"20260601154237-wf8q4iw","updated":"20260601090130"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260601154237-7b7a36g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7b7a36g","updated":"20260601090156"},"Children":[{"ID":"20260601154237-p11trsz","Type":"NodeParagraph","Properties":{"id":"20260601154237-p11trsz","updated":"20260601090158"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260601154237-hwk19g1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hwk19g1","updated":"20260601090200"},"Children":[{"ID":"20260601154237-sthvmm9","Type":"NodeParagraph","Properties":{"id":"20260601154237-sthvmm9","updated":"20260601090210"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260601154237-6vbt3wd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6vbt3wd","updated":"20260601090225"},"Children":[{"ID":"20260601154237-xfxvsqj","Type":"NodeParagraph","Properties":{"id":"20260601154237-xfxvsqj","updated":"20260601090225"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260601154237-dkkv2w0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dkkv2w0","updated":"20260601161055"},"Children":[{"ID":"20260601154237-8s1lito","Type":"NodeParagraph","Properties":{"id":"20260601154237-8s1lito","updated":"20260601161055"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260601154237-1f7uo7t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1f7uo7t","updated":"20260601090319"},"Children":[{"ID":"20260601154237-hmr09bi","Type":"NodeParagraph","Properties":{"id":"20260601154237-hmr09bi","updated":"20260601090319"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260601154237-fjy7f9k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fjy7f9k","updated":"20260601161048"},"Children":[{"ID":"20260601154237-0nwcsn5","Type":"NodeParagraph","Properties":{"id":"20260601154237-0nwcsn5","updated":"20260601161048"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260601154237-ztnjkxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ztnjkxh","updated":"20260601090430"},"Children":[{"ID":"20260601154237-fqthe1z","Type":"NodeParagraph","Properties":{"id":"20260601154237-fqthe1z","updated":"20260601090437"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260601154237-zojbdz1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-zojbdz1","updated":"20260601161034"},"Children":[{"ID":"20260601154237-ecqnuob","Type":"NodeParagraph","Properties":{"id":"20260601154237-ecqnuob","updated":"20260601161034"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260601154237-h1tdcqq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-h1tdcqq","updated":"20260601090508"},"Children":[{"ID":"20260601154237-9aiuefw","Type":"NodeParagraph","Properties":{"id":"20260601154237-9aiuefw","updated":"20260601090515"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260601154237-qgwxkao","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qgwxkao","updated":"20260601090527"},"Children":[{"ID":"20260601154237-82698a6","Type":"NodeParagraph","Properties":{"id":"20260601154237-82698a6","updated":"20260601090531"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260601154237-8stnykg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8stnykg","updated":"20260601090532"},"Children":[{"ID":"20260601154237-0d14vdl","Type":"NodeParagraph","Properties":{"id":"20260601154237-0d14vdl","updated":"20260601090548"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260601154237-dvk8b7y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dvk8b7y","updated":"20260601090559"},"Children":[{"ID":"20260601154237-9lljuit","Type":"NodeParagraph","Properties":{"id":"20260601154237-9lljuit","updated":"20260601090602"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260601154237-6d89qf9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6d89qf9","updated":"20260601090612"},"Children":[{"ID":"20260601154237-nna6gej","Type":"NodeParagraph","Properties":{"id":"20260601154237-nna6gej","updated":"20260601090612"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260601154237-9wv9gm4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9wv9gm4","updated":"20260601090622"},"Children":[{"ID":"20260601154237-gczq1aa","Type":"NodeParagraph","Properties":{"id":"20260601154237-gczq1aa","updated":"20260601090625"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260601154237-evz3w2s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-evz3w2s","updated":"20260601090633"},"Children":[{"ID":"20260601154237-uycs7il","Type":"NodeParagraph","Properties":{"id":"20260601154237-uycs7il","updated":"20260601090636"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260601154237-4in49c8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4in49c8","updated":"20260601090637"},"Children":[{"ID":"20260601154237-yrkfsfo","Type":"NodeParagraph","Properties":{"id":"20260601154237-yrkfsfo","updated":"20260601090650"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260601154237-d34t6g7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-d34t6g7","updated":"20260601090651"},"Children":[{"ID":"20260601154237-tesyznn","Type":"NodeParagraph","Properties":{"id":"20260601154237-tesyznn","updated":"20260601090703"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260601154237-40dghl2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-40dghl2","updated":"20260601090723"},"Children":[{"ID":"20260601154237-o0gwpy0","Type":"NodeParagraph","Properties":{"id":"20260601154237-o0gwpy0","updated":"20260601090724"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260601154237-llvzimc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-llvzimc","updated":"20260601090734"},"Children":[{"ID":"20260601154237-ums6m7v","Type":"NodeParagraph","Properties":{"id":"20260601154237-ums6m7v","updated":"20260601090739"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260601154237-ycvk56q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ycvk56q","updated":"20260601161017"},"Children":[{"ID":"20260601154237-r753n28","Type":"NodeParagraph","Properties":{"id":"20260601154237-r753n28","updated":"20260601161017"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260601154237-wdgm2ix","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wdgm2ix","updated":"20260601090812"},"Children":[{"ID":"20260601154237-btomtlz","Type":"NodeParagraph","Properties":{"id":"20260601154237-btomtlz","updated":"20260601090814"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260601154237-1mfrivl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1mfrivl","updated":"20260601090824"},"Children":[{"ID":"20260601154237-itegksj","Type":"NodeParagraph","Properties":{"id":"20260601154237-itegksj","updated":"20260601090824"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260601154237-5ivloe4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5ivloe4","updated":"20260601090852"},"Children":[{"ID":"20260601154237-dcp9s3f","Type":"NodeParagraph","Properties":{"id":"20260601154237-dcp9s3f","updated":"20260601090852"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260601154237-chwt8c9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-chwt8c9","updated":"20260601090900"},"Children":[{"ID":"20260601154237-zoxparm","Type":"NodeParagraph","Properties":{"id":"20260601154237-zoxparm","updated":"20260601090904"},"Children":[{"Type":"NodeText","Data":"没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260601154237-51wkhob","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-51wkhob","updated":"20260601090921"},"Children":[{"ID":"20260601154237-sa7hi0j","Type":"NodeParagraph","Properties":{"id":"20260601154237-sa7hi0j","updated":"20260601090924"},"Children":[{"Type":"NodeText","Data":"才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260601154237-k0reyyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k0reyyb","updated":"20260601090936"},"Children":[{"ID":"20260601154237-eyx2pmd","Type":"NodeParagraph","Properties":{"id":"20260601154237-eyx2pmd","updated":"20260601090937"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260601154237-le1nwpy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-le1nwpy","updated":"20260601090948"},"Children":[{"ID":"20260601154237-z2xb0qg","Type":"NodeParagraph","Properties":{"id":"20260601154237-z2xb0qg","updated":"20260601090956"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260601154237-xpd42i9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xpd42i9","updated":"20260601160957"},"Children":[{"ID":"20260601154237-x52bxim","Type":"NodeParagraph","Properties":{"id":"20260601154237-x52bxim","updated":"20260601160957"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260601154237-r2p9rv8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-r2p9rv8","updated":"20260601091022"},"Children":[{"ID":"20260601154237-pfa22sh","Type":"NodeParagraph","Properties":{"id":"20260601154237-pfa22sh","updated":"20260601091036"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260601154237-oodqqfd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oodqqfd","updated":"20260601160946"},"Children":[{"ID":"20260601154237-r1lm6db","Type":"NodeParagraph","Properties":{"id":"20260601154237-r1lm6db","updated":"20260601160946"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260601154237-kwdyymc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-kwdyymc","updated":"20260601091105"},"Children":[{"ID":"20260601154237-g2uyyok","Type":"NodeParagraph","Properties":{"id":"20260601154237-g2uyyok","updated":"20260601091108"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260601154237-n6z11gb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-n6z11gb","updated":"20260601160933"},"Children":[{"ID":"20260601154237-vyvz1mc","Type":"NodeParagraph","Properties":{"id":"20260601154237-vyvz1mc","updated":"20260601160933"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260601154237-3ctr94s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3ctr94s","updated":"20260601160918"},"Children":[{"ID":"20260601154237-ky4uii4","Type":"NodeParagraph","Properties":{"id":"20260601154237-ky4uii4","updated":"20260601160918"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260601154237-clz9ccq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-clz9ccq","updated":"20260601160907"},"Children":[{"ID":"20260601154237-jslhpqv","Type":"NodeParagraph","Properties":{"id":"20260601154237-jslhpqv","updated":"20260601160907"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260601154237-0o2l02l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0o2l02l","updated":"20260601091228"},"Children":[{"ID":"20260601154237-4pcoav7","Type":"NodeParagraph","Properties":{"id":"20260601154237-4pcoav7","updated":"20260601091229"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260601154237-evhwm4c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-evhwm4c","updated":"20260601091241"},"Children":[{"ID":"20260601154237-1fexg9c","Type":"NodeParagraph","Properties":{"id":"20260601154237-1fexg9c","updated":"20260601091246"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260601154237-5z0m2i5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5z0m2i5","updated":"20260601160844"},"Children":[{"ID":"20260601154237-7w8kf9h","Type":"NodeParagraph","Properties":{"id":"20260601154237-7w8kf9h","updated":"20260601160844"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260601154237-y1nh9nx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-y1nh9nx","updated":"20260601091317"},"Children":[{"ID":"20260601154237-8ci9aez","Type":"NodeParagraph","Properties":{"id":"20260601154237-8ci9aez","updated":"20260601091318"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260601154237-s8vsdu0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-s8vsdu0","updated":"20260601091319"},"Children":[{"ID":"20260601154237-729b7sp","Type":"NodeParagraph","Properties":{"id":"20260601154237-729b7sp","updated":"20260601091331"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260601154237-zzo09fp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-zzo09fp","updated":"20260601091332"},"Children":[{"ID":"20260601154237-ndzdsfc","Type":"NodeParagraph","Properties":{"id":"20260601154237-ndzdsfc","updated":"20260601091342"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260601154237-b29dj73","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-b29dj73","updated":"20260601091353"},"Children":[{"ID":"20260601154237-dub5tos","Type":"NodeParagraph","Properties":{"id":"20260601154237-dub5tos","updated":"20260601091353"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260601154237-mukzny7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mukzny7","updated":"20260601091402"},"Children":[{"ID":"20260601154237-vqpgjzb","Type":"NodeParagraph","Properties":{"id":"20260601154237-vqpgjzb","updated":"20260601091405"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260601154237-y6t2lcf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-y6t2lcf","updated":"20260601091417"},"Children":[{"ID":"20260601154237-i4f3qye","Type":"NodeParagraph","Properties":{"id":"20260601154237-i4f3qye","updated":"20260601091422"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260601154237-y47xcpo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-y47xcpo","updated":"20260601091431"},"Children":[{"ID":"20260601154237-j26w3j2","Type":"NodeParagraph","Properties":{"id":"20260601154237-j26w3j2","updated":"20260601091434"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260601154237-0a4g88l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0a4g88l","updated":"20260601091435"},"Children":[{"ID":"20260601154237-v7r1pgb","Type":"NodeParagraph","Properties":{"id":"20260601154237-v7r1pgb","updated":"20260601091503"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260601154237-10pe5yz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-10pe5yz","updated":"20260601091523"},"Children":[{"ID":"20260601154237-2yvqzdj","Type":"NodeParagraph","Properties":{"id":"20260601154237-2yvqzdj","updated":"20260601091524"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260601154237-mogratr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mogratr","updated":"20260601091541"},"Children":[{"ID":"20260601154237-oalrsws","Type":"NodeParagraph","Properties":{"id":"20260601154237-oalrsws","updated":"20260601091544"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260601154237-pwavr98","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-pwavr98","updated":"20260601091611"},"Children":[{"ID":"20260601154237-5mj7r2l","Type":"NodeParagraph","Properties":{"id":"20260601154237-5mj7r2l","updated":"20260601091614"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260601154237-ml9kqdq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ml9kqdq","updated":"20260601091615"},"Children":[{"ID":"20260601154237-d2yq0mq","Type":"NodeParagraph","Properties":{"id":"20260601154237-d2yq0mq","updated":"20260601091638"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260601154237-ukjghjb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ukjghjb","updated":"20260601091647"},"Children":[{"ID":"20260601154237-y64ll7s","Type":"NodeParagraph","Properties":{"id":"20260601154237-y64ll7s","updated":"20260601091700"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260601154237-0qeq4ue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0qeq4ue","updated":"20260601091656"},"Children":[{"ID":"20260601154237-dnj6s1d","Type":"NodeParagraph","Properties":{"id":"20260601154237-dnj6s1d","updated":"20260601091700"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260601154237-rswe3uj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-rswe3uj","updated":"20260601091709"},"Children":[{"ID":"20260601154237-nwbnq39","Type":"NodeParagraph","Properties":{"id":"20260601154237-nwbnq39","updated":"20260601091709"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260601154237-typ0kya","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-typ0kya","updated":"20260601091718"},"Children":[{"ID":"20260601154237-f8q9rqj","Type":"NodeParagraph","Properties":{"id":"20260601154237-f8q9rqj","updated":"20260601091721"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260601154237-v7zxlpu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-v7zxlpu","updated":"20260601091803"},"Children":[{"ID":"20260601154237-j27cn95","Type":"NodeParagraph","Properties":{"id":"20260601154237-j27cn95","updated":"20260601091803"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260601154237-bzes1f9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bzes1f9","updated":"20260601160822"},"Children":[{"ID":"20260601154237-4ayuq4n","Type":"NodeParagraph","Properties":{"id":"20260601154237-4ayuq4n","updated":"20260601160822"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260601154237-d5ymzlw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-d5ymzlw","updated":"20260601091834"},"Children":[{"ID":"20260601154237-4zw8icy","Type":"NodeParagraph","Properties":{"id":"20260601154237-4zw8icy","updated":"20260601091835"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260601154237-8teop8k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8teop8k","updated":"20260601091845"},"Children":[{"ID":"20260601154237-jguuj9f","Type":"NodeParagraph","Properties":{"id":"20260601154237-jguuj9f","updated":"20260601091859"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260601154237-y9qpri0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-y9qpri0","updated":"20260601091928"},"Children":[{"ID":"20260601154237-h1ilbu4","Type":"NodeParagraph","Properties":{"id":"20260601154237-h1ilbu4","updated":"20260601091936"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260601154237-q0mzz2e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-q0mzz2e","updated":"20260601092003"},"Children":[{"ID":"20260601154237-stojnk6","Type":"NodeParagraph","Properties":{"id":"20260601154237-stojnk6","updated":"20260601092007"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260601154237-diyz7yl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-diyz7yl","updated":"20260601092008"},"Children":[{"ID":"20260601154237-52mjwq8","Type":"NodeParagraph","Properties":{"id":"20260601154237-52mjwq8","updated":"20260601092025"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260601154237-cihynjj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-cihynjj","updated":"20260601092034"},"Children":[{"ID":"20260601154237-q18qwsx","Type":"NodeParagraph","Properties":{"id":"20260601154237-q18qwsx","updated":"20260601092036"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260601154237-1clk9a2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1clk9a2","updated":"20260601092046"},"Children":[{"ID":"20260601154237-zwhends","Type":"NodeParagraph","Properties":{"id":"20260601154237-zwhends","updated":"20260601092049"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260601154237-1181cng","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1181cng","updated":"20260601092050"},"Children":[{"ID":"20260601154237-zviutm2","Type":"NodeParagraph","Properties":{"id":"20260601154237-zviutm2","updated":"20260601092107"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260601154237-eczp16m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-eczp16m","updated":"20260601092115"},"Children":[{"ID":"20260601154237-62w4wq5","Type":"NodeParagraph","Properties":{"id":"20260601154237-62w4wq5","updated":"20260601092118"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260601154237-azasf7n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-azasf7n","updated":"20260601092126"},"Children":[{"ID":"20260601154237-7hefgmi","Type":"NodeParagraph","Properties":{"id":"20260601154237-7hefgmi","updated":"20260601092126"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260601154237-7kl89pr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7kl89pr","updated":"20260601092137"},"Children":[{"ID":"20260601154237-ozav4d9","Type":"NodeParagraph","Properties":{"id":"20260601154237-ozav4d9","updated":"20260601092144"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260601154237-4q40yzg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4q40yzg","updated":"20260601092152"},"Children":[{"ID":"20260601154237-bw9xqzm","Type":"NodeParagraph","Properties":{"id":"20260601154237-bw9xqzm","updated":"20260601092157"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260601154237-81ko3et","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-81ko3et","updated":"20260601092207"},"Children":[{"ID":"20260601154237-8bwzsbr","Type":"NodeParagraph","Properties":{"id":"20260601154237-8bwzsbr","updated":"20260601092210"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260601154237-q97wqdw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-q97wqdw","updated":"20260601092220"},"Children":[{"ID":"20260601154237-cp74znz","Type":"NodeParagraph","Properties":{"id":"20260601154237-cp74znz","updated":"20260601092220"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260601154237-1yjepix","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1yjepix","updated":"20260601092230"},"Children":[{"ID":"20260601154237-7k05sj7","Type":"NodeParagraph","Properties":{"id":"20260601154237-7k05sj7","updated":"20260601092232"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260601154237-1ppnz5s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1ppnz5s","updated":"20260601092234"},"Children":[{"ID":"20260601154237-amo22hu","Type":"NodeParagraph","Properties":{"id":"20260601154237-amo22hu","updated":"20260601092247"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260601154237-fxfwi11","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fxfwi11","updated":"20260601092303"},"Children":[{"ID":"20260601154237-8ynljtw","Type":"NodeParagraph","Properties":{"id":"20260601154237-8ynljtw","updated":"20260601092303"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260601154237-fhz7y5d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fhz7y5d","updated":"20260601092317"},"Children":[{"ID":"20260601154237-fnfj5n1","Type":"NodeParagraph","Properties":{"id":"20260601154237-fnfj5n1","updated":"20260601092317"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260601154237-au3f5ks","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-au3f5ks","updated":"20260601092329"},"Children":[{"ID":"20260601154237-fo2k412","Type":"NodeParagraph","Properties":{"id":"20260601154237-fo2k412","updated":"20260601092332"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260601154237-5y3o1y0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5y3o1y0","updated":"20260601092344"},"Children":[{"ID":"20260601154237-ic6t0mk","Type":"NodeParagraph","Properties":{"id":"20260601154237-ic6t0mk","updated":"20260601092344"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260601154237-5onkk61","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5onkk61","updated":"20260601160747"},"Children":[{"ID":"20260601154237-7qeinz9","Type":"NodeParagraph","Properties":{"id":"20260601154237-7qeinz9","updated":"20260601160747"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260601154237-u1j2ebr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-u1j2ebr","updated":"20260601092407"},"Children":[{"ID":"20260601154237-3ot788i","Type":"NodeParagraph","Properties":{"id":"20260601154237-3ot788i","updated":"20260601092407"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260601154237-8pxiwlj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8pxiwlj","updated":"20260601092415"},"Children":[{"ID":"20260601154237-zctsrwt","Type":"NodeParagraph","Properties":{"id":"20260601154237-zctsrwt","updated":"20260601092417"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260601154237-bool1o8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bool1o8","updated":"20260601092428"},"Children":[{"ID":"20260601154237-0lqa9q7","Type":"NodeParagraph","Properties":{"id":"20260601154237-0lqa9q7","updated":"20260601092430"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260601154237-ppsyemd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ppsyemd","updated":"20260601160732"},"Children":[{"ID":"20260601154237-ia9nyw5","Type":"NodeParagraph","Properties":{"id":"20260601154237-ia9nyw5","updated":"20260601160732"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260601154237-ordpjwp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ordpjwp","updated":"20260601160720"},"Children":[{"ID":"20260601154237-vk0dcpl","Type":"NodeParagraph","Properties":{"id":"20260601154237-vk0dcpl","updated":"20260601160720"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260601154237-nvizsc7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-nvizsc7","updated":"20260601160708"},"Children":[{"ID":"20260601154237-mzb2i0p","Type":"NodeParagraph","Properties":{"id":"20260601154237-mzb2i0p","updated":"20260601160708"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260601154237-ewvsoc7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ewvsoc7","updated":"20260601092744"},"Children":[{"ID":"20260601154237-t2fbxzp","Type":"NodeParagraph","Properties":{"id":"20260601154237-t2fbxzp","updated":"20260601092744"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260601154237-vmvqz7d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vmvqz7d","updated":"20260601092811"},"Children":[{"ID":"20260601154237-p2zppr7","Type":"NodeParagraph","Properties":{"id":"20260601154237-p2zppr7","updated":"20260601092814"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260601154237-ocdtzzj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ocdtzzj","updated":"20260601092823"},"Children":[{"ID":"20260601154237-xafd6a7","Type":"NodeParagraph","Properties":{"id":"20260601154237-xafd6a7","updated":"20260601092823"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260601154237-jl01m16","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jl01m16","updated":"20260601092840"},"Children":[{"ID":"20260601154237-3ivjk8a","Type":"NodeParagraph","Properties":{"id":"20260601154237-3ivjk8a","updated":"20260601092843"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260601154237-wq52a3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wq52a3x","updated":"20260601092854"},"Children":[{"ID":"20260601154237-55nkynl","Type":"NodeParagraph","Properties":{"id":"20260601154237-55nkynl","updated":"20260601092854"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260601154237-5y69k27","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5y69k27","updated":"20260601160650"},"Children":[{"ID":"20260601154237-lv5v2z9","Type":"NodeParagraph","Properties":{"id":"20260601154237-lv5v2z9","updated":"20260601160650"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260601154237-9w3agvp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9w3agvp","updated":"20260601092916"},"Children":[{"ID":"20260601154237-xjuivb1","Type":"NodeParagraph","Properties":{"id":"20260601154237-xjuivb1","updated":"20260601092916"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260601154237-t06picl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-t06picl","updated":"20260601092926"},"Children":[{"ID":"20260601154237-nmpmxk9","Type":"NodeParagraph","Properties":{"id":"20260601154237-nmpmxk9","updated":"20260601092933"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260601154237-mk741ch","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mk741ch","updated":"20260601160636"},"Children":[{"ID":"20260601154237-wywchwt","Type":"NodeParagraph","Properties":{"id":"20260601154237-wywchwt","updated":"20260601160636"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260601154237-xv4ua6o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xv4ua6o","updated":"20260601092958"},"Children":[{"ID":"20260601154237-urgbvp5","Type":"NodeParagraph","Properties":{"id":"20260601154237-urgbvp5","updated":"20260601092958"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260601154237-3kmc1nc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3kmc1nc","updated":"20260601093007"},"Children":[{"ID":"20260601154237-00q46o5","Type":"NodeParagraph","Properties":{"id":"20260601154237-00q46o5","updated":"20260601093007"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260601154237-90di27y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-90di27y","updated":"20260601093046"},"Children":[{"ID":"20260601154237-auxp61e","Type":"NodeParagraph","Properties":{"id":"20260601154237-auxp61e","updated":"20260601093050"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260601154237-7940k4j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7940k4j","updated":"20260601093051"},"Children":[{"ID":"20260601154237-s8w4ajn","Type":"NodeParagraph","Properties":{"id":"20260601154237-s8w4ajn","updated":"20260601093107"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260601154237-pkbsnye","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-pkbsnye","updated":"20260601093119"},"Children":[{"ID":"20260601154237-q7u7vgp","Type":"NodeParagraph","Properties":{"id":"20260601154237-q7u7vgp","updated":"20260601093119"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260601154237-knaohuw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-knaohuw","updated":"20260601093202"},"Children":[{"ID":"20260601154237-ycpdhbr","Type":"NodeParagraph","Properties":{"id":"20260601154237-ycpdhbr","updated":"20260601093202"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260601154237-wensmyj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wensmyj","updated":"20260601093744"},"Children":[{"ID":"20260601154237-fnwq0jo","Type":"NodeParagraph","Properties":{"id":"20260601154237-fnwq0jo","updated":"20260601093747"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260601154237-5l7l3t2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5l7l3t2","updated":"20260601093757"},"Children":[{"ID":"20260601154237-ehxa0wj","Type":"NodeParagraph","Properties":{"id":"20260601154237-ehxa0wj","updated":"20260601093759"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260601154237-49hpnap","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-49hpnap","updated":"20260601093815"},"Children":[{"ID":"20260601154237-9684umb","Type":"NodeParagraph","Properties":{"id":"20260601154237-9684umb","updated":"20260601093819"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260601154237-gkadid0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gkadid0","updated":"20260601093901"},"Children":[{"ID":"20260601154237-jq07jzy","Type":"NodeParagraph","Properties":{"id":"20260601154237-jq07jzy","updated":"20260601093904"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260601154237-bbtnthg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bbtnthg","updated":"20260601160626"},"Children":[{"ID":"20260601154237-r2klsb7","Type":"NodeParagraph","Properties":{"id":"20260601154237-r2klsb7","updated":"20260601160626"},"Children":[{"Type":"NodeText","Data":"雨果：世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260601154237-7bsl92e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7bsl92e","updated":"20260601094028"},"Children":[{"ID":"20260601154237-kctfrj5","Type":"NodeParagraph","Properties":{"id":"20260601154237-kctfrj5","updated":"20260601094035"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260601154237-1slm3tw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1slm3tw","updated":"20260601094141"},"Children":[{"ID":"20260601154237-wgq28ga","Type":"NodeParagraph","Properties":{"id":"20260601154237-wgq28ga","updated":"20260601094144"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260601154237-vqhbaia","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vqhbaia","updated":"20260601094200"},"Children":[{"ID":"20260601154237-uwfhf79","Type":"NodeParagraph","Properties":{"id":"20260601154237-uwfhf79","updated":"20260601094200"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260601154237-b28n2zh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-b28n2zh","updated":"20260601160552"},"Children":[{"ID":"20260601154237-by7gx9i","Type":"NodeParagraph","Properties":{"id":"20260601154237-by7gx9i","updated":"20260601160552"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260601154237-d5mw673","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-d5mw673","updated":"20260601094252"},"Children":[{"ID":"20260601154237-buy5cy0","Type":"NodeParagraph","Properties":{"id":"20260601154237-buy5cy0","updated":"20260601094254"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260601154237-oqsryzy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oqsryzy","updated":"20260601094309"},"Children":[{"ID":"20260601154237-ae8nasx","Type":"NodeParagraph","Properties":{"id":"20260601154237-ae8nasx","updated":"20260601094312"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260601154237-ho1vjos","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ho1vjos","updated":"20260601094332"},"Children":[{"ID":"20260601154237-kfm4zqr","Type":"NodeParagraph","Properties":{"id":"20260601154237-kfm4zqr","updated":"20260601094338"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260601154237-48kpcup","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-48kpcup","updated":"20260601094359"},"Children":[{"ID":"20260601154237-xbbu7dj","Type":"NodeParagraph","Properties":{"id":"20260601154237-xbbu7dj","updated":"20260601094401"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260601154237-b2si9u1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-b2si9u1","updated":"20260601160534"},"Children":[{"ID":"20260601154237-7qeet56","Type":"NodeParagraph","Properties":{"id":"20260601154237-7qeet56","updated":"20260601160534"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260601154237-xxyds5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xxyds5l","updated":"20260601160519"},"Children":[{"ID":"20260601154237-072f367","Type":"NodeParagraph","Properties":{"id":"20260601154237-072f367","updated":"20260601160519"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260601154237-dafycw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dafycw9","updated":"20260601094437"},"Children":[{"ID":"20260601154237-zk96658","Type":"NodeParagraph","Properties":{"id":"20260601154237-zk96658","updated":"20260601094439"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260601154237-h6wf3s9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-h6wf3s9","updated":"20260601094440"},"Children":[{"ID":"20260601154237-m2aw3lv","Type":"NodeParagraph","Properties":{"id":"20260601154237-m2aw3lv","updated":"20260601094455"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260601154237-mh5sv4q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mh5sv4q","updated":"20260601160503"},"Children":[{"ID":"20260601154237-amkkuc2","Type":"NodeParagraph","Properties":{"id":"20260601154237-amkkuc2","updated":"20260601160503"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260601154237-3zjrh2x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3zjrh2x","updated":"20260601094942"},"Children":[{"ID":"20260601154237-q1e01za","Type":"NodeParagraph","Properties":{"id":"20260601154237-q1e01za","updated":"20260601094944"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260601154237-3mkq8sc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3mkq8sc","updated":"20260601095000"},"Children":[{"ID":"20260601154237-60ijljy","Type":"NodeParagraph","Properties":{"id":"20260601154237-60ijljy","updated":"20260601095002"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260601154237-ny6hsfd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ny6hsfd","updated":"20260601095016"},"Children":[{"ID":"20260601154237-y0eatil","Type":"NodeParagraph","Properties":{"id":"20260601154237-y0eatil","updated":"20260601095016"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260601154237-qg4nrsy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qg4nrsy","updated":"20260601095027"},"Children":[{"ID":"20260601154237-ik8meol","Type":"NodeParagraph","Properties":{"id":"20260601154237-ik8meol","updated":"20260601095028"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260601154237-uuma963","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-uuma963","updated":"20260601095040"},"Children":[{"ID":"20260601154237-5seuzne","Type":"NodeParagraph","Properties":{"id":"20260601154237-5seuzne","updated":"20260601095041"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260601154237-2oy68ye","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2oy68ye","updated":"20260601095108"},"Children":[{"ID":"20260601154237-yjge36y","Type":"NodeParagraph","Properties":{"id":"20260601154237-yjge36y","updated":"20260601095125"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260601154237-al2nsdl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-al2nsdl","updated":"20260601095140"},"Children":[{"ID":"20260601154237-2mjzo9p","Type":"NodeParagraph","Properties":{"id":"20260601154237-2mjzo9p","updated":"20260601095146"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260601154237-0s9woy1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0s9woy1","updated":"20260601095147"},"Children":[{"ID":"20260601154237-0xqe72d","Type":"NodeParagraph","Properties":{"id":"20260601154237-0xqe72d","updated":"20260601095205"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260601154237-btv54ar","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-btv54ar","updated":"20260601095222"},"Children":[{"ID":"20260601154237-zmry530","Type":"NodeParagraph","Properties":{"id":"20260601154237-zmry530","updated":"20260601095222"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260601154237-1fix61a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1fix61a","updated":"20260601095234"},"Children":[{"ID":"20260601154237-kr75fc7","Type":"NodeParagraph","Properties":{"id":"20260601154237-kr75fc7","updated":"20260601095234"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260601154237-s6wndel","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-s6wndel","updated":"20260601095247"},"Children":[{"ID":"20260601154237-f41f4rw","Type":"NodeParagraph","Properties":{"id":"20260601154237-f41f4rw","updated":"20260601095255"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260601154237-gv1u80c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gv1u80c","updated":"20260601095304"},"Children":[{"ID":"20260601154237-amxp1v7","Type":"NodeParagraph","Properties":{"id":"20260601154237-amxp1v7","updated":"20260601095307"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260601154237-za34o7f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-za34o7f","updated":"20260601095308"},"Children":[{"ID":"20260601154237-l871tct","Type":"NodeParagraph","Properties":{"id":"20260601154237-l871tct","updated":"20260601095328"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260601154237-qyyld03","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qyyld03","updated":"20260601095329"},"Children":[{"ID":"20260601154237-ufwxpox","Type":"NodeParagraph","Properties":{"id":"20260601154237-ufwxpox","updated":"20260601095344"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260601154237-i1lsngg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-i1lsngg","updated":"20260601095345"},"Children":[{"ID":"20260601154237-6utsw6w","Type":"NodeParagraph","Properties":{"id":"20260601154237-6utsw6w","updated":"20260601095358"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260601154237-k02slgu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k02slgu","updated":"20260601095359"},"Children":[{"ID":"20260601154237-twplqhm","Type":"NodeParagraph","Properties":{"id":"20260601154237-twplqhm","updated":"20260601095410"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260601154237-c8b436u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-c8b436u","updated":"20260601095429"},"Children":[{"ID":"20260601154237-7b2jrki","Type":"NodeParagraph","Properties":{"id":"20260601154237-7b2jrki","updated":"20260601095434"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260601154237-ktuoe4f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ktuoe4f","updated":"20260601095454"},"Children":[{"ID":"20260601154237-tm4hum2","Type":"NodeParagraph","Properties":{"id":"20260601154237-tm4hum2","updated":"20260601095458"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260601154237-ifdm3dm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ifdm3dm","updated":"20260601095532"},"Children":[{"ID":"20260601154237-jcwuiqf","Type":"NodeParagraph","Properties":{"id":"20260601154237-jcwuiqf","updated":"20260601095536"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260601154237-wo7me0n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wo7me0n","updated":"20260601095549"},"Children":[{"ID":"20260601154237-xkknb2v","Type":"NodeParagraph","Properties":{"id":"20260601154237-xkknb2v","updated":"20260601095551"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260601154237-w2zfcs0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-w2zfcs0","updated":"20260601095600"},"Children":[{"ID":"20260601154237-wobkryi","Type":"NodeParagraph","Properties":{"id":"20260601154237-wobkryi","updated":"20260601095603"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260601154237-mvvdgz4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mvvdgz4","updated":"20260601095949"},"Children":[{"ID":"20260601154237-76zfhve","Type":"NodeParagraph","Properties":{"id":"20260601154237-76zfhve","updated":"20260601095952"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260601154237-mvq1df1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mvq1df1","updated":"20260601100055"},"Children":[{"ID":"20260601154237-l7fx0qc","Type":"NodeParagraph","Properties":{"id":"20260601154237-l7fx0qc","updated":"20260601100055"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260601154237-4vob73v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4vob73v","updated":"20260601100153"},"Children":[{"ID":"20260601154237-vtzydn1","Type":"NodeParagraph","Properties":{"id":"20260601154237-vtzydn1","updated":"20260601100153"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260601154237-p5zhve8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-p5zhve8","updated":"20260601100222"},"Children":[{"ID":"20260601154237-jim6unw","Type":"NodeParagraph","Properties":{"id":"20260601154237-jim6unw","updated":"20260601100301"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260601154237-u33v083","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-u33v083","updated":"20260601100323"},"Children":[{"ID":"20260601154237-njushjy","Type":"NodeParagraph","Properties":{"id":"20260601154237-njushjy","updated":"20260601100326"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260601154237-ojap34h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ojap34h","updated":"20260601100356"},"Children":[{"ID":"20260601154237-ekivh38","Type":"NodeParagraph","Properties":{"id":"20260601154237-ekivh38","updated":"20260601100357"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260601154237-oxxhgcc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oxxhgcc","updated":"20260601100413"},"Children":[{"ID":"20260601154237-zp86za4","Type":"NodeParagraph","Properties":{"id":"20260601154237-zp86za4","updated":"20260601100413"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260601154237-dhca7pq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dhca7pq","updated":"20260601100432"},"Children":[{"ID":"20260601154237-2y7gwbq","Type":"NodeParagraph","Properties":{"id":"20260601154237-2y7gwbq","updated":"20260601100432"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260601154237-r5wv4dp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-r5wv4dp","updated":"20260601100518"},"Children":[{"ID":"20260601154237-bzguzbe","Type":"NodeParagraph","Properties":{"id":"20260601154237-bzguzbe","updated":"20260601100518"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260601154237-qvzg14e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qvzg14e","updated":"20260601100535"},"Children":[{"ID":"20260601154237-y613cqv","Type":"NodeParagraph","Properties":{"id":"20260601154237-y613cqv","updated":"20260601100537"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260601154237-9seydn5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9seydn5","updated":"20260601100551"},"Children":[{"ID":"20260601154237-b2x4ba2","Type":"NodeParagraph","Properties":{"id":"20260601154237-b2x4ba2","updated":"20260601100554"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260601154237-ig6n9yq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ig6n9yq","updated":"20260601100633"},"Children":[{"ID":"20260601154237-yzztt15","Type":"NodeParagraph","Properties":{"id":"20260601154237-yzztt15","updated":"20260601100633"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260601154237-0nhuoq6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0nhuoq6","updated":"20260601100650"},"Children":[{"ID":"20260601154237-xuuyvhk","Type":"NodeParagraph","Properties":{"id":"20260601154237-xuuyvhk","updated":"20260601100650"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260601154237-k0hrlp8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k0hrlp8","updated":"20260601100713"},"Children":[{"ID":"20260601154237-d2yquxu","Type":"NodeParagraph","Properties":{"id":"20260601154237-d2yquxu","updated":"20260601100717"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260601154237-x7s9gb2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-x7s9gb2","updated":"20260601100733"},"Children":[{"ID":"20260601154237-aqfa86f","Type":"NodeParagraph","Properties":{"id":"20260601154237-aqfa86f","updated":"20260601100736"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260601154237-l432usd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-l432usd","updated":"20260601100737"},"Children":[{"ID":"20260601154237-ru43wf0","Type":"NodeParagraph","Properties":{"id":"20260601154237-ru43wf0","updated":"20260601100755"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260601154237-5waebgg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5waebgg","updated":"20260601100812"},"Children":[{"ID":"20260601154237-8bg7yg4","Type":"NodeParagraph","Properties":{"id":"20260601154237-8bg7yg4","updated":"20260601100812"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260601154237-1c9e8s7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1c9e8s7","updated":"20260601100828"},"Children":[{"ID":"20260601154237-fc6n5y3","Type":"NodeParagraph","Properties":{"id":"20260601154237-fc6n5y3","updated":"20260601100828"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260601154237-24ky7pi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-24ky7pi","updated":"20260601100846"},"Children":[{"ID":"20260601154237-1lhr3zd","Type":"NodeParagraph","Properties":{"id":"20260601154237-1lhr3zd","updated":"20260601100850"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260601154237-595ho2z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-595ho2z","updated":"20260601100910"},"Children":[{"ID":"20260601154237-8jx0wof","Type":"NodeParagraph","Properties":{"id":"20260601154237-8jx0wof","updated":"20260601100912"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260601154237-7jcqvib","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7jcqvib","updated":"20260601100914"},"Children":[{"ID":"20260601154237-o0z0t8t","Type":"NodeParagraph","Properties":{"id":"20260601154237-o0z0t8t","updated":"20260601100937"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260601154237-2to823z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2to823z","updated":"20260601100938"},"Children":[{"ID":"20260601154237-zd9loj8","Type":"NodeParagraph","Properties":{"id":"20260601154237-zd9loj8","updated":"20260601100956"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260601154237-lkz16gq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-lkz16gq","updated":"20260601101013"},"Children":[{"ID":"20260601154237-fmnpyuz","Type":"NodeParagraph","Properties":{"id":"20260601154237-fmnpyuz","updated":"20260601101016"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260601154237-39tcaxo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-39tcaxo","updated":"20260601101032"},"Children":[{"ID":"20260601154237-4khui4a","Type":"NodeParagraph","Properties":{"id":"20260601154237-4khui4a","updated":"20260601101034"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260601154237-cs6ilc2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-cs6ilc2","updated":"20260601101050"},"Children":[{"ID":"20260601154237-lq8a7s7","Type":"NodeParagraph","Properties":{"id":"20260601154237-lq8a7s7","updated":"20260601101053"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260601154237-yk2480f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yk2480f","updated":"20260601101109"},"Children":[{"ID":"20260601154237-ybvfkk2","Type":"NodeParagraph","Properties":{"id":"20260601154237-ybvfkk2","updated":"20260601101111"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260601154237-yhtkba5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yhtkba5","updated":"20260601101119"},"Children":[{"ID":"20260601154237-pxrn1l9","Type":"NodeParagraph","Properties":{"id":"20260601154237-pxrn1l9","updated":"20260601101122"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260601154237-6zct1j5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6zct1j5","updated":"20260601101153"},"Children":[{"ID":"20260601154237-viukoie","Type":"NodeParagraph","Properties":{"id":"20260601154237-viukoie","updated":"20260601101156"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260601154237-hkp6os5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hkp6os5","updated":"20260601101214"},"Children":[{"ID":"20260601154237-ypxjcwr","Type":"NodeParagraph","Properties":{"id":"20260601154237-ypxjcwr","updated":"20260601101226"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260601154237-ocfj8wd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ocfj8wd","updated":"20260601101827"},"Children":[{"ID":"20260601154237-putn5ts","Type":"NodeParagraph","Properties":{"id":"20260601154237-putn5ts","updated":"20260601101834"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260601154237-77aceb1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-77aceb1","updated":"20260601101243"},"Children":[{"ID":"20260601154237-3cgor32","Type":"NodeParagraph","Properties":{"id":"20260601154237-3cgor32","updated":"20260601101243"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260601154237-w4umktq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-w4umktq","updated":"20260601101301"},"Children":[{"ID":"20260601154237-pqd15ho","Type":"NodeParagraph","Properties":{"id":"20260601154237-pqd15ho","updated":"20260601101306"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260601154237-bq0g9gg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bq0g9gg","updated":"20260601101325"},"Children":[{"ID":"20260601154237-6d1bcv3","Type":"NodeParagraph","Properties":{"id":"20260601154237-6d1bcv3","updated":"20260601101325"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260601154237-4otnh3g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4otnh3g","updated":"20260601101402"},"Children":[{"ID":"20260601154237-o8qzzbv","Type":"NodeParagraph","Properties":{"id":"20260601154237-o8qzzbv","updated":"20260601101408"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260601154237-el7vlbf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-el7vlbf","updated":"20260601101409"},"Children":[{"ID":"20260601154237-ffiggjr","Type":"NodeParagraph","Properties":{"id":"20260601154237-ffiggjr","updated":"20260601101425"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260601154237-ol36fcp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ol36fcp","updated":"20260601101442"},"Children":[{"ID":"20260601154237-u7e4lhm","Type":"NodeParagraph","Properties":{"id":"20260601154237-u7e4lhm","updated":"20260601101443"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260601154237-azcm2pv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-azcm2pv","updated":"20260601101510"},"Children":[{"ID":"20260601154237-cbnkeor","Type":"NodeParagraph","Properties":{"id":"20260601154237-cbnkeor","updated":"20260601101513"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260601154237-fu9z8pa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fu9z8pa","updated":"20260601101711"},"Children":[{"ID":"20260601154237-unbk89k","Type":"NodeParagraph","Properties":{"id":"20260601154237-unbk89k","updated":"20260601101711"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260601154237-wxeygib","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wxeygib","updated":"20260601101744"},"Children":[{"ID":"20260601154237-64ftoz0","Type":"NodeParagraph","Properties":{"id":"20260601154237-64ftoz0","updated":"20260601101745"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260601154237-htva4ee","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-htva4ee","updated":"20260601101810"},"Children":[{"ID":"20260601154237-8xglh2n","Type":"NodeParagraph","Properties":{"id":"20260601154237-8xglh2n","updated":"20260601101815"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260601154237-jo0tlhf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jo0tlhf","updated":"20260601101858"},"Children":[{"ID":"20260601154237-66xcfsh","Type":"NodeParagraph","Properties":{"id":"20260601154237-66xcfsh","updated":"20260601101900"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260601154237-2eyitm2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2eyitm2","updated":"20260601101917"},"Children":[{"ID":"20260601154237-yw4rzkg","Type":"NodeParagraph","Properties":{"id":"20260601154237-yw4rzkg","updated":"20260601101919"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260601154237-5g4ijws","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5g4ijws","updated":"20260601101920"},"Children":[{"ID":"20260601154237-svwbhjj","Type":"NodeParagraph","Properties":{"id":"20260601154237-svwbhjj","updated":"20260601101937"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260601154237-muyirxv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-muyirxv","updated":"20260601102002"},"Children":[{"ID":"20260601154237-xcc7gay","Type":"NodeParagraph","Properties":{"id":"20260601154237-xcc7gay","updated":"20260601102005"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260601154237-rcvbbk9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-rcvbbk9","updated":"20260601102006"},"Children":[{"ID":"20260601154237-vsmp0rt","Type":"NodeParagraph","Properties":{"id":"20260601154237-vsmp0rt","updated":"20260601102021"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260601154237-4e2bnv4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4e2bnv4","updated":"20260601102033"},"Children":[{"ID":"20260601154237-cyqtdw4","Type":"NodeParagraph","Properties":{"id":"20260601154237-cyqtdw4","updated":"20260601102035"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260601154237-vlvg8g5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vlvg8g5","updated":"20260601102105"},"Children":[{"ID":"20260601154237-cnyxzte","Type":"NodeParagraph","Properties":{"id":"20260601154237-cnyxzte","updated":"20260601102107"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260601154237-8evxr28","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8evxr28","updated":"20260601102122"},"Children":[{"ID":"20260601154237-r5f4yle","Type":"NodeParagraph","Properties":{"id":"20260601154237-r5f4yle","updated":"20260601102124"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260601154237-j858hr0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-j858hr0","updated":"20260601102125"},"Children":[{"ID":"20260601154237-p8odg1o","Type":"NodeParagraph","Properties":{"id":"20260601154237-p8odg1o","updated":"20260601102255"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260601154237-yvgx47w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yvgx47w","updated":"20260601102257"},"Children":[{"ID":"20260601154237-buhex1h","Type":"NodeParagraph","Properties":{"id":"20260601154237-buhex1h","updated":"20260601102341"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260601154237-2om417q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2om417q","updated":"20260601102412"},"Children":[{"ID":"20260601154237-ek821lf","Type":"NodeParagraph","Properties":{"id":"20260601154237-ek821lf","updated":"20260601102412"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260601154237-mx02my0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mx02my0","updated":"20260601102428"},"Children":[{"ID":"20260601154237-xca0oil","Type":"NodeParagraph","Properties":{"id":"20260601154237-xca0oil","updated":"20260601102428"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260601154237-seqtgr5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-seqtgr5","updated":"20260601102504"},"Children":[{"ID":"20260601154237-aukh1st","Type":"NodeParagraph","Properties":{"id":"20260601154237-aukh1st","updated":"20260601102504"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260601154237-vi9gkrt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vi9gkrt","updated":"20260601160409"},"Children":[{"ID":"20260601154237-jaqoxt8","Type":"NodeParagraph","Properties":{"id":"20260601154237-jaqoxt8","updated":"20260601160409"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260601154237-29zw8re","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-29zw8re","updated":"20260601102544"},"Children":[{"ID":"20260601154237-1f3abgu","Type":"NodeParagraph","Properties":{"id":"20260601154237-1f3abgu","updated":"20260601102548"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260601154237-k7ybwog","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k7ybwog","updated":"20260601102603"},"Children":[{"ID":"20260601154237-h0riztg","Type":"NodeParagraph","Properties":{"id":"20260601154237-h0riztg","updated":"20260601102605"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260601154237-wz98ofy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wz98ofy","updated":"20260601102620"},"Children":[{"ID":"20260601154237-ns0fnsj","Type":"NodeParagraph","Properties":{"id":"20260601154237-ns0fnsj","updated":"20260601102621"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260601154237-zjw8twy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-zjw8twy","updated":"20260601160353"},"Children":[{"ID":"20260601154237-ec00pj8","Type":"NodeParagraph","Properties":{"id":"20260601154237-ec00pj8","updated":"20260601160353"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260601154237-bku5tqb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bku5tqb","updated":"20260601102653"},"Children":[{"ID":"20260601154237-a1w8nwy","Type":"NodeParagraph","Properties":{"id":"20260601154237-a1w8nwy","updated":"20260601102655"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260601154237-2r377eq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2r377eq","updated":"20260601102712"},"Children":[{"ID":"20260601154237-0s2g8fh","Type":"NodeParagraph","Properties":{"id":"20260601154237-0s2g8fh","updated":"20260601102723"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260601154237-sjmzakk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-sjmzakk","updated":"20260601102724"},"Children":[{"ID":"20260601154237-2ix06s4","Type":"NodeParagraph","Properties":{"id":"20260601154237-2ix06s4","updated":"20260601102741"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260601154237-bqgf9cb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bqgf9cb","updated":"20260601160339"},"Children":[{"ID":"20260601154237-gk1e7nj","Type":"NodeParagraph","Properties":{"id":"20260601154237-gk1e7nj","updated":"20260601160339"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260601154237-gdq0kui","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gdq0kui","updated":"20260601160327"},"Children":[{"ID":"20260601154237-yitqwbk","Type":"NodeParagraph","Properties":{"id":"20260601154237-yitqwbk","updated":"20260601160327"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260601154237-k2yl18o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k2yl18o","updated":"20260601102959"},"Children":[{"ID":"20260601154237-tthktzg","Type":"NodeParagraph","Properties":{"id":"20260601154237-tthktzg","updated":"20260601103000"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260601154237-lylokkd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-lylokkd","updated":"20260601103021"},"Children":[{"ID":"20260601154237-ydv4t1n","Type":"NodeParagraph","Properties":{"id":"20260601154237-ydv4t1n","updated":"20260601103023"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260601154237-sa43bne","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-sa43bne","updated":"20260601103111"},"Children":[{"ID":"20260601154237-ld735my","Type":"NodeParagraph","Properties":{"id":"20260601154237-ld735my","updated":"20260601103114"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260601154237-52mypmt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-52mypmt","updated":"20260601103130"},"Children":[{"ID":"20260601154237-8wvk6cy","Type":"NodeParagraph","Properties":{"id":"20260601154237-8wvk6cy","updated":"20260601103130"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260601154237-z64fynd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-z64fynd","updated":"20260601103226"},"Children":[{"ID":"20260601154237-fghbajx","Type":"NodeParagraph","Properties":{"id":"20260601154237-fghbajx","updated":"20260601103229"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260601154237-o8lct5e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-o8lct5e","updated":"20260601103244"},"Children":[{"ID":"20260601154237-66fnpcx","Type":"NodeParagraph","Properties":{"id":"20260601154237-66fnpcx","updated":"20260601103246"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260601154237-w085554","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-w085554","updated":"20260601103302"},"Children":[{"ID":"20260601154237-1eo5c3d","Type":"NodeParagraph","Properties":{"id":"20260601154237-1eo5c3d","updated":"20260601103303"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260601154237-vxftgy4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vxftgy4","updated":"20260601103314"},"Children":[{"ID":"20260601154237-ph7chk8","Type":"NodeParagraph","Properties":{"id":"20260601154237-ph7chk8","updated":"20260601103316"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260601154237-ym5o96v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ym5o96v","updated":"20260601103325"},"Children":[{"ID":"20260601154237-oqlbrgl","Type":"NodeParagraph","Properties":{"id":"20260601154237-oqlbrgl","updated":"20260601103327"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260601154237-xk3ky7c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xk3ky7c","updated":"20260601103351"},"Children":[{"ID":"20260601154237-hro346d","Type":"NodeParagraph","Properties":{"id":"20260601154237-hro346d","updated":"20260601103351"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260601154237-i4m8g7m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-i4m8g7m","updated":"20260601103403"},"Children":[{"ID":"20260601154237-3rje0lg","Type":"NodeParagraph","Properties":{"id":"20260601154237-3rje0lg","updated":"20260601103408"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260601154237-790j4io","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-790j4io","updated":"20260601103427"},"Children":[{"ID":"20260601154237-kjouc3x","Type":"NodeParagraph","Properties":{"id":"20260601154237-kjouc3x","updated":"20260601103428"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260601154237-1rmquax","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1rmquax","updated":"20260601103435"},"Children":[{"ID":"20260601154237-mmpfbci","Type":"NodeParagraph","Properties":{"id":"20260601154237-mmpfbci","updated":"20260601103437"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260601154237-u92hw3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-u92hw3x","updated":"20260601160257"},"Children":[{"ID":"20260601154237-icjhfrx","Type":"NodeParagraph","Properties":{"id":"20260601154237-icjhfrx","updated":"20260601160257"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260601154237-a2qhanj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-a2qhanj","updated":"20260601160233"},"Children":[{"ID":"20260601154237-om57zwg","Type":"NodeParagraph","Properties":{"id":"20260601154237-om57zwg","updated":"20260601160233"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260601154237-io2i5aq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-io2i5aq","updated":"20260601103542"},"Children":[{"ID":"20260601154237-c3p9mzo","Type":"NodeParagraph","Properties":{"id":"20260601154237-c3p9mzo","updated":"20260601103544"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260601154237-4ntnkg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4ntnkg6","updated":"20260601103559"},"Children":[{"ID":"20260601154237-vbfebml","Type":"NodeParagraph","Properties":{"id":"20260601154237-vbfebml","updated":"20260601103606"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260601154237-wt2vod5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-wt2vod5","updated":"20260601103623"},"Children":[{"ID":"20260601154237-aguu9d4","Type":"NodeParagraph","Properties":{"id":"20260601154237-aguu9d4","updated":"20260601103625"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260601154237-xb0dyan","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xb0dyan","updated":"20260601103638"},"Children":[{"ID":"20260601154237-khdo26t","Type":"NodeParagraph","Properties":{"id":"20260601154237-khdo26t","updated":"20260601103641"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260601154237-k18fnjj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k18fnjj","updated":"20260601103659"},"Children":[{"ID":"20260601154237-l395l6c","Type":"NodeParagraph","Properties":{"id":"20260601154237-l395l6c","updated":"20260601103701"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260601154237-z45snpu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-z45snpu","updated":"20260601160214"},"Children":[{"ID":"20260601154237-cicbpgp","Type":"NodeParagraph","Properties":{"id":"20260601154237-cicbpgp","updated":"20260601160214"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260601154237-mvh31ts","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mvh31ts","updated":"20260601103734"},"Children":[{"ID":"20260601154237-hj4gjc1","Type":"NodeParagraph","Properties":{"id":"20260601154237-hj4gjc1","updated":"20260601103735"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260601154237-fuxerik","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fuxerik","updated":"20260601103755"},"Children":[{"ID":"20260601154237-0rcknlv","Type":"NodeParagraph","Properties":{"id":"20260601154237-0rcknlv","updated":"20260601103755"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260601154237-vy2av5z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vy2av5z","updated":"20260601160151"},"Children":[{"ID":"20260601154237-4e12zqf","Type":"NodeParagraph","Properties":{"id":"20260601154237-4e12zqf","updated":"20260601160151"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260601154237-yt3cf1z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yt3cf1z","updated":"20260601103841"},"Children":[{"ID":"20260601154237-pa3ntrc","Type":"NodeParagraph","Properties":{"id":"20260601154237-pa3ntrc","updated":"20260601103849"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260601154237-il5l9mi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-il5l9mi","updated":"20260601103933"},"Children":[{"ID":"20260601154237-p12r0ot","Type":"NodeParagraph","Properties":{"id":"20260601154237-p12r0ot","updated":"20260601103933"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260601154237-iy777op","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-iy777op","updated":"20260601103943"},"Children":[{"ID":"20260601154237-xkd0bgh","Type":"NodeParagraph","Properties":{"id":"20260601154237-xkd0bgh","updated":"20260601103946"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260601154237-tldc1it","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-tldc1it","updated":"20260601103958"},"Children":[{"ID":"20260601154237-jqnxnn7","Type":"NodeParagraph","Properties":{"id":"20260601154237-jqnxnn7","updated":"20260601103958"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260601154237-9l9mwpz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9l9mwpz","updated":"20260601104033"},"Children":[{"ID":"20260601154237-9jai42a","Type":"NodeParagraph","Properties":{"id":"20260601154237-9jai42a","updated":"20260601104033"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260601154237-vbuayuz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vbuayuz","updated":"20260601104136"},"Children":[{"ID":"20260601154237-4rwm287","Type":"NodeParagraph","Properties":{"id":"20260601154237-4rwm287","updated":"20260601104139"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260601154237-rw65nua","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-rw65nua","updated":"20260601104155"},"Children":[{"ID":"20260601154237-k48xkmz","Type":"NodeParagraph","Properties":{"id":"20260601154237-k48xkmz","updated":"20260601104157"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260601154237-jrvmivk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jrvmivk","updated":"20260601104209"},"Children":[{"ID":"20260601154237-7keekyz","Type":"NodeParagraph","Properties":{"id":"20260601154237-7keekyz","updated":"20260601104212"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260601154237-ndj3nbm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ndj3nbm","updated":"20260601160137"},"Children":[{"ID":"20260601154237-rtpzsjx","Type":"NodeParagraph","Properties":{"id":"20260601154237-rtpzsjx","updated":"20260601160137"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260601154237-8kb0fdl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8kb0fdl","updated":"20260601104248"},"Children":[{"ID":"20260601154237-qpgzuc0","Type":"NodeParagraph","Properties":{"id":"20260601154237-qpgzuc0","updated":"20260601104248"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260601154237-50tqe4g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-50tqe4g","updated":"20260601104308"},"Children":[{"ID":"20260601154237-7ag09hv","Type":"NodeParagraph","Properties":{"id":"20260601154237-7ag09hv","updated":"20260601104312"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260601154237-5jrv7pl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5jrv7pl","updated":"20260601104330"},"Children":[{"ID":"20260601154237-95f173w","Type":"NodeParagraph","Properties":{"id":"20260601154237-95f173w","updated":"20260601104336"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260601154237-ckkdipr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ckkdipr","updated":"20260601104348"},"Children":[{"ID":"20260601154237-b7x0t73","Type":"NodeParagraph","Properties":{"id":"20260601154237-b7x0t73","updated":"20260601104348"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260601154237-028tyiu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-028tyiu","updated":"20260601160121"},"Children":[{"ID":"20260601154237-0pzgmup","Type":"NodeParagraph","Properties":{"id":"20260601154237-0pzgmup","updated":"20260601160121"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260601154237-bosd084","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bosd084","updated":"20260601104445"},"Children":[{"ID":"20260601154237-4x8c4jb","Type":"NodeParagraph","Properties":{"id":"20260601154237-4x8c4jb","updated":"20260601104448"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260601154237-7i3raf9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7i3raf9","updated":"20260601104449"},"Children":[{"ID":"20260601154237-813w4gd","Type":"NodeParagraph","Properties":{"id":"20260601154237-813w4gd","updated":"20260601104457"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260601154237-k4agwzz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k4agwzz","updated":"20260601104511"},"Children":[{"ID":"20260601154237-zkxtb20","Type":"NodeParagraph","Properties":{"id":"20260601154237-zkxtb20","updated":"20260601104514"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260601154237-kpgeudi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-kpgeudi","updated":"20260601104515"},"Children":[{"ID":"20260601154237-1gwx94a","Type":"NodeParagraph","Properties":{"id":"20260601154237-1gwx94a","updated":"20260601104533"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260601154237-8vqec7y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8vqec7y","updated":"20260601104547"},"Children":[{"ID":"20260601154237-s4ta4u7","Type":"NodeParagraph","Properties":{"id":"20260601154237-s4ta4u7","updated":"20260601104549"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260601154237-nuokah8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-nuokah8","updated":"20260601104611"},"Children":[{"ID":"20260601154237-3kbqt0y","Type":"NodeParagraph","Properties":{"id":"20260601154237-3kbqt0y","updated":"20260601104640"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260601154237-d0ntfj1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-d0ntfj1","updated":"20260601104651"},"Children":[{"ID":"20260601154237-a0vvsbl","Type":"NodeParagraph","Properties":{"id":"20260601154237-a0vvsbl","updated":"20260601104651"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260601154237-qcmiema","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qcmiema","updated":"20260601104706"},"Children":[{"ID":"20260601154237-t7o1czs","Type":"NodeParagraph","Properties":{"id":"20260601154237-t7o1czs","updated":"20260601104731"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260601154237-veocfcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-veocfcq","updated":"20260601104756"},"Children":[{"ID":"20260601154237-m9840xg","Type":"NodeParagraph","Properties":{"id":"20260601154237-m9840xg","updated":"20260601104801"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260601154237-lhz0bc3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-lhz0bc3","updated":"20260601104818"},"Children":[{"ID":"20260601154237-3rxgfbl","Type":"NodeParagraph","Properties":{"id":"20260601154237-3rxgfbl","updated":"20260601104820"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260601154237-w0qsswp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-w0qsswp","updated":"20260601104822"},"Children":[{"ID":"20260601154237-ndumj7v","Type":"NodeParagraph","Properties":{"id":"20260601154237-ndumj7v","updated":"20260601104836"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260601154237-also5bx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-also5bx","updated":"20260601104852"},"Children":[{"ID":"20260601154237-q8ihi1f","Type":"NodeParagraph","Properties":{"id":"20260601154237-q8ihi1f","updated":"20260601104853"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260601154237-efbq4o3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-efbq4o3","updated":"20260601104935"},"Children":[{"ID":"20260601154237-or2qsr7","Type":"NodeParagraph","Properties":{"id":"20260601154237-or2qsr7","updated":"20260601104938"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260601154237-531oj3s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-531oj3s","updated":"20260601104939"},"Children":[{"ID":"20260601154237-jsjz8pj","Type":"NodeParagraph","Properties":{"id":"20260601154237-jsjz8pj","updated":"20260601105948"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260601154237-2u75jno","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2u75jno","updated":"20260601105054"},"Children":[{"ID":"20260601154237-iazdhk3","Type":"NodeParagraph","Properties":{"id":"20260601154237-iazdhk3","updated":"20260601105054"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260601154237-4ybbd1v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4ybbd1v","updated":"20260601105212"},"Children":[{"ID":"20260601154237-xff3qde","Type":"NodeParagraph","Properties":{"id":"20260601154237-xff3qde","updated":"20260601105215"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260601154237-hfmrvfb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hfmrvfb","updated":"20260601105216"},"Children":[{"ID":"20260601154237-wt142fb","Type":"NodeParagraph","Properties":{"id":"20260601154237-wt142fb","updated":"20260601105234"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260601154237-36ivube","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-36ivube","updated":"20260601160053"},"Children":[{"ID":"20260601154237-504e524","Type":"NodeParagraph","Properties":{"id":"20260601154237-504e524","updated":"20260601160053"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260601154237-qtyj1r3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qtyj1r3","updated":"20260601105350"},"Children":[{"ID":"20260601154237-99umlqc","Type":"NodeParagraph","Properties":{"id":"20260601154237-99umlqc","updated":"20260601105353"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260601154237-9wkdpbi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9wkdpbi","updated":"20260601105418"},"Children":[{"ID":"20260601154237-7w9rq3g","Type":"NodeParagraph","Properties":{"id":"20260601154237-7w9rq3g","updated":"20260601105421"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260601154237-0bxyb86","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0bxyb86","updated":"20260601105529"},"Children":[{"ID":"20260601154237-gqy87xj","Type":"NodeParagraph","Properties":{"id":"20260601154237-gqy87xj","updated":"20260601105532"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260601154237-3hw1yr6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3hw1yr6","updated":"20260601105638"},"Children":[{"ID":"20260601154237-jh12901","Type":"NodeParagraph","Properties":{"id":"20260601154237-jh12901","updated":"20260601105639"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260601154237-k5ym3o0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k5ym3o0","updated":"20260601105747"},"Children":[{"ID":"20260601154237-srbipt4","Type":"NodeParagraph","Properties":{"id":"20260601154237-srbipt4","updated":"20260601105749"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260601154237-m0cgksb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-m0cgksb","updated":"20260601105834"},"Children":[{"ID":"20260601154237-eeeepym","Type":"NodeParagraph","Properties":{"id":"20260601154237-eeeepym","updated":"20260601105836"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260601154237-vjl7nkf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vjl7nkf","updated":"20260601160034"},"Children":[{"ID":"20260601154237-2ghuksi","Type":"NodeParagraph","Properties":{"id":"20260601154237-2ghuksi","updated":"20260601160034"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260601154237-jgn2bqt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-jgn2bqt","updated":"20260601105908"},"Children":[{"ID":"20260601154237-8yg80lp","Type":"NodeParagraph","Properties":{"id":"20260601154237-8yg80lp","updated":"20260601105927"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260601154237-dhbioon","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dhbioon","updated":"20260601110009"},"Children":[{"ID":"20260601154237-x5dic9j","Type":"NodeParagraph","Properties":{"id":"20260601154237-x5dic9j","updated":"20260601110011"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260601154237-3uy3kls","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3uy3kls","updated":"20260601110013"},"Children":[{"ID":"20260601154237-yi6kpi7","Type":"NodeParagraph","Properties":{"id":"20260601154237-yi6kpi7","updated":"20260601110034"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260601154237-oz1fli4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oz1fli4","updated":"20260601110035"},"Children":[{"ID":"20260601154237-uhlb16o","Type":"NodeParagraph","Properties":{"id":"20260601154237-uhlb16o","updated":"20260601110057"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260601154237-v0nx0g5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-v0nx0g5","updated":"20260601110117"},"Children":[{"ID":"20260601154237-qjvzxc5","Type":"NodeParagraph","Properties":{"id":"20260601154237-qjvzxc5","updated":"20260601110117"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260601154237-h7t3mwn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-h7t3mwn","updated":"20260601110134"},"Children":[{"ID":"20260601154237-lwrheqo","Type":"NodeParagraph","Properties":{"id":"20260601154237-lwrheqo","updated":"20260601110134"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260601154237-i5ovha3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-i5ovha3","updated":"20260601110135"},"Children":[{"ID":"20260601154237-sto4jce","Type":"NodeParagraph","Properties":{"id":"20260601154237-sto4jce","updated":"20260601110202"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260601154237-8hkcfby","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-8hkcfby","updated":"20260601110228"},"Children":[{"ID":"20260601154237-p5sd3s8","Type":"NodeParagraph","Properties":{"id":"20260601154237-p5sd3s8","updated":"20260601110230"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260601154237-dfxdm4v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dfxdm4v","updated":"20260601110351"},"Children":[{"ID":"20260601154237-1n919md","Type":"NodeParagraph","Properties":{"id":"20260601154237-1n919md","updated":"20260601110352"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260601154237-yjumxlk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-yjumxlk","updated":"20260601110430"},"Children":[{"ID":"20260601154237-4egcjvc","Type":"NodeParagraph","Properties":{"id":"20260601154237-4egcjvc","updated":"20260601110430"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260601154237-k772nvg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k772nvg","updated":"20260601155935"},"Children":[{"ID":"20260601154237-tr0rw65","Type":"NodeParagraph","Properties":{"id":"20260601154237-tr0rw65","updated":"20260601155935"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260601154237-bgsxs59","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-bgsxs59","updated":"20260601110454"},"Children":[{"ID":"20260601154237-5y6wl95","Type":"NodeParagraph","Properties":{"id":"20260601154237-5y6wl95","updated":"20260601110525"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260601154237-qlfjbvo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-qlfjbvo","updated":"20260601110547"},"Children":[{"ID":"20260601154237-0mr0u8m","Type":"NodeParagraph","Properties":{"id":"20260601154237-0mr0u8m","updated":"20260601110547"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260601154237-oytvp5m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oytvp5m","updated":"20260601110613"},"Children":[{"ID":"20260601154237-r3pg1sd","Type":"NodeParagraph","Properties":{"id":"20260601154237-r3pg1sd","updated":"20260601110613"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260601154237-e1tahem","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-e1tahem","updated":"20260601110633"},"Children":[{"ID":"20260601154237-z81txm7","Type":"NodeParagraph","Properties":{"id":"20260601154237-z81txm7","updated":"20260601110635"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260601154237-mweg9ts","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-mweg9ts","updated":"20260601155855"},"Children":[{"ID":"20260601154237-kitwq61","Type":"NodeParagraph","Properties":{"id":"20260601154237-kitwq61","updated":"20260601155855"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260601154237-p9ycvjs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-p9ycvjs","updated":"20260601110654"},"Children":[{"ID":"20260601154237-ap711qy","Type":"NodeParagraph","Properties":{"id":"20260601154237-ap711qy","updated":"20260601110733"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260601154237-gyuvzzw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gyuvzzw","updated":"20260601155806"},"Children":[{"ID":"20260601154237-kj1pki6","Type":"NodeParagraph","Properties":{"id":"20260601154237-kj1pki6","updated":"20260601155806"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260601154237-317f5g0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-317f5g0","updated":"20260601110748"},"Children":[{"ID":"20260601154237-tncmxe2","Type":"NodeParagraph","Properties":{"id":"20260601154237-tncmxe2","updated":"20260601110806"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260601154237-0jcj1qq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-0jcj1qq","updated":"20260601110807"},"Children":[{"ID":"20260601154237-cyonb51","Type":"NodeParagraph","Properties":{"id":"20260601154237-cyonb51","updated":"20260601110820"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260601154237-11aujcj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-11aujcj","updated":"20260601110847"},"Children":[{"ID":"20260601154237-toendte","Type":"NodeParagraph","Properties":{"id":"20260601154237-toendte","updated":"20260601110849"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260601154237-05va3kf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-05va3kf","updated":"20260601155729"},"Children":[{"ID":"20260601154237-9eim8cy","Type":"NodeParagraph","Properties":{"id":"20260601154237-9eim8cy","updated":"20260601155729"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260601154237-lmmfqg8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-lmmfqg8","updated":"20260601110924"},"Children":[{"ID":"20260601154237-k44tqgz","Type":"NodeParagraph","Properties":{"id":"20260601154237-k44tqgz","updated":"20260601110928"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260601154237-dyvbe0p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dyvbe0p","updated":"20260601155713"},"Children":[{"ID":"20260601154237-9b3kzpg","Type":"NodeParagraph","Properties":{"id":"20260601154237-9b3kzpg","updated":"20260601155713"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260601154237-sfvpmgw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-sfvpmgw","updated":"20260601111207"},"Children":[{"ID":"20260601154237-a6zttwu","Type":"NodeParagraph","Properties":{"id":"20260601154237-a6zttwu","updated":"20260601111207"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260601154237-7iqj5n6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7iqj5n6","updated":"20260601111259"},"Children":[{"ID":"20260601154237-au87i9h","Type":"NodeParagraph","Properties":{"id":"20260601154237-au87i9h","updated":"20260601111300"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260601154237-6k6ahdi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6k6ahdi","updated":"20260601111312"},"Children":[{"ID":"20260601154237-2jqvwnd","Type":"NodeParagraph","Properties":{"id":"20260601154237-2jqvwnd","updated":"20260601111315"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260601154237-n0z0p4f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-n0z0p4f","updated":"20260601111338"},"Children":[{"ID":"20260601154237-3lzwgys","Type":"NodeParagraph","Properties":{"id":"20260601154237-3lzwgys","updated":"20260601111341"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260601154237-59eik93","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-59eik93","updated":"20260601111416"},"Children":[{"ID":"20260601154237-fhs9dzo","Type":"NodeParagraph","Properties":{"id":"20260601154237-fhs9dzo","updated":"20260601111419"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260601154237-4qp95co","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-4qp95co","updated":"20260601111434"},"Children":[{"ID":"20260601154237-21j3arf","Type":"NodeParagraph","Properties":{"id":"20260601154237-21j3arf","updated":"20260601111436"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260601154237-iyojhrr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-iyojhrr","updated":"20260601111544"},"Children":[{"ID":"20260601154237-sdmblzq","Type":"NodeParagraph","Properties":{"id":"20260601154237-sdmblzq","updated":"20260601111607"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260601154237-xe5eilf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-xe5eilf","updated":"20260601111625"},"Children":[{"ID":"20260601154237-hf5st5m","Type":"NodeParagraph","Properties":{"id":"20260601154237-hf5st5m","updated":"20260601111630"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260601154237-ac6f41n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ac6f41n","updated":"20260601111649"},"Children":[{"ID":"20260601154237-l9283d3","Type":"NodeParagraph","Properties":{"id":"20260601154237-l9283d3","updated":"20260601111652"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260601154237-gmd6a22","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gmd6a22","updated":"20260601111715"},"Children":[{"ID":"20260601154237-wiw122r","Type":"NodeParagraph","Properties":{"id":"20260601154237-wiw122r","updated":"20260601111721"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260601154237-52yd1us","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-52yd1us","updated":"20260601111729"},"Children":[{"ID":"20260601154237-zuf2awc","Type":"NodeParagraph","Properties":{"id":"20260601154237-zuf2awc","updated":"20260601111731"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260601154237-ct227fd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ct227fd","updated":"20260601111755"},"Children":[{"ID":"20260601154237-eazegfz","Type":"NodeParagraph","Properties":{"id":"20260601154237-eazegfz","updated":"20260601111758"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260601154237-59j9c7h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-59j9c7h","updated":"20260601121437"},"Children":[{"ID":"20260601154237-kn2dsyw","Type":"NodeParagraph","Properties":{"id":"20260601154237-kn2dsyw","updated":"20260601111817"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260601154237-lctlnit","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-lctlnit","updated":"20260601111818"},"Children":[{"ID":"20260601154237-u4nhud2","Type":"NodeParagraph","Properties":{"id":"20260601154237-u4nhud2","updated":"20260601111907"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260601154237-sk8f443","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-sk8f443","updated":"20260601111951"},"Children":[{"ID":"20260601154237-4oeiycn","Type":"NodeParagraph","Properties":{"id":"20260601154237-4oeiycn","updated":"20260601111954"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260601154237-hx1bkzo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hx1bkzo","updated":"20260601112013"},"Children":[{"ID":"20260601154237-ntzbfm7","Type":"NodeParagraph","Properties":{"id":"20260601154237-ntzbfm7","updated":"20260601112016"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260601154237-lxdelkq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-lxdelkq","updated":"20260601112051"},"Children":[{"ID":"20260601154237-ph5593w","Type":"NodeParagraph","Properties":{"id":"20260601154237-ph5593w","updated":"20260601112051"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260601154237-b2e53p5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-b2e53p5","updated":"20260601112113"},"Children":[{"ID":"20260601154237-38wd8lt","Type":"NodeParagraph","Properties":{"id":"20260601154237-38wd8lt","updated":"20260601112113"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260601154237-5okh2i8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5okh2i8","updated":"20260601112223"},"Children":[{"ID":"20260601154237-5w9mjsb","Type":"NodeParagraph","Properties":{"id":"20260601154237-5w9mjsb","updated":"20260601112223"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260601154237-hbt3nyn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-hbt3nyn","updated":"20260601112311"},"Children":[{"ID":"20260601154237-68wmlf1","Type":"NodeParagraph","Properties":{"id":"20260601154237-68wmlf1","updated":"20260601112311"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260601154237-gk5l9f2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gk5l9f2","updated":"20260601112319"},"Children":[{"ID":"20260601154237-oq4xzb2","Type":"NodeParagraph","Properties":{"id":"20260601154237-oq4xzb2","updated":"20260601112338"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260601154237-e2b7731","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-e2b7731","updated":"20260601112417"},"Children":[{"ID":"20260601154237-buwlg17","Type":"NodeParagraph","Properties":{"id":"20260601154237-buwlg17","updated":"20260601112420"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260601154237-fam49i3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-fam49i3","updated":"20260601155630"},"Children":[{"ID":"20260601154237-flbpk43","Type":"NodeParagraph","Properties":{"id":"20260601154237-flbpk43","updated":"20260601155630"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260601154237-en68aky","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-en68aky","updated":"20260601112704"},"Children":[{"ID":"20260601154237-yd54vqt","Type":"NodeParagraph","Properties":{"id":"20260601154237-yd54vqt","updated":"20260601112707"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260601154237-h6gs8m1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-h6gs8m1","updated":"20260601112725"},"Children":[{"ID":"20260601154237-401vzor","Type":"NodeParagraph","Properties":{"id":"20260601154237-401vzor","updated":"20260601112734"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260601154237-z9305fb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-z9305fb","updated":"20260601112814"},"Children":[{"ID":"20260601154237-wzczr9b","Type":"NodeParagraph","Properties":{"id":"20260601154237-wzczr9b","updated":"20260601112817"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260601154237-6octpdx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6octpdx","updated":"20260601124904"},"Children":[{"ID":"20260601154237-nhbfn0b","Type":"NodeParagraph","Properties":{"id":"20260601154237-nhbfn0b","updated":"20260601124907"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260601154237-gjebr88","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-gjebr88","updated":"20260601112851"},"Children":[{"ID":"20260601154237-dvja58g","Type":"NodeParagraph","Properties":{"id":"20260601154237-dvja58g","updated":"20260601112851"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260601154237-khhl7ic","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-khhl7ic","updated":"20260601155607"},"Children":[{"ID":"20260601154237-hz1ild6","Type":"NodeParagraph","Properties":{"id":"20260601154237-hz1ild6","updated":"20260601155607"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260601154237-ik63lcp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ik63lcp","updated":"20260601121809"},"Children":[{"ID":"20260601154237-iube8tp","Type":"NodeParagraph","Properties":{"id":"20260601154237-iube8tp","updated":"20260601121820"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260601154237-6bizlxz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-6bizlxz","updated":"20260601121853"},"Children":[{"ID":"20260601154237-vgld7a1","Type":"NodeParagraph","Properties":{"id":"20260601154237-vgld7a1","updated":"20260601121853"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260601154237-axatrva","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-axatrva","updated":"20260601124353"},"Children":[{"ID":"20260601154237-rz0vqe9","Type":"NodeParagraph","Properties":{"id":"20260601154237-rz0vqe9","updated":"20260601124353"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260601154237-2dmrld0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2dmrld0","updated":"20260601124706"},"Children":[{"ID":"20260601154237-4xoxfz2","Type":"NodeParagraph","Properties":{"id":"20260601154237-4xoxfz2","updated":"20260601124706"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260601154237-9qufyy9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9qufyy9","updated":"20260601124716"},"Children":[{"ID":"20260601154237-b0g0huh","Type":"NodeParagraph","Properties":{"id":"20260601154237-b0g0huh","updated":"20260601124717"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260601154237-cn2vbpa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-cn2vbpa","updated":"20260601124821"},"Children":[{"ID":"20260601154237-140bjqw","Type":"NodeParagraph","Properties":{"id":"20260601154237-140bjqw","updated":"20260601124822"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260601154237-nwvnnhm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-nwvnnhm","updated":"20260601124832"},"Children":[{"ID":"20260601154237-qgfnjkl","Type":"NodeParagraph","Properties":{"id":"20260601154237-qgfnjkl","updated":"20260601124832"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260601154237-38wldp1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-38wldp1","updated":"20260601124434"},"Children":[{"ID":"20260601154237-bo4a6zv","Type":"NodeParagraph","Properties":{"id":"20260601154237-bo4a6zv","updated":"20260601124434"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260601154237-unnm4uk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-unnm4uk","updated":"20260601124748"},"Children":[{"ID":"20260601154237-2agns11","Type":"NodeParagraph","Properties":{"id":"20260601154237-2agns11","updated":"20260601124748"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260601154237-n8xqrz1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-n8xqrz1","updated":"20260601125013"},"Children":[{"ID":"20260601154237-0klzjhr","Type":"NodeParagraph","Properties":{"id":"20260601154237-0klzjhr","updated":"20260601125027"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260601154237-02dhsns","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-02dhsns","updated":"20260601124920"},"Children":[{"ID":"20260601154237-w5fnyzx","Type":"NodeParagraph","Properties":{"id":"20260601154237-w5fnyzx","updated":"20260601124920"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260601154237-skoxk2x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-skoxk2x","updated":"20260601125039"},"Children":[{"ID":"20260601154237-gjkxdjm","Type":"NodeParagraph","Properties":{"id":"20260601154237-gjkxdjm","updated":"20260601125039"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260601154237-k6vo5tz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-k6vo5tz","updated":"20260601125050"},"Children":[{"ID":"20260601154237-rf2rote","Type":"NodeParagraph","Properties":{"id":"20260601154237-rf2rote","updated":"20260601125051"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260601154237-9lrcpos","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-9lrcpos","updated":"20260601125059"},"Children":[{"ID":"20260601154237-0pafp0z","Type":"NodeParagraph","Properties":{"id":"20260601154237-0pafp0z","updated":"20260601125059"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260601154237-rnak2oy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-rnak2oy","updated":"20260601125108"},"Children":[{"ID":"20260601154237-228ebmx","Type":"NodeParagraph","Properties":{"id":"20260601154237-228ebmx","updated":"20260601125109"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260601154237-tjlhj1z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-tjlhj1z","updated":"20260601125119"},"Children":[{"ID":"20260601154237-gizd2gv","Type":"NodeParagraph","Properties":{"id":"20260601154237-gizd2gv","updated":"20260601125119"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260601154237-vdkzzmm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vdkzzmm","updated":"20260601125132"},"Children":[{"ID":"20260601154237-jo0xe6n","Type":"NodeParagraph","Properties":{"id":"20260601154237-jo0xe6n","updated":"20260601125132"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260601154237-32d8rdh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-32d8rdh","updated":"20260601125356"},"Children":[{"ID":"20260601154237-6qtldh0","Type":"NodeParagraph","Properties":{"id":"20260601154237-6qtldh0","updated":"20260601125356"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260601154237-ih5f43w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ih5f43w","updated":"20260601125432"},"Children":[{"ID":"20260601154237-5p80go0","Type":"NodeParagraph","Properties":{"id":"20260601154237-5p80go0","updated":"20260601125433"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260601154237-ze47fo2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-ze47fo2","updated":"20260601125145"},"Children":[{"ID":"20260601154237-xzh5zlg","Type":"NodeParagraph","Properties":{"id":"20260601154237-xzh5zlg","updated":"20260601125913"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260601154237-s4svt2t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-s4svt2t","updated":"20260601124809"},"Children":[{"ID":"20260601154237-01qw3wj","Type":"NodeParagraph","Properties":{"id":"20260601154237-01qw3wj","updated":"20260601125921"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260601154237-oyc33xl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-oyc33xl","updated":"20260601124729"},"Children":[{"ID":"20260601154237-mhz4wjg","Type":"NodeParagraph","Properties":{"id":"20260601154237-mhz4wjg","updated":"20260601124729"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260601154237-2hz7jec","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-2hz7jec","updated":"20260601155404"},"Children":[{"ID":"20260601154237-yjxjy40","Type":"NodeParagraph","Properties":{"id":"20260601154237-yjxjy40","updated":"20260601155404"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"。"}]}]},{"ID":"20260601154237-dcyh9mf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-dcyh9mf","updated":"20260601155515"},"Children":[{"ID":"20260601154237-dnbnq0i","Type":"NodeParagraph","Properties":{"id":"20260601154237-dnbnq0i","updated":"20260601155515"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260601154237-es8tep9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-es8tep9","updated":"20260601155530"},"Children":[{"ID":"20260601154237-0qav9vu","Type":"NodeParagraph","Properties":{"id":"20260601154237-0qav9vu","updated":"20260601155530"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260601154237-7chx1sw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-7chx1sw","updated":"20260601155436"},"Children":[{"ID":"20260601154237-gottqln","Type":"NodeParagraph","Properties":{"id":"20260601154237-gottqln","updated":"20260601155436"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260601154237-f01s8gl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-f01s8gl","updated":"20260601155451"},"Children":[{"ID":"20260601154237-s8zz1ze","Type":"NodeParagraph","Properties":{"id":"20260601154237-s8zz1ze","updated":"20260601155451"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260601154237-3r3zsrx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-3r3zsrx","updated":"20260601125730"},"Children":[{"ID":"20260601154237-uf0a4ev","Type":"NodeParagraph","Properties":{"id":"20260601154237-uf0a4ev","updated":"20260601125730"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260601154237-vhg7k0s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-vhg7k0s","updated":"20260601125829"},"Children":[{"ID":"20260601154237-mu7l1uf","Type":"NodeParagraph","Properties":{"id":"20260601154237-mu7l1uf","updated":"20260601125832"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260601154237-5t91x4f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-5t91x4f","updated":"20260601125950"},"Children":[{"ID":"20260601154237-s3om61r","Type":"NodeParagraph","Properties":{"id":"20260601154237-s3om61r","updated":"20260601130000"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260601154237-1nkfcr0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601154237-1nkfcr0","updated":"20260601130030"},"Children":[{"ID":"20260601154237-cof70yk","Type":"NodeParagraph","Properties":{"id":"20260601154237-cof70yk","updated":"20260601130030"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]}]}]}]}]},{"ID":"20260531092721-auz2x2v","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260531092721-auz2x2v","updated":"20260531092756"},"Children":[{"ID":"20260531092721-q7hzj08","Type":"NodeParagraph","Properties":{"id":"20260531092721-q7hzj08","updated":"20260531092756"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：840至860字"}]}]}]},{"ID":"20260531092721-qv9gtee","Type":"NodeParagraph","Properties":{"id":"20260531092721-qv9gtee","updated":"20260531092721"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【输出格式】"}]},{"ID":"20260531092721-k6ze49w","Type":"NodeList","ListData":{},"Properties":{"id":"20260531092721-k6ze49w","updated":"20260531092721"},"Children":[{"ID":"20260531092721-l9lo5eg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260531092721-l9lo5eg","updated":"20260531092721"},"Children":[{"ID":"20260531092721-ai2gezm","Type":"NodeParagraph","Properties":{"id":"20260531092721-ai2gezm","updated":"20260531092721"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260531092721-1uqzh9j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260531092721-1uqzh9j","updated":"20260531092721"},"Children":[{"ID":"20260531092721-enh4i0h","Type":"NodeParagraph","Properties":{"id":"20260531092721-enh4i0h","updated":"20260531092721"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]}]}]},{"ID":"20260531094103-nuvggne","Type":"NodeParagraph","Properties":{"id":"20260531094103-nuvggne","updated":"20260601132743"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【作文题目/材料/原文】"},{"Type":"NodeText","Data":"\n（在此处粘贴具体的作文题目、材料或话题，例如：2025年全国一卷关于老舍、艾青、穆旦的材料……）"}]},{"ID":"20260601122104-fjp9bco","Type":"NodeParagraph","Properties":{"id":"20260601122104-fjp9bco","updated":"20260601122104"}}]}