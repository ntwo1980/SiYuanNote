cttakk2","Type":"NodeParagraph","Properties":{"id":"20260601082421-cttakk2","updated":"20260601082427"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260601082439-1nwoxza","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082439-1nwoxza","updated":"20260601082439"},"Children":[{"ID":"20260601082439-9j7guwe","Type":"NodeParagraph","Properties":{"id":"20260601082439-9j7guwe","updated":"20260601082439"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260601082500-iwgf93t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082500-iwgf93t","updated":"20260601082500"},"Children":[{"ID":"20260601082500-ml6rlrq","Type":"NodeParagraph","Properties":{"id":"20260601082500-ml6rlrq","updated":"20260601082500"},"Children":[{"Type":"NodeText","Data":"当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260601082520-zoatdaz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082520-zoatdaz","updated":"20260601082520"},"Children":[{"ID":"20260601082520-y9nbs10","Type":"NodeParagraph","Properties":{"id":"20260601082520-y9nbs10","updated":"20260601082521"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260601082542-dhbe7r5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082542-dhbe7r5","updated":"20260601082542"},"Children":[{"ID":"20260601082542-4c9psbm","Type":"NodeParagraph","Properties":{"id":"20260601082542-4c9psbm","updated":"20260601082545"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260601082611-kk0xcfy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082611-kk0xcfy","updated":"20260601082611"},"Children":[{"ID":"20260601082611-c1g8ikz","Type":"NodeParagraph","Properties":{"id":"20260601082611-c1g8ikz","updated":"20260601082615"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260601082634-bd4k2gg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082634-bd4k2gg","updated":"20260601082634"},"Children":[{"ID":"20260601082634-4lmzbyj","Type":"NodeParagraph","Properties":{"id":"20260601082634-4lmzbyj","updated":"20260601082649"},"Children":[{"Type":"NodeText","Data":"青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260601082714-zhkngbm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082714-zhkngbm","updated":"20260601082714"},"Children":[{"ID":"20260601082714-v10b80r","Type":"NodeParagraph","Properties":{"id":"20260601082714-v10b80r","updated":"20260601082714"},"Children":[{"Type":"NodeText","Data":"我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260601082739-uozqha7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082739-uozqha7","updated":"20260601082739"},"Children":[{"ID":"20260601082739-nbwdlak","Type":"NodeParagraph","Properties":{"id":"20260601082739-nbwdlak","updated":"20260601082740"},"Children":[{"Type":"NodeText","Data":"大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260601082800-sjy11yx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082800-sjy11yx","updated":"20260601082800"},"Children":[{"ID":"20260601082800-hzhd4gs","Type":"NodeParagraph","Properties":{"id":"20260601082800-hzhd4gs","updated":"20260601082800"},"Children":[{"Type":"NodeText","Data":"西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260601082814-3tzhu29","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082814-3tzhu29","updated":"20260601082814"},"Children":[{"ID":"20260601082814-uzc3hlp","Type":"NodeParagraph","Properties":{"id":"20260601082814-uzc3hlp","updated":"20260601082814"},"Children":[{"Type":"NodeText","Data":"在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260601082922-d9k077p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082922-d9k077p","updated":"20260601082922"},"Children":[{"ID":"20260601082922-bh7eh4l","Type":"NodeParagraph","Properties":{"id":"20260601082922-bh7eh4l","updated":"20260601082923"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260601082938-x3me9ue","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601082938-x3me9ue","updated":"20260601082938"},"Children":[{"ID":"20260601082938-32f7xnj","Type":"NodeParagraph","Properties":{"id":"20260601082938-32f7xnj","updated":"20260601082938"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260601083002-vza9tev","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083002-vza9tev","updated":"20260601083002"},"Children":[{"ID":"20260601083002-ut3jqwb","Type":"NodeParagraph","Properties":{"id":"20260601083002-ut3jqwb","updated":"20260601083002"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260601083019-4p4fen0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083019-4p4fen0","updated":"20260601083019"},"Children":[{"ID":"20260601083019-cuh0p6z","Type":"NodeParagraph","Properties":{"id":"20260601083019-cuh0p6z","updated":"20260601083019"},"Children":[{"Type":"NodeText","Data":"经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260601083050-02810my","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083050-02810my","updated":"20260601083050"},"Children":[{"ID":"20260601083050-fogr2tc","Type":"NodeParagraph","Properties":{"id":"20260601083050-fogr2tc","updated":"20260601083050"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260601083103-vtbjy9s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083103-vtbjy9s","updated":"20260601083103"},"Children":[{"ID":"20260601083103-2zbcx15","Type":"NodeParagraph","Properties":{"id":"20260601083103-2zbcx15","updated":"20260601083106"},"Children":[{"Type":"NodeText","Data":"理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260601083127-eov3fda","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083127-eov3fda","updated":"20260601083127"},"Children":[{"ID":"20260601083127-hkw429b","Type":"NodeParagraph","Properties":{"id":"20260601083127-hkw429b","updated":"20260601083130"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260601083249-esgbq1c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083249-esgbq1c","updated":"20260601083249"},"Children":[{"ID":"20260601083249-1kaundq","Type":"NodeParagraph","Properties":{"id":"20260601083249-1kaundq","updated":"20260601083250"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260601083305-ze01s3a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083305-ze01s3a","updated":"20260601083305"},"Children":[{"ID":"20260601083305-l9dqk9g","Type":"NodeParagraph","Properties":{"id":"20260601083305-l9dqk9g","updated":"20260601083305"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260601083357-l8ygxes","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083357-l8ygxes","updated":"20260601083357"},"Children":[{"ID":"20260601083357-b376hpl","Type":"NodeParagraph","Properties":{"id":"20260601083357-b376hpl","updated":"20260601083400"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260601083417-0r2934g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083417-0r2934g","updated":"20260601083417"},"Children":[{"ID":"20260601083417-6c3qo7q","Type":"NodeParagraph","Properties":{"id":"20260601083417-6c3qo7q","updated":"20260601083420"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260601083608-nhta3jp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083608-nhta3jp","updated":"20260601083608"},"Children":[{"ID":"20260601083608-oixd8vn","Type":"NodeParagraph","Properties":{"id":"20260601083608-oixd8vn","updated":"20260601083611"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260601083651-lqrt00n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083651-lqrt00n","updated":"20260601083651"},"Children":[{"ID":"20260601083651-8avav8a","Type":"NodeParagraph","Properties":{"id":"20260601083651-8avav8a","updated":"20260601083652"},"Children":[{"Type":"NodeText","Data":"只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260601083705-83au2db","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083705-83au2db","updated":"20260601083705"},"Children":[{"ID":"20260601083705-qmgvadu","Type":"NodeParagraph","Properties":{"id":"20260601083705-qmgvadu","updated":"20260601083710"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260601083720-v31xueb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083720-v31xueb","updated":"20260601083720"},"Children":[{"ID":"20260601083720-85nkst9","Type":"NodeParagraph","Properties":{"id":"20260601083720-85nkst9","updated":"20260601083724"},"Children":[{"Type":"NodeText","Data":"没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260601083741-ifv2ywu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083741-ifv2ywu","updated":"20260601083741"},"Children":[{"ID":"20260601083741-4kij71i","Type":"NodeParagraph","Properties":{"id":"20260601083741-4kij71i","updated":"20260601083744"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260601083753-8adm9x9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083753-8adm9x9","updated":"20260601083753"},"Children":[{"ID":"20260601083753-o9wnfmi","Type":"NodeParagraph","Properties":{"id":"20260601083753-o9wnfmi","updated":"20260601083756"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260601083808-j5lthqk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083808-j5lthqk","updated":"20260601083808"},"Children":[{"ID":"20260601083808-8v1l2hq","Type":"NodeParagraph","Properties":{"id":"20260601083808-8v1l2hq","updated":"20260601083811"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260601083823-on5pwsk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083823-on5pwsk","updated":"20260601083823"},"Children":[{"ID":"20260601083823-fn7s1w6","Type":"NodeParagraph","Properties":{"id":"20260601083823-fn7s1w6","updated":"20260601083824"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260601083834-8lxan7h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083834-8lxan7h","updated":"20260601083834"},"Children":[{"ID":"20260601083834-hh9ysrv","Type":"NodeParagraph","Properties":{"id":"20260601083834-hh9ysrv","updated":"20260601083839"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260601083851-lkpa1zj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083851-lkpa1zj","updated":"20260601083851"},"Children":[{"ID":"20260601083851-xrkr61q","Type":"NodeParagraph","Properties":{"id":"20260601083851-xrkr61q","updated":"20260601083854"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260601083903-7nnhhp3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083903-7nnhhp3","updated":"20260601083903"},"Children":[{"ID":"20260601083903-ghmd8nn","Type":"NodeParagraph","Properties":{"id":"20260601083903-ghmd8nn","updated":"20260601083906"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260601083926-62ioq6x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083926-62ioq6x","updated":"20260601083926"},"Children":[{"ID":"20260601083926-ittkhh2","Type":"NodeParagraph","Properties":{"id":"20260601083926-ittkhh2","updated":"20260601083930"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260601083941-jmh8hyf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083941-jmh8hyf","updated":"20260601083941"},"Children":[{"ID":"20260601083941-pmibz5l","Type":"NodeParagraph","Properties":{"id":"20260601083941-pmibz5l","updated":"20260601083944"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260601083953-j3pkgjr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601083953-j3pkgjr","updated":"20260601083953"},"Children":[{"ID":"20260601083953-8gtjm1o","Type":"NodeParagraph","Properties":{"id":"20260601083953-8gtjm1o","updated":"20260601083957"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260601084016-5ztrvqy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084016-5ztrvqy","updated":"20260601084016"},"Children":[{"ID":"20260601084016-twsjh0u","Type":"NodeParagraph","Properties":{"id":"20260601084016-twsjh0u","updated":"20260601084020"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260601084044-oelm2sd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084044-oelm2sd","updated":"20260601084044"},"Children":[{"ID":"20260601084044-puxbqlx","Type":"NodeParagraph","Properties":{"id":"20260601084044-puxbqlx","updated":"20260601084048"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260601084059-69yrm3k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084059-69yrm3k","updated":"20260601084059"},"Children":[{"ID":"20260601084059-b6posxh","Type":"NodeParagraph","Properties":{"id":"20260601084059-b6posxh","updated":"20260601084103"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260601084126-kegvq89","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084126-kegvq89","updated":"20260601084126"},"Children":[{"ID":"20260601084126-ejr37o5","Type":"NodeParagraph","Properties":{"id":"20260601084126-ejr37o5","updated":"20260601084126"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260601084139-w2tcrsn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084139-w2tcrsn","updated":"20260601084139"},"Children":[{"ID":"20260601084139-eycnts1","Type":"NodeParagraph","Properties":{"id":"20260601084139-eycnts1","updated":"20260601084139"},"Children":[{"Type":"NodeText","Data":"人，有了物质才能生存；有了精神，那才是生活。"}]}]},{"ID":"20260601084201-ytjxyc5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084201-ytjxyc5","updated":"20260601084201"},"Children":[{"ID":"20260601084201-ksqumdi","Type":"NodeParagraph","Properties":{"id":"20260601084201-ksqumdi","updated":"20260601084204"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260601084215-pi0j9zr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084215-pi0j9zr","updated":"20260601084215"},"Children":[{"ID":"20260601084215-xtmt0o8","Type":"NodeParagraph","Properties":{"id":"20260601084215-xtmt0o8","updated":"20260601084215"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260601084225-af6ob9q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084225-af6ob9q","updated":"20260601084225"},"Children":[{"ID":"20260601084225-5b8vkk3","Type":"NodeParagraph","Properties":{"id":"20260601084225-5b8vkk3","updated":"20260601084225"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260601084240-ejjn7eh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084240-ejjn7eh","updated":"20260601084240"},"Children":[{"ID":"20260601084240-tdovkwh","Type":"NodeParagraph","Properties":{"id":"20260601084240-tdovkwh","updated":"20260601084243"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260601084244-wo87eiu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084244-wo87eiu","updated":"20260601084244"},"Children":[{"ID":"20260601084244-oqsa1tz","Type":"NodeParagraph","Properties":{"id":"20260601084244-oqsa1tz","updated":"20260601084256"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260601084307-0cje8u7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084307-0cje8u7","updated":"20260601084307"},"Children":[{"ID":"20260601084307-hhjdy2u","Type":"NodeParagraph","Properties":{"id":"20260601084307-hhjdy2u","updated":"20260601084307"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260601084316-w3ujlj6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084316-w3ujlj6","updated":"20260601084316"},"Children":[{"ID":"20260601084316-a3zvu9o","Type":"NodeParagraph","Properties":{"id":"20260601084316-a3zvu9o","updated":"20260601084323"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260601084336-7815aa2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084336-7815aa2","updated":"20260601084336"},"Children":[{"ID":"20260601084336-jgxdrsr","Type":"NodeParagraph","Properties":{"id":"20260601084336-jgxdrsr","updated":"20260601084340"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260601084341-9yw3ngr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084341-9yw3ngr","updated":"20260601084341"},"Children":[{"ID":"20260601084341-zr4gel2","Type":"NodeParagraph","Properties":{"id":"20260601084341-zr4gel2","updated":"20260601084350"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260601084400-eayrt1n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084400-eayrt1n","updated":"20260601084400"},"Children":[{"ID":"20260601084400-8mkc331","Type":"NodeParagraph","Properties":{"id":"20260601084400-8mkc331","updated":"20260601084403"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260601084411-pwcqria","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084411-pwcqria","updated":"20260601084411"},"Children":[{"ID":"20260601084411-eqd9u5p","Type":"NodeParagraph","Properties":{"id":"20260601084411-eqd9u5p","updated":"20260601084412"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260601084422-hcbml0o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084422-hcbml0o","updated":"20260601084422"},"Children":[{"ID":"20260601084422-dfnu4z9","Type":"NodeParagraph","Properties":{"id":"20260601084422-dfnu4z9","updated":"20260601084432"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260601084445-6ua6xtj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084445-6ua6xtj","updated":"20260601084445"},"Children":[{"ID":"20260601084445-x7yf216","Type":"NodeParagraph","Properties":{"id":"20260601084445-x7yf216","updated":"20260601084450"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260601084503-lwbcbf2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084503-lwbcbf2","updated":"20260601084503"},"Children":[{"ID":"20260601084503-p83h95q","Type":"NodeParagraph","Properties":{"id":"20260601084503-p83h95q","updated":"20260601084503"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260601084525-8pnfp4t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084525-8pnfp4t","updated":"20260601084525"},"Children":[{"ID":"20260601084525-7o4b33y","Type":"NodeParagraph","Properties":{"id":"20260601084525-7o4b33y","updated":"20260601084536"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260601084547-s9x6md7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084547-s9x6md7","updated":"20260601084547"},"Children":[{"ID":"20260601084547-v2qtlmc","Type":"NodeParagraph","Properties":{"id":"20260601084547-v2qtlmc","updated":"20260601084547"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260601084556-m3samzj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084556-m3samzj","updated":"20260601084556"},"Children":[{"ID":"20260601084556-dp3o24i","Type":"NodeParagraph","Properties":{"id":"20260601084556-dp3o24i","updated":"20260601084556"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260601084607-3aqat21","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084607-3aqat21","updated":"20260601084607"},"Children":[{"ID":"20260601084607-5kks8gq","Type":"NodeParagraph","Properties":{"id":"20260601084607-5kks8gq","updated":"20260601084610"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260601084627-7v9e6g9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084627-7v9e6g9","updated":"20260601084627"},"Children":[{"ID":"20260601084627-4cf3e1g","Type":"NodeParagraph","Properties":{"id":"20260601084627-4cf3e1g","updated":"20260601084627"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260601084643-8wus9bb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084643-8wus9bb","updated":"20260601084643"},"Children":[{"ID":"20260601084643-fzpire3","Type":"NodeParagraph","Properties":{"id":"20260601084643-fzpire3","updated":"20260601084643"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260601084702-z3x8bki","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084702-z3x8bki","updated":"20260601084702"},"Children":[{"ID":"20260601084702-swmub8a","Type":"NodeParagraph","Properties":{"id":"20260601084702-swmub8a","updated":"20260601084702"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260601084712-e4k2uh1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084712-e4k2uh1","updated":"20260601084712"},"Children":[{"ID":"20260601084712-09y60dq","Type":"NodeParagraph","Properties":{"id":"20260601084712-09y60dq","updated":"20260601084718"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260601084719-37877nk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084719-37877nk","updated":"20260601084719"},"Children":[{"ID":"20260601084719-d50f06b","Type":"NodeParagraph","Properties":{"id":"20260601084719-d50f06b","updated":"20260601084734"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260601084743-mfbdg5w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084743-mfbdg5w","updated":"20260601084743"},"Children":[{"ID":"20260601084743-p271f30","Type":"NodeParagraph","Properties":{"id":"20260601084743-p271f30","updated":"20260601084745"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260601084746-9i2pa2p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084746-9i2pa2p","updated":"20260601084746"},"Children":[{"ID":"20260601084746-9zvpnbd","Type":"NodeParagraph","Properties":{"id":"20260601084746-9zvpnbd","updated":"20260601084757"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260601084758-c21ysii","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084758-c21ysii","updated":"20260601084758"},"Children":[{"ID":"20260601084758-hzh766g","Type":"NodeParagraph","Properties":{"id":"20260601084758-hzh766g","updated":"20260601084816"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260601084832-20f2inz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084832-20f2inz","updated":"20260601084832"},"Children":[{"ID":"20260601084832-4dguw9t","Type":"NodeParagraph","Properties":{"id":"20260601084832-4dguw9t","updated":"20260601084832"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260601084844-21f1m5w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084844-21f1m5w","updated":"20260601084844"},"Children":[{"ID":"20260601084844-oz8vvw2","Type":"NodeParagraph","Properties":{"id":"20260601084844-oz8vvw2","updated":"20260601084844"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260601084921-wj61eev","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084921-wj61eev","updated":"20260601084921"},"Children":[{"ID":"20260601084921-la8f4sp","Type":"NodeParagraph","Properties":{"id":"20260601084921-la8f4sp","updated":"20260601084921"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260601084934-550v1zg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084934-550v1zg","updated":"20260601084934"},"Children":[{"ID":"20260601084934-guc1p5x","Type":"NodeParagraph","Properties":{"id":"20260601084934-guc1p5x","updated":"20260601084934"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260601084948-uvdg86q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601084948-uvdg86q","updated":"20260601084948"},"Children":[{"ID":"20260601084948-hqr6bwh","Type":"NodeParagraph","Properties":{"id":"20260601084948-hqr6bwh","updated":"20260601084951"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260601085017-big5j9n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085017-big5j9n","updated":"20260601085017"},"Children":[{"ID":"20260601085017-q2oww2b","Type":"NodeParagraph","Properties":{"id":"20260601085017-q2oww2b","updated":"20260601085020"},"Children":[{"Type":"NodeText","Data":"个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260601085037-vxc9xmd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085037-vxc9xmd","updated":"20260601085037"},"Children":[{"ID":"20260601085037-tgx07s8","Type":"NodeParagraph","Properties":{"id":"20260601085037-tgx07s8","updated":"20260601085038"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260601085049-7eh55tn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085049-7eh55tn","updated":"20260601085049"},"Children":[{"ID":"20260601085049-ww3hwki","Type":"NodeParagraph","Properties":{"id":"20260601085049-ww3hwki","updated":"20260601085049"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260601085058-t4q4t6g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085058-t4q4t6g","updated":"20260601085058"},"Children":[{"ID":"20260601085058-1moswae","Type":"NodeParagraph","Properties":{"id":"20260601085058-1moswae","updated":"20260601085102"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260601085115-v9llndv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085115-v9llndv","updated":"20260601085115"},"Children":[{"ID":"20260601085115-goohkgq","Type":"NodeParagraph","Properties":{"id":"20260601085115-goohkgq","updated":"20260601085115"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260601085125-a21jecv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085125-a21jecv","updated":"20260601085125"},"Children":[{"ID":"20260601085125-rkorxu0","Type":"NodeParagraph","Properties":{"id":"20260601085125-rkorxu0","updated":"20260601085128"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260601085139-7wcaaas","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085139-7wcaaas","updated":"20260601085139"},"Children":[{"ID":"20260601085139-6huqjmh","Type":"NodeParagraph","Properties":{"id":"20260601085139-6huqjmh","updated":"20260601085141"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260601085158-3z9zf6s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085158-3z9zf6s","updated":"20260601085158"},"Children":[{"ID":"20260601085158-dk207oj","Type":"NodeParagraph","Properties":{"id":"20260601085158-dk207oj","updated":"20260601085202"},"Children":[{"Type":"NodeText","Data":"手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260601085213-9p5c4c0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085213-9p5c4c0","updated":"20260601085213"},"Children":[{"ID":"20260601085213-ofv84t4","Type":"NodeParagraph","Properties":{"id":"20260601085213-ofv84t4","updated":"20260601085213"},"Children":[{"Type":"NodeText","Data":"我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260601085239-ebz50g4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085239-ebz50g4","updated":"20260601085239"},"Children":[{"ID":"20260601085239-n93tks2","Type":"NodeParagraph","Properties":{"id":"20260601085239-n93tks2","updated":"20260601085259"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260601085309-x22zbk0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085309-x22zbk0","updated":"20260601085309"},"Children":[{"ID":"20260601085309-wqrk4b1","Type":"NodeParagraph","Properties":{"id":"20260601085309-wqrk4b1","updated":"20260601085313"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260601085324-1afilds","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085324-1afilds","updated":"20260601085324"},"Children":[{"ID":"20260601085324-7f4p2nt","Type":"NodeParagraph","Properties":{"id":"20260601085324-7f4p2nt","updated":"20260601085327"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260601085342-hmyys1n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085342-hmyys1n","updated":"20260601085342"},"Children":[{"ID":"20260601085342-dfk1fpd","Type":"NodeParagraph","Properties":{"id":"20260601085342-dfk1fpd","updated":"20260601085342"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260601085356-hrpu47h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085356-hrpu47h","updated":"20260601085356"},"Children":[{"ID":"20260601085356-3b2gtt8","Type":"NodeParagraph","Properties":{"id":"20260601085356-3b2gtt8","updated":"20260601085356"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260601085425-r2qpu0x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085425-r2qpu0x","updated":"20260601085425"},"Children":[{"ID":"20260601085425-v2gernf","Type":"NodeParagraph","Properties":{"id":"20260601085425-v2gernf","updated":"20260601085427"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260601085442-6i7ct2w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085442-6i7ct2w","updated":"20260601085442"},"Children":[{"ID":"20260601085442-9er6u47","Type":"NodeParagraph","Properties":{"id":"20260601085442-9er6u47","updated":"20260601085457"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260601085428-azs5lch","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085428-azs5lch","updated":"20260601085428"},"Children":[{"ID":"20260601085428-vbtx7pt","Type":"NodeParagraph","Properties":{"id":"20260601085428-vbtx7pt","updated":"20260601085458"},"Children":[{"Type":"NodeText","Data":"一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260601085512-khkvoor","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085512-khkvoor","updated":"20260601085512"},"Children":[{"ID":"20260601085512-5rrba5f","Type":"NodeParagraph","Properties":{"id":"20260601085512-5rrba5f","updated":"20260601085515"},"Children":[{"Type":"NodeText","Data":"在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260601085539-a1ctcp6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085539-a1ctcp6","updated":"20260601085539"},"Children":[{"ID":"20260601085539-uwnziia","Type":"NodeParagraph","Properties":{"id":"20260601085539-uwnziia","updated":"20260601085543"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260601085551-e0l75hv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085551-e0l75hv","updated":"20260601085551"},"Children":[{"ID":"20260601085551-qp1k7v9","Type":"NodeParagraph","Properties":{"id":"20260601085551-qp1k7v9","updated":"20260601085552"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260601085603-ru9knta","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085603-ru9knta","updated":"20260601085603"},"Children":[{"ID":"20260601085603-xfhubjh","Type":"NodeParagraph","Properties":{"id":"20260601085603-xfhubjh","updated":"20260601085608"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260601085609-131gffp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085609-131gffp","updated":"20260601085609"},"Children":[{"ID":"20260601085609-fjc9135","Type":"NodeParagraph","Properties":{"id":"20260601085609-fjc9135","updated":"20260601085653"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260601085709-ev6100n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085709-ev6100n","updated":"20260601085709"},"Children":[{"ID":"20260601085709-cpmxmur","Type":"NodeParagraph","Properties":{"id":"20260601085709-cpmxmur","updated":"20260601085719"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260601085739-hnxrnw6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085739-hnxrnw6","updated":"20260601085739"},"Children":[{"ID":"20260601085739-b0odugu","Type":"NodeParagraph","Properties":{"id":"20260601085739-b0odugu","updated":"20260601085739"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260601085753-mekloas","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085753-mekloas","updated":"20260601085753"},"Children":[{"ID":"20260601085753-zbzmm18","Type":"NodeParagraph","Properties":{"id":"20260601085753-zbzmm18","updated":"20260601085753"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260601085807-wbuemxq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085807-wbuemxq","updated":"20260601085807"},"Children":[{"ID":"20260601085807-zcmalfm","Type":"NodeParagraph","Properties":{"id":"20260601085807-zcmalfm","updated":"20260601085808"},"Children":[{"Type":"NodeText","Data":"世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260601085819-y7lf388","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085819-y7lf388","updated":"20260601085819"},"Children":[{"ID":"20260601085819-j6ngoz2","Type":"NodeParagraph","Properties":{"id":"20260601085819-j6ngoz2","updated":"20260601085823"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260601085833-y2aqgqy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085833-y2aqgqy","updated":"20260601085833"},"Children":[{"ID":"20260601085833-f26s1hu","Type":"NodeParagraph","Properties":{"id":"20260601085833-f26s1hu","updated":"20260601085837"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260601085845-bo5v0bx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085845-bo5v0bx","updated":"20260601085845"},"Children":[{"ID":"20260601085845-3pvi8jd","Type":"NodeParagraph","Properties":{"id":"20260601085845-3pvi8jd","updated":"20260601085845"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260601085856-ll7hbjm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085856-ll7hbjm","updated":"20260601085856"},"Children":[{"ID":"20260601085856-m5dav98","Type":"NodeParagraph","Properties":{"id":"20260601085856-m5dav98","updated":"20260601085856"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260601085911-v7bv7h4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601085911-v7bv7h4","updated":"20260601085911"},"Children":[{"ID":"20260601085911-zavvg9h","Type":"NodeParagraph","Properties":{"id":"20260601085911-zavvg9h","updated":"20260601085911"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260601090112-r5n9kyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090112-r5n9kyb","updated":"20260601090112"},"Children":[{"ID":"20260601090112-59dz4j8","Type":"NodeParagraph","Properties":{"id":"20260601090112-59dz4j8","updated":"20260601090116"},"Children":[{"Type":"NodeText","Data":"有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260601090127-t9uy6on","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090127-t9uy6on","updated":"20260601090127"},"Children":[{"ID":"20260601090127-q6gc49l","Type":"NodeParagraph","Properties":{"id":"20260601090127-q6gc49l","updated":"20260601090130"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260601090156-8ak00ku","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090156-8ak00ku","updated":"20260601090156"},"Children":[{"ID":"20260601090156-izgvoxm","Type":"NodeParagraph","Properties":{"id":"20260601090156-izgvoxm","updated":"20260601090158"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260601090200-mq2voep","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090200-mq2voep","updated":"20260601090200"},"Children":[{"ID":"20260601090200-i6eeomi","Type":"NodeParagraph","Properties":{"id":"20260601090200-i6eeomi","updated":"20260601090210"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260601090225-6y8s5rc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090225-6y8s5rc","updated":"20260601090225"},"Children":[{"ID":"20260601090225-3a89xor","Type":"NodeParagraph","Properties":{"id":"20260601090225-3a89xor","updated":"20260601090225"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260601090244-2fk4db2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090244-2fk4db2","updated":"20260601090244"},"Children":[{"ID":"20260601090244-q9otb2o","Type":"NodeParagraph","Properties":{"id":"20260601090244-q9otb2o","updated":"20260601090248"},"Children":[{"Type":"NodeText","Data":"苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260601090319-44uky5w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090319-44uky5w","updated":"20260601090319"},"Children":[{"ID":"20260601090319-59gaiva","Type":"NodeParagraph","Properties":{"id":"20260601090319-59gaiva","updated":"20260601090319"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260601090419-3j2o5uc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090419-3j2o5uc","updated":"20260601090419"},"Children":[{"ID":"20260601090419-b4ur3xn","Type":"NodeParagraph","Properties":{"id":"20260601090419-b4ur3xn","updated":"20260601090422"},"Children":[{"Type":"NodeText","Data":"每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260601090430-eolaewq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090430-eolaewq","updated":"20260601090430"},"Children":[{"ID":"20260601090430-vgzd3l2","Type":"NodeParagraph","Properties":{"id":"20260601090430-vgzd3l2","updated":"20260601090437"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260601090455-sdmoapi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090455-sdmoapi","updated":"20260601090455"},"Children":[{"ID":"20260601090455-95si09v","Type":"NodeParagraph","Properties":{"id":"20260601090455-95si09v","updated":"20260601090458"},"Children":[{"Type":"NodeText","Data":"谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260601090508-10xjx3u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090508-10xjx3u","updated":"20260601090508"},"Children":[{"ID":"20260601090508-erd4fbg","Type":"NodeParagraph","Properties":{"id":"20260601090508-erd4fbg","updated":"20260601090515"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260601090527-vb594nt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090527-vb594nt","updated":"20260601090527"},"Children":[{"ID":"20260601090527-lucznnm","Type":"NodeParagraph","Properties":{"id":"20260601090527-lucznnm","updated":"20260601090531"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260601090532-1taqcq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090532-1taqcq3","updated":"20260601090532"},"Children":[{"ID":"20260601090542-fw2vczt","Type":"NodeParagraph","Properties":{"id":"20260601090542-fw2vczt","updated":"20260601090548"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260601090559-87slh3u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090559-87slh3u","updated":"20260601090559"},"Children":[{"ID":"20260601090559-lq3hmjo","Type":"NodeParagraph","Properties":{"id":"20260601090559-lq3hmjo","updated":"20260601090602"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260601090612-3cxhjs8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090612-3cxhjs8","updated":"20260601090612"},"Children":[{"ID":"20260601090612-0l0m188","Type":"NodeParagraph","Properties":{"id":"20260601090612-0l0m188","updated":"20260601090612"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260601090622-oxvm9q0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090622-oxvm9q0","updated":"20260601090622"},"Children":[{"ID":"20260601090622-rwe1ujg","Type":"NodeParagraph","Properties":{"id":"20260601090622-rwe1ujg","updated":"20260601090625"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260601090633-66xcwoo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090633-66xcwoo","updated":"20260601090633"},"Children":[{"ID":"20260601090633-wywpw6y","Type":"NodeParagraph","Properties":{"id":"20260601090633-wywpw6y","updated":"20260601090636"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260601090637-gfv7aq0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090637-gfv7aq0","updated":"20260601090637"},"Children":[{"ID":"20260601090637-cs3w62f","Type":"NodeParagraph","Properties":{"id":"20260601090637-cs3w62f","updated":"20260601090650"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260601090651-1p72ezk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090651-1p72ezk","updated":"20260601090651"},"Children":[{"ID":"20260601090651-1ecv5c8","Type":"NodeParagraph","Properties":{"id":"20260601090651-1ecv5c8","updated":"20260601090703"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260601090723-96zdnjh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090723-96zdnjh","updated":"20260601090723"},"Children":[{"ID":"20260601090723-7t6lcn0","Type":"NodeParagraph","Properties":{"id":"20260601090723-7t6lcn0","updated":"20260601090724"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260601090734-f51uvod","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090734-f51uvod","updated":"20260601090734"},"Children":[{"ID":"20260601090734-asy9mdd","Type":"NodeParagraph","Properties":{"id":"20260601090734-asy9mdd","updated":"20260601090739"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260601090751-3sg6ba6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090751-3sg6ba6","updated":"20260601090751"},"Children":[{"ID":"20260601090751-3necei9","Type":"NodeParagraph","Properties":{"id":"20260601090751-3necei9","updated":"20260601090755"},"Children":[{"Type":"NodeText","Data":"你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260601090812-z7qs5xg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090812-z7qs5xg","updated":"20260601090812"},"Children":[{"ID":"20260601090812-misfu2r","Type":"NodeParagraph","Properties":{"id":"20260601090812-misfu2r","updated":"20260601090814"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260601090824-odup56e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090824-odup56e","updated":"20260601090824"},"Children":[{"ID":"20260601090824-g4unk4m","Type":"NodeParagraph","Properties":{"id":"20260601090824-g4unk4m","updated":"20260601090824"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260601090852-hurm9p4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090852-hurm9p4","updated":"20260601090852"},"Children":[{"ID":"20260601090852-nv8fkk4","Type":"NodeParagraph","Properties":{"id":"20260601090852-nv8fkk4","updated":"20260601090852"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260601090900-wz4spaj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090900-wz4spaj","updated":"20260601090900"},"Children":[{"ID":"20260601090900-ow64nve","Type":"NodeParagraph","Properties":{"id":"20260601090900-ow64nve","updated":"20260601090904"},"Children":[{"Type":"NodeText","Data":"没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260601090921-oxgv5k6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090921-oxgv5k6","updated":"20260601090921"},"Children":[{"ID":"20260601090921-nbf1yf0","Type":"NodeParagraph","Properties":{"id":"20260601090921-nbf1yf0","updated":"20260601090924"},"Children":[{"Type":"NodeText","Data":"才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260601090936-0vuhyz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090936-0vuhyz2","updated":"20260601090936"},"Children":[{"ID":"20260601090936-t9x8ahm","Type":"NodeParagraph","Properties":{"id":"20260601090936-t9x8ahm","updated":"20260601090937"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260601090948-tjte1qo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601090948-tjte1qo","updated":"20260601090948"},"Children":[{"ID":"20260601090948-p0h9lqr","Type":"NodeParagraph","Properties":{"id":"20260601090948-p0h9lqr","updated":"20260601090956"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260601091011-6t8cs95","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091011-6t8cs95","updated":"20260601091011"},"Children":[{"ID":"20260601091011-ydmoo2c","Type":"NodeParagraph","Properties":{"id":"20260601091011-ydmoo2c","updated":"20260601091013"},"Children":[{"Type":"NodeText","Data":"天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260601091022-ymprk4i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091022-ymprk4i","updated":"20260601091022"},"Children":[{"ID":"20260601091022-so1gwqt","Type":"NodeParagraph","Properties":{"id":"20260601091022-so1gwqt","updated":"20260601091036"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260601091053-0req9f2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091053-0req9f2","updated":"20260601091053"},"Children":[{"ID":"20260601091053-j5leazc","Type":"NodeParagraph","Properties":{"id":"20260601091053-j5leazc","updated":"20260601091053"},"Children":[{"Type":"NodeText","Data":"当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260601091105-orzgzqv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091105-orzgzqv","updated":"20260601091105"},"Children":[{"ID":"20260601091105-ddnrbg0","Type":"NodeParagraph","Properties":{"id":"20260601091105-ddnrbg0","updated":"20260601091108"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260601091139-qj0oc70","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091139-qj0oc70","updated":"20260601091139"},"Children":[{"ID":"20260601091139-ulofbfm","Type":"NodeParagraph","Properties":{"id":"20260601091139-ulofbfm","updated":"20260601091142"},"Children":[{"Type":"NodeText","Data":"荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260601091204-9olv684","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091204-9olv684","updated":"20260601091204"},"Children":[{"ID":"20260601091204-hj6nt09","Type":"NodeParagraph","Properties":{"id":"20260601091204-hj6nt09","updated":"20260601091204"},"Children":[{"Type":"NodeText","Data":"谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260601091218-lwh252l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091218-lwh252l","updated":"20260601091218"},"Children":[{"ID":"20260601091218-dz7cysv","Type":"NodeParagraph","Properties":{"id":"20260601091218-dz7cysv","updated":"20260601091218"},"Children":[{"Type":"NodeText","Data":"梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260601091228-7pj5156","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091228-7pj5156","updated":"20260601091228"},"Children":[{"ID":"20260601091228-c0lwul2","Type":"NodeParagraph","Properties":{"id":"20260601091228-c0lwul2","updated":"20260601091229"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260601091241-490z7v7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091241-490z7v7","updated":"20260601091241"},"Children":[{"ID":"20260601091241-5mrcb7h","Type":"NodeParagraph","Properties":{"id":"20260601091241-5mrcb7h","updated":"20260601091246"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260601091256-orktrdw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091256-orktrdw","updated":"20260601091256"},"Children":[{"ID":"20260601091256-214bnqr","Type":"NodeParagraph","Properties":{"id":"20260601091256-214bnqr","updated":"20260601091257"},"Children":[{"Type":"NodeText","Data":"误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260601091317-5k1qg0v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091317-5k1qg0v","updated":"20260601091317"},"Children":[{"ID":"20260601091317-s71xlf1","Type":"NodeParagraph","Properties":{"id":"20260601091317-s71xlf1","updated":"20260601091318"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260601091319-ktp6qfk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091319-ktp6qfk","updated":"20260601091319"},"Children":[{"ID":"20260601091319-p58xnoa","Type":"NodeParagraph","Properties":{"id":"20260601091319-p58xnoa","updated":"20260601091331"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260601091332-iljls02","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091332-iljls02","updated":"20260601091332"},"Children":[{"ID":"20260601091332-tnyunvc","Type":"NodeParagraph","Properties":{"id":"20260601091332-tnyunvc","updated":"20260601091342"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260601091353-ipms55p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091353-ipms55p","updated":"20260601091353"},"Children":[{"ID":"20260601091353-egty8gf","Type":"NodeParagraph","Properties":{"id":"20260601091353-egty8gf","updated":"20260601091353"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260601091402-v4teumh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091402-v4teumh","updated":"20260601091402"},"Children":[{"ID":"20260601091402-ttadzv1","Type":"NodeParagraph","Properties":{"id":"20260601091402-ttadzv1","updated":"20260601091405"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260601091417-mwstq5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091417-mwstq5l","updated":"20260601091417"},"Children":[{"ID":"20260601091417-q7gzu1h","Type":"NodeParagraph","Properties":{"id":"20260601091417-q7gzu1h","updated":"20260601091422"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260601091431-h8q4iz3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091431-h8q4iz3","updated":"20260601091431"},"Children":[{"ID":"20260601091431-e2mbxnx","Type":"NodeParagraph","Properties":{"id":"20260601091431-e2mbxnx","updated":"20260601091434"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260601091435-7ej1bq3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091435-7ej1bq3","updated":"20260601091435"},"Children":[{"ID":"20260601091435-5kae1l8","Type":"NodeParagraph","Properties":{"id":"20260601091435-5kae1l8","updated":"20260601091503"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260601091523-e598o0j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091523-e598o0j","updated":"20260601091523"},"Children":[{"ID":"20260601091523-gutdxxx","Type":"NodeParagraph","Properties":{"id":"20260601091523-gutdxxx","updated":"20260601091524"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260601091541-le13l37","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091541-le13l37","updated":"20260601091541"},"Children":[{"ID":"20260601091541-hd1i14h","Type":"NodeParagraph","Properties":{"id":"20260601091541-hd1i14h","updated":"20260601091544"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260601091611-r5ujvg0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091611-r5ujvg0","updated":"20260601091611"},"Children":[{"ID":"20260601091611-0vl4bq8","Type":"NodeParagraph","Properties":{"id":"20260601091611-0vl4bq8","updated":"20260601091614"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260601091615-q30nskb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091615-q30nskb","updated":"20260601091615"},"Children":[{"ID":"20260601091615-oa1ouc4","Type":"NodeParagraph","Properties":{"id":"20260601091615-oa1ouc4","updated":"20260601091638"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260601091647-j3soqc2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091647-j3soqc2","updated":"20260601091647"},"Children":[{"ID":"20260601091647-o3iqtdi","Type":"NodeParagraph","Properties":{"id":"20260601091647-o3iqtdi","updated":"20260601091700"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260601091656-8gyy6tu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091656-8gyy6tu","updated":"20260601091656"},"Children":[{"ID":"20260601091656-aysudrt","Type":"NodeParagraph","Properties":{"id":"20260601091656-aysudrt","updated":"20260601091700"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260601091709-75j3wtu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091709-75j3wtu","updated":"20260601091709"},"Children":[{"ID":"20260601091709-4uk6ouo","Type":"NodeParagraph","Properties":{"id":"20260601091709-4uk6ouo","updated":"20260601091709"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260601091718-noflszh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091718-noflszh","updated":"20260601091718"},"Children":[{"ID":"20260601091718-an4gk52","Type":"NodeParagraph","Properties":{"id":"20260601091718-an4gk52","updated":"20260601091721"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260601091803-6qmi6fw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091803-6qmi6fw","updated":"20260601091803"},"Children":[{"ID":"20260601091803-c2woliu","Type":"NodeParagraph","Properties":{"id":"20260601091803-c2woliu","updated":"20260601091803"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260601091821-zlthezd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091821-zlthezd","updated":"20260601091821"},"Children":[{"ID":"20260601091821-614l43x","Type":"NodeParagraph","Properties":{"id":"20260601091821-614l43x","updated":"20260601091821"},"Children":[{"Type":"NodeText","Data":"请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260601091834-27vhvju","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091834-27vhvju","updated":"20260601091834"},"Children":[{"ID":"20260601091834-2642prn","Type":"NodeParagraph","Properties":{"id":"20260601091834-2642prn","updated":"20260601091835"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260601091845-oaze8b9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091845-oaze8b9","updated":"20260601091845"},"Children":[{"ID":"20260601091845-8g3s8uh","Type":"NodeParagraph","Properties":{"id":"20260601091845-8g3s8uh","updated":"20260601091859"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260601091928-eicedrt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601091928-eicedrt","updated":"20260601091928"},"Children":[{"ID":"20260601091928-x57jk4d","Type":"NodeParagraph","Properties":{"id":"20260601091928-x57jk4d","updated":"20260601091936"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260601092003-xjpdu0r","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092003-xjpdu0r","updated":"20260601092003"},"Children":[{"ID":"20260601092003-ab8ju70","Type":"NodeParagraph","Properties":{"id":"20260601092003-ab8ju70","updated":"20260601092007"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260601092008-fd3bto0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092008-fd3bto0","updated":"20260601092008"},"Children":[{"ID":"20260601092008-xqqf220","Type":"NodeParagraph","Properties":{"id":"20260601092008-xqqf220","updated":"20260601092025"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260601092034-stu9zba","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092034-stu9zba","updated":"20260601092034"},"Children":[{"ID":"20260601092034-7i33uuf","Type":"NodeParagraph","Properties":{"id":"20260601092034-7i33uuf","updated":"20260601092036"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260601092046-95nl3jd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092046-95nl3jd","updated":"20260601092046"},"Children":[{"ID":"20260601092046-ry5hbng","Type":"NodeParagraph","Properties":{"id":"20260601092046-ry5hbng","updated":"20260601092049"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260601092050-j9gqrln","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092050-j9gqrln","updated":"20260601092050"},"Children":[{"ID":"20260601092050-h5htz1y","Type":"NodeParagraph","Properties":{"id":"20260601092050-h5htz1y","updated":"20260601092107"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260601092115-tf9oanc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092115-tf9oanc","updated":"20260601092115"},"Children":[{"ID":"20260601092115-bylbt4j","Type":"NodeParagraph","Properties":{"id":"20260601092115-bylbt4j","updated":"20260601092118"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260601092126-5soo2ud","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092126-5soo2ud","updated":"20260601092126"},"Children":[{"ID":"20260601092126-kqwnsax","Type":"NodeParagraph","Properties":{"id":"20260601092126-kqwnsax","updated":"20260601092126"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260601092137-wohrcog","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092137-wohrcog","updated":"20260601092137"},"Children":[{"ID":"20260601092137-y3raz7x","Type":"NodeParagraph","Properties":{"id":"20260601092137-y3raz7x","updated":"20260601092144"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260601092152-nlhbuk4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092152-nlhbuk4","updated":"20260601092152"},"Children":[{"ID":"20260601092152-savdtb0","Type":"NodeParagraph","Properties":{"id":"20260601092152-savdtb0","updated":"20260601092157"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260601092207-jleada5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092207-jleada5","updated":"20260601092207"},"Children":[{"ID":"20260601092207-vpg38gw","Type":"NodeParagraph","Properties":{"id":"20260601092207-vpg38gw","updated":"20260601092210"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260601092220-b7dzkw3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092220-b7dzkw3","updated":"20260601092220"},"Children":[{"ID":"20260601092220-fc29h0l","Type":"NodeParagraph","Properties":{"id":"20260601092220-fc29h0l","updated":"20260601092220"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260601092230-5a5zhwe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092230-5a5zhwe","updated":"20260601092230"},"Children":[{"ID":"20260601092230-vq2cggr","Type":"NodeParagraph","Properties":{"id":"20260601092230-vq2cggr","updated":"20260601092232"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260601092234-vbm75nf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092234-vbm75nf","updated":"20260601092234"},"Children":[{"ID":"20260601092234-whor85r","Type":"NodeParagraph","Properties":{"id":"20260601092234-whor85r","updated":"20260601092247"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260601092303-7ryqkqu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092303-7ryqkqu","updated":"20260601092303"},"Children":[{"ID":"20260601092303-m9roitd","Type":"NodeParagraph","Properties":{"id":"20260601092303-m9roitd","updated":"20260601092303"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260601092317-mfba99a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092317-mfba99a","updated":"20260601092317"},"Children":[{"ID":"20260601092317-njh3u3j","Type":"NodeParagraph","Properties":{"id":"20260601092317-njh3u3j","updated":"20260601092317"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260601092329-4tsm2le","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092329-4tsm2le","updated":"20260601092329"},"Children":[{"ID":"20260601092329-9pclk09","Type":"NodeParagraph","Properties":{"id":"20260601092329-9pclk09","updated":"20260601092332"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260601092344-pbmmd8n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092344-pbmmd8n","updated":"20260601092344"},"Children":[{"ID":"20260601092344-c5j1p3q","Type":"NodeParagraph","Properties":{"id":"20260601092344-c5j1p3q","updated":"20260601092344"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260601092356-wyn9jl9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092356-wyn9jl9","updated":"20260601092356"},"Children":[{"ID":"20260601092356-xqpfaia","Type":"NodeParagraph","Properties":{"id":"20260601092356-xqpfaia","updated":"20260601092357"},"Children":[{"Type":"NodeText","Data":"当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260601092407-mp46in5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092407-mp46in5","updated":"20260601092407"},"Children":[{"ID":"20260601092407-eyt7un9","Type":"NodeParagraph","Properties":{"id":"20260601092407-eyt7un9","updated":"20260601092407"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260601092415-aktzeq8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092415-aktzeq8","updated":"20260601092415"},"Children":[{"ID":"20260601092415-77u7d3u","Type":"NodeParagraph","Properties":{"id":"20260601092415-77u7d3u","updated":"20260601092417"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260601092428-wya76gq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092428-wya76gq","updated":"20260601092428"},"Children":[{"ID":"20260601092428-0od09bj","Type":"NodeParagraph","Properties":{"id":"20260601092428-0od09bj","updated":"20260601092430"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260601092501-l567hhi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092501-l567hhi","updated":"20260601092501"},"Children":[{"ID":"20260601092501-74kf87e","Type":"NodeParagraph","Properties":{"id":"20260601092501-74kf87e","updated":"20260601092504"},"Children":[{"Type":"NodeText","Data":"聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260601092713-59wm71k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092713-59wm71k","updated":"20260601092713"},"Children":[{"ID":"20260601092713-f8gri70","Type":"NodeParagraph","Properties":{"id":"20260601092713-f8gri70","updated":"20260601092716"},"Children":[{"Type":"NodeText","Data":"世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260601092728-sg73ct5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092728-sg73ct5","updated":"20260601092728"},"Children":[{"ID":"20260601092728-gls08bm","Type":"NodeParagraph","Properties":{"id":"20260601092728-gls08bm","updated":"20260601092728"},"Children":[{"Type":"NodeText","Data":"财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260601092744-p13rwj1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092744-p13rwj1","updated":"20260601092744"},"Children":[{"ID":"20260601092744-0dgp6hj","Type":"NodeParagraph","Properties":{"id":"20260601092744-0dgp6hj","updated":"20260601092744"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260601092811-nyeuz0t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092811-nyeuz0t","updated":"20260601092811"},"Children":[{"ID":"20260601092811-qzdfqxr","Type":"NodeParagraph","Properties":{"id":"20260601092811-qzdfqxr","updated":"20260601092814"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260601092823-9gu5nyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092823-9gu5nyb","updated":"20260601092823"},"Children":[{"ID":"20260601092823-j1ywg5b","Type":"NodeParagraph","Properties":{"id":"20260601092823-j1ywg5b","updated":"20260601092823"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260601092840-50bkego","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092840-50bkego","updated":"20260601092840"},"Children":[{"ID":"20260601092840-g8c38xu","Type":"NodeParagraph","Properties":{"id":"20260601092840-g8c38xu","updated":"20260601092843"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260601092854-w7s9o79","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092854-w7s9o79","updated":"20260601092854"},"Children":[{"ID":"20260601092854-g4r9318","Type":"NodeParagraph","Properties":{"id":"20260601092854-g4r9318","updated":"20260601092854"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260601092903-zbg3miz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092903-zbg3miz","updated":"20260601092903"},"Children":[{"ID":"20260601092903-5jdb4fp","Type":"NodeParagraph","Properties":{"id":"20260601092903-5jdb4fp","updated":"20260601092906"},"Children":[{"Type":"NodeText","Data":"凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260601092916-axw8b4o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092916-axw8b4o","updated":"20260601092916"},"Children":[{"ID":"20260601092916-n4fyyfg","Type":"NodeParagraph","Properties":{"id":"20260601092916-n4fyyfg","updated":"20260601092916"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260601092926-nreypnq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092926-nreypnq","updated":"20260601092926"},"Children":[{"ID":"20260601092926-ez1aggc","Type":"NodeParagraph","Properties":{"id":"20260601092926-ez1aggc","updated":"20260601092933"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260601092934-6ha68s0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092934-6ha68s0","updated":"20260601092934"},"Children":[{"ID":"20260601092934-yz6gzdo","Type":"NodeParagraph","Properties":{"id":"20260601092934-yz6gzdo","updated":"20260601092945"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶(wù)之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260601092958-mo51anc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601092958-mo51anc","updated":"20260601092958"},"Children":[{"ID":"20260601092958-x4z3xpa","Type":"NodeParagraph","Properties":{"id":"20260601092958-x4z3xpa","updated":"20260601092958"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260601093007-x96ys8y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093007-x96ys8y","updated":"20260601093007"},"Children":[{"ID":"20260601093007-juiijas","Type":"NodeParagraph","Properties":{"id":"20260601093007-juiijas","updated":"20260601093007"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260601093046-rbkb9ie","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093046-rbkb9ie","updated":"20260601093046"},"Children":[{"ID":"20260601093046-rb34p3w","Type":"NodeParagraph","Properties":{"id":"20260601093046-rb34p3w","updated":"20260601093050"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260601093051-7ysml5i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093051-7ysml5i","updated":"20260601093051"},"Children":[{"ID":"20260601093051-cved7fc","Type":"NodeParagraph","Properties":{"id":"20260601093051-cved7fc","updated":"20260601093107"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260601093119-4oh6oso","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093119-4oh6oso","updated":"20260601093119"},"Children":[{"ID":"20260601093119-loqqxta","Type":"NodeParagraph","Properties":{"id":"20260601093119-loqqxta","updated":"20260601093119"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260601093202-1l0cf0a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093202-1l0cf0a","updated":"20260601093202"},"Children":[{"ID":"20260601093202-gt3ecop","Type":"NodeParagraph","Properties":{"id":"20260601093202-gt3ecop","updated":"20260601093202"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260601093744-zs7omkj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093744-zs7omkj","updated":"20260601093744"},"Children":[{"ID":"20260601093744-jjz88s0","Type":"NodeParagraph","Properties":{"id":"20260601093744-jjz88s0","updated":"20260601093747"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260601093757-97yzady","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093757-97yzady","updated":"20260601093757"},"Children":[{"ID":"20260601093757-q8fosow","Type":"NodeParagraph","Properties":{"id":"20260601093757-q8fosow","updated":"20260601093759"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260601093815-s9yetct","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093815-s9yetct","updated":"20260601093815"},"Children":[{"ID":"20260601093815-5bnse2h","Type":"NodeParagraph","Properties":{"id":"20260601093815-5bnse2h","updated":"20260601093819"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260601093901-huwab12","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093901-huwab12","updated":"20260601093901"},"Children":[{"ID":"20260601093901-c3iikor","Type":"NodeParagraph","Properties":{"id":"20260601093901-c3iikor","updated":"20260601093904"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260601093922-52qut15","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601093922-52qut15","updated":"20260601093922"},"Children":[{"ID":"20260601093922-ap8sw9b","Type":"NodeParagraph","Properties":{"id":"20260601093922-ap8sw9b","updated":"20260601093925"},"Children":[{"Type":"NodeText","Data":"世界上最宽阔的是海洋，比海洋宽阔的是天空，比天空宽阔的是人的胸怀。"}]}]},{"ID":"20260601094028-s78prsq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094028-s78prsq","updated":"20260601094028"},"Children":[{"ID":"20260601094028-pm5b9dk","Type":"NodeParagraph","Properties":{"id":"20260601094028-pm5b9dk","updated":"20260601094035"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260601094141-mtxkssa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094141-mtxkssa","updated":"20260601094141"},"Children":[{"ID":"20260601094141-kvru23c","Type":"NodeParagraph","Properties":{"id":"20260601094141-kvru23c","updated":"20260601094144"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260601094200-3dywr40","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094200-3dywr40","updated":"20260601094200"},"Children":[{"ID":"20260601094200-oqibvky","Type":"NodeParagraph","Properties":{"id":"20260601094200-oqibvky","updated":"20260601094200"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260601094217-nfppjji","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094217-nfppjji","updated":"20260601094217"},"Children":[{"ID":"20260601094217-uszahtd","Type":"NodeParagraph","Properties":{"id":"20260601094217-uszahtd","updated":"20260601094219"},"Children":[{"Type":"NodeText","Data":"生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260601094252-q3zz5ov","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094252-q3zz5ov","updated":"20260601094252"},"Children":[{"ID":"20260601094252-ws6k38c","Type":"NodeParagraph","Properties":{"id":"20260601094252-ws6k38c","updated":"20260601094254"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260601094309-4grojxt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094309-4grojxt","updated":"20260601094309"},"Children":[{"ID":"20260601094309-b1hfsfw","Type":"NodeParagraph","Properties":{"id":"20260601094309-b1hfsfw","updated":"20260601094312"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260601094332-skdwg68","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094332-skdwg68","updated":"20260601094332"},"Children":[{"ID":"20260601094332-vea413s","Type":"NodeParagraph","Properties":{"id":"20260601094332-vea413s","updated":"20260601094338"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260601094359-8r0xi5y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094359-8r0xi5y","updated":"20260601094359"},"Children":[{"ID":"20260601094359-jz2gxo6","Type":"NodeParagraph","Properties":{"id":"20260601094359-jz2gxo6","updated":"20260601094401"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260601094411-io1cpcm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094411-io1cpcm","updated":"20260601094411"},"Children":[{"ID":"20260601094411-3xoskjz","Type":"NodeParagraph","Properties":{"id":"20260601094411-3xoskjz","updated":"20260601094413"},"Children":[{"Type":"NodeText","Data":"那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260601094424-tzlm6w8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094424-tzlm6w8","updated":"20260601094424"},"Children":[{"ID":"20260601094424-7jye7i5","Type":"NodeParagraph","Properties":{"id":"20260601094424-7jye7i5","updated":"20260601094424"},"Children":[{"Type":"NodeText","Data":"其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260601094437-lwfa7ni","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094437-lwfa7ni","updated":"20260601094437"},"Children":[{"ID":"20260601094437-eambx41","Type":"NodeParagraph","Properties":{"id":"20260601094437-eambx41","updated":"20260601094439"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260601094440-lu9gz5n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094440-lu9gz5n","updated":"20260601094440"},"Children":[{"ID":"20260601094440-lmvk1ck","Type":"NodeParagraph","Properties":{"id":"20260601094440-lmvk1ck","updated":"20260601094455"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260601094506-2rl0u3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094506-2rl0u3x","updated":"20260601094506"},"Children":[{"ID":"20260601094506-z9dfncl","Type":"NodeParagraph","Properties":{"id":"20260601094506-z9dfncl","updated":"20260601094925"},"Children":[{"Type":"NodeText","Data":"希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260601094942-cvx2cis","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601094942-cvx2cis","updated":"20260601094942"},"Children":[{"ID":"20260601094942-jatt8t6","Type":"NodeParagraph","Properties":{"id":"20260601094942-jatt8t6","updated":"20260601094944"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260601095000-n9vlpcx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095000-n9vlpcx","updated":"20260601095000"},"Children":[{"ID":"20260601095000-csr1lot","Type":"NodeParagraph","Properties":{"id":"20260601095000-csr1lot","updated":"20260601095002"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260601095016-3uzzfzj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095016-3uzzfzj","updated":"20260601095016"},"Children":[{"ID":"20260601095016-sk8t0ah","Type":"NodeParagraph","Properties":{"id":"20260601095016-sk8t0ah","updated":"20260601095016"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260601095027-u8qvymu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095027-u8qvymu","updated":"20260601095027"},"Children":[{"ID":"20260601095027-3ehbq9v","Type":"NodeParagraph","Properties":{"id":"20260601095027-3ehbq9v","updated":"20260601095028"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260601095040-l2an9cj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095040-l2an9cj","updated":"20260601095040"},"Children":[{"ID":"20260601095040-fqo175c","Type":"NodeParagraph","Properties":{"id":"20260601095040-fqo175c","updated":"20260601095041"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260601095108-sxg85z5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095108-sxg85z5","updated":"20260601095108"},"Children":[{"ID":"20260601095108-cdi908y","Type":"NodeParagraph","Properties":{"id":"20260601095108-cdi908y","updated":"20260601095125"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260601095140-ctitnpz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095140-ctitnpz","updated":"20260601095140"},"Children":[{"ID":"20260601095140-0ozz23v","Type":"NodeParagraph","Properties":{"id":"20260601095140-0ozz23v","updated":"20260601095146"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260601095147-p6yyu0g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095147-p6yyu0g","updated":"20260601095147"},"Children":[{"ID":"20260601095147-3oghtol","Type":"NodeParagraph","Properties":{"id":"20260601095147-3oghtol","updated":"20260601095205"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260601095222-rua9dbo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095222-rua9dbo","updated":"20260601095222"},"Children":[{"ID":"20260601095222-7eynfj8","Type":"NodeParagraph","Properties":{"id":"20260601095222-7eynfj8","updated":"20260601095222"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260601095234-hujs8ge","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095234-hujs8ge","updated":"20260601095234"},"Children":[{"ID":"20260601095234-zbad869","Type":"NodeParagraph","Properties":{"id":"20260601095234-zbad869","updated":"20260601095234"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260601095247-8lkk7qx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095247-8lkk7qx","updated":"20260601095247"},"Children":[{"ID":"20260601095247-56xyoen","Type":"NodeParagraph","Properties":{"id":"20260601095247-56xyoen","updated":"20260601095255"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260601095304-ivavqat","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095304-ivavqat","updated":"20260601095304"},"Children":[{"ID":"20260601095304-vlu76er","Type":"NodeParagraph","Properties":{"id":"20260601095304-vlu76er","updated":"20260601095307"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260601095308-ni9f6rr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095308-ni9f6rr","updated":"20260601095308"},"Children":[{"ID":"20260601095308-3is8h8a","Type":"NodeParagraph","Properties":{"id":"20260601095308-3is8h8a","updated":"20260601095328"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260601095329-qycclb6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095329-qycclb6","updated":"20260601095329"},"Children":[{"ID":"20260601095329-r6754eg","Type":"NodeParagraph","Properties":{"id":"20260601095329-r6754eg","updated":"20260601095344"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260601095345-mhkojet","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095345-mhkojet","updated":"20260601095345"},"Children":[{"ID":"20260601095345-uuo68qh","Type":"NodeParagraph","Properties":{"id":"20260601095345-uuo68qh","updated":"20260601095358"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260601095359-k7uuk0e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095359-k7uuk0e","updated":"20260601095359"},"Children":[{"ID":"20260601095359-bnamg43","Type":"NodeParagraph","Properties":{"id":"20260601095359-bnamg43","updated":"20260601095410"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260601095429-6r962c3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095429-6r962c3","updated":"20260601095429"},"Children":[{"ID":"20260601095429-p885bnx","Type":"NodeParagraph","Properties":{"id":"20260601095429-p885bnx","updated":"20260601095434"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260601095454-prqi722","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095454-prqi722","updated":"20260601095454"},"Children":[{"ID":"20260601095454-6o5grwg","Type":"NodeParagraph","Properties":{"id":"20260601095454-6o5grwg","updated":"20260601095458"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260601095532-t1riz01","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095532-t1riz01","updated":"20260601095532"},"Children":[{"ID":"20260601095532-kwylyxi","Type":"NodeParagraph","Properties":{"id":"20260601095532-kwylyxi","updated":"20260601095536"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260601095549-x8gqoas","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095549-x8gqoas","updated":"20260601095549"},"Children":[{"ID":"20260601095549-r77o6x6","Type":"NodeParagraph","Properties":{"id":"20260601095549-r77o6x6","updated":"20260601095551"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260601095600-ui829d0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095600-ui829d0","updated":"20260601095600"},"Children":[{"ID":"20260601095600-44ndvt8","Type":"NodeParagraph","Properties":{"id":"20260601095600-44ndvt8","updated":"20260601095603"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260601095949-7u8191n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601095949-7u8191n","updated":"20260601095949"},"Children":[{"ID":"20260601095949-np1op6a","Type":"NodeParagraph","Properties":{"id":"20260601095949-np1op6a","updated":"20260601095952"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260601100055-uy9q25c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100055-uy9q25c","updated":"20260601100055"},"Children":[{"ID":"20260601100055-6zb899h","Type":"NodeParagraph","Properties":{"id":"20260601100055-6zb899h","updated":"20260601100055"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260601100153-m28gqp3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100153-m28gqp3","updated":"20260601100153"},"Children":[{"ID":"20260601100153-cuj52jv","Type":"NodeParagraph","Properties":{"id":"20260601100153-cuj52jv","updated":"20260601100153"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260601100222-7ehqydw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100222-7ehqydw","updated":"20260601100222"},"Children":[{"ID":"20260601100222-w3xzwwo","Type":"NodeParagraph","Properties":{"id":"20260601100222-w3xzwwo","updated":"20260601100301"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260601100323-mppvxkw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100323-mppvxkw","updated":"20260601100323"},"Children":[{"ID":"20260601100323-c7br6jx","Type":"NodeParagraph","Properties":{"id":"20260601100323-c7br6jx","updated":"20260601100326"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260601100356-zhgo974","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100356-zhgo974","updated":"20260601100356"},"Children":[{"ID":"20260601100356-v4zpfg5","Type":"NodeParagraph","Properties":{"id":"20260601100356-v4zpfg5","updated":"20260601100357"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260601100413-i08zs2z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100413-i08zs2z","updated":"20260601100413"},"Children":[{"ID":"20260601100413-w7qk4ky","Type":"NodeParagraph","Properties":{"id":"20260601100413-w7qk4ky","updated":"20260601100413"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260601100432-mrrh7tp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100432-mrrh7tp","updated":"20260601100432"},"Children":[{"ID":"20260601100432-5kcqo11","Type":"NodeParagraph","Properties":{"id":"20260601100432-5kcqo11","updated":"20260601100432"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260601100518-1m8iglf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100518-1m8iglf","updated":"20260601100518"},"Children":[{"ID":"20260601100518-24mspk8","Type":"NodeParagraph","Properties":{"id":"20260601100518-24mspk8","updated":"20260601100518"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260601100535-q0rawt8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100535-q0rawt8","updated":"20260601100535"},"Children":[{"ID":"20260601100535-6affvbs","Type":"NodeParagraph","Properties":{"id":"20260601100535-6affvbs","updated":"20260601100537"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260601100551-9cfxta0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100551-9cfxta0","updated":"20260601100551"},"Children":[{"ID":"20260601100551-wy7aghx","Type":"NodeParagraph","Properties":{"id":"20260601100551-wy7aghx","updated":"20260601100554"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260601100633-wnyw6go","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100633-wnyw6go","updated":"20260601100633"},"Children":[{"ID":"20260601100633-2h0byco","Type":"NodeParagraph","Properties":{"id":"20260601100633-2h0byco","updated":"20260601100633"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260601100650-jqsmi4m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100650-jqsmi4m","updated":"20260601100650"},"Children":[{"ID":"20260601100650-k8i3ab5","Type":"NodeParagraph","Properties":{"id":"20260601100650-k8i3ab5","updated":"20260601100650"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260601100713-q0rbbn1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100713-q0rbbn1","updated":"20260601100713"},"Children":[{"ID":"20260601100713-dyva6bw","Type":"NodeParagraph","Properties":{"id":"20260601100713-dyva6bw","updated":"20260601100717"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260601100733-q2m8369","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100733-q2m8369","updated":"20260601100733"},"Children":[{"ID":"20260601100733-ul6erms","Type":"NodeParagraph","Properties":{"id":"20260601100733-ul6erms","updated":"20260601100736"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260601100737-evjzkju","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100737-evjzkju","updated":"20260601100737"},"Children":[{"ID":"20260601100737-9mbtbdn","Type":"NodeParagraph","Properties":{"id":"20260601100737-9mbtbdn","updated":"20260601100755"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260601100812-7d6yany","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100812-7d6yany","updated":"20260601100812"},"Children":[{"ID":"20260601100812-do52zri","Type":"NodeParagraph","Properties":{"id":"20260601100812-do52zri","updated":"20260601100812"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260601100828-hjdezld","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100828-hjdezld","updated":"20260601100828"},"Children":[{"ID":"20260601100828-lxt90ik","Type":"NodeParagraph","Properties":{"id":"20260601100828-lxt90ik","updated":"20260601100828"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260601100846-vvahesz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100846-vvahesz","updated":"20260601100846"},"Children":[{"ID":"20260601100846-sbbc6y3","Type":"NodeParagraph","Properties":{"id":"20260601100846-sbbc6y3","updated":"20260601100850"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260601100910-tvs47v8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100910-tvs47v8","updated":"20260601100910"},"Children":[{"ID":"20260601100910-l5qe21h","Type":"NodeParagraph","Properties":{"id":"20260601100910-l5qe21h","updated":"20260601100912"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260601100914-a2jwvw0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100914-a2jwvw0","updated":"20260601100914"},"Children":[{"ID":"20260601100914-sruzw0f","Type":"NodeParagraph","Properties":{"id":"20260601100914-sruzw0f","updated":"20260601100937"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260601100938-kdbfsaa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601100938-kdbfsaa","updated":"20260601100938"},"Children":[{"ID":"20260601100938-2u59c6w","Type":"NodeParagraph","Properties":{"id":"20260601100938-2u59c6w","updated":"20260601100956"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260601101013-0ualrz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101013-0ualrz2","updated":"20260601101013"},"Children":[{"ID":"20260601101013-lxz60ki","Type":"NodeParagraph","Properties":{"id":"20260601101013-lxz60ki","updated":"20260601101016"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260601101032-ydvx9fd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101032-ydvx9fd","updated":"20260601101032"},"Children":[{"ID":"20260601101032-wfqunrd","Type":"NodeParagraph","Properties":{"id":"20260601101032-wfqunrd","updated":"20260601101034"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260601101050-gdcuulh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101050-gdcuulh","updated":"20260601101050"},"Children":[{"ID":"20260601101050-tz6c2t5","Type":"NodeParagraph","Properties":{"id":"20260601101050-tz6c2t5","updated":"20260601101053"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260601101109-ttugnkh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101109-ttugnkh","updated":"20260601101109"},"Children":[{"ID":"20260601101109-x8uuuiq","Type":"NodeParagraph","Properties":{"id":"20260601101109-x8uuuiq","updated":"20260601101111"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260601101119-tr4tm3x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101119-tr4tm3x","updated":"20260601101119"},"Children":[{"ID":"20260601101119-hjknghe","Type":"NodeParagraph","Properties":{"id":"20260601101119-hjknghe","updated":"20260601101122"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260601101153-banc0fr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101153-banc0fr","updated":"20260601101153"},"Children":[{"ID":"20260601101153-c1q0zgd","Type":"NodeParagraph","Properties":{"id":"20260601101153-c1q0zgd","updated":"20260601101156"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260601101214-oupa4t8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101214-oupa4t8","updated":"20260601101214"},"Children":[{"ID":"20260601101214-zmkrgoi","Type":"NodeParagraph","Properties":{"id":"20260601101214-zmkrgoi","updated":"20260601101226"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260601101827-c13kvq1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101827-c13kvq1","updated":"20260601101827"},"Children":[{"ID":"20260601101827-6g0c13h","Type":"NodeParagraph","Properties":{"id":"20260601101827-6g0c13h","updated":"20260601101834"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260601101243-cwlt08s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101243-cwlt08s","updated":"20260601101243"},"Children":[{"ID":"20260601101243-nhtwlz1","Type":"NodeParagraph","Properties":{"id":"20260601101243-nhtwlz1","updated":"20260601101243"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260601101301-g4fn9od","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101301-g4fn9od","updated":"20260601101301"},"Children":[{"ID":"20260601101301-52an3as","Type":"NodeParagraph","Properties":{"id":"20260601101301-52an3as","updated":"20260601101306"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260601101325-csoxmdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101325-csoxmdt","updated":"20260601101325"},"Children":[{"ID":"20260601101325-ryvrhve","Type":"NodeParagraph","Properties":{"id":"20260601101325-ryvrhve","updated":"20260601101325"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260601101402-q1qxdsw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101402-q1qxdsw","updated":"20260601101402"},"Children":[{"ID":"20260601101402-y01okha","Type":"NodeParagraph","Properties":{"id":"20260601101402-y01okha","updated":"20260601101408"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260601101409-ik0t1ck","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101409-ik0t1ck","updated":"20260601101409"},"Children":[{"ID":"20260601101409-r5wk87z","Type":"NodeParagraph","Properties":{"id":"20260601101409-r5wk87z","updated":"20260601101425"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260601101442-79j0cay","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101442-79j0cay","updated":"20260601101442"},"Children":[{"ID":"20260601101442-3wow1wt","Type":"NodeParagraph","Properties":{"id":"20260601101442-3wow1wt","updated":"20260601101443"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260601101510-1glkbnv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101510-1glkbnv","updated":"20260601101510"},"Children":[{"ID":"20260601101510-9l6z7w2","Type":"NodeParagraph","Properties":{"id":"20260601101510-9l6z7w2","updated":"20260601101513"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260601101711-5bmexl4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101711-5bmexl4","updated":"20260601101711"},"Children":[{"ID":"20260601101711-ivj1ndp","Type":"NodeParagraph","Properties":{"id":"20260601101711-ivj1ndp","updated":"20260601101711"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260601101744-wvpkosd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101744-wvpkosd","updated":"20260601101744"},"Children":[{"ID":"20260601101744-a4mp81i","Type":"NodeParagraph","Properties":{"id":"20260601101744-a4mp81i","updated":"20260601101745"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260601101810-1swwzsq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101810-1swwzsq","updated":"20260601101810"},"Children":[{"ID":"20260601101810-skbfu6p","Type":"NodeParagraph","Properties":{"id":"20260601101810-skbfu6p","updated":"20260601101815"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260601101858-a2zewqs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101858-a2zewqs","updated":"20260601101858"},"Children":[{"ID":"20260601101858-o4onthc","Type":"NodeParagraph","Properties":{"id":"20260601101858-o4onthc","updated":"20260601101900"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260601101917-nk5291a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101917-nk5291a","updated":"20260601101917"},"Children":[{"ID":"20260601101917-jk2iwq8","Type":"NodeParagraph","Properties":{"id":"20260601101917-jk2iwq8","updated":"20260601101919"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260601101920-k9c1w3p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601101920-k9c1w3p","updated":"20260601101920"},"Children":[{"ID":"20260601101920-lsuljcx","Type":"NodeParagraph","Properties":{"id":"20260601101920-lsuljcx","updated":"20260601101937"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260601102002-2j3p8wu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102002-2j3p8wu","updated":"20260601102002"},"Children":[{"ID":"20260601102002-231skld","Type":"NodeParagraph","Properties":{"id":"20260601102002-231skld","updated":"20260601102005"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260601102006-eqzmykp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102006-eqzmykp","updated":"20260601102006"},"Children":[{"ID":"20260601102006-erz9toq","Type":"NodeParagraph","Properties":{"id":"20260601102006-erz9toq","updated":"20260601102021"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260601102033-k7x4x7g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102033-k7x4x7g","updated":"20260601102033"},"Children":[{"ID":"20260601102033-s9mjj6v","Type":"NodeParagraph","Properties":{"id":"20260601102033-s9mjj6v","updated":"20260601102035"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260601102105-jkw1hzh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102105-jkw1hzh","updated":"20260601102105"},"Children":[{"ID":"20260601102105-m1e1izo","Type":"NodeParagraph","Properties":{"id":"20260601102105-m1e1izo","updated":"20260601102107"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260601102122-7d8vbjg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102122-7d8vbjg","updated":"20260601102122"},"Children":[{"ID":"20260601102122-oqg3zsm","Type":"NodeParagraph","Properties":{"id":"20260601102122-oqg3zsm","updated":"20260601102124"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260601102125-54of55s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102125-54of55s","updated":"20260601102125"},"Children":[{"ID":"20260601102125-5954qh6","Type":"NodeParagraph","Properties":{"id":"20260601102125-5954qh6","updated":"20260601102255"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260601102257-mdo04m6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102257-mdo04m6","updated":"20260601102257"},"Children":[{"ID":"20260601102257-51byxb9","Type":"NodeParagraph","Properties":{"id":"20260601102257-51byxb9","updated":"20260601102341"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260601102412-ebnseg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102412-ebnseg6","updated":"20260601102412"},"Children":[{"ID":"20260601102412-igi9o6p","Type":"NodeParagraph","Properties":{"id":"20260601102412-igi9o6p","updated":"20260601102412"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260601102428-93jhpwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102428-93jhpwm","updated":"20260601102428"},"Children":[{"ID":"20260601102428-8qqws1u","Type":"NodeParagraph","Properties":{"id":"20260601102428-8qqws1u","updated":"20260601102428"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260601102504-fjfk9o9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102504-fjfk9o9","updated":"20260601102504"},"Children":[{"ID":"20260601102504-9l57x06","Type":"NodeParagraph","Properties":{"id":"20260601102504-9l57x06","updated":"20260601102504"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260601102527-3v0k151","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102527-3v0k151","updated":"20260601102527"},"Children":[{"ID":"20260601102527-5dh58nw","Type":"NodeParagraph","Properties":{"id":"20260601102527-5dh58nw","updated":"20260601102528"},"Children":[{"Type":"NodeText","Data":"不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260601102544-dpg4n37","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102544-dpg4n37","updated":"20260601102544"},"Children":[{"ID":"20260601102544-wtt468r","Type":"NodeParagraph","Properties":{"id":"20260601102544-wtt468r","updated":"20260601102548"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260601102603-5alnb5o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102603-5alnb5o","updated":"20260601102603"},"Children":[{"ID":"20260601102603-u7g39jc","Type":"NodeParagraph","Properties":{"id":"20260601102603-u7g39jc","updated":"20260601102605"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260601102620-21843ke","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102620-21843ke","updated":"20260601102620"},"Children":[{"ID":"20260601102620-593nlfg","Type":"NodeParagraph","Properties":{"id":"20260601102620-593nlfg","updated":"20260601102621"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260601102641-gcl57pp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102641-gcl57pp","updated":"20260601102641"},"Children":[{"ID":"20260601102641-rdilxws","Type":"NodeParagraph","Properties":{"id":"20260601102641-rdilxws","updated":"20260601102643"},"Children":[{"Type":"NodeText","Data":"敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260601102653-mleitdq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102653-mleitdq","updated":"20260601102653"},"Children":[{"ID":"20260601102653-kzu4ji7","Type":"NodeParagraph","Properties":{"id":"20260601102653-kzu4ji7","updated":"20260601102655"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260601102712-efxrf38","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102712-efxrf38","updated":"20260601102712"},"Children":[{"ID":"20260601102712-u3addrp","Type":"NodeParagraph","Properties":{"id":"20260601102712-u3addrp","updated":"20260601102723"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260601102724-do85y0j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102724-do85y0j","updated":"20260601102724"},"Children":[{"ID":"20260601102724-dwz7efb","Type":"NodeParagraph","Properties":{"id":"20260601102724-dwz7efb","updated":"20260601102741"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260601102911-rjqovyo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102911-rjqovyo","updated":"20260601102911"},"Children":[{"ID":"20260601102911-2ccx9u4","Type":"NodeParagraph","Properties":{"id":"20260601102911-2ccx9u4","updated":"20260601102913"},"Children":[{"Type":"NodeText","Data":"永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260601102942-l65nixu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102942-l65nixu","updated":"20260601102942"},"Children":[{"ID":"20260601102942-0vp0eky","Type":"NodeParagraph","Properties":{"id":"20260601102942-0vp0eky","updated":"20260601102944"},"Children":[{"Type":"NodeText","Data":"如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260601102959-gqx5jr0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601102959-gqx5jr0","updated":"20260601102959"},"Children":[{"ID":"20260601102959-g4h9rbf","Type":"NodeParagraph","Properties":{"id":"20260601102959-g4h9rbf","updated":"20260601103000"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260601103021-mu7612o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103021-mu7612o","updated":"20260601103021"},"Children":[{"ID":"20260601103021-kgud0bg","Type":"NodeParagraph","Properties":{"id":"20260601103021-kgud0bg","updated":"20260601103023"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260601103111-c7jersn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103111-c7jersn","updated":"20260601103111"},"Children":[{"ID":"20260601103111-xdx844m","Type":"NodeParagraph","Properties":{"id":"20260601103111-xdx844m","updated":"20260601103114"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260601103124-dgkpf3j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103124-dgkpf3j","updated":"20260601103130"},"Children":[{"ID":"20260601103124-gabw6th","Type":"NodeParagraph","Properties":{"id":"20260601103124-gabw6th","updated":"20260601103130"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260601103226-an7ouqb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103226-an7ouqb","updated":"20260601103226"},"Children":[{"ID":"20260601103226-9y2cemc","Type":"NodeParagraph","Properties":{"id":"20260601103226-9y2cemc","updated":"20260601103229"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260601103244-7thzjky","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103244-7thzjky","updated":"20260601103244"},"Children":[{"ID":"20260601103244-srpvpm6","Type":"NodeParagraph","Properties":{"id":"20260601103244-srpvpm6","updated":"20260601103246"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260601103302-uiirzgn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103302-uiirzgn","updated":"20260601103302"},"Children":[{"ID":"20260601103302-bc5am4r","Type":"NodeParagraph","Properties":{"id":"20260601103302-bc5am4r","updated":"20260601103303"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260601103314-cgwbptu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103314-cgwbptu","updated":"20260601103314"},"Children":[{"ID":"20260601103314-2rzfcmn","Type":"NodeParagraph","Properties":{"id":"20260601103314-2rzfcmn","updated":"20260601103316"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260601103325-dkumls0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103325-dkumls0","updated":"20260601103325"},"Children":[{"ID":"20260601103325-8hk4vg8","Type":"NodeParagraph","Properties":{"id":"20260601103325-8hk4vg8","updated":"20260601103327"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260601103351-5xcxgik","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103351-5xcxgik","updated":"20260601103351"},"Children":[{"ID":"20260601103351-kb3n2l8","Type":"NodeParagraph","Properties":{"id":"20260601103351-kb3n2l8","updated":"20260601103351"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260601103403-c9dcb4n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103403-c9dcb4n","updated":"20260601103403"},"Children":[{"ID":"20260601103403-mtpbjja","Type":"NodeParagraph","Properties":{"id":"20260601103403-mtpbjja","updated":"20260601103408"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260601103427-me1j770","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103427-me1j770","updated":"20260601103427"},"Children":[{"ID":"20260601103427-383teif","Type":"NodeParagraph","Properties":{"id":"20260601103427-383teif","updated":"20260601103428"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260601103435-0tilt3f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103435-0tilt3f","updated":"20260601103435"},"Children":[{"ID":"20260601103435-2qkmowt","Type":"NodeParagraph","Properties":{"id":"20260601103435-2qkmowt","updated":"20260601103437"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260601103508-d9ah4ez","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103508-d9ah4ez","updated":"20260601103508"},"Children":[{"ID":"20260601103508-wn0fcks","Type":"NodeParagraph","Properties":{"id":"20260601103508-wn0fcks","updated":"20260601103510"},"Children":[{"Type":"NodeText","Data":"构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260601103527-p9ebwjm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103527-p9ebwjm","updated":"20260601103527"},"Children":[{"ID":"20260601103527-2if90qf","Type":"NodeParagraph","Properties":{"id":"20260601103527-2if90qf","updated":"20260601103529"},"Children":[{"Type":"NodeText","Data":"任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260601103542-5bzvv4a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103542-5bzvv4a","updated":"20260601103542"},"Children":[{"ID":"20260601103542-cqb9o8e","Type":"NodeParagraph","Properties":{"id":"20260601103542-cqb9o8e","updated":"20260601103544"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260601103559-b3v4fje","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103559-b3v4fje","updated":"20260601103559"},"Children":[{"ID":"20260601103559-w27luph","Type":"NodeParagraph","Properties":{"id":"20260601103559-w27luph","updated":"20260601103606"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260601103623-fo7e3zi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103623-fo7e3zi","updated":"20260601103623"},"Children":[{"ID":"20260601103623-yqhfvze","Type":"NodeParagraph","Properties":{"id":"20260601103623-yqhfvze","updated":"20260601103625"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260601103638-zsos6l7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103638-zsos6l7","updated":"20260601103638"},"Children":[{"ID":"20260601103638-97cu7xv","Type":"NodeParagraph","Properties":{"id":"20260601103638-97cu7xv","updated":"20260601103641"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260601103659-7hsr6bu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103659-7hsr6bu","updated":"20260601103659"},"Children":[{"ID":"20260601103659-4wp3yrz","Type":"NodeParagraph","Properties":{"id":"20260601103659-4wp3yrz","updated":"20260601103701"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260601103718-4nyxpf4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103718-4nyxpf4","updated":"20260601103718"},"Children":[{"ID":"20260601103718-0krxdvo","Type":"NodeParagraph","Properties":{"id":"20260601103718-0krxdvo","updated":"20260601103721"},"Children":[{"Type":"NodeText","Data":"凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260601103734-z6lgkcb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103734-z6lgkcb","updated":"20260601103734"},"Children":[{"ID":"20260601103734-7jrzq4n","Type":"NodeParagraph","Properties":{"id":"20260601103734-7jrzq4n","updated":"20260601103735"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260601103755-okdeu63","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103755-okdeu63","updated":"20260601103755"},"Children":[{"ID":"20260601103755-14nsoot","Type":"NodeParagraph","Properties":{"id":"20260601103755-14nsoot","updated":"20260601103755"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260601103821-2yko01a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103821-2yko01a","updated":"20260601103821"},"Children":[{"ID":"20260601103821-yu2wh18","Type":"NodeParagraph","Properties":{"id":"20260601103821-yu2wh18","updated":"20260601103821"},"Children":[{"Type":"NodeText","Data":"一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260601103841-d3chumz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103841-d3chumz","updated":"20260601103841"},"Children":[{"ID":"20260601103841-7iocv1l","Type":"NodeParagraph","Properties":{"id":"20260601103841-7iocv1l","updated":"20260601103849"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260601103933-phn4plz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103933-phn4plz","updated":"20260601103933"},"Children":[{"ID":"20260601103933-bfagq9t","Type":"NodeParagraph","Properties":{"id":"20260601103933-bfagq9t","updated":"20260601103933"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260601103943-3ijienp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103943-3ijienp","updated":"20260601103943"},"Children":[{"ID":"20260601103943-e7pvhx5","Type":"NodeParagraph","Properties":{"id":"20260601103943-e7pvhx5","updated":"20260601103946"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260601103958-ull7d29","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601103958-ull7d29","updated":"20260601103958"},"Children":[{"ID":"20260601103958-zjed85q","Type":"NodeParagraph","Properties":{"id":"20260601103958-zjed85q","updated":"20260601103958"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260601104033-b2lauwc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104033-b2lauwc","updated":"20260601104033"},"Children":[{"ID":"20260601104033-a43e2vt","Type":"NodeParagraph","Properties":{"id":"20260601104033-a43e2vt","updated":"20260601104033"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260601104136-kunfrun","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104136-kunfrun","updated":"20260601104136"},"Children":[{"ID":"20260601104136-oynklmx","Type":"NodeParagraph","Properties":{"id":"20260601104136-oynklmx","updated":"20260601104139"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260601104155-53c1zvj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104155-53c1zvj","updated":"20260601104155"},"Children":[{"ID":"20260601104155-govydu4","Type":"NodeParagraph","Properties":{"id":"20260601104155-govydu4","updated":"20260601104157"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260601104209-o9wg2mw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104209-o9wg2mw","updated":"20260601104209"},"Children":[{"ID":"20260601104209-i2h9xy2","Type":"NodeParagraph","Properties":{"id":"20260601104209-i2h9xy2","updated":"20260601104212"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260601104228-c9i3ebu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104228-c9i3ebu","updated":"20260601104228"},"Children":[{"ID":"20260601104228-dfofq94","Type":"NodeParagraph","Properties":{"id":"20260601104228-dfofq94","updated":"20260601104228"},"Children":[{"Type":"NodeText","Data":"我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260601104248-leczdhr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104248-leczdhr","updated":"20260601104248"},"Children":[{"ID":"20260601104248-eqfrfdr","Type":"NodeParagraph","Properties":{"id":"20260601104248-eqfrfdr","updated":"20260601104248"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260601104308-cms2dsj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104308-cms2dsj","updated":"20260601104308"},"Children":[{"ID":"20260601104308-7sw879x","Type":"NodeParagraph","Properties":{"id":"20260601104308-7sw879x","updated":"20260601104312"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260601104330-22r69z7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104330-22r69z7","updated":"20260601104330"},"Children":[{"ID":"20260601104330-7ty79tm","Type":"NodeParagraph","Properties":{"id":"20260601104330-7ty79tm","updated":"20260601104336"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260601104348-72b2rfp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104348-72b2rfp","updated":"20260601104348"},"Children":[{"ID":"20260601104348-punfsqt","Type":"NodeParagraph","Properties":{"id":"20260601104348-punfsqt","updated":"20260601104348"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260601104413-8v3a6nr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104413-8v3a6nr","updated":"20260601104413"},"Children":[{"ID":"20260601104413-zg6kted","Type":"NodeParagraph","Properties":{"id":"20260601104413-zg6kted","updated":"20260601104414"},"Children":[{"Type":"NodeText","Data":"这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260601104445-qknjlk6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104445-qknjlk6","updated":"20260601104445"},"Children":[{"ID":"20260601104445-vhwe2a8","Type":"NodeParagraph","Properties":{"id":"20260601104445-vhwe2a8","updated":"20260601104448"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260601104449-23skxry","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104449-23skxry","updated":"20260601104449"},"Children":[{"ID":"20260601104449-c5etdor","Type":"NodeParagraph","Properties":{"id":"20260601104449-c5etdor","updated":"20260601104457"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260601104511-shh7uom","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104511-shh7uom","updated":"20260601104511"},"Children":[{"ID":"20260601104511-d807gp8","Type":"NodeParagraph","Properties":{"id":"20260601104511-d807gp8","updated":"20260601104514"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260601104515-o3mhb52","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104515-o3mhb52","updated":"20260601104515"},"Children":[{"ID":"20260601104515-31xs65t","Type":"NodeParagraph","Properties":{"id":"20260601104515-31xs65t","updated":"20260601104533"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260601104547-e8znx2x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104547-e8znx2x","updated":"20260601104547"},"Children":[{"ID":"20260601104547-f6nivww","Type":"NodeParagraph","Properties":{"id":"20260601104547-f6nivww","updated":"20260601104549"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260601104611-zp1kims","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104611-zp1kims","updated":"20260601104611"},"Children":[{"ID":"20260601104611-6fweyv9","Type":"NodeParagraph","Properties":{"id":"20260601104611-6fweyv9","updated":"20260601104640"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260601104651-q18pkog","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104651-q18pkog","updated":"20260601104651"},"Children":[{"ID":"20260601104651-ta25g2j","Type":"NodeParagraph","Properties":{"id":"20260601104651-ta25g2j","updated":"20260601104651"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260601104706-tvmsf18","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104706-tvmsf18","updated":"20260601104706"},"Children":[{"ID":"20260601104706-sf22tii","Type":"NodeParagraph","Properties":{"id":"20260601104706-sf22tii","updated":"20260601104731"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260601104756-ztdv5w6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104756-ztdv5w6","updated":"20260601104756"},"Children":[{"ID":"20260601104756-tglqr3d","Type":"NodeParagraph","Properties":{"id":"20260601104756-tglqr3d","updated":"20260601104801"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260601104818-eo5chmj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104818-eo5chmj","updated":"20260601104818"},"Children":[{"ID":"20260601104818-w6p5pv7","Type":"NodeParagraph","Properties":{"id":"20260601104818-w6p5pv7","updated":"20260601104820"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260601104822-te4qe2f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104822-te4qe2f","updated":"20260601104822"},"Children":[{"ID":"20260601104822-9nlgw5q","Type":"NodeParagraph","Properties":{"id":"20260601104822-9nlgw5q","updated":"20260601104836"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260601104852-1u453t7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104852-1u453t7","updated":"20260601104852"},"Children":[{"ID":"20260601104852-5joa7er","Type":"NodeParagraph","Properties":{"id":"20260601104852-5joa7er","updated":"20260601104853"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260601104935-yd6a2fu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104935-yd6a2fu","updated":"20260601104935"},"Children":[{"ID":"20260601104935-5ic92wf","Type":"NodeParagraph","Properties":{"id":"20260601104935-5ic92wf","updated":"20260601104938"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260601104939-qacvaug","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601104939-qacvaug","updated":"20260601104939"},"Children":[{"ID":"20260601104939-n4cr5nm","Type":"NodeParagraph","Properties":{"id":"20260601104939-n4cr5nm","updated":"20260601105948"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260601105054-h5gkz8h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105054-h5gkz8h","updated":"20260601105054"},"Children":[{"ID":"20260601105054-jj1tv7o","Type":"NodeParagraph","Properties":{"id":"20260601105054-jj1tv7o","updated":"20260601105054"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260601105212-shvd6wh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105212-shvd6wh","updated":"20260601105212"},"Children":[{"ID":"20260601105212-ex7lpjf","Type":"NodeParagraph","Properties":{"id":"20260601105212-ex7lpjf","updated":"20260601105215"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260601105216-r5ksrth","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105216-r5ksrth","updated":"20260601105216"},"Children":[{"ID":"20260601105216-o22nulu","Type":"NodeParagraph","Properties":{"id":"20260601105216-o22nulu","updated":"20260601105234"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260601105255-t95rwdu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105255-t95rwdu","updated":"20260601105255"},"Children":[{"ID":"20260601105255-4ngyq85","Type":"NodeParagraph","Properties":{"id":"20260601105255-4ngyq85","updated":"20260601105258"},"Children":[{"Type":"NodeText","Data":"未来不足惧，过往不须泣。"}]}]},{"ID":"20260601105350-7pgxaqy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105350-7pgxaqy","updated":"20260601105350"},"Children":[{"ID":"20260601105350-aj3e0de","Type":"NodeParagraph","Properties":{"id":"20260601105350-aj3e0de","updated":"20260601105353"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260601105418-pmlv8dy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105418-pmlv8dy","updated":"20260601105418"},"Children":[{"ID":"20260601105418-rkd05e2","Type":"NodeParagraph","Properties":{"id":"20260601105418-rkd05e2","updated":"20260601105421"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260601105529-j88ss58","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105529-j88ss58","updated":"20260601105529"},"Children":[{"ID":"20260601105529-1teknaq","Type":"NodeParagraph","Properties":{"id":"20260601105529-1teknaq","updated":"20260601105532"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260601105638-arbk70k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105638-arbk70k","updated":"20260601105638"},"Children":[{"ID":"20260601105638-n39frl4","Type":"NodeParagraph","Properties":{"id":"20260601105638-n39frl4","updated":"20260601105639"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260601105747-h3tr9ud","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105747-h3tr9ud","updated":"20260601105747"},"Children":[{"ID":"20260601105747-2uxvn67","Type":"NodeParagraph","Properties":{"id":"20260601105747-2uxvn67","updated":"20260601105749"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260601105834-rnce05d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105834-rnce05d","updated":"20260601105834"},"Children":[{"ID":"20260601105834-5y46fz6","Type":"NodeParagraph","Properties":{"id":"20260601105834-5y46fz6","updated":"20260601105836"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260601105837-9aomdi0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105837-9aomdi0","updated":"20260601105837"},"Children":[{"ID":"20260601105837-q3q0960","Type":"NodeParagraph","Properties":{"id":"20260601105837-q3q0960","updated":"20260601105907"},"Children":[{"Type":"NodeText","Data":"爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260601105908-i4vbr9p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601105908-i4vbr9p","updated":"20260601105908"},"Children":[{"ID":"20260601105908-gmis96i","Type":"NodeParagraph","Properties":{"id":"20260601105908-gmis96i","updated":"20260601105927"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260601110009-p9gptwo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110009-p9gptwo","updated":"20260601110009"},"Children":[{"ID":"20260601110009-wwh6wj7","Type":"NodeParagraph","Properties":{"id":"20260601110009-wwh6wj7","updated":"20260601110011"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260601110013-xjc2dnh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110013-xjc2dnh","updated":"20260601110013"},"Children":[{"ID":"20260601110013-bpoto9e","Type":"NodeParagraph","Properties":{"id":"20260601110013-bpoto9e","updated":"20260601110034"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260601110035-px1qvyb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110035-px1qvyb","updated":"20260601110035"},"Children":[{"ID":"20260601110035-1ss3xoz","Type":"NodeParagraph","Properties":{"id":"20260601110035-1ss3xoz","updated":"20260601110057"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260601110117-4ch7n66","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110117-4ch7n66","updated":"20260601110117"},"Children":[{"ID":"20260601110117-9o0pqsd","Type":"NodeParagraph","Properties":{"id":"20260601110117-9o0pqsd","updated":"20260601110117"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260601110134-mkstjr7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110134-mkstjr7","updated":"20260601110134"},"Children":[{"ID":"20260601110134-1ci9pcy","Type":"NodeParagraph","Properties":{"id":"20260601110134-1ci9pcy","updated":"20260601110134"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260601110135-81fb8dr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110135-81fb8dr","updated":"20260601110135"},"Children":[{"ID":"20260601110135-v2cw50w","Type":"NodeParagraph","Properties":{"id":"20260601110135-v2cw50w","updated":"20260601110202"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260601110228-d6tjg7w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110228-d6tjg7w","updated":"20260601110228"},"Children":[{"ID":"20260601110228-u2j6ho5","Type":"NodeParagraph","Properties":{"id":"20260601110228-u2j6ho5","updated":"20260601110230"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260601110351-itowmd9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110351-itowmd9","updated":"20260601110351"},"Children":[{"ID":"20260601110351-syx94zu","Type":"NodeParagraph","Properties":{"id":"20260601110351-syx94zu","updated":"20260601110352"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260601110430-r860x1d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110430-r860x1d","updated":"20260601110430"},"Children":[{"ID":"20260601110430-axyeom0","Type":"NodeParagraph","Properties":{"id":"20260601110430-axyeom0","updated":"20260601110430"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260601110449-h3hhdwv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110449-h3hhdwv","updated":"20260601110449"},"Children":[{"ID":"20260601110449-mapx3it","Type":"NodeParagraph","Properties":{"id":"20260601110449-mapx3it","updated":"20260601110453"},"Children":[{"Type":"NodeText","Data":"我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260601110454-4smip85","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110454-4smip85","updated":"20260601110454"},"Children":[{"ID":"20260601110454-1120znk","Type":"NodeParagraph","Properties":{"id":"20260601110454-1120znk","updated":"20260601110525"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260601110547-m04tlnt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110547-m04tlnt","updated":"20260601110547"},"Children":[{"ID":"20260601110547-567rekh","Type":"NodeParagraph","Properties":{"id":"20260601110547-567rekh","updated":"20260601110547"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260601110613-zzxra5a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110613-zzxra5a","updated":"20260601110613"},"Children":[{"ID":"20260601110613-68w8foj","Type":"NodeParagraph","Properties":{"id":"20260601110613-68w8foj","updated":"20260601110613"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260601110633-t7l9ei3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110633-t7l9ei3","updated":"20260601110633"},"Children":[{"ID":"20260601110633-bsndotn","Type":"NodeParagraph","Properties":{"id":"20260601110633-bsndotn","updated":"20260601110635"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260601110647-lhdo183","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110647-lhdo183","updated":"20260601110647"},"Children":[{"ID":"20260601110647-2cwgmg8","Type":"NodeParagraph","Properties":{"id":"20260601110647-2cwgmg8","updated":"20260601110652"},"Children":[{"Type":"NodeText","Data":"果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260601110654-dwmqyw0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110654-dwmqyw0","updated":"20260601110654"},"Children":[{"ID":"20260601110654-r1jdjo2","Type":"NodeParagraph","Properties":{"id":"20260601110654-r1jdjo2","updated":"20260601110733"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260601110734-ymdk1t6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110734-ymdk1t6","updated":"20260601110734"},"Children":[{"ID":"20260601110734-6zkhqxv","Type":"NodeParagraph","Properties":{"id":"20260601110734-6zkhqxv","updated":"20260601110747"},"Children":[{"Type":"NodeText","Data":"做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260601110748-en362at","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110748-en362at","updated":"20260601110748"},"Children":[{"ID":"20260601110748-szzbsso","Type":"NodeParagraph","Properties":{"id":"20260601110748-szzbsso","updated":"20260601110806"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260601110807-mvb2vro","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110807-mvb2vro","updated":"20260601110807"},"Children":[{"ID":"20260601110807-f3lb0ni","Type":"NodeParagraph","Properties":{"id":"20260601110807-f3lb0ni","updated":"20260601110820"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260601110847-157alim","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110847-157alim","updated":"20260601110847"},"Children":[{"ID":"20260601110847-s9z5rah","Type":"NodeParagraph","Properties":{"id":"20260601110847-s9z5rah","updated":"20260601110849"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260601110859-nlza882","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110859-nlza882","updated":"20260601110859"},"Children":[{"ID":"20260601110859-vtwg4w1","Type":"NodeParagraph","Properties":{"id":"20260601110859-vtwg4w1","updated":"20260601110902"},"Children":[{"Type":"NodeText","Data":"才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260601110924-du64skd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601110924-du64skd","updated":"20260601110924"},"Children":[{"ID":"20260601110924-02f9ybs","Type":"NodeParagraph","Properties":{"id":"20260601110924-02f9ybs","updated":"20260601110928"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260601111017-yxf94me","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111017-yxf94me","updated":"20260601111017"},"Children":[{"ID":"20260601111017-hq89zks","Type":"NodeParagraph","Properties":{"id":"20260601111017-hq89zks","updated":"20260601111017"},"Children":[{"Type":"NodeText","Data":"一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260601111207-wev1iqs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111207-wev1iqs","updated":"20260601111207"},"Children":[{"ID":"20260601111207-vacto9e","Type":"NodeParagraph","Properties":{"id":"20260601111207-vacto9e","updated":"20260601111207"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260601111259-va9ul57","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111259-va9ul57","updated":"20260601111259"},"Children":[{"ID":"20260601111259-neae5cx","Type":"NodeParagraph","Properties":{"id":"20260601111259-neae5cx","updated":"20260601111300"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260601111312-40gppyr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111312-40gppyr","updated":"20260601111312"},"Children":[{"ID":"20260601111312-6w8t0ii","Type":"NodeParagraph","Properties":{"id":"20260601111312-6w8t0ii","updated":"20260601111315"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260601111338-krm4uz5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111338-krm4uz5","updated":"20260601111338"},"Children":[{"ID":"20260601111338-xhyb4zy","Type":"NodeParagraph","Properties":{"id":"20260601111338-xhyb4zy","updated":"20260601111341"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260601111416-4ghy7r1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111416-4ghy7r1","updated":"20260601111416"},"Children":[{"ID":"20260601111416-o5is1gd","Type":"NodeParagraph","Properties":{"id":"20260601111416-o5is1gd","updated":"20260601111419"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260601111434-haz90tr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111434-haz90tr","updated":"20260601111434"},"Children":[{"ID":"20260601111434-60kbfah","Type":"NodeParagraph","Properties":{"id":"20260601111434-60kbfah","updated":"20260601111436"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260601111544-1vtzifn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111544-1vtzifn","updated":"20260601111544"},"Children":[{"ID":"20260601111544-h1rxihq","Type":"NodeParagraph","Properties":{"id":"20260601111544-h1rxihq","updated":"20260601111607"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260601111625-9j2ye13","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111625-9j2ye13","updated":"20260601111625"},"Children":[{"ID":"20260601111625-huhw6vj","Type":"NodeParagraph","Properties":{"id":"20260601111625-huhw6vj","updated":"20260601111630"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260601111649-uzym0al","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111649-uzym0al","updated":"20260601111649"},"Children":[{"ID":"20260601111649-gjs4dzq","Type":"NodeParagraph","Properties":{"id":"20260601111649-gjs4dzq","updated":"20260601111652"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260601111715-5jwyvzr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111715-5jwyvzr","updated":"20260601111715"},"Children":[{"ID":"20260601111715-ql1s22u","Type":"NodeParagraph","Properties":{"id":"20260601111715-ql1s22u","updated":"20260601111721"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260601111729-r2r2tji","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111729-r2r2tji","updated":"20260601111729"},"Children":[{"ID":"20260601111729-6q6hvi7","Type":"NodeParagraph","Properties":{"id":"20260601111729-6q6hvi7","updated":"20260601111731"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260601111755-e4hn49s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111755-e4hn49s","updated":"20260601111755"},"Children":[{"ID":"20260601111755-zpnet69","Type":"NodeParagraph","Properties":{"id":"20260601111755-zpnet69","updated":"20260601111758"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260601111814-0cgks6z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111814-0cgks6z","updated":"20260601121437"},"Children":[{"ID":"20260601111814-1r2h9zd","Type":"NodeParagraph","Properties":{"id":"20260601111814-1r2h9zd","updated":"20260601111817"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260601111818-mme8gzd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111818-mme8gzd","updated":"20260601111818"},"Children":[{"ID":"20260601111818-oad3qyp","Type":"NodeParagraph","Properties":{"id":"20260601111818-oad3qyp","updated":"20260601111907"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260601111951-sr7vcxn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601111951-sr7vcxn","updated":"20260601111951"},"Children":[{"ID":"20260601111951-m49w775","Type":"NodeParagraph","Properties":{"id":"20260601111951-m49w775","updated":"20260601111954"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260601112013-s2s08ko","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112013-s2s08ko","updated":"20260601112013"},"Children":[{"ID":"20260601112013-7r9xuw7","Type":"NodeParagraph","Properties":{"id":"20260601112013-7r9xuw7","updated":"20260601112016"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260601112051-6ivdwd7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112051-6ivdwd7","updated":"20260601112051"},"Children":[{"ID":"20260601112051-uimd7yw","Type":"NodeParagraph","Properties":{"id":"20260601112051-uimd7yw","updated":"20260601112051"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260601112113-gwuq7z0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112113-gwuq7z0","updated":"20260601112113"},"Children":[{"ID":"20260601112113-0bfvmad","Type":"NodeParagraph","Properties":{"id":"20260601112113-0bfvmad","updated":"20260601112113"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260601112223-2kzytmw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112223-2kzytmw","updated":"20260601112223"},"Children":[{"ID":"20260601112223-ojuhkti","Type":"NodeParagraph","Properties":{"id":"20260601112223-ojuhkti","updated":"20260601112223"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260601112311-26fl8j3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112311-26fl8j3","updated":"20260601112311"},"Children":[{"ID":"20260601112311-3407nyg","Type":"NodeParagraph","Properties":{"id":"20260601112311-3407nyg","updated":"20260601112311"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260601112319-750r2eo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112319-750r2eo","updated":"20260601112319"},"Children":[{"ID":"20260601112319-fkhuags","Type":"NodeParagraph","Properties":{"id":"20260601112319-fkhuags","updated":"20260601112338"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260601112417-39pq65v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112417-39pq65v","updated":"20260601112417"},"Children":[{"ID":"20260601112417-tvy7myj","Type":"NodeParagraph","Properties":{"id":"20260601112417-tvy7myj","updated":"20260601112420"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260601112606-f81oblc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112606-f81oblc","updated":"20260601112606"},"Children":[{"ID":"20260601112606-mwwh4mn","Type":"NodeParagraph","Properties":{"id":"20260601112606-mwwh4mn","updated":"20260601112608"},"Children":[{"Type":"NodeText","Data":"与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260601112704-67ziv51","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112704-67ziv51","updated":"20260601112704"},"Children":[{"ID":"20260601112704-mo3jz46","Type":"NodeParagraph","Properties":{"id":"20260601112704-mo3jz46","updated":"20260601112707"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260601112725-r8dli7b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112725-r8dli7b","updated":"20260601112725"},"Children":[{"ID":"20260601112725-1rpdgg3","Type":"NodeParagraph","Properties":{"id":"20260601112725-1rpdgg3","updated":"20260601112734"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260601112814-jdr0brf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112814-jdr0brf","updated":"20260601112814"},"Children":[{"ID":"20260601112814-5og17re","Type":"NodeParagraph","Properties":{"id":"20260601112814-5og17re","updated":"20260601112817"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260601124904-qhggzem","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124904-qhggzem","updated":"20260601124904"},"Children":[{"ID":"20260601124904-hyf7ali","Type":"NodeParagraph","Properties":{"id":"20260601124904-hyf7ali","updated":"20260601124907"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260601112848-28q5w8d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601112848-28q5w8d","updated":"20260601112851"},"Children":[{"ID":"20260601112848-je6lk4p","Type":"NodeParagraph","Properties":{"id":"20260601112848-je6lk4p","updated":"20260601112851"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260601124946-fjjd9m9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124946-fjjd9m9","updated":"20260601124946"},"Children":[{"ID":"20260601124946-5tm4n7e","Type":"NodeParagraph","Properties":{"id":"20260601124946-5tm4n7e","updated":"20260601124954"},"Children":[{"Type":"NodeText","Data":"昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260601121809-41y6vtg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601121809-41y6vtg","updated":"20260601121809"},"Children":[{"ID":"20260601121809-0ctffgs","Type":"NodeParagraph","Properties":{"id":"20260601121809-0ctffgs","updated":"20260601121820"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260601121845-iykum1j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601121845-iykum1j","updated":"20260601121853"},"Children":[{"ID":"20260601121845-bswttp4","Type":"NodeParagraph","Properties":{"id":"20260601121845-bswttp4","updated":"20260601121853"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260601124353-eh59jvr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124353-eh59jvr","updated":"20260601124353"},"Children":[{"ID":"20260601124353-ujoxwop","Type":"NodeParagraph","Properties":{"id":"20260601124353-ujoxwop","updated":"20260601124353"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260601124706-7yym1fn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124706-7yym1fn","updated":"20260601124706"},"Children":[{"ID":"20260601124706-z7gbgz3","Type":"NodeParagraph","Properties":{"id":"20260601124706-z7gbgz3","updated":"20260601124706"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260601124716-atvu8ge","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124716-atvu8ge","updated":"20260601124716"},"Children":[{"ID":"20260601124716-4xbgo7a","Type":"NodeParagraph","Properties":{"id":"20260601124716-4xbgo7a","updated":"20260601124717"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260601124821-zlpg08q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124821-zlpg08q","updated":"20260601124821"},"Children":[{"ID":"20260601124821-o5lisl6","Type":"NodeParagraph","Properties":{"id":"20260601124821-o5lisl6","updated":"20260601124822"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260601124832-bw5l4iq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124832-bw5l4iq","updated":"20260601124832"},"Children":[{"ID":"20260601124832-jmfi3y4","Type":"NodeParagraph","Properties":{"id":"20260601124832-jmfi3y4","updated":"20260601124832"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260601124434-zprfsgg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124434-zprfsgg","updated":"20260601124434"},"Children":[{"ID":"20260601124434-vt9twvh","Type":"NodeParagraph","Properties":{"id":"20260601124434-vt9twvh","updated":"20260601124434"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260601124748-4r0f69c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124748-4r0f69c","updated":"20260601124748"},"Children":[{"ID":"20260601124748-q1d1o13","Type":"NodeParagraph","Properties":{"id":"20260601124748-q1d1o13","updated":"20260601124748"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260601125013-wbyukam","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125013-wbyukam","updated":"20260601125013"},"Children":[{"ID":"20260601125013-thy7goq","Type":"NodeParagraph","Properties":{"id":"20260601125013-thy7goq","updated":"20260601125027"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260601124920-0wilgum","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124920-0wilgum","updated":"20260601124920"},"Children":[{"ID":"20260601124920-g3bqfzp","Type":"NodeParagraph","Properties":{"id":"20260601124920-g3bqfzp","updated":"20260601124920"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260601125039-mbrqv10","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125039-mbrqv10","updated":"20260601125039"},"Children":[{"ID":"20260601125039-3nxt49m","Type":"NodeParagraph","Properties":{"id":"20260601125039-3nxt49m","updated":"20260601125039"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260601125050-fyo3xwe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125050-fyo3xwe","updated":"20260601125050"},"Children":[{"ID":"20260601125050-61ow1et","Type":"NodeParagraph","Properties":{"id":"20260601125050-61ow1et","updated":"20260601125051"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260601125059-ayqig9s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125059-ayqig9s","updated":"20260601125059"},"Children":[{"ID":"20260601125059-uxycm1m","Type":"NodeParagraph","Properties":{"id":"20260601125059-uxycm1m","updated":"20260601125059"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260601125108-e2k0csi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125108-e2k0csi","updated":"20260601125108"},"Children":[{"ID":"20260601125108-zsg5k1g","Type":"NodeParagraph","Properties":{"id":"20260601125108-zsg5k1g","updated":"20260601125109"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260601125119-v50oy9k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125119-v50oy9k","updated":"20260601125119"},"Children":[{"ID":"20260601125119-aywfhb8","Type":"NodeParagraph","Properties":{"id":"20260601125119-aywfhb8","updated":"20260601125119"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260601125132-v3pxha2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125132-v3pxha2","updated":"20260601125132"},"Children":[{"ID":"20260601125132-m3lt18w","Type":"NodeParagraph","Properties":{"id":"20260601125132-m3lt18w","updated":"20260601125132"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260601125356-shfkm7a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125356-shfkm7a","updated":"20260601125356"},"Children":[{"ID":"20260601125356-zr8z84f","Type":"NodeParagraph","Properties":{"id":"20260601125356-zr8z84f","updated":"20260601125356"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260601125432-mb4i7di","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125432-mb4i7di","updated":"20260601125432"},"Children":[{"ID":"20260601125432-e5flw9j","Type":"NodeParagraph","Properties":{"id":"20260601125432-e5flw9j","updated":"20260601125433"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260601125145-qt9nkge","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125145-qt9nkge","updated":"20260601125145"},"Children":[{"ID":"20260601125145-c5llzh6","Type":"NodeParagraph","Properties":{"id":"20260601125145-c5llzh6","updated":"20260601125913"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260601124809-7hbimxz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124809-7hbimxz","updated":"20260601124809"},"Children":[{"ID":"20260601124809-ywhrsls","Type":"NodeParagraph","Properties":{"id":"20260601124809-ywhrsls","updated":"20260601125921"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260601124729-4cabfje","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124729-4cabfje","updated":"20260601124729"},"Children":[{"ID":"20260601124729-w11yb40","Type":"NodeParagraph","Properties":{"id":"20260601124729-w11yb40","updated":"20260601124729"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260601124531-ruqbr86","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124531-ruqbr86","updated":"20260601124531"},"Children":[{"ID":"20260601124531-4jvi0il","Type":"NodeParagraph","Properties":{"id":"20260601124531-4jvi0il","updated":"20260601124539"},"Children":[{"Type":"NodeText","Data":"命定的局限尽可永在，不屈的挑战却不可须臾或缺"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"。"}]}]},{"ID":"20260601124605-egwj8qe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601124605-egwj8qe","updated":"20260601124605"},"Children":[{"ID":"20260601124605-9bycb9s","Type":"NodeParagraph","Properties":{"id":"20260601124605-9bycb9s","updated":"20260601124614"},"Children":[{"Type":"NodeText","Data":"当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260601125551-6kd74p8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125551-6kd74p8","updated":"20260601125551"},"Children":[{"ID":"20260601125551-eedpzwo","Type":"NodeParagraph","Properties":{"id":"20260601125551-eedpzwo","updated":"20260601125559"},"Children":[{"Type":"NodeText","Data":"我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260601125627-tuzk7a3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125627-tuzk7a3","updated":"20260601125627"},"Children":[{"ID":"20260601125627-710i4ej","Type":"NodeParagraph","Properties":{"id":"20260601125627-710i4ej","updated":"20260601125630"},"Children":[{"Type":"NodeText","Data":"心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260601125646-27rsof5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125646-27rsof5","updated":"20260601125646"},"Children":[{"ID":"20260601125646-b0ans30","Type":"NodeParagraph","Properties":{"id":"20260601125646-b0ans30","updated":"20260601125646"},"Children":[{"Type":"NodeText","Data":"遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260601125708-x3ojnwv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125708-x3ojnwv","updated":"20260601125730"},"Children":[{"ID":"20260601125708-56r01ve","Type":"NodeParagraph","Properties":{"id":"20260601125708-56r01ve","updated":"20260601125730"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260601125829-fui152z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125829-fui152z","updated":"20260601125829"},"Children":[{"ID":"20260601125829-ysqxewg","Type":"NodeParagraph","Properties":{"id":"20260601125829-ysqxewg","updated":"20260601125832"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260601125950-q7ttxm7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601125950-q7ttxm7","updated":"20260601125950"},"Children":[{"ID":"20260601125950-0s3vf5w","Type":"NodeParagraph","Properties":{"id":"20260601125950-0s3vf5w","updated":"20260601130000"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260601130029-6n9nc2n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260601130029-6n9nc2n","updated":"20260601130030"},"Children":[{"ID":"20260601130029-2e6dz2k","Type":"NodeParagraph","Properties":{"id":"20260601130029-2e6dz2k","updated":"20260601130030"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]}]}]},{"ID":"20260531092721-auz2x2v","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260531092721-auz2x2v","updated":"20260531092756"},"Children":[{"ID":"20260531092721-q7hzj08","Type":"NodeParagraph","Properties":{"id":"20260531092721-q7hzj08","updated":"20260531092756"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：840至860字"}]}]}]},{"ID":"20260531092721-qv9gtee","Type":"NodeParagraph","Properties":{"id":"20260531092721-qv9gtee","updated":"20260531092721"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【输出格式】"}]},{"ID":"20260531092721-k6ze49w","Type":"NodeList","ListData":{},"Properties":{"id":"20260531092721-k6ze49w","updated":"20260531092721"},"Children":[{"ID":"20260531092721-l9lo5eg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260531092721-l9lo5eg","updated":"20260531092721"},"Children":[{"ID":"20260531092721-ai2gezm","Type":"NodeParagraph","Properties":{"id":"20260531092721-ai2gezm","updated":"20260531092721"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260531092721-1uqzh9j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260531092721-1uqzh9j","updated":"20260531092721"},"Children":[{"ID":"20260531092721-enh4i0h","Type":"NodeParagraph","Properties":{"id":"20260531092721-enh4i0h","updated":"20260531092721"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]}]}]},{"ID":"20260531094103-nuvggne","Type":"NodeParagraph","Properties":{"id":"20260531094103-nuvggne","updated":"20260531094105"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【作文题目/材料】"},{"Type":"NodeText","Data":"\n（在此处粘贴具体的作文题目、材料或话题，例如：2025年全国一卷关于老舍、艾青、穆旦的材料……）"}]},{"ID":"20260601122104-fjp9bco","Type":"NodeParagraph","Properties":{"id":"20260601122104-fjp9bco","updated":"20260601122104"}}]}