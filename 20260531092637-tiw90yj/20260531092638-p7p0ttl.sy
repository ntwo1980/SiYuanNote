kfu5","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"NS4=","Num":5},"Properties":{"id":"20260603112457-u65kfu5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-581zaxh","Type":"NodeParagraph","Properties":{"id":"20260603112457-581zaxh","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"思维与论证（核心技法）"},{"Type":"NodeText","Data":"     ："}]},{"ID":"20260603112457-r4fyxxx","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-r4fyxxx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ohj23f9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ohj23f9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-06vqeg7","Type":"NodeParagraph","Properties":{"id":"20260603112457-06vqeg7","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"必备论式组合"},{"Type":"NodeText","Data":"：优先使用下列方法中的两种及以上，根据文章需要自然融入，避免刻意拼装。"}]},{"ID":"20260603112457-rhkg3pl","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-rhkg3pl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vgwsrle","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vgwsrle","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k6x613q","Type":"NodeParagraph","Properties":{"id":"20260603112457-k6x613q","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分解论证（拉升与钻洞）"},{"Type":"NodeText","Data":"     ：证明分论点时，注意分论点间的层递关系。可采用“拉升式”（由底层肉身/物质体验升华到高层灵魂/生存层面）或“钻洞式”（由表层社会现象深入挖掘背后的文化基因或心理动因）。"}]}]},{"ID":"20260603112457-94clgy9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-94clgy9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bqn23mb","Type":"NodeParagraph","Properties":{"id":"20260603112457-bqn23mb","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"举例论证（典型事例）"},{"Type":"NodeText","Data":"     ：选取古今中外典型人物或时事热点，通过具体故事来支撑论点，做到叙议结合，拒绝单纯堆砌素材。"}]}]},{"ID":"20260603112457-xyoidsv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xyoidsv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rd5wuoy","Type":"NodeParagraph","Properties":{"id":"20260603112457-rd5wuoy","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"归谬论证（反向推导）"},{"Type":"NodeText","Data":"     ：先提出与论点相反的假定，推导出荒谬或不可接受的后果，从而有力地反证原论点的正确性，增强说服力。"}]}]}]}]},{"ID":"20260603112457-zfzzzt3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zfzzzt3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y35gft5","Type":"NodeParagraph","Properties":{"id":"20260603112457-y35gft5","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辅助论式拓展"},{"Type":"NodeText","Data":"：可适当穿插使用道理/引证论证（引用经典著作、名人警句）、类比论证（通过相似事物比较类推）或反证法，丰富文章的论证维度。"}]}]},{"ID":"20260603112457-z6ii236","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z6ii236","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qdk0lep","Type":"NodeParagraph","Properties":{"id":"20260603112457-qdk0lep","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"隐性植入辩证法"},{"Type":"NodeText","Data":"：将辩证法的三大规律(对立同一、量变质变、否定之否定)内化为文章的底层逻辑，但"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"严禁直接出现"},{"Type":"NodeText","Data":"“对立统一”、“量变质变”、“否定之否定”等哲学术语。具体操作如下："}]},{"ID":"20260603112457-w447l8k","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-w447l8k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bdp4isx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bdp4isx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-iuob34j","Type":"NodeParagraph","Properties":{"id":"20260603112457-iuob34j","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现矛盾转化"},{"Type":"NodeText","Data":"：分析事物内部的矛盾双方（如危与机、强与弱），阐述它们在特定条件下如何相互依存并向对立面转化。"}]}]},{"ID":"20260603112457-1402vzg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1402vzg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g7ovdky","Type":"NodeParagraph","Properties":{"id":"20260603112457-g7ovdky","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现积累与飞跃"},{"Type":"NodeText","Data":"：论述从微小的积累到质的突破的过程，强调厚积薄发的重要性。"}]}]},{"ID":"20260603112457-kq2kqz2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kq2kqz2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lcjek44","Type":"NodeParagraph","Properties":{"id":"20260603112457-lcjek44","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"体现螺旋上升"},{"Type":"NodeText","Data":"：展现事物发展不是简单的循环，而是看似回归原点实则境界提升的曲折前进过程。"}]}]}]}]},{"ID":"20260603112457-i6t1pxz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i6t1pxz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lwocgvc","Type":"NodeParagraph","Properties":{"id":"20260603112457-lwocgvc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"论据要充分且鲜活，拒绝陈词滥调（避免过度使用司马迁、李白、爱迪生等老套素材）。结合时事热点、历史文化等多维度素材。"}]}]}]}]},{"ID":"20260603112457-tc7npjh","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ni4=","Num":6},"Properties":{"id":"20260603112457-tc7npjh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qukpq3i","Type":"NodeParagraph","Properties":{"id":"20260603112457-qukpq3i","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"核心素材优先库："}]},{"ID":"20260603112457-htb3xde","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-htb3xde","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mpao8gy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mpao8gy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ydi0vfg","Type":"NodeParagraph","Properties":{"id":"20260603112457-ydi0vfg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"钱伟长（中国力学之父）：必须作为核心论据或升华点。重点使用其“九一八事变后，物理仅15分的他毅然弃文从理，只为‘科学救国’”的转折。体现“个人命运与国家命运的同频共振”，以此替换老旧的“范仲淹”、“岳飞”等素材。"}]}]},{"ID":"20260603112457-58knt5t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-58knt5t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jq79v3z","Type":"NodeParagraph","Properties":{"id":"20260603112457-jq79v3z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"西西弗斯（加缪笔下的荒诞英雄）：必须作为核心意象。重点描写他推石上山的徒劳与坚持，引用“登上顶峰的斗争本身足以充实人的心灵”。用以论证“在无意义的生活中构建意义”、“过程即意义”，以此替换老旧的“海伦·凯勒”、“张海迪”等素材。"}]}]}]}]},{"ID":"20260603112457-ibxoei5","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Ny4=","Num":7},"Properties":{"id":"20260603112457-ibxoei5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eqsgw3d","Type":"NodeParagraph","Properties":{"id":"20260603112457-eqsgw3d","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"古典底蕴与化用："}]},{"ID":"20260603112457-713qc17","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-713qc17","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o5fckk8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o5fckk8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uqiydby","Type":"NodeParagraph","Properties":{"id":"20260603112457-uqiydby","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"至少自然嵌入2–3条下面提供的的典故、文章(不必引用原文，文章总结、提炼亦可)、诗词名句、电影，并保证与论证逻辑紧密相关。在保证与论证逻辑紧密相关的情况下，优先使用标记为(优先)的条目。"}]},{"ID":"20260603112457-qzt4gy2","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-qzt4gy2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5zcbh5j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5zcbh5j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5ydir9q","Type":"NodeParagraph","Properties":{"id":"20260603112457-5ydir9q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《尚书》五福：寿、福、康宁、攸好德、考终命(优先)"}]}]},{"ID":"20260603112457-o6142y7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o6142y7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tsiv96y","Type":"NodeParagraph","Properties":{"id":"20260603112457-tsiv96y","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"鲁迅：无穷的远方，无数的人们，都与我相关。(优先)"}]}]},{"ID":"20260603112457-3qly8k7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3qly8k7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7djnjzd","Type":"NodeParagraph","Properties":{"id":"20260603112457-7djnjzd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰：世界上只有一种英雄主义，就是在认清生活的真相之后依然热爱生活。(优先)"}]}]},{"ID":"20260603112457-kr1d3h3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kr1d3h3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-26y1p79","Type":"NodeParagraph","Properties":{"id":"20260603112457-26y1p79","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"投之亡地然后存，陷之死地然后生。"}]}]},{"ID":"20260603112457-0c95fh2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0c95fh2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uum3tjo","Type":"NodeParagraph","Properties":{"id":"20260603112457-uum3tjo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603112457-19bl6be","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-19bl6be","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0jiv9yq","Type":"NodeParagraph","Properties":{"id":"20260603112457-0jiv9yq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"路遥《平凡的世界》当一个人集中地凝视着自己的不幸时，他就很难想象别人的苦难。"}]}]},{"ID":"20260603112457-g6obczn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g6obczn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-glpkt6i","Type":"NodeParagraph","Properties":{"id":"20260603112457-glpkt6i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"小敌之坚，大敌之擒也。"}]}]},{"ID":"20260603112457-vtktwqd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vtktwqd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dgqd7tr","Type":"NodeParagraph","Properties":{"id":"20260603112457-dgqd7tr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"小人肥口，君子肥身。"}]}]},{"ID":"20260603112457-1woiof6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1woiof6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dqgk1cj","Type":"NodeParagraph","Properties":{"id":"20260603112457-dqgk1cj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我生本无乡，心安是归处。"}]}]},{"ID":"20260603112457-p3jrrvn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p3jrrvn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-29vrnk4","Type":"NodeParagraph","Properties":{"id":"20260603112457-29vrnk4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陈独秀：青春如初春，如朝日，如百卉之萌动，如利刃之新发于硎(xíng)，人生最宝贵之时期也。"}]}]},{"ID":"20260603112457-cy07kwk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cy07kwk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vyrvr2k","Type":"NodeParagraph","Properties":{"id":"20260603112457-vyrvr2k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"舒婷《致橡树》：我们分担寒潮、风雷、霹雳；我们共享雾霭流岚、虹霓。"}]}]},{"ID":"20260603112457-d0kjb5c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-d0kjb5c","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u6q9anp","Type":"NodeParagraph","Properties":{"id":"20260603112457-u6q9anp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《美丽心灵》约翰·纳什"}]}]},{"ID":"20260603112457-yvxkiw9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yvxkiw9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-q30ga7j","Type":"NodeParagraph","Properties":{"id":"20260603112457-q30ga7j","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"西格里夫·萨松：心有猛虎，细嗅蔷薇。"}]}]},{"ID":"20260603112457-bn8o7n2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bn8o7n2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2zpzcqr","Type":"NodeParagraph","Properties":{"id":"20260603112457-2zpzcqr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"歌德：大胆的见解就好比下棋时移动一个棋子，它可能被吃掉，但它却是胜局的起点。"}]}]},{"ID":"20260603112457-fpc42bq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fpc42bq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1a1tj5u","Type":"NodeParagraph","Properties":{"id":"20260603112457-1a1tj5u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"加缪：西西弗斯无声的全部快乐就在于：他的命运是属于他的，他的岩石是他的事情。"}]}]},{"ID":"20260603112457-fkjb1aa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fkjb1aa","updated":"20260603112457"},"Children":[{"ID":"20260603112457-n4i5dbu","Type":"NodeParagraph","Properties":{"id":"20260603112457-n4i5dbu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"加缪：在隆冬，我终于知道，我身上有一个不可战胜的夏天。"}]}]},{"ID":"20260603112457-of3brat","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-of3brat","updated":"20260603112457"},"Children":[{"ID":"20260603112457-75sgwkc","Type":"NodeParagraph","Properties":{"id":"20260603112457-75sgwkc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海明威：一个人可以被毁灭， "},{"Type":"NodeTextMark","TextMarkType":"mark","TextMarkTextContent":"但不能被打败。"}]}]},{"ID":"20260603112457-uxbz2m8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uxbz2m8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-226a8nd","Type":"NodeParagraph","Properties":{"id":"20260603112457-226a8nd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"杨绛：生活一半是柴米油盐，一半是星辰大海。"}]}]},{"ID":"20260603112457-n35jaet","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-n35jaet","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bf2iigf","Type":"NodeParagraph","Properties":{"id":"20260603112457-bf2iigf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗素：参差多态乃是人类幸福的本源。"}]}]},{"ID":"20260603112457-84ijoro","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-84ijoro","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d491nb7","Type":"NodeParagraph","Properties":{"id":"20260603112457-d491nb7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昭昭若日月之明，离离如星辰之行。"}]}]},{"ID":"20260603112457-qz48fwt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qz48fwt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i2obail","Type":"NodeParagraph","Properties":{"id":"20260603112457-i2obail","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"事以急败，思因缓得。"}]}]},{"ID":"20260603112457-4tnbrh2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4tnbrh2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-695fe6v","Type":"NodeParagraph","Properties":{"id":"20260603112457-695fe6v","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"晚来风定钓丝闲，上下是新月。千里水天一色，看孤鸿明灭。"}]}]},{"ID":"20260603112457-be1xepd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-be1xepd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7sehgy3","Type":"NodeParagraph","Properties":{"id":"20260603112457-7sehgy3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"老舍《骆驼祥子》：经验是生活的肥料，有什么样的经验便变成什么样的人，在沙漠里养不出牡丹来。"}]}]},{"ID":"20260603112457-vfpvszz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vfpvszz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6gyoxbu","Type":"NodeParagraph","Properties":{"id":"20260603112457-6gyoxbu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"黄金累千，不如一贤。"}]}]},{"ID":"20260603112457-6h00jhw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6h00jhw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-06szcnk","Type":"NodeParagraph","Properties":{"id":"20260603112457-06szcnk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"歌德：理论是灰色的，唯生命之树常青。"}]}]},{"ID":"20260603112457-0beuv7y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0beuv7y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9iewf5n","Type":"NodeParagraph","Properties":{"id":"20260603112457-9iewf5n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道不同，不相为谋。"}]}]},{"ID":"20260603112457-rlsco8b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rlsco8b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-av8z23x","Type":"NodeParagraph","Properties":{"id":"20260603112457-av8z23x","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"浴不必江海，要之去垢；马不必骐骥，要之善走。"}]}]},{"ID":"20260603112457-q7bq99p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q7bq99p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-c9x8qyi","Type":"NodeParagraph","Properties":{"id":"20260603112457-c9x8qyi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苟利于民不必法古，苟周于事不必循旧。"}]}]},{"ID":"20260603112457-rzcogwa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rzcogwa","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4nehocr","Type":"NodeParagraph","Properties":{"id":"20260603112457-4nehocr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"怀重宝者，不以夜行；任大功者，不以轻敌。"}]}]},{"ID":"20260603112457-oexhbep","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oexhbep","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h5vkwr4","Type":"NodeParagraph","Properties":{"id":"20260603112457-h5vkwr4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"独行穿落叶，闲坐数流萤。"}]}]},{"ID":"20260603112457-jws1tli","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jws1tli","updated":"20260603112457"},"Children":[{"ID":"20260603112457-f7a9gig","Type":"NodeParagraph","Properties":{"id":"20260603112457-f7a9gig","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"佯北勿从，锐卒勿攻，饵兵勿食。"}]}]},{"ID":"20260603112457-8zbppzj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8zbppzj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-b84kwds","Type":"NodeParagraph","Properties":{"id":"20260603112457-b84kwds","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：只有流过血的手指，才能弹出世间的绝唱。"}]}]},{"ID":"20260603112457-lbjok2a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lbjok2a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0aba913","Type":"NodeParagraph","Properties":{"id":"20260603112457-0aba913","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"特鲁多医生墓志铭：医生有时治愈，常常帮助，总是安慰。"}]}]},{"ID":"20260603112457-ci3uk9o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ci3uk9o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xgmhxxw","Type":"NodeParagraph","Properties":{"id":"20260603112457-xgmhxxw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《蛤蟆先生去看心理医生》：没有一种批判比自我批判更强烈，也没有一个法官比我们自己更严苛。"}]}]},{"ID":"20260603112457-jdoipjz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jdoipjz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4uqnhsl","Type":"NodeParagraph","Properties":{"id":"20260603112457-4uqnhsl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"德不孤，必有邻。"}]}]},{"ID":"20260603112457-r5l4i3a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r5l4i3a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-62veo6p","Type":"NodeParagraph","Properties":{"id":"20260603112457-62veo6p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"吹灭读书灯，一身都是月。"}]}]},{"ID":"20260603112457-4c2b9yy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4c2b9yy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-syz2vs8","Type":"NodeParagraph","Properties":{"id":"20260603112457-syz2vs8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古今之成大事业、大学问者，必经过三种之境界：“昨夜西风凋碧树，独上高楼，望尽天涯路”，此第一境也；“衣带渐宽终不悔，为伊消得人憔悴”，此第二境也；“众里寻他千百度，蓦然回首，那人却在灯火阑珊处”，此第三境也。"}]}]},{"ID":"20260603112457-5h5r6pw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5h5r6pw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cu1q5xw","Type":"NodeParagraph","Properties":{"id":"20260603112457-cu1q5xw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"勿以身贵而贱人，勿以独见而违众。"}]}]},{"ID":"20260603112457-962171z","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-962171z","updated":"20260603112457"},"Children":[{"ID":"20260603112457-w1vni6o","Type":"NodeParagraph","Properties":{"id":"20260603112457-w1vni6o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山河虽无恙，吾辈当自强。"}]}]},{"ID":"20260603112457-oanew42","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oanew42","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i8khnzk","Type":"NodeParagraph","Properties":{"id":"20260603112457-i8khnzk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君埋泉下泥销骨，我寄人间雪满头。"}]}]},{"ID":"20260603112457-dgfkw25","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dgfkw25","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qpbxm0s","Type":"NodeParagraph","Properties":{"id":"20260603112457-qpbxm0s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"蛇蛇硕言，出自口矣。巧言如簧，颜之厚矣。"}]}]},{"ID":"20260603112457-1cm9pi5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1cm9pi5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bir5qq8","Type":"NodeParagraph","Properties":{"id":"20260603112457-bir5qq8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良剑期乎断，不期乎镆铘；良马期乎千里，不期乎骥骜(jì ào)。"}]}]},{"ID":"20260603112457-vz61d9h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vz61d9h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-umi869t","Type":"NodeParagraph","Properties":{"id":"20260603112457-umi869t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"勤能补拙，学可医愚。"}]}]},{"ID":"20260603112457-wr0lngl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wr0lngl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1ec0y6e","Type":"NodeParagraph","Properties":{"id":"20260603112457-1ec0y6e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"男儿何不带吴钩，收取关山五十州。请君暂上凌烟阁，若个书生万户侯？"}]}]},{"ID":"20260603112457-d9hm378","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-d9hm378","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xanwqx2","Type":"NodeParagraph","Properties":{"id":"20260603112457-xanwqx2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为政不难，不得罪于巨室。"}]}]},{"ID":"20260603112457-ey4q2qd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ey4q2qd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-13da2ho","Type":"NodeParagraph","Properties":{"id":"20260603112457-13da2ho","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"长恨人心不如水，等闲平地起波澜。"}]}]},{"ID":"20260603112457-j1ng2lk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j1ng2lk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p6hoxij","Type":"NodeParagraph","Properties":{"id":"20260603112457-p6hoxij","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"试玉要烧三日满，辨材须待七年期。"}]}]},{"ID":"20260603112457-yh9ngqr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yh9ngqr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uoaidb3","Type":"NodeParagraph","Properties":{"id":"20260603112457-uoaidb3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"清风一枕南窗卧，闲阅床头几卷书。"}]}]},{"ID":"20260603112457-25bg0c3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-25bg0c3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ew7vxer","Type":"NodeParagraph","Properties":{"id":"20260603112457-ew7vxer","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不知而自以为知，百祸之宗也。"}]}]},{"ID":"20260603112457-3228wc5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3228wc5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-akqmit2","Type":"NodeParagraph","Properties":{"id":"20260603112457-akqmit2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"轻财足以聚人，律己足以服人，量宽足以得人，身先足以率人。"}]}]},{"ID":"20260603112457-p7bbev6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p7bbev6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xqxl4ld","Type":"NodeParagraph","Properties":{"id":"20260603112457-xqxl4ld","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百战百胜，不如一忍。"}]}]},{"ID":"20260603112457-hnv42d4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hnv42d4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hbzcbuc","Type":"NodeParagraph","Properties":{"id":"20260603112457-hbzcbuc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"功名半纸，风雪千山。"}]}]},{"ID":"20260603112457-1gpzf3i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1gpzf3i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8g2sc61","Type":"NodeParagraph","Properties":{"id":"20260603112457-8g2sc61","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"井以甘竭，李以苦成。"}]}]},{"ID":"20260603112457-xrhbkv7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xrhbkv7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7qrfn8s","Type":"NodeParagraph","Properties":{"id":"20260603112457-7qrfn8s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赠君明月满前溪，直到西湖畔。"}]}]},{"ID":"20260603112457-w62ymra","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w62ymra","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r16rhxb","Type":"NodeParagraph","Properties":{"id":"20260603112457-r16rhxb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道虽迩(ěr)，不行不至；事虽小，不为不成。"}]}]},{"ID":"20260603112457-u0qzw8g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u0qzw8g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tjk1bed","Type":"NodeParagraph","Properties":{"id":"20260603112457-tjk1bed","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为草当作兰，为木当作松。兰秋香风远，松寒不改容。"}]}]},{"ID":"20260603112457-mgo1r70","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mgo1r70","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jsd6a8w","Type":"NodeParagraph","Properties":{"id":"20260603112457-jsd6a8w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用威者不轻怒，善用恩者不妄施。"}]}]},{"ID":"20260603112457-dre1u45","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dre1u45","updated":"20260603112457"},"Children":[{"ID":"20260603112457-03vcots","Type":"NodeParagraph","Properties":{"id":"20260603112457-03vcots","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马先驯而后求良，人先信而后求能。"}]}]},{"ID":"20260603112457-5q4c0vi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5q4c0vi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dx1t9an","Type":"NodeParagraph","Properties":{"id":"20260603112457-dx1t9an","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603112457-sqded7q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-sqded7q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lo8fni0","Type":"NodeParagraph","Properties":{"id":"20260603112457-lo8fni0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人要是不能从过程中体味幸福和快乐，生命就成了一场荒诞的苦役。"}]}]},{"ID":"20260603112457-qs4ib54","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qs4ib54","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8xb0fcs","Type":"NodeParagraph","Properties":{"id":"20260603112457-8xb0fcs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君王城上竖降旗，妾在深宫那得知？十四万人齐解甲，更无一个是男儿！"}]}]},{"ID":"20260603112457-nlydm2g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nlydm2g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1dx2qop","Type":"NodeParagraph","Properties":{"id":"20260603112457-1dx2qop","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用兵者，避其锐气，击其惰归，此治气者也。"}]}]},{"ID":"20260603112457-odux2ek","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-odux2ek","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kk5mqut","Type":"NodeParagraph","Properties":{"id":"20260603112457-kk5mqut","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"政入万山围子里，一山放出一山拦。"}]}]},{"ID":"20260603112457-eihtand","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-eihtand","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uwgay3k","Type":"NodeParagraph","Properties":{"id":"20260603112457-uwgay3k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地者万物之逆旅也；光阴者百代之过客也。"}]}]},{"ID":"20260603112457-9x2pltx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9x2pltx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4jtznhl","Type":"NodeParagraph","Properties":{"id":"20260603112457-4jtznhl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"虽不能至，心向往之。"}]}]},{"ID":"20260603112457-pw3dm2p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pw3dm2p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1l8mak7","Type":"NodeParagraph","Properties":{"id":"20260603112457-1l8mak7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"高者未必贤，下者未必愚。"}]}]},{"ID":"20260603112457-ngct527","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ngct527","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hykcupv","Type":"NodeParagraph","Properties":{"id":"20260603112457-hykcupv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"与朋友交游，须将他们好处留心学来，方能受益；对圣贤言语，必要我平时照样行去，才算读书。"}]}]},{"ID":"20260603112457-zecjzh2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zecjzh2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5jz319e","Type":"NodeParagraph","Properties":{"id":"20260603112457-5jz319e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"二人同心，其利断金；同心之言，其臭(xiù)如兰。"}]}]},{"ID":"20260603112457-jbcex9i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jbcex9i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-srpz710","Type":"NodeParagraph","Properties":{"id":"20260603112457-srpz710","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子不蔽人之美，不言人之恶。"}]}]},{"ID":"20260603112457-dca0ha9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dca0ha9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i3h2dkw","Type":"NodeParagraph","Properties":{"id":"20260603112457-i3h2dkw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603112457-vrdhyxq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vrdhyxq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5gdcxbw","Type":"NodeParagraph","Properties":{"id":"20260603112457-5gdcxbw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道德用于自律时好过一切法律，用于律他时坏过一切私刑！"}]}]},{"ID":"20260603112457-16fpjbs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-16fpjbs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wdvoyqd","Type":"NodeParagraph","Properties":{"id":"20260603112457-wdvoyqd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山高自有客行路，水深自有渡船人。"}]}]},{"ID":"20260603112457-conzeit","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-conzeit","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8m7hsez","Type":"NodeParagraph","Properties":{"id":"20260603112457-8m7hsez","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603112457-ia9hi1u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ia9hi1u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-f11rwvv","Type":"NodeParagraph","Properties":{"id":"20260603112457-f11rwvv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不忘初心，方得始终。初心易得，始终难守。"}]}]},{"ID":"20260603112457-r6g9mpx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r6g9mpx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gzndefa","Type":"NodeParagraph","Properties":{"id":"20260603112457-gzndefa","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不迁怒，不贰过。"}]}]},{"ID":"20260603112457-qbz3tdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qbz3tdt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7z9w4el","Type":"NodeParagraph","Properties":{"id":"20260603112457-7z9w4el","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"用兵之法，十则围之，五则攻之，倍则分之，敌则能战之，少则能逃之，不若则能避之。"}]}]},{"ID":"20260603112457-7tcv5tk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7tcv5tk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rv4g9pz","Type":"NodeParagraph","Properties":{"id":"20260603112457-rv4g9pz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"越自尊大，越见器小。"}]}]},{"ID":"20260603112457-nflz8ij","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nflz8ij","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lmmhthr","Type":"NodeParagraph","Properties":{"id":"20260603112457-lmmhthr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"浮云一别后，流水十年间。"}]}]},{"ID":"20260603112457-jlbc0vc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jlbc0vc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cq7jpv4","Type":"NodeParagraph","Properties":{"id":"20260603112457-cq7jpv4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"穆勒 ：个人的自由，以不侵犯他人的自由为自由。"}]}]},{"ID":"20260603112457-4919jdm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4919jdm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1ls7u8r","Type":"NodeParagraph","Properties":{"id":"20260603112457-1ls7u8r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"小舟从此逝，江海寄余生。"}]}]},{"ID":"20260603112457-an2ehct","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-an2ehct","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tcv8bes","Type":"NodeParagraph","Properties":{"id":"20260603112457-tcv8bes","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"云山苍苍，江水泱泱，先生之风，山高水长！"}]}]},{"ID":"20260603112457-krz6dy2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-krz6dy2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ic3utiq","Type":"NodeParagraph","Properties":{"id":"20260603112457-ic3utiq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"行远道者假于车，济江海者因于舟。"}]}]},{"ID":"20260603112457-2h6lw5i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2h6lw5i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-etxt4av","Type":"NodeParagraph","Properties":{"id":"20260603112457-etxt4av","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一花独放不是春，百花齐放春满园。"}]}]},{"ID":"20260603112457-2yagzv5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2yagzv5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ghq6uva","Type":"NodeParagraph","Properties":{"id":"20260603112457-ghq6uva","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"立志欲坚不欲锐，成功在久不在速。"}]}]},{"ID":"20260603112457-ypkd82t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ypkd82t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vzw20i4","Type":"NodeParagraph","Properties":{"id":"20260603112457-vzw20i4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赏不逾日，罚不还面。"}]}]},{"ID":"20260603112457-0gmmqgi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0gmmqgi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dukqmeo","Type":"NodeParagraph","Properties":{"id":"20260603112457-dukqmeo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"布伦南：手头上有点钱的人认为爱是世界上最重要的东西，而穷人则明白世界上最重要的是金钱。"}]}]},{"ID":"20260603112457-9b9yf1g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9b9yf1g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uyw6m67","Type":"NodeParagraph","Properties":{"id":"20260603112457-uyw6m67","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"冯至《十四行集》：我们准备着，深深地领受，那些意想不到的奇迹。在漫长的岁月里，忽然有彗星的出现，狂风乍起。"}]}]},{"ID":"20260603112457-k7js9qf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k7js9qf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ilobeyp","Type":"NodeParagraph","Properties":{"id":"20260603112457-ilobeyp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"疾风怒雨，禽鸟戚戚；霁月光风，草木欣欣。天地不可一日无和气，人心不可一日无喜神。"}]}]},{"ID":"20260603112457-awbca52","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-awbca52","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i5pi66m","Type":"NodeParagraph","Properties":{"id":"20260603112457-i5pi66m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丈夫之高华，只在于道德气节。鄙夫之炫耀，但求诸服饰起居。"}]}]},{"ID":"20260603112457-0b9lcmn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0b9lcmn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6j6bnuq","Type":"NodeParagraph","Properties":{"id":"20260603112457-6j6bnuq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"甘井近竭，招木近伐。"}]}]},{"ID":"20260603112457-86prvj6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-86prvj6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-52f9qfw","Type":"NodeParagraph","Properties":{"id":"20260603112457-52f9qfw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用兵者，屈人之兵而非战也，拔人之城而非攻也，毁人之国而非久也，必以全争于天下。故兵不顿而利可全，此谋攻之法也。"}]}]},{"ID":"20260603112457-hbv77ai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hbv77ai","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1q2i7xr","Type":"NodeParagraph","Properties":{"id":"20260603112457-1q2i7xr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"你吞并一切，像远方，像大海，像时间。"}]}]},{"ID":"20260603112457-fjutp24","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fjutp24","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fc633f3","Type":"NodeParagraph","Properties":{"id":"20260603112457-fc633f3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"挟取笔端风雨，快写胸中丘壑，不肯下樊笼。"}]}]},{"ID":"20260603112457-r843gd9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r843gd9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mr5o61i","Type":"NodeParagraph","Properties":{"id":"20260603112457-mr5o61i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"巴尔扎克：一星陨落，黯淡不了星空灿烂；一花凋零，荒芜不了整个春天。"}]}]},{"ID":"20260603112457-kktw0fi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kktw0fi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pmik9it","Type":"NodeParagraph","Properties":{"id":"20260603112457-pmik9it","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"伯修斯：在所有不幸中，最不幸的事是曾经幸福过。"}]}]},{"ID":"20260603112457-1oino2u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1oino2u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p2k8zhw","Type":"NodeParagraph","Properties":{"id":"20260603112457-p2k8zhw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"草萤有耀终非火，荷露虽团岂是珠。"}]}]},{"ID":"20260603112457-nob28nt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nob28nt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l183juh","Type":"NodeParagraph","Properties":{"id":"20260603112457-l183juh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"耳闻之不如目见之，目见之不如足践之。"}]}]},{"ID":"20260603112457-vofeqzp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vofeqzp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uji2jbz","Type":"NodeParagraph","Properties":{"id":"20260603112457-uji2jbz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"卖花担上，买得一枝春欲放。"}]}]},{"ID":"20260603112457-ife9vvr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ife9vvr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i4otizu","Type":"NodeParagraph","Properties":{"id":"20260603112457-i4otizu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"亭亭山上松，瑟(sè)瑟谷中风。风声一何盛，松枝一何劲。冰霜正惨凄，终岁常端正。岂不罹(lí)凝寒，松柏有本性。"}]}]},{"ID":"20260603112457-did5r7h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-did5r7h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yjsxokx","Type":"NodeParagraph","Properties":{"id":"20260603112457-yjsxokx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"好问则裕，自用则小。"}]}]},{"ID":"20260603112457-mgw7fnc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mgw7fnc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xjzzogq","Type":"NodeParagraph","Properties":{"id":"20260603112457-xjzzogq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雾失楼台，月迷津渡。"}]}]},{"ID":"20260603112457-q8mzjjv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q8mzjjv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sjfib8o","Type":"NodeParagraph","Properties":{"id":"20260603112457-sjfib8o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：世界以痛吻我，我也要报之以歌。"}]}]},{"ID":"20260603112457-nz9uqii","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nz9uqii","updated":"20260603112457"},"Children":[{"ID":"20260603112457-380ci0v","Type":"NodeParagraph","Properties":{"id":"20260603112457-380ci0v","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"千人之诺诺，不如一士之谔谔。"}]}]},{"ID":"20260603112457-iez54t0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iez54t0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-npw959u","Type":"NodeParagraph","Properties":{"id":"20260603112457-npw959u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"早岁读书无甚解，晚年省事有奇功。"}]}]},{"ID":"20260603112457-r2cpkgz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r2cpkgz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-el60t2d","Type":"NodeParagraph","Properties":{"id":"20260603112457-el60t2d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"你所浪费的今天，是昨天死去的人奢望的明天；你所厌恶的现在，是未来的你回不去的曾经。"}]}]},{"ID":"20260603112457-z5tdph1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z5tdph1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p79yzsq","Type":"NodeParagraph","Properties":{"id":"20260603112457-p79yzsq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：有很多人常常抱怨没有机会，其实没有机会本身亦是一个机会：一个锻炼自己耐力和充分积蓄自己力量的机会。"}]}]},{"ID":"20260603112457-836gees","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-836gees","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kqd5yy7","Type":"NodeParagraph","Properties":{"id":"20260603112457-kqd5yy7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"世界让我遍体鳞伤，但伤口长出的却是翅膀。"}]}]},{"ID":"20260603112457-tai0hki","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tai0hki","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6t58yef","Type":"NodeParagraph","Properties":{"id":"20260603112457-6t58yef","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"凡战者，以正合，以奇胜。"}]}]},{"ID":"20260603112457-qu7opbt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qu7opbt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-e82fzif","Type":"NodeParagraph","Properties":{"id":"20260603112457-e82fzif","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"方其中，圆其外。"}]}]},{"ID":"20260603112457-neic2zv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-neic2zv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p4j177i","Type":"NodeParagraph","Properties":{"id":"20260603112457-p4j177i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"独学而无友，则孤陋而寡闻。"}]}]},{"ID":"20260603112457-w8xf8o0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w8xf8o0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lsjqiw9","Type":"NodeParagraph","Properties":{"id":"20260603112457-lsjqiw9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"史铁生：苦难既然把我推到了悬崖的边缘，那么就让我在这悬崖的边缘坐下来，顺便看看悬崖下的流岚雾霭，唱支歌给你听。"}]}]},{"ID":"20260603112457-2ecng9u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2ecng9u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rsavit7","Type":"NodeParagraph","Properties":{"id":"20260603112457-rsavit7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"国虽大，好战必亡；天下虽安，忘战必危。"}]}]},{"ID":"20260603112457-2vuv6il","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2vuv6il","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0n73avh","Type":"NodeParagraph","Properties":{"id":"20260603112457-0n73avh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"加缪：每个冬天的句号都是春暖花开。"}]}]},{"ID":"20260603112457-9pvn45u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9pvn45u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eog62x9","Type":"NodeParagraph","Properties":{"id":"20260603112457-eog62x9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百里趋利，兵家所忌。"}]}]},{"ID":"20260603112457-8sz3pui","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8sz3pui","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ueqlt8z","Type":"NodeParagraph","Properties":{"id":"20260603112457-ueqlt8z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李大钊：谁对时间越吝啬，时间对谁越慷慨。"}]}]},{"ID":"20260603112457-qnzym7o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qnzym7o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-c3yjqwa","Type":"NodeParagraph","Properties":{"id":"20260603112457-c3yjqwa","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"粗缯大布裹生涯，腹有诗书气自华。"}]}]},{"ID":"20260603112457-r2mk4sm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r2mk4sm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6w8yn2o","Type":"NodeParagraph","Properties":{"id":"20260603112457-6w8yn2o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"夫未战而庙算胜者，得算多也；未战而庙算不胜者，得算少也。多算胜，少算不胜，而况于无算乎？"}]}]},{"ID":"20260603112457-2cvo8t1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2cvo8t1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tpervdi","Type":"NodeParagraph","Properties":{"id":"20260603112457-tpervdi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"慈不掌兵，情不立事，义不理财，善不为官。"}]}]},{"ID":"20260603112457-loxf8o3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-loxf8o3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bbeadzs","Type":"NodeParagraph","Properties":{"id":"20260603112457-bbeadzs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大巧在所不为，大智在所不虑。"}]}]},{"ID":"20260603112457-zhsmif1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zhsmif1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ucuz42y","Type":"NodeParagraph","Properties":{"id":"20260603112457-ucuz42y","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海到尽头天作岸，山登绝顶我为峰。"}]}]},{"ID":"20260603112457-erqm7o6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-erqm7o6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u07iftq","Type":"NodeParagraph","Properties":{"id":"20260603112457-u07iftq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨之为物，能令昼短，能令夜长。"}]}]},{"ID":"20260603112457-g6lumnt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g6lumnt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u64svmn","Type":"NodeParagraph","Properties":{"id":"20260603112457-u64svmn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善出奇者，无穷如天地，不竭如江海。"}]}]},{"ID":"20260603112457-etj9gpo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-etj9gpo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-il52pey","Type":"NodeParagraph","Properties":{"id":"20260603112457-il52pey","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大丈夫行事，当磊磊落落，如日月皎然。"}]}]},{"ID":"20260603112457-76zhweg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-76zhweg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0sx0el5","Type":"NodeParagraph","Properties":{"id":"20260603112457-0sx0el5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知者行之始，行者知之成。"}]}]},{"ID":"20260603112457-cdyicff","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cdyicff","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5rwdp0w","Type":"NodeParagraph","Properties":{"id":"20260603112457-5rwdp0w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善用兵者不以短击长，而以长击短。"}]}]},{"ID":"20260603112457-12mqlww","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-12mqlww","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vcl2gvm","Type":"NodeParagraph","Properties":{"id":"20260603112457-vcl2gvm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"振衣千仞冈，濯足万里流。"}]}]},{"ID":"20260603112457-er52ha1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-er52ha1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-99ihoel","Type":"NodeParagraph","Properties":{"id":"20260603112457-99ihoel","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：你今天受的苦、吃的亏、担的责、扛的罪、忍的痛，到最后都会变成光，照亮你的路。"}]}]},{"ID":"20260603112457-w6x45d4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w6x45d4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0t2958u","Type":"NodeParagraph","Properties":{"id":"20260603112457-0t2958u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"张而不弛，文武弗能也；弛而不张，文武弗为也。一张一弛，文武之道也。"}]}]},{"ID":"20260603112457-srp9nos","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-srp9nos","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4unr2u2","Type":"NodeParagraph","Properties":{"id":"20260603112457-4unr2u2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善为士者，不武；善战者，不怒；善胜敌者，不与；善用人者，为之下。是谓不争之德，是谓用人之力。"}]}]},{"ID":"20260603112457-4xsqi6o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4xsqi6o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-thcpqmg","Type":"NodeParagraph","Properties":{"id":"20260603112457-thcpqmg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"中心藏之，何日忘之！"}]}]},{"ID":"20260603112457-82otjey","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-82otjey","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3w7uclr","Type":"NodeParagraph","Properties":{"id":"20260603112457-3w7uclr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：没有比脚更长的路，没有比人更高的山。"}]}]},{"ID":"20260603112457-nvoq36s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nvoq36s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-te37wmd","Type":"NodeParagraph","Properties":{"id":"20260603112457-te37wmd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"歌德：才能是在寂静中造就，而品格则是在世间汹涌波涛中形成。"}]}]},{"ID":"20260603112457-loxkk21","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-loxkk21","updated":"20260603112457"},"Children":[{"ID":"20260603112457-67ybkgu","Type":"NodeParagraph","Properties":{"id":"20260603112457-67ybkgu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我有迷魂招不得，雄鸡一声天下白。少年心事当拏云，谁念幽寒坐呜呃。"}]}]},{"ID":"20260603112457-yql7r46","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yql7r46","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xhm9iio","Type":"NodeParagraph","Properties":{"id":"20260603112457-xhm9iio","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尺之木必有节目，寸之玉必有瑕疵。"}]}]},{"ID":"20260603112457-hh54lbp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hh54lbp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6qoa8my","Type":"NodeParagraph","Properties":{"id":"20260603112457-6qoa8my","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"曾国藩：天下古今之庸人，皆以一惰字致败；天下古今之才人，皆以一傲字致败。"}]}]},{"ID":"20260603112457-pbi4hgm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pbi4hgm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-inb7gbr","Type":"NodeParagraph","Properties":{"id":"20260603112457-inb7gbr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"培根：当你孤独寂寞时，阅读可以消遣。当你高谈阔论时，知识可供装饰。当你处世行事时，正确运用知识意味着力量。"}]}]},{"ID":"20260603112457-o2hh2u2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o2hh2u2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-avqlcyv","Type":"NodeParagraph","Properties":{"id":"20260603112457-avqlcyv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"辅车相依，唇亡齿寒。"}]}]},{"ID":"20260603112457-kgzvsi4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kgzvsi4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6gylmnv","Type":"NodeParagraph","Properties":{"id":"20260603112457-6gylmnv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"池田大作：荣誉有如萤虫之火，在黑暗的夜空里，它放着光，显示出美丽，极其可贵。但是靠近一看，立刻就会明白它是何等的软弱无力。"}]}]},{"ID":"20260603112457-edl9lfn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-edl9lfn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4l9yqi4","Type":"NodeParagraph","Properties":{"id":"20260603112457-4l9yqi4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：谁终将声震人间，必长久深自缄默；谁终将点燃闪电，必长久如云漂泊。我的时代还没有到来，有的人死后方生。"}]}]},{"ID":"20260603112457-hlhgobt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hlhgobt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6hhwvd6","Type":"NodeParagraph","Properties":{"id":"20260603112457-6hhwvd6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"三毛：梦想，可以天花乱坠；理想，是我们一步一个脚印踩出来的坎坷道路。"}]}]},{"ID":"20260603112457-eqx1xm8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-eqx1xm8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9osxa6f","Type":"NodeParagraph","Properties":{"id":"20260603112457-9osxa6f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"志不可一日坠，心不可一日放。"}]}]},{"ID":"20260603112457-g41b6j8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g41b6j8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gp7f0z5","Type":"NodeParagraph","Properties":{"id":"20260603112457-gp7f0z5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一双冷眼看世人，满腔热血酬知己。"}]}]},{"ID":"20260603112457-fkm4r66","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fkm4r66","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xwyeojd","Type":"NodeParagraph","Properties":{"id":"20260603112457-xwyeojd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗翔：误解是人生常态，理解是稀缺的例外。"}]}]},{"ID":"20260603112457-lut2bzw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lut2bzw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-himfgtn","Type":"NodeParagraph","Properties":{"id":"20260603112457-himfgtn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"杀人亦有限，列国自有疆。苟能制侵陵，岂在多杀伤。"}]}]},{"ID":"20260603112457-3cd8kdy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3cd8kdy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-aqoyiwd","Type":"NodeParagraph","Properties":{"id":"20260603112457-aqoyiwd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"朝闻道，夕死可矣。"}]}]},{"ID":"20260603112457-ilx12xo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ilx12xo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bqsls91","Type":"NodeParagraph","Properties":{"id":"20260603112457-bqsls91","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丈夫四方志，安可辞固穷。"}]}]},{"ID":"20260603112457-wu1edgg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wu1edgg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kzzxocj","Type":"NodeParagraph","Properties":{"id":"20260603112457-kzzxocj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"粪虫至秽变为蝉，而饮露于秋风；腐草无光化为荧，而耀采于夏月。故知洁常自污出，明每从暗生也。"}]}]},{"ID":"20260603112457-l39jz5l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l39jz5l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ff7hhqz","Type":"NodeParagraph","Properties":{"id":"20260603112457-ff7hhqz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"物以稀为贵，情因老更慈。"}]}]},{"ID":"20260603112457-byb58df","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-byb58df","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cwggnys","Type":"NodeParagraph","Properties":{"id":"20260603112457-cwggnys","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不可积，过不可长。"}]}]},{"ID":"20260603112457-gv6zzso","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gv6zzso","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h4fb2hv","Type":"NodeParagraph","Properties":{"id":"20260603112457-h4fb2hv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不能受谏，安能谏人。"}]}]},{"ID":"20260603112457-aechj8x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-aechj8x","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xtyo9ox","Type":"NodeParagraph","Properties":{"id":"20260603112457-xtyo9ox","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生岂草木，寒暑移此心。"}]}]},{"ID":"20260603112457-vbmuueo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vbmuueo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jd0a12s","Type":"NodeParagraph","Properties":{"id":"20260603112457-jd0a12s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大丈夫当容人，勿为人所容。"}]}]},{"ID":"20260603112457-jsnw0jg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jsnw0jg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dhwx0ke","Type":"NodeParagraph","Properties":{"id":"20260603112457-dhwx0ke","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不为无益之事，何以悦有涯之生。"}]}]},{"ID":"20260603112457-brbcmk3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-brbcmk3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5wagujo","Type":"NodeParagraph","Properties":{"id":"20260603112457-5wagujo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海棠未雨，梨花先雪。"}]}]},{"ID":"20260603112457-scp5fwq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-scp5fwq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1c6ibfs","Type":"NodeParagraph","Properties":{"id":"20260603112457-1c6ibfs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"地薄者大木不产，水浅者大鱼不游。"}]}]},{"ID":"20260603112457-t7ajsv4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t7ajsv4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2256uby","Type":"NodeParagraph","Properties":{"id":"20260603112457-2256uby","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"忧勤是美德，太苦则无以适性怡情；淡泊是高风，太枯则无以济人利物。"}]}]},{"ID":"20260603112457-iji5ovy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-iji5ovy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1yhiioo","Type":"NodeParagraph","Properties":{"id":"20260603112457-1yhiioo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"读书为身上之用，而人以为纸上之用。"}]}]},{"ID":"20260603112457-5cljpvg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5cljpvg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fdisflw","Type":"NodeParagraph","Properties":{"id":"20260603112457-fdisflw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天可补，海可填，南山可移。日月既往，不可复追。"}]}]},{"ID":"20260603112457-4x14hyf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4x14hyf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g7iv7gq","Type":"NodeParagraph","Properties":{"id":"20260603112457-g7iv7gq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼布尔：请赐予我平静，去接受我无法改变的；给予我勇气，去改变我能改变的；赐我智慧，分辨这两者的区别。"}]}]},{"ID":"20260603112457-rhauqxn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rhauqxn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s85m5fh","Type":"NodeParagraph","Properties":{"id":"20260603112457-s85m5fh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"腹中贮书一万卷，不肯低头在草莽。"}]}]},{"ID":"20260603112457-wetlmk5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wetlmk5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m47thts","Type":"NodeParagraph","Properties":{"id":"20260603112457-m47thts","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"须知少日拏云志，曾许人间第一流。"}]}]},{"ID":"20260603112457-08wo36q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-08wo36q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v49oqb4","Type":"NodeParagraph","Properties":{"id":"20260603112457-v49oqb4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"时间的步伐有三种：未来姗姗来迟，现在像箭一样飞逝，过去永远静立不动。"}]}]},{"ID":"20260603112457-x0jkwbf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-x0jkwbf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0u85pjr","Type":"NodeParagraph","Properties":{"id":"20260603112457-0u85pjr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天若无雪霜，青松不如草。地若无山川，何人重平道。"}]}]},{"ID":"20260603112457-uf91380","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uf91380","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fyw8ero","Type":"NodeParagraph","Properties":{"id":"20260603112457-fyw8ero","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"凡心所向，素履所往，生如逆旅，一苇以航。"}]}]},{"ID":"20260603112457-t81zv6n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t81zv6n","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8j4pyx2","Type":"NodeParagraph","Properties":{"id":"20260603112457-8j4pyx2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"缓事宜急干，敏则有功；急事宜缓办，忙则多错。"}]}]},{"ID":"20260603112457-fuvnkk1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fuvnkk1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6ix2ylw","Type":"NodeParagraph","Properties":{"id":"20260603112457-6ix2ylw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"众口铄金，积毁销骨。"}]}]},{"ID":"20260603112457-3mmoxdy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3mmoxdy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-iq38n7w","Type":"NodeParagraph","Properties":{"id":"20260603112457-iq38n7w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"春日迟迟，卉木萋萋。"}]}]},{"ID":"20260603112457-0bdc6zq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0bdc6zq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-psock3l","Type":"NodeParagraph","Properties":{"id":"20260603112457-psock3l","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"若有恒何必三更眠五更起，最无益莫过一日曝十日寒。"}]}]},{"ID":"20260603112457-aucvryv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-aucvryv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-n2vd6q0","Type":"NodeParagraph","Properties":{"id":"20260603112457-n2vd6q0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百战百胜，非善之善者也；不战而屈人之兵，善之善者也。"}]}]},{"ID":"20260603112457-5eb57mm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5eb57mm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7whvd7e","Type":"NodeParagraph","Properties":{"id":"20260603112457-7whvd7e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人之相知，贵相知心。"}]}]},{"ID":"20260603112457-o1ubfbn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o1ubfbn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9a4scn2","Type":"NodeParagraph","Properties":{"id":"20260603112457-9a4scn2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"桃李春风一杯酒，江湖夜雨十年灯。"}]}]},{"ID":"20260603112457-c7wsj8o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c7wsj8o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-804jv0v","Type":"NodeParagraph","Properties":{"id":"20260603112457-804jv0v","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"东风知我欲山行，吹断檐间积雨声。"}]}]},{"ID":"20260603112457-qjiez47","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qjiez47","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8dzdc3d","Type":"NodeParagraph","Properties":{"id":"20260603112457-8dzdc3d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"桐花万里丹山路，雏凤清于老凤声。"}]}]},{"ID":"20260603112457-h6rb8m2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-h6rb8m2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sng76ba","Type":"NodeParagraph","Properties":{"id":"20260603112457-sng76ba","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生不能设计，你只能面对。"}]}]},{"ID":"20260603112457-e9y02w8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-e9y02w8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dpfbck3","Type":"NodeParagraph","Properties":{"id":"20260603112457-dpfbck3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。"}]}]},{"ID":"20260603112457-p4xduk3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p4xduk3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-533xobl","Type":"NodeParagraph","Properties":{"id":"20260603112457-533xobl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"心随长风去，吹散万里云。"}]}]},{"ID":"20260603112457-zrhomh0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zrhomh0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jhs52i4","Type":"NodeParagraph","Properties":{"id":"20260603112457-jhs52i4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"见面怜清瘦，呼儿问苦辛。"}]}]},{"ID":"20260603112457-tamihn4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tamihn4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9lqjsq0","Type":"NodeParagraph","Properties":{"id":"20260603112457-9lqjsq0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"查尔斯·A·比尔德：当天空黑暗到一定程度，星辰就会熠熠生辉。"}]}]},{"ID":"20260603112457-jzfgchi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jzfgchi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eqejtjo","Type":"NodeParagraph","Properties":{"id":"20260603112457-eqejtjo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪中何以赠君别，惟有青青松树枝。"}]}]},{"ID":"20260603112457-f9str36","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f9str36","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ly2ijjd","Type":"NodeParagraph","Properties":{"id":"20260603112457-ly2ijjd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"赏必加于有功，刑必断于有罪。"}]}]},{"ID":"20260603112457-by7u6tz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-by7u6tz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rjj68fx","Type":"NodeParagraph","Properties":{"id":"20260603112457-rjj68fx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"规小节者不能成荣名，恶小耻者不能立大功。"}]}]},{"ID":"20260603112457-y7tqfd1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y7tqfd1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m7x2nf5","Type":"NodeParagraph","Properties":{"id":"20260603112457-m7x2nf5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"沈从文：聪明人要理解生活，愚蠢人要习惯生活。"}]}]},{"ID":"20260603112457-a78vbdr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-a78vbdr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7xbni4v","Type":"NodeParagraph","Properties":{"id":"20260603112457-7xbni4v","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"康德：世界上有两件东西能震撼人们的心灵：一件是我们心中崇高的道德标准；另一件是我们头顶上灿烂的星空。"}]}]},{"ID":"20260603112457-4ksl3fc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4ksl3fc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ojdi5w2","Type":"NodeParagraph","Properties":{"id":"20260603112457-ojdi5w2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"叔本华：财富就像海水，饮得越多，渴得越厉害。名望实际上也是如此。"}]}]},{"ID":"20260603112457-oqt6ilt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oqt6ilt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ji2myyw","Type":"NodeParagraph","Properties":{"id":"20260603112457-ji2myyw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵者，国之大事，死生之地，存亡之道，不可不察也。"}]}]},{"ID":"20260603112457-hunfbkp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hunfbkp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ey73ogs","Type":"NodeParagraph","Properties":{"id":"20260603112457-ey73ogs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵无常势，水无常形，能因敌变化而取胜者，谓之神。"}]}]},{"ID":"20260603112457-5yqx6xr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5yqx6xr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ei285t8","Type":"NodeParagraph","Properties":{"id":"20260603112457-ei285t8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"何物动人二月杏花八月桂，有谁催我三更灯火五更鸡。"}]}]},{"ID":"20260603112457-dvgiqae","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dvgiqae","updated":"20260603112457"},"Children":[{"ID":"20260603112457-21u2jhh","Type":"NodeParagraph","Properties":{"id":"20260603112457-21u2jhh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"自古骄兵多致败，从来轻敌少成功。"}]}]},{"ID":"20260603112457-91v80md","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-91v80md","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3txpwqu","Type":"NodeParagraph","Properties":{"id":"20260603112457-3txpwqu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知往日所往之非，则学日进矣；见世人可取者多，则德日进矣。"}]}]},{"ID":"20260603112457-py9qrhi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-py9qrhi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3bnvu1s","Type":"NodeParagraph","Properties":{"id":"20260603112457-3bnvu1s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马太福音：凡有的，还要加倍给他，叫他有余；没有的，连他剩余的也要夺过来。"}]}]},{"ID":"20260603112457-kmge0vg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kmge0vg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-msvam6k","Type":"NodeParagraph","Properties":{"id":"20260603112457-msvam6k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"风流不在谈锋胜，袖手无言味最长。"}]}]},{"ID":"20260603112457-lnyi68s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lnyi68s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pogqkzb","Type":"NodeParagraph","Properties":{"id":"20260603112457-pogqkzb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"恻隐之心，人皆有之；羞恶之心，人皆有之；恭敬之心，人皆有之；是非之心，人皆有之。"}]}]},{"ID":"20260603112457-uuqzuyd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uuqzuyd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kl0yaul","Type":"NodeParagraph","Properties":{"id":"20260603112457-kl0yaul","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"攻人以谋不以力，用兵斗智不斗多。"}]}]},{"ID":"20260603112457-pi9adg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-pi9adg6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k8v6osr","Type":"NodeParagraph","Properties":{"id":"20260603112457-k8v6osr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"已识乾坤大，犹怜草木青。"}]}]},{"ID":"20260603112457-hexa0so","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hexa0so","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x1aqgvd","Type":"NodeParagraph","Properties":{"id":"20260603112457-x1aqgvd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"鹏北海，凤朝阳。又携书剑路茫茫。明年此日青云上，却笑人间举子忙。"}]}]},{"ID":"20260603112457-gxen883","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gxen883","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tj6634i","Type":"NodeParagraph","Properties":{"id":"20260603112457-tj6634i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"朝饮木兰之坠露兮，夕餐秋菊之落英。"}]}]},{"ID":"20260603112457-tedoqhe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tedoqhe","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pkvpoxu","Type":"NodeParagraph","Properties":{"id":"20260603112457-pkvpoxu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"千人同心则得千人之力，万人异心则无一人之用。"}]}]},{"ID":"20260603112457-8iginqz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8iginqz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-547y7y8","Type":"NodeParagraph","Properties":{"id":"20260603112457-547y7y8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"出其所不趋，趋其所不意。"}]}]},{"ID":"20260603112457-ubgtrp9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ubgtrp9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sael25b","Type":"NodeParagraph","Properties":{"id":"20260603112457-sael25b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"戒骄风清月朗，除躁海阔天空。"}]}]},{"ID":"20260603112457-xf6ayzl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xf6ayzl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0e7e5yn","Type":"NodeParagraph","Properties":{"id":"20260603112457-0e7e5yn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"何时杖尔看南雪，我与梅花两白头。"}]}]},{"ID":"20260603112457-21r0n4o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-21r0n4o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h1ib5cp","Type":"NodeParagraph","Properties":{"id":"20260603112457-h1ib5cp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一时宠利有尽，千秋青史难欺。"}]}]},{"ID":"20260603112457-29zllss","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-29zllss","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g6rkul0","Type":"NodeParagraph","Properties":{"id":"20260603112457-g6rkul0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山川异域，风月同天。"}]}]},{"ID":"20260603112457-k32zy58","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k32zy58","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4ntveor","Type":"NodeParagraph","Properties":{"id":"20260603112457-4ntveor","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"白石似玉，奸佞似贤。"}]}]},{"ID":"20260603112457-6ivx7e5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6ivx7e5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6nyythy","Type":"NodeParagraph","Properties":{"id":"20260603112457-6nyythy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"深厚的教养所集成的勇猛，远远胜过无知无情者的鲁莽。"}]}]},{"ID":"20260603112457-hoanrbw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hoanrbw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a0jm6nx","Type":"NodeParagraph","Properties":{"id":"20260603112457-a0jm6nx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"积财千万，不如薄技在身。"}]}]},{"ID":"20260603112457-r81ir25","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r81ir25","updated":"20260603112457"},"Children":[{"ID":"20260603112457-37nd5sf","Type":"NodeParagraph","Properties":{"id":"20260603112457-37nd5sf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海明威：生活总是让我们遍体鳞伤，但到后来，那些受伤的地方一定会变成我们最强壮的地方。"}]}]},{"ID":"20260603112457-i41xy38","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i41xy38","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9yz4o4r","Type":"NodeParagraph","Properties":{"id":"20260603112457-9yz4o4r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"当年不肯嫁春风，无端却被秋风误。"}]}]},{"ID":"20260603112457-669a3l8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-669a3l8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ka1x2rx","Type":"NodeParagraph","Properties":{"id":"20260603112457-ka1x2rx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良辰美景奈何天，赏心乐事谁家院。"}]}]},{"ID":"20260603112457-xenyr6l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xenyr6l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2ujorw6","Type":"NodeParagraph","Properties":{"id":"20260603112457-2ujorw6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"唤起一天明月，照我满怀冰雪，浩荡百川流。"}]}]},{"ID":"20260603112457-dh0raok","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dh0raok","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kjkxhek","Type":"NodeParagraph","Properties":{"id":"20260603112457-kjkxhek","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"休对故人思故国，且将新火试新茶。诗酒趁年华。"}]}]},{"ID":"20260603112457-ifywpb7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ifywpb7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-w68b7vt","Type":"NodeParagraph","Properties":{"id":"20260603112457-w68b7vt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：那些听不见音乐的人，认为那些跳舞的人疯了。"}]}]},{"ID":"20260603112457-vs00kcg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vs00kcg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uwf4eov","Type":"NodeParagraph","Properties":{"id":"20260603112457-uwf4eov","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：其实人跟树是一样的，越是向往高处的阳光，它的根就越要伸向黑暗的地底。"}]}]},{"ID":"20260603112457-un3euqk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-un3euqk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kvm8iqp","Type":"NodeParagraph","Properties":{"id":"20260603112457-kvm8iqp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"玉可碎而不可改其白，竹可焚而不可毁其节。"}]}]},{"ID":"20260603112457-p26huyl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p26huyl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-lcavnqm","Type":"NodeParagraph","Properties":{"id":"20260603112457-lcavnqm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"南风吹其心，摇摇为谁吐？"}]}]},{"ID":"20260603112457-sfsgpi0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-sfsgpi0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ejzvo56","Type":"NodeParagraph","Properties":{"id":"20260603112457-ejzvo56","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"巴金：希望是人生之需要。人如没有希望，何异江河干涸了流水？"}]}]},{"ID":"20260603112457-f7b2ls4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f7b2ls4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cfk6b2r","Type":"NodeParagraph","Properties":{"id":"20260603112457-cfk6b2r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"穷不失义，达不离道。"}]}]},{"ID":"20260603112457-srbublx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-srbublx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sg6czjm","Type":"NodeParagraph","Properties":{"id":"20260603112457-sg6czjm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为者常成，行者常至。"}]}]},{"ID":"20260603112457-xj401a4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xj401a4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bawaqi9","Type":"NodeParagraph","Properties":{"id":"20260603112457-bawaqi9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"青云当自致，何必求知音？"}]}]},{"ID":"20260603112457-9p26pvk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9p26pvk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fwovmfb","Type":"NodeParagraph","Properties":{"id":"20260603112457-fwovmfb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"争名者于朝，争利者于市。"}]}]},{"ID":"20260603112457-eoineyw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-eoineyw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-flutt24","Type":"NodeParagraph","Properties":{"id":"20260603112457-flutt24","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天上浮云如白衣，斯须变幻如苍狗。"}]}]},{"ID":"20260603112457-9lalcl9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9lalcl9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z6lr2b2","Type":"NodeParagraph","Properties":{"id":"20260603112457-z6lr2b2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"莺花犹怕春光老，岂可教人枉度春？"}]}]},{"ID":"20260603112457-mizw69t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mizw69t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1xaf7t9","Type":"NodeParagraph","Properties":{"id":"20260603112457-1xaf7t9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生芳秽有千载，世上荣枯无百年。"}]}]},{"ID":"20260603112457-tvf8wtl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tvf8wtl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qx0k2d3","Type":"NodeParagraph","Properties":{"id":"20260603112457-qx0k2d3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"当你的欢乐和悲哀变大的时候，世界就变小了。"}]}]},{"ID":"20260603112457-bymqavz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bymqavz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g9krja2","Type":"NodeParagraph","Properties":{"id":"20260603112457-g9krja2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"故将有五危，必死可杀，必生可虏，忿速可侮，廉洁可辱，爱民可烦。"}]}]},{"ID":"20260603112457-nwlo558","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nwlo558","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3ajgqrk","Type":"NodeParagraph","Properties":{"id":"20260603112457-3ajgqrk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"纵使文章惊海内，纸上苍生而已。"}]}]},{"ID":"20260603112457-wd1205j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wd1205j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d7ywfpf","Type":"NodeParagraph","Properties":{"id":"20260603112457-d7ywfpf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"死生契阔，与子成说。执子之手，与子偕老。"}]}]},{"ID":"20260603112457-kha0aua","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kha0aua","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pow6wwc","Type":"NodeParagraph","Properties":{"id":"20260603112457-pow6wwc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兼听则明，偏信则暗。"}]}]},{"ID":"20260603112457-csilyso","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-csilyso","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2wxmic9","Type":"NodeParagraph","Properties":{"id":"20260603112457-2wxmic9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"弃燕雀小志，作鸿鹄高翔。"}]}]},{"ID":"20260603112457-xf6z6mt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xf6z6mt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1gd055f","Type":"NodeParagraph","Properties":{"id":"20260603112457-1gd055f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"眼界要阔，遍历名山大川；度量要宏，熟读五经诸史。"}]}]},{"ID":"20260603112457-xwdaxn0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xwdaxn0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ac90pu8","Type":"NodeParagraph","Properties":{"id":"20260603112457-ac90pu8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地存肝胆，江山阅鬓华。"}]}]},{"ID":"20260603112457-kwf8shv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kwf8shv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2tnpegs","Type":"NodeParagraph","Properties":{"id":"20260603112457-2tnpegs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生不相见，动如参与商。"}]}]},{"ID":"20260603112457-d8g2i7p","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-d8g2i7p","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zpp0ub2","Type":"NodeParagraph","Properties":{"id":"20260603112457-zpp0ub2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"莫道君行早，更有早行人。"}]}]},{"ID":"20260603112457-sq2dsjq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-sq2dsjq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2ztmw2h","Type":"NodeParagraph","Properties":{"id":"20260603112457-2ztmw2h","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"大人者，不失其赤子之心者也。"}]}]},{"ID":"20260603112457-8yhg74i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8yhg74i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m4p8p1y","Type":"NodeParagraph","Properties":{"id":"20260603112457-m4p8p1y","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"英雄者，胸怀大志，腹有良谋，有包藏宇宙之机，吞吐天地之志者也。"}]}]},{"ID":"20260603112457-vn3yjp7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vn3yjp7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r6tn87l","Type":"NodeParagraph","Properties":{"id":"20260603112457-r6tn87l","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪里温柔，水边明秀，不借春工力。"}]}]},{"ID":"20260603112457-vpsswog","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vpsswog","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vqpunk5","Type":"NodeParagraph","Properties":{"id":"20260603112457-vqpunk5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良言一句三冬暖，恶语伤人六月寒。"}]}]},{"ID":"20260603112457-kn5h17j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kn5h17j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-blf6t2r","Type":"NodeParagraph","Properties":{"id":"20260603112457-blf6t2r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"学如弓弩，才如箭镞。"}]}]},{"ID":"20260603112457-ciqsvqq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ciqsvqq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x5t0pue","Type":"NodeParagraph","Properties":{"id":"20260603112457-x5t0pue","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人不读书，其犹夜行。"}]}]},{"ID":"20260603112457-90qucpj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-90qucpj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qfz74hv","Type":"NodeParagraph","Properties":{"id":"20260603112457-qfz74hv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"穷猿奔林，岂暇择木！"}]}]},{"ID":"20260603112457-gohpal5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gohpal5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-44pma7c","Type":"NodeParagraph","Properties":{"id":"20260603112457-44pma7c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"令在必信，法在必行。"}]}]},{"ID":"20260603112457-4brburv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4brburv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xcrups3","Type":"NodeParagraph","Properties":{"id":"20260603112457-xcrups3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"其疾如风，其徐如林，侵掠如火，不动如山，难知如阴，动如雷震。"}]}]},{"ID":"20260603112457-fe7lep6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fe7lep6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1cu0dxk","Type":"NodeParagraph","Properties":{"id":"20260603112457-1cu0dxk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天下熙熙，皆为利来；天下攘攘，皆为利往。"}]}]},{"ID":"20260603112457-nsey13f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nsey13f","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ijigxo2","Type":"NodeParagraph","Properties":{"id":"20260603112457-ijigxo2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我亦飘零久！十年来，深恩负尽，死生师友。"}]}]},{"ID":"20260603112457-qj48v7y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qj48v7y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y87119h","Type":"NodeParagraph","Properties":{"id":"20260603112457-y87119h","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"板凳要坐十年冷，文章不写一句空。"}]}]},{"ID":"20260603112457-2xg4xd8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2xg4xd8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bpt58et","Type":"NodeParagraph","Properties":{"id":"20260603112457-bpt58et","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"有心为善，虽善不赏；无心为恶，虽恶不罚。"}]}]},{"ID":"20260603112457-qy9lj1w","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qy9lj1w","updated":"20260603112457"},"Children":[{"ID":"20260603112457-x0xr526","Type":"NodeParagraph","Properties":{"id":"20260603112457-x0xr526","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不目见口问，不能尽知也。"}]}]},{"ID":"20260603112457-m66dhnc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m66dhnc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-w2ciaks","Type":"NodeParagraph","Properties":{"id":"20260603112457-w2ciaks","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一年之计，莫如树谷；十年之计，莫如树木；终身之计，莫如树人。"}]}]},{"ID":"20260603112457-h608nxj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-h608nxj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zdr7ax1","Type":"NodeParagraph","Properties":{"id":"20260603112457-zdr7ax1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不因幸运而故步自封，不因厄运而一蹶不振。"}]}]},{"ID":"20260603112457-zb93qcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zb93qcq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0xgebk5","Type":"NodeParagraph","Properties":{"id":"20260603112457-0xgebk5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"良弓难张，然可以及高入深；良马难乘，然可以任重致远。"}]}]},{"ID":"20260603112457-761ebwc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-761ebwc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u24kohh","Type":"NodeParagraph","Properties":{"id":"20260603112457-u24kohh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"上兵伐谋，其次伐交，其次伐兵，其下攻城。"}]}]},{"ID":"20260603112457-vzufbbf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vzufbbf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wvzmtm4","Type":"NodeParagraph","Properties":{"id":"20260603112457-wvzmtm4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"志合者不以山海为远，道乖者不以咫尺为近。"}]}]},{"ID":"20260603112457-ls4aock","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ls4aock","updated":"20260603112457"},"Children":[{"ID":"20260603112457-frbwrnx","Type":"NodeParagraph","Properties":{"id":"20260603112457-frbwrnx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海水梦悠悠，君愁我亦愁。南风知我意，吹梦到西洲。"}]}]},{"ID":"20260603112457-rvw72se","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rvw72se","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p5y7afj","Type":"NodeParagraph","Properties":{"id":"20260603112457-p5y7afj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不幸者常常愿意同幸运者相比，抱怨自己的运气。幸运者常常不愿同不幸者相比，相信自己的努力。"}]}]},{"ID":"20260603112457-kuw0dpi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kuw0dpi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7hc9r04","Type":"NodeParagraph","Properties":{"id":"20260603112457-7hc9r04","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"怯生于勇，弱生于强。"}]}]},{"ID":"20260603112457-y987h8o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y987h8o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6hb02wj","Type":"NodeParagraph","Properties":{"id":"20260603112457-6hb02wj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"贵上极则反贱，贱下极则反贵。贵出如粪土，贱取如珠玉。"}]}]},{"ID":"20260603112457-udszxxh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-udszxxh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uki8qho","Type":"NodeParagraph","Properties":{"id":"20260603112457-uki8qho","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"有志者事竟成破釜沉舟百二秦关终属楚，苦心人天不负卧薪尝胆三千越甲可吞吴。"}]}]},{"ID":"20260603112457-fe2dd4b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fe2dd4b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jc0ovxp","Type":"NodeParagraph","Properties":{"id":"20260603112457-jc0ovxp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昔日之得不足以自衿，今日之成不容以自限。"}]}]},{"ID":"20260603112457-t77n3xy","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t77n3xy","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9v7ofuh","Type":"NodeParagraph","Properties":{"id":"20260603112457-9v7ofuh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不善操舟者，恶河之曲。"}]}]},{"ID":"20260603112457-gn7msv5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gn7msv5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qbwkuh8","Type":"NodeParagraph","Properties":{"id":"20260603112457-qbwkuh8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"操千曲而后晓声，观千剑而后识器。"}]}]},{"ID":"20260603112457-x5zvq85","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-x5zvq85","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5qoklav","Type":"NodeParagraph","Properties":{"id":"20260603112457-5qoklav","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"长安何处在，只在马蹄下。"}]}]},{"ID":"20260603112457-3jxpzdt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3jxpzdt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7anwnd5","Type":"NodeParagraph","Properties":{"id":"20260603112457-7anwnd5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人情阅尽秋云厚，世事经多蜀道平。"}]}]},{"ID":"20260603112457-hm8bvog","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hm8bvog","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cy2aw9d","Type":"NodeParagraph","Properties":{"id":"20260603112457-cy2aw9d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"志行万里者，不中道而辍足。"}]}]},{"ID":"20260603112457-yhmhklx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yhmhklx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-axe9bjq","Type":"NodeParagraph","Properties":{"id":"20260603112457-axe9bjq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"交友须带三分侠气，做人要存一点素心。"}]}]},{"ID":"20260603112457-vadvco8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vadvco8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1ls50rc","Type":"NodeParagraph","Properties":{"id":"20260603112457-1ls50rc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"男儿不展风云志，空负天生八尺躯。"}]}]},{"ID":"20260603112457-p2pfbeo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p2pfbeo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ughclub","Type":"NodeParagraph","Properties":{"id":"20260603112457-ughclub","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"愿作远方兽，步步比肩行。愿作深山木，枝枝连理生。"}]}]},{"ID":"20260603112457-6odnzzq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6odnzzq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-adfwr8h","Type":"NodeParagraph","Properties":{"id":"20260603112457-adfwr8h","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵不厌诈，将贵知机。"}]}]},{"ID":"20260603112457-usgeu9c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-usgeu9c","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uk7vmuz","Type":"NodeParagraph","Properties":{"id":"20260603112457-uk7vmuz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"上士闻道，勤而行之；中士闻道，若存若亡；下士闻道，大笑之。不笑不足以为道。"}]}]},{"ID":"20260603112457-v0izcqq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v0izcqq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-btsmtit","Type":"NodeParagraph","Properties":{"id":"20260603112457-btsmtit","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子慎始，差若毫厘，缪以千里。"}]}]},{"ID":"20260603112457-gcjuo3e","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gcjuo3e","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eln51rb","Type":"NodeParagraph","Properties":{"id":"20260603112457-eln51rb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古来多被虚名误，宁负虚名身莫负。"}]}]},{"ID":"20260603112457-zhgcas5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zhgcas5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j6bkzui","Type":"NodeParagraph","Properties":{"id":"20260603112457-j6bkzui","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我志在寥阔，畴昔梦登天。摩挲素月，俯仰已千年。"}]}]},{"ID":"20260603112457-bkao116","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bkao116","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jy0nmlr","Type":"NodeParagraph","Properties":{"id":"20260603112457-jy0nmlr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我们每个人出生的时候，并非是两手空空，而是捏了一张生命的借记卡。"}]}]},{"ID":"20260603112457-smaocqq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-smaocqq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-abhqj7m","Type":"NodeParagraph","Properties":{"id":"20260603112457-abhqj7m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"好风凭借力，送我上青云。"}]}]},{"ID":"20260603112457-13i6mfm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-13i6mfm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kxkvol7","Type":"NodeParagraph","Properties":{"id":"20260603112457-kxkvol7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"玉在山而草木润，渊生珠而崖不枯。"}]}]},{"ID":"20260603112457-cqglgss","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cqglgss","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z4o66fd","Type":"NodeParagraph","Properties":{"id":"20260603112457-z4o66fd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"学之染人，甚于丹青。"}]}]},{"ID":"20260603112457-he9sgn7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-he9sgn7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wzy1vt4","Type":"NodeParagraph","Properties":{"id":"20260603112457-wzy1vt4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天地有万古，此身不再得；人生只百年，此日最易过。"}]}]},{"ID":"20260603112457-mmw9l2o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mmw9l2o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-y122tw9","Type":"NodeParagraph","Properties":{"id":"20260603112457-y122tw9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"十有九人堪白眼，百无一用是书生。"}]}]},{"ID":"20260603112457-syog3hi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-syog3hi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-aqe7o7c","Type":"NodeParagraph","Properties":{"id":"20260603112457-aqe7o7c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丈夫志四海，万里犹比邻。"}]}]},{"ID":"20260603112457-v4hwjgc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-v4hwjgc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-svs3fx9","Type":"NodeParagraph","Properties":{"id":"20260603112457-svs3fx9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"仗义每多屠狗辈，负心多是读书人。"}]}]},{"ID":"20260603112457-kwd4sl6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kwd4sl6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-blfrsi3","Type":"NodeParagraph","Properties":{"id":"20260603112457-blfrsi3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"涓涓不塞，将为江河。荧荧不救，炎炎奈何。"}]}]},{"ID":"20260603112457-01b0y6k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-01b0y6k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nhsu1j1","Type":"NodeParagraph","Properties":{"id":"20260603112457-nhsu1j1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生如寄，多忧何为？今我不乐，岁月如驰。"}]}]},{"ID":"20260603112457-fvrsqcq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fvrsqcq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2opivkr","Type":"NodeParagraph","Properties":{"id":"20260603112457-2opivkr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天行有常，不为尧存，不为桀亡。"}]}]},{"ID":"20260603112457-r8lhwai","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r8lhwai","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ifp108b","Type":"NodeParagraph","Properties":{"id":"20260603112457-ifp108b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"读书志在圣贤，非徒科第；为官心存君国，岂计身家？"}]}]},{"ID":"20260603112457-ad3mp7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ad3mp7j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-v5hbaor","Type":"NodeParagraph","Properties":{"id":"20260603112457-v5hbaor","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"少而好学，如日出之阳；壮而好学，如日中之光；老而好学，如秉烛之明。"}]}]},{"ID":"20260603112457-mcwcisw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-mcwcisw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xlns89n","Type":"NodeParagraph","Properties":{"id":"20260603112457-xlns89n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"纪伯伦：不要因为走得太远而忘记为什么出发。"}]}]},{"ID":"20260603112457-wn22p1d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wn22p1d","updated":"20260603112457"},"Children":[{"ID":"20260603112457-upag416","Type":"NodeParagraph","Properties":{"id":"20260603112457-upag416","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"用赏者贵信，用罚者贵必。"}]}]},{"ID":"20260603112457-tq39wby","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tq39wby","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0e4dcax","Type":"NodeParagraph","Properties":{"id":"20260603112457-0e4dcax","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"傲不可长，欲不可纵，乐不可极，志不可满。"}]}]},{"ID":"20260603112457-tn4ee5b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-tn4ee5b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dy2cn58","Type":"NodeParagraph","Properties":{"id":"20260603112457-dy2cn58","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子爱财，取之有道。"}]}]},{"ID":"20260603112457-w2ndkkq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w2ndkkq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oychrrh","Type":"NodeParagraph","Properties":{"id":"20260603112457-oychrrh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"余光中：敢在时间里自焚的人，必在永恒里结晶。"}]}]},{"ID":"20260603112457-ciscuml","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ciscuml","updated":"20260603112457"},"Children":[{"ID":"20260603112457-scpbecb","Type":"NodeParagraph","Properties":{"id":"20260603112457-scpbecb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"主不可以怒而兴师，将不可以愠而致战；合于利而动，不合于利而止。"}]}]},{"ID":"20260603112457-noiba8o","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-noiba8o","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ggkhbzy","Type":"NodeParagraph","Properties":{"id":"20260603112457-ggkhbzy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兵形象水，水之形，避高而趋下，兵之形，避实而击虚。"}]}]},{"ID":"20260603112457-nv1vkjz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nv1vkjz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3gajg33","Type":"NodeParagraph","Properties":{"id":"20260603112457-3gajg33","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"海子：永远是这样，风后面是风，天空上面是天空，道路前面还是道路。"}]}]},{"ID":"20260603112457-rpu9o9c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rpu9o9c","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yxb1d8g","Type":"NodeParagraph","Properties":{"id":"20260603112457-yxb1d8g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"史铁生：如果你抑郁了，说明你活在过去；如果你焦虑了，说明你活在未来；如果你平静了，才说明你活在现在。"}]}]},{"ID":"20260603112457-b2d9oec","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-b2d9oec","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k0orw09","Type":"NodeParagraph","Properties":{"id":"20260603112457-k0orw09","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"对愁人勿乐，对哭人勿笑，对失意人勿矜。"}]}]},{"ID":"20260603112457-qxdggl0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-qxdggl0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wsqa0mj","Type":"NodeParagraph","Properties":{"id":"20260603112457-wsqa0mj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知胜有五：知可以战与不可以战者胜，识众寡之用者胜，上下同欲者胜，以虞待不虞者胜，将能而君不御者胜。"}]}]},{"ID":"20260603112457-atmqbkm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-atmqbkm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-17bqtp9","Type":"NodeParagraph","Properties":{"id":"20260603112457-17bqtp9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"钝学累功，不妨精熟。"}]}]},{"ID":"20260603112457-t2zao8y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-t2zao8y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-t6xa7oz","Type":"NodeParagraph","Properties":{"id":"20260603112457-t6xa7oz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"闭门即是深山，读书随处净土。"}]}]},{"ID":"20260603112457-zo72el3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zo72el3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zyet6he","Type":"NodeParagraph","Properties":{"id":"20260603112457-zyet6he","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人非生而知之者，孰能无惑?惑而不从师，其为惑也，终不解矣。"}]}]},{"ID":"20260603112457-lp33qg4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lp33qg4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4stmeiu","Type":"NodeParagraph","Properties":{"id":"20260603112457-4stmeiu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"见胜不过众人之所知，非善之善者也；战胜而天下曰善，非善之善者也。"}]}]},{"ID":"20260603112457-owaxw8y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-owaxw8y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qltz7kh","Type":"NodeParagraph","Properties":{"id":"20260603112457-qltz7kh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"折芦花赠远，零落一身秋。"}]}]},{"ID":"20260603112457-c3ylp91","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c3ylp91","updated":"20260603112457"},"Children":[{"ID":"20260603112457-k9vd257","Type":"NodeParagraph","Properties":{"id":"20260603112457-k9vd257","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"老骥伏枥志千里，短锥处囊半寸锋。"}]}]},{"ID":"20260603112457-e980m7l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-e980m7l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-skgrodm","Type":"NodeParagraph","Properties":{"id":"20260603112457-skgrodm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"只要厄运打不垮信念，希望之光就会驱散绝望之云。"}]}]},{"ID":"20260603112457-x3hpa6u","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-x3hpa6u","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fzt47lv","Type":"NodeParagraph","Properties":{"id":"20260603112457-fzt47lv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"以势交者，势尽则疏，以利合者，利尽则散。"}]}]},{"ID":"20260603112457-ciot7n5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ciot7n5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-by9dipi","Type":"NodeParagraph","Properties":{"id":"20260603112457-by9dipi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"如月之恒，如日之升。"}]}]},{"ID":"20260603112457-7nr7yix","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7nr7yix","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6im2xbs","Type":"NodeParagraph","Properties":{"id":"20260603112457-6im2xbs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"合军聚众，务在激气。"}]}]},{"ID":"20260603112457-1vkoty5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1vkoty5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xdc47tj","Type":"NodeParagraph","Properties":{"id":"20260603112457-xdc47tj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"贝尔纳：构成我们学习最大障碍的是已知的东西，而不是未知的东西。"}]}]},{"ID":"20260603112457-nowzlu6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nowzlu6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pljh40r","Type":"NodeParagraph","Properties":{"id":"20260603112457-pljh40r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"约瑟夫·海勒《第二十二条军规》：任何值得为它而死的东西，肯定值得为它而生。"}]}]},{"ID":"20260603112457-jumny6h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jumny6h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bssu4n6","Type":"NodeParagraph","Properties":{"id":"20260603112457-bssu4n6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"云路鹏程九万里，雪窗萤火二十年。"}]}]},{"ID":"20260603112457-wo15nfm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wo15nfm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-62wnazf","Type":"NodeParagraph","Properties":{"id":"20260603112457-62wnazf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"华而不实，怨之所聚也。"}]}]},{"ID":"20260603112457-oktbabr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oktbabr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ks9kfr5","Type":"NodeParagraph","Properties":{"id":"20260603112457-ks9kfr5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"精卫衔微木，将以填沧海；刑天舞干戚，猛志固常在。"}]}]},{"ID":"20260603112457-hyc7ciu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hyc7ciu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9ot6w8q","Type":"NodeParagraph","Properties":{"id":"20260603112457-9ot6w8q","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"自知者不怨人，知命者不怨天；怨人者穷，怨天者无志。"}]}]},{"ID":"20260603112457-k3qq24c","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k3qq24c","updated":"20260603112457"},"Children":[{"ID":"20260603112457-l97rrg2","Type":"NodeParagraph","Properties":{"id":"20260603112457-l97rrg2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"丹青不知老将至，富贵于我如浮云。"}]}]},{"ID":"20260603112457-dyu1ki6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dyu1ki6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-aj0cfp4","Type":"NodeParagraph","Properties":{"id":"20260603112457-aj0cfp4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"胡适：凡富于创造性的人必敏于模仿，凡不善于模仿的人决不能创造。"}]}]},{"ID":"20260603112457-ki6w53g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ki6w53g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ora2cb7","Type":"NodeParagraph","Properties":{"id":"20260603112457-ora2cb7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"节义傲青云，文章高白雪。"}]}]},{"ID":"20260603112457-i5qch66","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i5qch66","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yw14d1r","Type":"NodeParagraph","Properties":{"id":"20260603112457-yw14d1r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"提得起，放得下，算得到，做得完，看得破，撇得开。"}]}]},{"ID":"20260603112457-vxkrzqu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vxkrzqu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ldb593f","Type":"NodeParagraph","Properties":{"id":"20260603112457-ldb593f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪曾祺：一定要爱着点什么，恰似草木对光阴的钟情。"}]}]},{"ID":"20260603112457-o319ml5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o319ml5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-uxpjunf","Type":"NodeParagraph","Properties":{"id":"20260603112457-uxpjunf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我有所念人，隔在远远乡。我有所感事，结在深深肠。"}]}]},{"ID":"20260603112457-zkk9qrz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zkk9qrz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8mo3u5t","Type":"NodeParagraph","Properties":{"id":"20260603112457-8mo3u5t","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"草不谢荣于春风，木不怨落于秋天。"}]}]},{"ID":"20260603112457-5ucbdp5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5ucbdp5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4hzxqnj","Type":"NodeParagraph","Properties":{"id":"20260603112457-4hzxqnj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一竹一兰一石，有节有香有骨。"}]}]},{"ID":"20260603112457-7a0dd50","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7a0dd50","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i7cwtrq","Type":"NodeParagraph","Properties":{"id":"20260603112457-i7cwtrq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"笔落惊风雨，诗成泣鬼神。"}]}]},{"ID":"20260603112457-7ea1mbe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7ea1mbe","updated":"20260603112457"},"Children":[{"ID":"20260603112457-21cridm","Type":"NodeParagraph","Properties":{"id":"20260603112457-21cridm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。"}]}]},{"ID":"20260603112457-yfir4wb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yfir4wb","updated":"20260603112457"},"Children":[{"ID":"20260603112457-edk9o58","Type":"NodeParagraph","Properties":{"id":"20260603112457-edk9o58","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"山不让尘，川不辞盈。"}]}]},{"ID":"20260603112457-4hs2m8y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4hs2m8y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eyg92po","Type":"NodeParagraph","Properties":{"id":"20260603112457-eyg92po","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"皑如山上雪，皎若云间月。"}]}]},{"ID":"20260603112457-luj6o3a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-luj6o3a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cm0i4bz","Type":"NodeParagraph","Properties":{"id":"20260603112457-cm0i4bz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"客子光阴诗卷里，杏花消息雨声中。"}]}]},{"ID":"20260603112457-7augz3m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7augz3m","updated":"20260603112457"},"Children":[{"ID":"20260603112457-01to2o2","Type":"NodeParagraph","Properties":{"id":"20260603112457-01to2o2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：我们的眼睛就是我们的监狱，而目光所及之处就是监狱的围墙。"}]}]},{"ID":"20260603112457-ppoqcqo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ppoqcqo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jk0ew7i","Type":"NodeParagraph","Properties":{"id":"20260603112457-jk0ew7i","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪中送炭人间少，锦上添花世上多。"}]}]},{"ID":"20260603112457-a7693cp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-a7693cp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jvxzp03","Type":"NodeParagraph","Properties":{"id":"20260603112457-jvxzp03","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"蒲柳之姿，望秋而落；松柏之质，经霜弥茂。"}]}]},{"ID":"20260603112457-kh3pwvs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kh3pwvs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4rsute0","Type":"NodeParagraph","Properties":{"id":"20260603112457-4rsute0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"不戚戚于贫贱，不汲汲于富贵。"}]}]},{"ID":"20260603112457-uzdtvsq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-uzdtvsq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9c5a7jd","Type":"NodeParagraph","Properties":{"id":"20260603112457-9c5a7jd","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"门前红叶地，不扫待知音。"}]}]},{"ID":"20260603112457-1g36m1n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1g36m1n","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g734l7n","Type":"NodeParagraph","Properties":{"id":"20260603112457-g734l7n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"村上春树：这个世界上根本没有正确的选择，我们只不过是要努力奋斗，使当初的选择变得正确。"}]}]},{"ID":"20260603112457-7k9opgp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7k9opgp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-smxd8si","Type":"NodeParagraph","Properties":{"id":"20260603112457-smxd8si","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"缘木求鱼，煎水作冰。"}]}]},{"ID":"20260603112457-2ngms2g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2ngms2g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-c52009b","Type":"NodeParagraph","Properties":{"id":"20260603112457-c52009b","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苟日新，日日新，又日新。"}]}]},{"ID":"20260603112457-hxhsnuh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hxhsnuh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jw2bwo0","Type":"NodeParagraph","Properties":{"id":"20260603112457-jw2bwo0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"贫无可奈惟求俭，拙亦何妨只要勤。"}]}]},{"ID":"20260603112457-5927iyd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5927iyd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ja12w8c","Type":"NodeParagraph","Properties":{"id":"20260603112457-ja12w8c","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"文章千古事，得失寸心知。"}]}]},{"ID":"20260603112457-md94e7j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-md94e7j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3vc1cvt","Type":"NodeParagraph","Properties":{"id":"20260603112457-3vc1cvt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雨滴能击穿石头，并不是下落的速度快，而是因为掉落在石头上的次数多。"}]}]},{"ID":"20260603112457-zhsded0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zhsded0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qkdyye2","Type":"NodeParagraph","Properties":{"id":"20260603112457-qkdyye2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人有逆天之时，天无绝人之路。"}]}]},{"ID":"20260603112457-zy3kvjg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zy3kvjg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-53g4ii6","Type":"NodeParagraph","Properties":{"id":"20260603112457-53g4ii6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"宁为宇宙闲吟客，怕作乾坤窃禄人。"}]}]},{"ID":"20260603112457-cu45819","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cu45819","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zjntl5g","Type":"NodeParagraph","Properties":{"id":"20260603112457-zjntl5g","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"受光于隙见一床，受光于窗见室央，受光于庭户见一堂，受光于天下照四方。"}]}]},{"ID":"20260603112457-phrzi0h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-phrzi0h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gdtsi6f","Type":"NodeParagraph","Properties":{"id":"20260603112457-gdtsi6f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马不可以服重，牛不可以追速。"}]}]},{"ID":"20260603112457-74dn0qn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-74dn0qn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1bt66kj","Type":"NodeParagraph","Properties":{"id":"20260603112457-1bt66kj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"改过不吝，从善如流。"}]}]},{"ID":"20260603112457-h61irhl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-h61irhl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hywcxq9","Type":"NodeParagraph","Properties":{"id":"20260603112457-hywcxq9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"虚负凌云万丈才，一生襟抱未曾开。鸟啼花落人何在，竹死桐枯凤不来。"}]}]},{"ID":"20260603112457-jt1ljvt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jt1ljvt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hyabiy3","Type":"NodeParagraph","Properties":{"id":"20260603112457-hyabiy3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"兰生幽谷，不为莫服而不芳；舟在江海，不为莫乘而不浮；君子行义，不为莫知而止休。"}]}]},{"ID":"20260603112457-rgws1op","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rgws1op","updated":"20260603112457"},"Children":[{"ID":"20260603112457-to2fs9s","Type":"NodeParagraph","Properties":{"id":"20260603112457-to2fs9s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一日不思量，也攒眉千度。"}]}]},{"ID":"20260603112457-psuumnh","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-psuumnh","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fhjps1a","Type":"NodeParagraph","Properties":{"id":"20260603112457-fhjps1a","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"彊弩之极，矢不能穿鲁缟；冲风之末，力不能漂鸿毛。"}]}]},{"ID":"20260603112457-9y4jbyj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9y4jbyj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-n7x8n85","Type":"NodeParagraph","Properties":{"id":"20260603112457-n7x8n85","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"时来天地皆同力，运去英雄不自由。"}]}]},{"ID":"20260603112457-1iq290j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1iq290j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m052bw8","Type":"NodeParagraph","Properties":{"id":"20260603112457-m052bw8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"倒持干戈，授人以柄。"}]}]},{"ID":"20260603112457-g65pauc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g65pauc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-djd2ijm","Type":"NodeParagraph","Properties":{"id":"20260603112457-djd2ijm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生一世，草生一春。来如风雨，去似微尘。"}]}]},{"ID":"20260603112457-m9xkzpc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-m9xkzpc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0conwxg","Type":"NodeParagraph","Properties":{"id":"20260603112457-0conwxg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"雪莱：未来不足惧，过往不须泣。"}]}]},{"ID":"20260603112457-cfjutjj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cfjutjj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-df3oq9a","Type":"NodeParagraph","Properties":{"id":"20260603112457-df3oq9a","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"从善如登，从恶如崩。"}]}]},{"ID":"20260603112457-vfxly7h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vfxly7h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-24v6z9e","Type":"NodeParagraph","Properties":{"id":"20260603112457-24v6z9e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"春生、夏长、秋收、冬藏，天之正也。"}]}]},{"ID":"20260603112457-xq0h55t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xq0h55t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-58pgo7u","Type":"NodeParagraph","Properties":{"id":"20260603112457-58pgo7u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"前事不忘，后事之师。"}]}]},{"ID":"20260603112457-hzxwzyz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hzxwzyz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-se79hpq","Type":"NodeParagraph","Properties":{"id":"20260603112457-se79hpq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"逢人不说人间事，便是人间无事人。"}]}]},{"ID":"20260603112457-f37gkzu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f37gkzu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-balmucb","Type":"NodeParagraph","Properties":{"id":"20260603112457-balmucb","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"花开花落树之常，能上能下人中强。"}]}]},{"ID":"20260603112457-2jfixro","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2jfixro","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kyzil12","Type":"NodeParagraph","Properties":{"id":"20260603112457-kyzil12","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"立品同白玉，读书到青云。"}]}]},{"ID":"20260603112457-hil6hb0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hil6hb0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-if3qzkf","Type":"NodeParagraph","Properties":{"id":"20260603112457-if3qzkf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陀思妥耶夫斯基：爱具体的人，不要爱抽象的人。"}]}]},{"ID":"20260603112457-wt3qj78","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wt3qj78","updated":"20260603112457"},"Children":[{"ID":"20260603112457-d99rdrq","Type":"NodeParagraph","Properties":{"id":"20260603112457-d99rdrq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"凭君莫话封侯事，一将功成万骨枯。"}]}]},{"ID":"20260603112457-85e3uwm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-85e3uwm","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1xvlwf5","Type":"NodeParagraph","Properties":{"id":"20260603112457-1xvlwf5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。有无相生，难易相成，长短相形，高下相盈，音声相和，前后相随，恒也。"}]}]},{"ID":"20260603112457-cdtap7v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cdtap7v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-67pyyw7","Type":"NodeParagraph","Properties":{"id":"20260603112457-67pyyw7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子之心事，天青日白，不可使人不知；君子之才华，玉韫珠藏，不可使人易知。"}]}]},{"ID":"20260603112457-nor59nd","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nor59nd","updated":"20260603112457"},"Children":[{"ID":"20260603112457-915oas8","Type":"NodeParagraph","Properties":{"id":"20260603112457-915oas8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"除掉荒草的最好办法，不是让除完草的土地荒着，而是种上庄稼。"}]}]},{"ID":"20260603112457-o8cxjjn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-o8cxjjn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-py2pu4p","Type":"NodeParagraph","Properties":{"id":"20260603112457-py2pu4p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"善战者，求之于势，不责于人。故能择人而任势。"}]}]},{"ID":"20260603112457-nsbwxer","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nsbwxer","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oyel1b3","Type":"NodeParagraph","Properties":{"id":"20260603112457-oyel1b3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"川泽纳污，所以成其深；山岳藏疾，所以就其大。"}]}]},{"ID":"20260603112457-a9fllf3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-a9fllf3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9btulre","Type":"NodeParagraph","Properties":{"id":"20260603112457-9btulre","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"覆水不可收，行云难重寻。"}]}]},{"ID":"20260603112457-lt501fn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lt501fn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gu1hzf7","Type":"NodeParagraph","Properties":{"id":"20260603112457-gu1hzf7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"相鼠有皮，人而无仪！人而无仪，不死何为？"}]}]},{"ID":"20260603112457-99l9d1q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-99l9d1q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-9asa14y","Type":"NodeParagraph","Properties":{"id":"20260603112457-9asa14y","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"为天地立心，为生民立命，为往圣继绝学，为万世开太平。"}]}]},{"ID":"20260603112457-jbidlcz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jbidlcz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-3ifbzp4","Type":"NodeParagraph","Properties":{"id":"20260603112457-3ifbzp4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"狡兔死，走狗烹；飞鸟尽，良弓藏；敌国破，谋臣亡。"}]}]},{"ID":"20260603112457-xuwf62s","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-xuwf62s","updated":"20260603112457"},"Children":[{"ID":"20260603112457-h52no1u","Type":"NodeParagraph","Properties":{"id":"20260603112457-h52no1u","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"马丁·路德·金：我们这一代人终将感到悔恨，不仅仅因为坏人的可憎言行，更因为好人的可怕沉默。"}]}]},{"ID":"20260603112457-3smgtlz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3smgtlz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-98bjn7n","Type":"NodeParagraph","Properties":{"id":"20260603112457-98bjn7n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"我本将心向明月，奈何明月照沟渠。"}]}]},{"ID":"20260603112457-cq165dr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cq165dr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8ww0ebs","Type":"NodeParagraph","Properties":{"id":"20260603112457-8ww0ebs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"临渊羡鱼，不如退而结网；扬汤止沸，不如去火抽薪。"}]}]},{"ID":"20260603112457-jez92zl","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jez92zl","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wwov2ws","Type":"NodeParagraph","Properties":{"id":"20260603112457-wwov2ws","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"芳林新叶催陈叶，流水前波让后波。"}]}]},{"ID":"20260603112457-z7w4dg8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-z7w4dg8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nu3rqdt","Type":"NodeParagraph","Properties":{"id":"20260603112457-nu3rqdt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"日出扶桑一丈高，人间万事细如毛。野夫怒见不平处，磨损胸中万古刀。"}]}]},{"ID":"20260603112457-bgbjhvi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bgbjhvi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j6juic3","Type":"NodeParagraph","Properties":{"id":"20260603112457-j6juic3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：果实的事业是尊贵的，花的事业是甜美的，但是让我做叶的事业吧，叶是谦逊地、专心地垂着绿荫的。"}]}]},{"ID":"20260603112457-kfpbawu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kfpbawu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wu1bapv","Type":"NodeParagraph","Properties":{"id":"20260603112457-wu1bapv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子耻不修，不耻见污。"}]}]},{"ID":"20260603112457-yhxzmhu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yhxzmhu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jwvt9fw","Type":"NodeParagraph","Properties":{"id":"20260603112457-jwvt9fw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陶行知：做学问就是要学要问。光学不问，只做到一半；光问不学，也只是一半。又学又问，才是完整的学问。"}]}]},{"ID":"20260603112457-fcw5irw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fcw5irw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dfuifeh","Type":"NodeParagraph","Properties":{"id":"20260603112457-dfuifeh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"恶不可积，过不可长。"}]}]},{"ID":"20260603112457-91x9f08","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-91x9f08","updated":"20260603112457"},"Children":[{"ID":"20260603112457-jm7uxtr","Type":"NodeParagraph","Properties":{"id":"20260603112457-jm7uxtr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"众里嫣然通一顾，人间颜色如尘土。"}]}]},{"ID":"20260603112457-s2evcmo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s2evcmo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oqd160o","Type":"NodeParagraph","Properties":{"id":"20260603112457-oqd160o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"将者，智、信、仁、勇、严也。"}]}]},{"ID":"20260603112457-vd5ikvo","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vd5ikvo","updated":"20260603112457"},"Children":[{"ID":"20260603112457-e07b2r3","Type":"NodeParagraph","Properties":{"id":"20260603112457-e07b2r3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"老舍：才华是刀刃，辛苦是磨刀石。很锋利的刀刃，若日久不用石磨，也会生锈，成为废物。"}]}]},{"ID":"20260603112457-dyrdwd2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dyrdwd2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-61uh6fm","Type":"NodeParagraph","Properties":{"id":"20260603112457-61uh6fm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"少年侠气，交结五都雄。肝胆洞，毛发耸。立谈中，死生同。一诺千金重。"}]}]},{"ID":"20260603112457-f5nd5o2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f5nd5o2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-10z0z8n","Type":"NodeParagraph","Properties":{"id":"20260603112457-10z0z8n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"罗曼·罗兰 ：一个人的绝对自由是疯狂，一个国家的绝对自由是混乱。"}]}]},{"ID":"20260603112457-1mfyaje","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1mfyaje","updated":"20260603112457"},"Children":[{"ID":"20260603112457-iqgbkh0","Type":"NodeParagraph","Properties":{"id":"20260603112457-iqgbkh0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"学然后知不足，教然后知困。"}]}]},{"ID":"20260603112457-29gp1sw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-29gp1sw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bvd2il2","Type":"NodeParagraph","Properties":{"id":"20260603112457-bvd2il2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"记人之长，忘人之短。"}]}]},{"ID":"20260603112457-u2j38p8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u2j38p8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-94tsig6","Type":"NodeParagraph","Properties":{"id":"20260603112457-94tsig6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知彼知己者，百战不殆；不知彼而知己，一胜一负，不知彼，不知己，每战必殆。"}]}]},{"ID":"20260603112457-i9vkznq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i9vkznq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xe3l807","Type":"NodeParagraph","Properties":{"id":"20260603112457-xe3l807","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"月缺不改光，剑折不改刚。月缺魄易满，剑折铸复良。势利压山岳，难屈志士肠。男儿自有守，可杀不可苟。"}]}]},{"ID":"20260603112457-zyyx03d","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zyyx03d","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bovmsyt","Type":"NodeParagraph","Properties":{"id":"20260603112457-bovmsyt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生贵相知，何必金与钱？"}]}]},{"ID":"20260603112457-yaaujcf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yaaujcf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qk2pgrr","Type":"NodeParagraph","Properties":{"id":"20260603112457-qk2pgrr","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"有真才者，必不矜才。有实学者，必不夸学。"}]}]},{"ID":"20260603112457-9g1vkoe","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9g1vkoe","updated":"20260603112457"},"Children":[{"ID":"20260603112457-cbhaj0e","Type":"NodeParagraph","Properties":{"id":"20260603112457-cbhaj0e","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"薄我货者也，欲与我市者也；訾我行者，欲与我友者也。"}]}]},{"ID":"20260603112457-3ckjos6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3ckjos6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0ile3nv","Type":"NodeParagraph","Properties":{"id":"20260603112457-0ile3nv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"风乍起，吹皱一池春水。"}]}]},{"ID":"20260603112457-17fu14i","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-17fu14i","updated":"20260603112457"},"Children":[{"ID":"20260603112457-fybj3sl","Type":"NodeParagraph","Properties":{"id":"20260603112457-fybj3sl","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生万事须自为，跬步江山即寥廓。"}]}]},{"ID":"20260603112457-u5qzqbb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u5qzqbb","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p2apcej","Type":"NodeParagraph","Properties":{"id":"20260603112457-p2apcej","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"十年磨一剑，霜刃未曾试。今日把示君，谁有不平事？"}]}]},{"ID":"20260603112457-4mhuqo1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4mhuqo1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pj2sppi","Type":"NodeParagraph","Properties":{"id":"20260603112457-pj2sppi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"草木秋死，松柏独在。"}]}]},{"ID":"20260603112457-bjaavvs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-bjaavvs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8yfpqmf","Type":"NodeParagraph","Properties":{"id":"20260603112457-8yfpqmf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生是一匹马，轻快而健壮的马。人，要像骑手那样大胆而细心地驾驭它。"}]}]},{"ID":"20260603112457-w0coo6f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w0coo6f","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o3p4dzu","Type":"NodeParagraph","Properties":{"id":"20260603112457-o3p4dzu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"水广者鱼大，山高者树修。"}]}]},{"ID":"20260603112457-deen8ki","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-deen8ki","updated":"20260603112457"},"Children":[{"ID":"20260603112457-m8wivht","Type":"NodeParagraph","Properties":{"id":"20260603112457-m8wivht","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人生如梦，把梦看得太认真，固然是个大傻瓜；但以为人生如梦，就以为不必认真，也是个头等大傻瓜。"}]}]},{"ID":"20260603112457-3nxrt0l","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3nxrt0l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8mywgme","Type":"NodeParagraph","Properties":{"id":"20260603112457-8mywgme","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"一叶浮萍归大海，为人何处不相逢！"}]}]},{"ID":"20260603112457-9mrmqu2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9mrmqu2","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vujl93j","Type":"NodeParagraph","Properties":{"id":"20260603112457-vujl93j","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"力田不如逢年，善仕不如遇合。"}]}]},{"ID":"20260603112457-gg8p7ad","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gg8p7ad","updated":"20260603112457"},"Children":[{"ID":"20260603112457-navr154","Type":"NodeParagraph","Properties":{"id":"20260603112457-navr154","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"道路难行钱作马，城池不克酒为兵。"}]}]},{"ID":"20260603112457-cutsmek","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cutsmek","updated":"20260603112457"},"Children":[{"ID":"20260603112457-liavaw1","Type":"NodeParagraph","Properties":{"id":"20260603112457-liavaw1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古人云，“读书百遍，其义自见”。谓读得熟，则不待解说，自晓其义也。余尝谓，读书有三到，谓心到，眼到，口到。心不在此，则眼不看仔细，心眼既不专一，却只漫浪诵读，决不能记，记亦不能久也。三到之中，心到最急。心既到矣，眼口岂不到乎？"}]}]},{"ID":"20260603112457-q1ae9yn","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-q1ae9yn","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tx7m7j7","Type":"NodeParagraph","Properties":{"id":"20260603112457-tx7m7j7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"知人者智，自知者明。胜人者有力，自胜者强。知足者富。强行者有志。"}]}]},{"ID":"20260603112457-l5k8m2b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l5k8m2b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nfjbm4z","Type":"NodeParagraph","Properties":{"id":"20260603112457-nfjbm4z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"驿寄梅花，鱼传尺素。"}]}]},{"ID":"20260603112457-8k1ku40","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-8k1ku40","updated":"20260603112457"},"Children":[{"ID":"20260603112457-u1jgvp1","Type":"NodeParagraph","Properties":{"id":"20260603112457-u1jgvp1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"自然既极博大，也极残忍，战胜一切，孕育众生。蝼蚁蚍蜉，伟人巨匠，一样在它怀抱中，和光同见。"}]}]},{"ID":"20260603112457-nwrur4f","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nwrur4f","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p3bwjgh","Type":"NodeParagraph","Properties":{"id":"20260603112457-p3bwjgh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：与恶龙缠斗过久，自身亦成恶龙；凝视深渊过久，深渊将回以凝视。"}]}]},{"ID":"20260603112457-hbcwygq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-hbcwygq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-oo59w7r","Type":"NodeParagraph","Properties":{"id":"20260603112457-oo59w7r","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"天戴其苍，地履其黄，纵有千古，横有八荒，前途似海，来日方长。"}]}]},{"ID":"20260603112457-k7rpdg0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-k7rpdg0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a6rjn51","Type":"NodeParagraph","Properties":{"id":"20260603112457-a6rjn51","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"君子坦荡荡，小人长戚戚。"}]}]},{"ID":"20260603112457-rraox2q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-rraox2q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zrf5l3w","Type":"NodeParagraph","Properties":{"id":"20260603112457-zrf5l3w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"心中有丘壑，眉目作山河。"}]}]},{"ID":"20260603112457-naccvxs","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-naccvxs","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vz2yov1","Type":"NodeParagraph","Properties":{"id":"20260603112457-vz2yov1","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"寄蜉蝣于天地，渺沧海之一粟。哀吾生之须臾，羡长江之无穷。"}]}]},{"ID":"20260603112457-6t5wojf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6t5wojf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yc7xcgk","Type":"NodeParagraph","Properties":{"id":"20260603112457-yc7xcgk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"明代思想家袁了凡：昨日种种，譬如昨日死；今日种种，譬如今日生。"}]}]},{"ID":"20260603112457-2akhwrv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2akhwrv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-aywib3z","Type":"NodeParagraph","Properties":{"id":"20260603112457-aywib3z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"黑格尔：只有永远躺在泥坑里的人，才不会再掉进坑里。"}]}]},{"ID":"20260603112457-jlsqm47","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jlsqm47","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zexzvgw","Type":"NodeParagraph","Properties":{"id":"20260603112457-zexzvgw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"尼采：每一个不曾起舞的日子都是对生命的辜负。"}]}]},{"ID":"20260603112457-no77frg","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-no77frg","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yty3pyi","Type":"NodeParagraph","Properties":{"id":"20260603112457-yty3pyi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子在齐闻《韶》，三月不知肉味，曰：‘不图为乐之至于斯也。’"}]}]},{"ID":"20260603112457-a8nx66j","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-a8nx66j","updated":"20260603112457"},"Children":[{"ID":"20260603112457-5mbqduf","Type":"NodeParagraph","Properties":{"id":"20260603112457-5mbqduf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"史铁生：命定的局限尽可永在，不屈的挑战却不可须臾或缺。"}]}]},{"ID":"20260603112457-9cjkaub","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9cjkaub","updated":"20260603112457"},"Children":[{"ID":"20260603112457-32vsgv3","Type":"NodeParagraph","Properties":{"id":"20260603112457-32vsgv3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：当我走向你的时候，我原想收获一缕春风，你却给了我整个春天。"}]}]},{"ID":"20260603112457-yon8edp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yon8edp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-iaonh47","Type":"NodeParagraph","Properties":{"id":"20260603112457-iaonh47","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"泰戈尔：我相信，在群星当中有一颗星星，引领我的生命，穿越不可知的黑暗。"}]}]},{"ID":"20260603112457-u8emd7a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-u8emd7a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kjgfnn3","Type":"NodeParagraph","Properties":{"id":"20260603112457-kjgfnn3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汪国真：心晴的时候，雨也是晴；心雨的时候，晴也是雨。"}]}]},{"ID":"20260603112457-61qrbaw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-61qrbaw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-6sm063o","Type":"NodeParagraph","Properties":{"id":"20260603112457-6sm063o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"聂卫平：遇到顺势而下的时候，就一泻千里；遇到阻碍过不去的时候，就绕一下，但我的目标一直是向前走的。"}]}]},{"ID":"20260603112457-2xggamt","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2xggamt","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7bwlwgq","Type":"NodeParagraph","Properties":{"id":"20260603112457-7bwlwgq","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"曼德拉：我没有失败过。要么赢得胜利，要么学到东西。"}]}]},{"ID":"20260603112457-exqghmb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-exqghmb","updated":"20260603112457"},"Children":[{"ID":"20260603112457-phl16yg","Type":"NodeParagraph","Properties":{"id":"20260603112457-phl16yg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"时间是单程车票，我们只能向前；而记忆是随身行李，始终伴你同行。"}]}]},{"ID":"20260603112457-6b4lars","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6b4lars","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0vlvjee","Type":"NodeParagraph","Properties":{"id":"20260603112457-0vlvjee","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"喷泉之所以漂亮，是因为它有压力；瀑布之所以壮观，是因为它没有退路；滴水之所以能穿石，是因为它贵在坚持。一只站在树枝上的鸟，从不害怕树枝会断裂，因为它相信的不是树枝，而是它自己的翅膀。"}]}]},{"ID":"20260603112457-ujijlhw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ujijlhw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-54ei8qi","Type":"NodeParagraph","Properties":{"id":"20260603112457-54ei8qi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"追风赶月莫停留，平芜尽处是春山。"}]}]},{"ID":"20260603112457-nyd6g7h","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-nyd6g7h","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bwmrm6m","Type":"NodeParagraph","Properties":{"id":"20260603112457-bwmrm6m","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苏轼《浣溪沙·游蕲水清泉寺》"}]}]},{"ID":"20260603112457-9rt99nw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-9rt99nw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kx0woa2","Type":"NodeParagraph","Properties":{"id":"20260603112457-kx0woa2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"朱敦儒《鹧鸪天·西都作》"}]}]},{"ID":"20260603112457-307sc1b","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-307sc1b","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0xw609s","Type":"NodeParagraph","Properties":{"id":"20260603112457-0xw609s","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"杜甫《蜀相》"}]}]},{"ID":"20260603112457-i3fiosx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-i3fiosx","updated":"20260603112457"},"Children":[{"ID":"20260603112457-f556rxh","Type":"NodeParagraph","Properties":{"id":"20260603112457-f556rxh","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《忆秦娥》"}]}]},{"ID":"20260603112457-ii21q92","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ii21q92","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vs0qla3","Type":"NodeParagraph","Properties":{"id":"20260603112457-vs0qla3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《上李邕》"}]}]},{"ID":"20260603112457-81w3pvz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-81w3pvz","updated":"20260603112457"},"Children":[{"ID":"20260603112457-curxshg","Type":"NodeParagraph","Properties":{"id":"20260603112457-curxshg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"陆游《金错刀行》"}]}]},{"ID":"20260603112457-kcz3k3m","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kcz3k3m","updated":"20260603112457"},"Children":[{"ID":"20260603112457-qb8lpmi","Type":"NodeParagraph","Properties":{"id":"20260603112457-qb8lpmi","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李煜《虞美人》"}]}]},{"ID":"20260603112457-lht9v5g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lht9v5g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j09qpfc","Type":"NodeParagraph","Properties":{"id":"20260603112457-j09qpfc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"白居易《琵琶行》"}]}]},{"ID":"20260603112457-kklbfrv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kklbfrv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yb8tsz9","Type":"NodeParagraph","Properties":{"id":"20260603112457-yb8tsz9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"礼记《大学》"}]}]},{"ID":"20260603112457-lu7m2kv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lu7m2kv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r4ymr27","Type":"NodeParagraph","Properties":{"id":"20260603112457-r4ymr27","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"范仲淹《岳阳楼记》"}]}]},{"ID":"20260603112457-wx6wq5n","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-wx6wq5n","updated":"20260603112457"},"Children":[{"ID":"20260603112457-pkaxz9d","Type":"NodeParagraph","Properties":{"id":"20260603112457-pkaxz9d","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"张若虚《春江花月夜》"}]}]},{"ID":"20260603112457-yiipara","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-yiipara","updated":"20260603112457"},"Children":[{"ID":"20260603112457-14e488n","Type":"NodeParagraph","Properties":{"id":"20260603112457-14e488n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《侠客行》"}]}]},{"ID":"20260603112457-w0oiv6k","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w0oiv6k","updated":"20260603112457"},"Children":[{"ID":"20260603112457-yz7vets","Type":"NodeParagraph","Properties":{"id":"20260603112457-yz7vets","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"诗经《无衣》"}]}]},{"ID":"20260603112457-n3wrirq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-n3wrirq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-q6ph69k","Type":"NodeParagraph","Properties":{"id":"20260603112457-q6ph69k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"诗经《木瓜》"}]}]},{"ID":"20260603112457-zwdyjny","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-zwdyjny","updated":"20260603112457"},"Children":[{"ID":"20260603112457-4vzjv5n","Type":"NodeParagraph","Properties":{"id":"20260603112457-4vzjv5n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"王维《终南别业》"}]}]},{"ID":"20260603112457-l27mtmi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-l27mtmi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ymsvmu2","Type":"NodeParagraph","Properties":{"id":"20260603112457-ymsvmu2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李清照《武陵春·春晚》"}]}]},{"ID":"20260603112457-4rx5atj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4rx5atj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2oien8p","Type":"NodeParagraph","Properties":{"id":"20260603112457-2oien8p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"李白《宣州谢脁楼饯别校书叔云》"}]}]},{"ID":"20260603112457-lvthwg6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lvthwg6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ec6va4w","Type":"NodeParagraph","Properties":{"id":"20260603112457-ec6va4w","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"蒋捷《虞美人·听雨》"}]}]},{"ID":"20260603112457-ttzsh14","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ttzsh14","updated":"20260603112457"},"Children":[{"ID":"20260603112457-e9x1sfm","Type":"NodeParagraph","Properties":{"id":"20260603112457-e9x1sfm","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"苏轼《前赤壁赋》"}]}]},{"ID":"20260603112457-ccgj591","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ccgj591","updated":"20260603112457"},"Children":[{"ID":"20260603112457-imep63k","Type":"NodeParagraph","Properties":{"id":"20260603112457-imep63k","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"欧阳修《醉翁亭记》"}]}]},{"ID":"20260603112457-b679z9t","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-b679z9t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s0rwsr2","Type":"NodeParagraph","Properties":{"id":"20260603112457-s0rwsr2","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"汉乐府《长歌行》"}]}]},{"ID":"20260603112457-1j10sc5","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1j10sc5","updated":"20260603112457"},"Children":[{"ID":"20260603112457-1vwek65","Type":"NodeParagraph","Properties":{"id":"20260603112457-1vwek65","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603112457-20gts4y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-20gts4y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dxh14gw","Type":"NodeParagraph","Properties":{"id":"20260603112457-dxh14gw","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《湖心亭看雪》"}]}]},{"ID":"20260603112457-c4e64ij","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-c4e64ij","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kmwu880","Type":"NodeParagraph","Properties":{"id":"20260603112457-kmwu880","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"《滕王阁序》"}]}]},{"ID":"20260603112457-kn0mwg1","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kn0mwg1","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ypi3hvj","Type":"NodeParagraph","Properties":{"id":"20260603112457-ypi3hvj","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"庄周《北冥有鱼》"}]}]},{"ID":"20260603112457-s4xeogb","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s4xeogb","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gr4307z","Type":"NodeParagraph","Properties":{"id":"20260603112457-gr4307z","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"韩愈 《马说》"}]}]},{"ID":"20260603112457-5a19awa","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5a19awa","updated":"20260603112457"},"Children":[{"ID":"20260603112457-thw0ags","Type":"NodeParagraph","Properties":{"id":"20260603112457-thw0ags","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"欧阳修《秋声赋》"}]}]},{"ID":"20260603112457-050bf6a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-050bf6a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ltd0pjn","Type":"NodeParagraph","Properties":{"id":"20260603112457-ltd0pjn","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"百里奚之未遇时也，亡虢而虏晋，饭牛于秦，传鬻以五羊之皮。公孙枝得而说之，献诸缪公，三日，请属事焉。缪公曰：“买之五羊之皮而属事焉，无乃为天下笑乎？”公孙枝对曰：“信贤而任之，君之明也；让贤而下之，臣之忠也。君为明君，臣为忠臣。彼信贤，境内将服，敌国且畏，夫谁暇笑哉？”缪公遂用之。"}]}]},{"ID":"20260603112457-1p1zghp","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1p1zghp","updated":"20260603112457"},"Children":[{"ID":"20260603112457-r9htaal","Type":"NodeParagraph","Properties":{"id":"20260603112457-r9htaal","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"齐桓公好服紫，一国尽服紫。当是时也，五素不得一紫。桓公患之，谓管仲曰：“寡人好服紫，紫贵甚，一国百姓好服紫不已，寡人奈何？”管仲曰：“君欲何不试勿衣紫也，谓左右曰：吾甚恶紫之臭。于是左右适有衣紫而进者，公必曰：‘少却，吾恶紫臭。’”公曰：“诺。”于是日郎中莫衣紫，其明日国中莫衣紫，三日境内莫衣紫也。"}]}]},{"ID":"20260603112457-orubcrf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-orubcrf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ikq4zdk","Type":"NodeParagraph","Properties":{"id":"20260603112457-ikq4zdk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"逢蒙学射于羿，尽羿之道，思天下惟羿为愈己，于是杀羿。孟子曰：“是亦羿有罪焉。”公明仪曰：“宜若无罪焉。”曰：“薄乎云尔，恶得无罪？郑人使子濯孺子侵卫，卫得庾公之斯追之。子濯孺子曰：‘今日我疾作，不可以执弓，吾死矣夫！’问其仆曰：‘追我者谁也？’其仆曰：‘庾公之斯也。’曰：‘吾生矣。’其仆曰：‘庾公之斯，卫之善射者也。夫子曰“吾生”，何谓也？’曰‘庾公之斯学射于尹公之他，尹公之他学射于我，夫尹公之他，端人也，其取友必端矣。’庾公之斯至，曰：‘夫子何为不执弓？’曰：‘今日我疾作，不可以执弓。’曰：‘小人学射于尹公之他，尹公之他学射于夫子，我不忍以夫子之道反害夫子。虽然，今日之事，君事也，我不敢废。抽矢叩轮，去其金，发乘矢而后反。’”"}]}]},{"ID":"20260603112457-gzf3gxi","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gzf3gxi","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p738xhz","Type":"NodeParagraph","Properties":{"id":"20260603112457-p738xhz","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"伯夷叔齐，孤竹君之二子也。父欲立叔齐，及父卒，叔齐让伯夷。伯夷曰：“父命也。”遂逃去。叔齐亦不肯立而逃之。国人立其中子。于是伯夷叔齐闻西伯昌善养老，盍往归焉。及至，西伯卒。武王载木主，号为文王，东伐纣。伯夷叔齐叩马而谏曰：“父死不葬，爰及干戈，可谓孝乎？以臣弑君，可谓仁乎？”左右欲兵之。太公曰：“此义人也。”扶而去之。武王已平殷乱，天下宗周，而伯夷叔齐耻之，义不食周粟，隐于首阳山，采薇而食之。"}]}]},{"ID":"20260603112457-5ibpnub","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5ibpnub","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vq0etu4","Type":"NodeParagraph","Properties":{"id":"20260603112457-vq0etu4","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"人有卖骏马者，比三旦立于市，人莫知之。往见伯乐曰：“臣有骏马，欲卖之，比三旦立于市，人莫与言，愿子还而视之。去而顾之，臣请献一朝之贾。”伯乐乃还而视之，去而顾之，一旦而马价十倍。"}]}]},{"ID":"20260603112457-a360b37","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-a360b37","updated":"20260603112457"},"Children":[{"ID":"20260603112457-hrvi6ef","Type":"NodeParagraph","Properties":{"id":"20260603112457-hrvi6ef","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"多闻阙疑，慎言其余，则寡尤；多见阙殆，慎行其余，则寡悔。言寡尤，行寡悔，禄在其中矣。"}]}]},{"ID":"20260603112457-ic652bu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ic652bu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-q1mayue","Type":"NodeParagraph","Properties":{"id":"20260603112457-q1mayue","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"孔子适郑，与弟子相失，孔子独立郭东门。郑人或谓子贡曰：“东门有人，其颡似尧，其项类皋陶，其肩类子产，然自要以下不及禹三寸，累累若丧家之狗。”子贡以实告孔子。孔子欣然笑曰：“形状，末也。而谓似丧家之狗，然哉！然哉！”"}]}]},{"ID":"20260603112457-smnk9jf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-smnk9jf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-f5hrr3n","Type":"NodeParagraph","Properties":{"id":"20260603112457-f5hrr3n","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"孔子晚而喜《易》，序《彖》、《系》、《象》、《说卦》、《文言》。读《易》，韦编三绝。曰：“假我数年，若是，我于《易》则彬彬矣。"}]}]},{"ID":"20260603112457-f4zsfpq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-f4zsfpq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-olpzpet","Type":"NodeParagraph","Properties":{"id":"20260603112457-olpzpet","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"叔孙武叔语大夫于朝曰：“子贡贤于仲尼。” 子服景伯以告子贡。 子贡曰：“譬之宫墙，赐之墙也及肩，窥见室家之好。夫子之墙数仞，不得其门而入，不见宗庙之美，百官之富。得其门者或寡矣。夫子之云，不亦宜乎！”"}]}]},{"ID":"20260603112457-59mkzbv","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-59mkzbv","updated":"20260603112457"},"Children":[{"ID":"20260603112457-s7q3403","Type":"NodeParagraph","Properties":{"id":"20260603112457-s7q3403","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"齐桓公读书于堂上。轮扁斫轮于堂下，释椎凿而上，问桓公曰：“敢问，公之所读者何言邪？”公曰：“圣人之言也。”曰：“圣人在乎？”公曰：“已死矣。”曰：“然则君之所读者，古人之糟魄已夫？”桓公曰：“寡人读书，轮人安得议乎！有说则可，无说则死。”轮扁曰：“臣也从臣之事观之。斫轮，徐则甘而不固，疾则苦而不入。不徐不疾，得之于手而应于心，口不能言，有数存焉于其间。臣不能以喻臣之子，臣之子亦不能受之于臣，是以行年七十而老斫轮。古之人与其不可传也死矣，然则君之所读者，古人之糟魄已夫！"}]}]},{"ID":"20260603112457-caca1gq","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-caca1gq","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vhux2sy","Type":"NodeParagraph","Properties":{"id":"20260603112457-vhux2sy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"厉王虐，国人谤王。召公告曰：“民不堪命矣！”王怒，得卫巫使监谤者，以告则杀之。国人莫敢言，道路以目。王喜，告召公曰：“吾能弭谤矣，乃不敢言。”召公曰：“是障之也。防民之口，甚于防川。川壅而溃，伤人必多，民亦如之。是故为川者，决之使导；为民者，宣之使言。”"}]}]},{"ID":"20260603112457-gem6ji3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-gem6ji3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-zmu1sgf","Type":"NodeParagraph","Properties":{"id":"20260603112457-zmu1sgf","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"公输子削竹木以为鹊，成而飞之，三日不下，公输子自以为至巧。子墨子谓公输子曰：“子之为鹊也，不如匠之为车辖。须臾斫三寸之木，而任五十石之重。故所为功，利于人谓之巧，不利于人谓之拙。”"}]}]},{"ID":"20260603112457-oolrpi3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-oolrpi3","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0xv9v96","Type":"NodeParagraph","Properties":{"id":"20260603112457-0xv9v96","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"齐桓公见小臣稷，一日三至，弗得见。从者曰：“万乘之主，见布衣之士，一日三至，而弗得见，亦可以止矣！”桓公曰：“不然。士骜禄爵者，固轻其主；其主骜霸者，亦轻其士。纵夫子骜禄爵，吾庸敢骜霸王乎？”遂见之不可止。"}]}]},{"ID":"20260603112457-5ttbuc4","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-5ttbuc4","updated":"20260603112457"},"Children":[{"ID":"20260603112457-bzgrq0p","Type":"NodeParagraph","Properties":{"id":"20260603112457-bzgrq0p","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。既已施于国，吾欲用之家。”乃乘扁舟浮于江湖，变名易姓，适齐为鸱夷子皮，之陶为朱公。朱公以为陶天下之中，诸侯四通，货物所交易也。乃治产积居，与时逐而不责于人。故善治生者，能择人而任时。十九年之中三致千金。”"}]}]},{"ID":"20260603112457-r5kfcnu","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-r5kfcnu","updated":"20260603112457"},"Children":[{"ID":"20260603112457-2hbcntx","Type":"NodeParagraph","Properties":{"id":"20260603112457-2hbcntx","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子夏之晋，过卫，有读史记者曰：“晋师三豕涉河。”子夏曰：“非也，是己亥也。夫已与三相近，豕与亥相似。”至于晋而问之，则曰：“晋师己亥涉河也。”辞多类非而是，多类是而非。是非之经，不可不分。"}]}]},{"ID":"20260603112457-kfo0rso","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-kfo0rso","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0dbaena","Type":"NodeParagraph","Properties":{"id":"20260603112457-0dbaena","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子夏过曾子。曾子曰：“入食。”子夏曰：“不为公费乎？”曾子曰：“君子有三费，饮食不在其中；君子有三乐，钟磬琴瑟不在其中。”子夏曰：“敢问三乐？”曾子曰：“有亲可畏，有君可事，有子可遗，此一乐也。有亲可谏，有君可去，有子可怒，此二乐也。有君可喻，有友可助，此三乐也。”子夏问：“敢问三费？”曾子曰：“少而学，长而忘，此一费也。事君有功，而轻负之，此二费也，久交友而中绝之，此三费也。”"}]}]},{"ID":"20260603112457-lior58a","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-lior58a","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ss4qiok","Type":"NodeParagraph","Properties":{"id":"20260603112457-ss4qiok","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昔秦伯嫁其女于晋公子，令晋为之饰装，从衣文之媵七十人。至晋，晋人爱其妾而贱公女。此可谓善嫁妾，而未可谓善嫁女也。"}]}]},{"ID":"20260603112457-dmewjhj","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dmewjhj","updated":"20260603112457"},"Children":[{"ID":"20260603112457-g1no717","Type":"NodeParagraph","Properties":{"id":"20260603112457-g1no717","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"昔者曾子处费，费人有与曾子同名族者而杀人。人告曾子母曰：“曾参杀人。”曾子之母曰：“吾子不杀人。”织自若。有顷焉，人又曰：“曾参杀人。”其母尚织自若也。顷之，一人又告之曰：“曾参杀人。”其母惧，投杼逾墙而走。"}]}]},{"ID":"20260603112457-fkq4e7q","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-fkq4e7q","updated":"20260603112457"},"Children":[{"ID":"20260603112457-od12zj9","Type":"NodeParagraph","Properties":{"id":"20260603112457-od12zj9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"范蠡遂去，自齐遗大夫种书曰：“飞鸟尽，良弓藏；狡兔死，走狗烹。越王为人长颈鸟喙，可与共患难，不可与共乐。子何不去？”"}]}]},{"ID":"20260603112457-j1wt4ab","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-j1wt4ab","updated":"20260603112457"},"Children":[{"ID":"20260603112457-kn6w1n3","Type":"NodeParagraph","Properties":{"id":"20260603112457-kn6w1n3","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"禽子问曰：多言有益乎？墨子曰：虾蟆、蛙黾，日夜恒鸣，口干舌擗，然而不听。今观晨鸡，时夜而鸣，天下振动。多言何益？唯其言之时也。"}]}]},{"ID":"20260603112457-y4h68y8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-y4h68y8","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o2y86n5","Type":"NodeParagraph","Properties":{"id":"20260603112457-o2y86n5","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"巫马子谓子墨子曰：\"子兼爱天下，未云利也，我不爱天下，未云贼也。功皆未至，子何独自是而非我哉？”子墨子曰：今有燎者于此，一人奉水将灌之，一人掺火将益之，功皆未至，子何贵于二人？”巫马子曰：我是彼奉水者之意，而非夫掺火者之意。”子墨子曰：\"吾亦是吾意而非子之意也。”"}]}]},{"ID":"20260603112457-7j8wnda","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7j8wnda","updated":"20260603112457"},"Children":[{"ID":"20260603112457-e589hkt","Type":"NodeParagraph","Properties":{"id":"20260603112457-e589hkt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"叶公问孔子于子路，子路不对。子曰：“女奚不曰：其为人也，发愤忘食，乐以忘忧，不知老之将至云尔。”"}]}]},{"ID":"20260603112457-2syed6g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2syed6g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-tti8ro7","Type":"NodeParagraph","Properties":{"id":"20260603112457-tti8ro7","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子路日:““伤哉贫也!生无以养，死无以葬。”子曰:“啜菽饮水，孝也。”"}]}]},{"ID":"20260603112457-ncgkpz9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ncgkpz9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-0mmb5v8","Type":"NodeParagraph","Properties":{"id":"20260603112457-0mmb5v8","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"生活不仅有田园与诗，更有眼前的苟且。"}]}]},{"ID":"20260603112457-ibucsco","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ibucsco","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ralmrb6","Type":"NodeParagraph","Properties":{"id":"20260603112457-ralmrb6","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"子曰：“后生可畏，焉知来者之不如今也？四十、五十而无闻焉，斯亦不足畏也已。”"}]}]},{"ID":"20260603112457-crm11g7","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-crm11g7","updated":"20260603112457"},"Children":[{"ID":"20260603112457-sj8l66a","Type":"NodeParagraph","Properties":{"id":"20260603112457-sj8l66a","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"古人云：“知行合一。”而在现代决策理论中，这一思想被进一步具体化为一种动态更新的过程：人并非先有完备之知，才敢行动，而是在行动中修正认知。正如贝叶斯原理所揭示的——判断并非一成不变，而是在一次次反馈中逼近真实。由此看来，真正的理性，不是避免犯错，而是不断纠错。"}]}]},{"ID":"20260603112457-0gm0o24","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-0gm0o24","updated":"20260603112457"},"Children":[{"ID":"20260603112457-damgc8o","Type":"NodeParagraph","Properties":{"id":"20260603112457-damgc8o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"破窗效应：如果环境中的不良现象被放任存在，会诱使人们效仿，甚至变本加厉。"}]}]},{"ID":"20260603112457-s3i1ygk","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-s3i1ygk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-521l6la","Type":"NodeParagraph","Properties":{"id":"20260603112457-521l6la","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"锚定效应：人们在做决定时，容易受第一印象或第一条信息的支配。"}]}]},{"ID":"20260603112457-vgb3m0g","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-vgb3m0g","updated":"20260603112457"},"Children":[{"ID":"20260603112457-t8sroee","Type":"NodeParagraph","Properties":{"id":"20260603112457-t8sroee","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"羊群效应：指人们经常受到多数人影响，而跟从大众的思想或行为。"}]}]},{"ID":"20260603112457-6fkcl02","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6fkcl02","updated":"20260603112457"},"Children":[{"ID":"20260603112457-wlgd10o","Type":"NodeParagraph","Properties":{"id":"20260603112457-wlgd10o","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"习得性无助：指人在经历了某种失败或挫折后，产生的放弃努力的悲观心理。"}]}]},{"ID":"20260603112457-aywticw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-aywticw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-f5fm1uv","Type":"NodeParagraph","Properties":{"id":"20260603112457-f5fm1uv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"手表定律：只有一只手表时能知道时间，拥有两只或以上反而无法确定时间。"}]}]},{"ID":"20260603112457-jddxcrr","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-jddxcrr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-altlf29","Type":"NodeParagraph","Properties":{"id":"20260603112457-altlf29","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"鳄鱼法则：当被鳄鱼咬住腿，若用手去解救，手也会被咬。唯一的办法是牺牲那条腿。它揭示了及时止损、果决舍弃的智慧。"}]}]},{"ID":"20260603112457-cnsahc0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cnsahc0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-dw79ymc","Type":"NodeParagraph","Properties":{"id":"20260603112457-dw79ymc","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"刺猬理论：刺猬天冷时靠拢取暖，但必须保持距离以免刺伤对方。完美诠释了人际交往中“距离产生美”以及分寸感的重要性。"}]}]},{"ID":"20260603112457-3yvxew9","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-3yvxew9","updated":"20260603112457"},"Children":[{"ID":"20260603112457-gq04ljk","Type":"NodeParagraph","Properties":{"id":"20260603112457-gq04ljk","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"熵增定律：在一个封闭系统中，若无外力做功，系统会自发趋向无序和混乱。人需要主动引入“负熵”（如持续学习、自律），才能对抗生命的无序与懈怠。"}]}]},{"ID":"20260603112457-ntv3hdc","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ntv3hdc","updated":"20260603112457"},"Children":[{"ID":"20260603112457-05ioovp","Type":"NodeParagraph","Properties":{"id":"20260603112457-05ioovp","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"氨基酸组合效应：组成人体蛋白的8种氨基酸，只要有一种不足，其他7种就无法合成蛋白质。适合论证团队合作中缺一不可的整体性，或者个人素养的全面性。"}]}]},{"ID":"20260603112457-g1edvyw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-g1edvyw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-8p3mc90","Type":"NodeParagraph","Properties":{"id":"20260603112457-8p3mc90","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"幸存者效应：只看到“活下来的人”“成功者”“被看见的案例”，却忽略了那些被淘汰、失败、沉默的大多数，于是容易得出片面甚至错误的结论。"}]}]},{"ID":"20260603112457-ifw6ono","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-ifw6ono","updated":"20260603112457"},"Children":[{"ID":"20260603112457-81yxqp0","Type":"NodeParagraph","Properties":{"id":"20260603112457-81yxqp0","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"奥卡姆剃刀：如无必要，勿增实体。"}]}]},{"ID":"20260603112457-6zafriw","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-6zafriw","updated":"20260603112457"},"Children":[{"ID":"20260603112457-i8vfujo","Type":"NodeParagraph","Properties":{"id":"20260603112457-i8vfujo","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"墨菲定律：如果有两种或两种以上的方式去做某件事，而其中一种会导致灾难，那么必定会有人选择这种方式。"}]}]},{"ID":"20260603112457-4seu1ti","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-4seu1ti","updated":"20260603112457"},"Children":[{"ID":"20260603112457-a3c2hfv","Type":"NodeParagraph","Properties":{"id":"20260603112457-a3c2hfv","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"波普尔证伪主义：科学理论的价值不在于被证明为真，而在于能够被不断检验并有可能被证伪，从而在批判中逐步逼近真理。"}]}]},{"ID":"20260603112457-1qz0tx6","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-1qz0tx6","updated":"20260603112457"},"Children":[{"ID":"20260603112457-j5ba3d9","Type":"NodeParagraph","Properties":{"id":"20260603112457-j5ba3d9","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"皮亚杰建构主义：知识不是接受的，是主动建构的"}]}]},{"ID":"20260603112457-cndryvf","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-cndryvf","updated":"20260603112457"},"Children":[{"ID":"20260603112457-haa4gvs","Type":"NodeParagraph","Properties":{"id":"20260603112457-haa4gvs","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"怀疑主义：对既有认知保持怀疑"}]}]},{"ID":"20260603112457-w2ulj51","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-w2ulj51","updated":"20260603112457"},"Children":[{"ID":"20260603112457-srckqtt","Type":"NodeParagraph","Properties":{"id":"20260603112457-srckqtt","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"黑格尔辩证法：真理在矛盾和冲突中发展"}]}]},{"ID":"20260603112457-dkcd1l0","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-dkcd1l0","updated":"20260603112457"},"Children":[{"ID":"20260603112457-rttukwu","Type":"NodeParagraph","Properties":{"id":"20260603112457-rttukwu","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"实践论：实践是检验真理的唯一标准"}]}]}]}]},{"ID":"20260603112457-7iqm2ko","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-7iqm2ko","updated":"20260603112457"},"Children":[{"ID":"20260603112457-7pnbbvg","Type":"NodeParagraph","Properties":{"id":"20260603112457-7pnbbvg","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"融合方式要如盐溶于水般不着痕迹，可采用语录式题记、巧妙化用意象、隐喻重构等方式。严禁为了炫技而生搬硬套、强行堆砌，确保古典元素与现代文思共生共振，而非逻辑割裂。"}]}]}]}]},{"ID":"20260603112457-e3acv0y","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OC4=","Num":8},"Properties":{"id":"20260603112457-e3acv0y","updated":"20260603112457"},"Children":[{"ID":"20260603112457-z18dx4d","Type":"NodeParagraph","Properties":{"id":"20260603112457-z18dx4d","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"篇幅"},{"Type":"NodeText","Data":"：840至860字"}]}]},{"ID":"20260603112457-kk5z87t","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"OS4=","Num":9},"Properties":{"id":"20260603112457-kk5z87t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-vxd40wk","Type":"NodeParagraph","Properties":{"id":"20260603112457-vxd40wk","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"输出格式"}]}]}]},{"ID":"20260603112457-n9vty86","Type":"NodeList","ListData":{},"Properties":{"id":"20260603112457-n9vty86","updated":"20260603112457"},"Children":[{"ID":"20260603112457-p8ryr4v","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-p8ryr4v","updated":"20260603112457"},"Children":[{"ID":"20260603112457-mos5gvy","Type":"NodeParagraph","Properties":{"id":"20260603112457-mos5gvy","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"标题（居中，力求新颖、吸睛）"}]}]},{"ID":"20260603112457-2057s1x","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260603112457-2057s1x","updated":"20260603112457"},"Children":[{"ID":"20260603112457-eg7d957","Type":"NodeParagraph","Properties":{"id":"20260603112457-eg7d957","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"正文（分段清晰，每段首行缩进两字符）"}]},{"ID":"20260603112457-imv44wy","Type":"NodeParagraph","Properties":{"id":"20260603112457-imv44wy","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【作文题目/材料/原文】"},{"Type":"NodeText","Data":"\n（在此处粘贴具体的作文题目、材料或话题，例如：2025年全国一卷关于老舍、艾青、穆旦的材料……）"}]}]}]},{"ID":"20260603112457-nfp51cr","Type":"NodeList","ListData":{"Typ":1},"Properties":{"id":"20260603112457-nfp51cr","updated":"20260603112457"},"Children":[{"ID":"20260603112457-o8hqzfk","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"MS4=","Num":1},"Properties":{"id":"20260603112457-o8hqzfk","updated":"20260603112457"},"Children":[{"ID":"20260603112457-ieeug3f","Type":"NodeParagraph","Properties":{"id":"20260603112457-ieeug3f","updated":"20260603112457"},"Children":[{"Type":"NodeText","Data":"请根据我提供的【作文题目/材料/原文】，创作或修改一篇符合高考满分标准（60分制）的优秀作文。"}]},{"ID":"20260603112457-dy2cko5","Type":"NodeParagraph","Properties":{"id":"20260603112457-dy2cko5","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"【写作要求与指令】"}]}]},{"ID":"20260603112457-22q260l","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260603112457-22q260l","updated":"20260603112457"},"Children":[{"ID":"20260603112457-xbjnk4n","Type":"NodeParagraph","Properties":{"id":"20260603112457-xbjnk4n","updated":"20260603112457"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"审题与立意"},{"Type":"NodeText","Data":"：精准剖析材料的核心内涵，提炼出深刻、新颖且具有时代意义的中心论点。立意要高远，体现当代青年的思辨能力与家国情怀。"}]}]},{"ID":"20260603112457-xt44w6t","Type":"NodeListItem","ListData":{"Typ":1,"Delimiter":46,"Marker":"My4=","Num":3},"Properties":{"id":"20260603112457-xt44w6t","updated":"20260603112457"},"Children":[{"ID":"20260603112457-nz54nks","Type":"NodeParagraph","Properties":{"id":"20260603112457-nz54nks","updated":"20260603112457"},"Children":[{"T