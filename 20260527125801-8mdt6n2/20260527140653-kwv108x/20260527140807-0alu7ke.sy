527163304"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"混淆时态"},{"Type":"NodeText","Data":"：把“未然”（推测、将来）说成“已然”（已经发生），或反之。"}]}]},{"ID":"20260527163304-ylt0xis","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527163304-ylt0xis","updated":"20260527163304"},"Children":[{"ID":"20260527163304-jzh830j","Type":"NodeParagraph","Properties":{"id":"20260527163304-jzh830j","updated":"20260527163304"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"无中生有"},{"Type":"NodeText","Data":"：选项中出现了原文根本没有涉及的观点或对比。"}]}]},{"ID":"20260527163304-r5ix4f3","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527163304-r5ix4f3","updated":"20260527163304"},"Children":[{"ID":"20260527163304-o3vq314","Type":"NodeParagraph","Properties":{"id":"20260527163304-o3vq314","updated":"20260527163304"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"偷换概念"},{"Type":"NodeText","Data":"：对核心概念的解释与原文不一致，或在转述时悄悄改变了概念的内涵。"}]}]}]},{"ID":"20260527163304-4icpq8t","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260527163304-4icpq8t","updated":"20260527163304"},"Children":[{"Type":"NodeText","Data":"思路脉络类"}]},{"ID":"20260527163304-dvi6a4o","Type":"NodeParagraph","Properties":{"id":"20260527163304-dvi6a4o","updated":"20260527163304"},"Children":[{"Type":"NodeText","Data":"当题目要求梳理“行文思路”或“论证思路”时，常用以下术语串联答案："}]},{"ID":"20260527163304-jz2c86j","Type":"NodeList","ListData":{},"Properties":{"id":"20260527163304-jz2c86j","updated":"20260527163304"},"Children":[{"ID":"20260527163304-7kd8eo2","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527163304-7kd8eo2","updated":"20260527163304"},"Children":[{"ID":"20260527163304-pmeadx8","Type":"NodeParagraph","Properties":{"id":"20260527163304-pmeadx8","updated":"20260527163304"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"引出话题/提出观点"},{"Type":"NodeText","Data":"：通常用于开头段落的概括。"}]}]},{"ID":"20260527163304-o1ekki8","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527163304-o1ekki8","updated":"20260527163304"},"Children":[{"ID":"20260527163304-b3tdmqo","Type":"NodeParagraph","Properties":{"id":"20260527163304-b3tdmqo","updated":"20260527163304"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"展开论述/具体分析"},{"Type":"NodeText","Data":"：用于中间段落，可结合论证方法说明（如“通过……事例进行分析”）。"}]}]},{"ID":"20260527163304-55kzh6y","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527163304-55kzh6y","updated":"20260527163304"},"Children":[{"ID":"20260527163304-x026zyc","Type":"NodeParagraph","Properties":{"id":"20260527163304-x026zyc","updated":"20260527163304"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"得出结论/总结全文"},{"Type":"NodeText","Data":"：用于结尾段落的概括。"}]}]}]},{"ID":"20260527163304-gf7zg4w","Type":"NodeParagraph","Properties":{"id":"20260527163304-gf7zg4w","updated":"20260527163304"},"Children":[{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实战应用建议"},{"Type":"NodeText","Data":"：在实际作答简答题时，建议采用 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"“术语 + 结合文本分析”"},{"Type":"NodeText","Data":" 的格式。例如：“本文运用了"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"举例论证"},{"Type":"NodeText","Data":"的方法，列举了……的事例，具体有力地证明了……的观点。”"}]}]}