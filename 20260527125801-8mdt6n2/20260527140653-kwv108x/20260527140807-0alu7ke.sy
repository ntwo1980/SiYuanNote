60527160431"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"留痕迹"},{"Type":"NodeText","Data":"：在材料侧边简要标注段落主旨（如“①概念界定”“②现状分析”“③对策建议”），便于后续精准定位。"}]}]}]},{"ID":"20260527160431-nkggunv","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260527160431-nkggunv","updated":"20260527161253"},"Children":[{"Type":"NodeText","Data":"二、审清题意，锁定答题区间"}]},{"ID":"20260527160431-xgds7ma","Type":"NodeList","ListData":{},"Properties":{"id":"20260527160431-xgds7ma","updated":"20260527160431"},"Children":[{"ID":"20260527160431-4a31wvz","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527160431-4a31wvz","updated":"20260527160431"},"Children":[{"ID":"20260527160431-jvl8qfy","Type":"NodeParagraph","Properties":{"id":"20260527160431-jvl8qfy","updated":"20260527160431"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"辨题型"},{"Type":"NodeText","Data":"：明确是信息筛选、逻辑推断、内容概括、观点评价还是迁移应用。"}]}]},{"ID":"20260527160431-p7ptxsm","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527160431-p7ptxsm","updated":"20260527160431"},"Children":[{"ID":"20260527160431-vti9y0j","Type":"NodeParagraph","Properties":{"id":"20260527160431-vti9y0j","updated":"20260527160431"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"抠字眼"},{"Type":"NodeText","Data":"：圈出题干限定词（范围、程度、时间、条件）与设问词（“根据材料一”“下列说法不正确的一项是”“概括……特点”）。"}]}]},{"ID":"20260527160431-ka8einx","Type":"NodeListItem","ListData":{"BulletChar":42,"Marker":"Kg=="},"Properties":{"id":"20260527160431-ka8einx","updated":"20260527160431"},"Children":[{"ID":"20260527160431-0p46m8q","Type":"NodeParagraph","Properties":{"id":"20260527160431-0p46m8q","updated":"20260527160431"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"预判区"},{"Type":"NodeText","Data":"：根据题干关键词（人名、数据、专有名词、核心观点）迅速锁定原文对应段落，避免通篇重读。"}]}]}]},{"ID":"20260527160431-2grpyz2","Type":"NodeHeadi